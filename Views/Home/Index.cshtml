        <div class="d-flex flex-wrap" style="gap:10px;">
            <a asp-controller="GamePlay" asp-action="Index" class="btn btn-outline-secondary">
                <i class="fas fa-map me-1"></i> Quick Start: Open Map
            </a>
            <a asp-controller="TeamManagement" asp-action="Index" class="btn btn-outline-secondary">
                <i class="fas fa-users me-1"></i> Manage Teams
            </a>
            <a asp-controller="AdminToken" asp-action="Dashboard" class="btn btn-outline-secondary">
                <i class="fas fa-database me-1"></i> Token Admin
            </a>
        </div>
    </section> *@
</div>


