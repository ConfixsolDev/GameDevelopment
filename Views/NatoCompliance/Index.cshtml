@{
    ViewData["Title"] = "NATO Compliance Dashboard";
}

<div class="nato-compliance-container">
    <div class="compliance-header">
        <h1>NATO Compliance Verification Dashboard</h1>
        <p>Comprehensive NATO standards compliance verification and system integration status</p>
    </div>

    <div class="compliance-overview">
        <div class="overview-card">
            <h3>Overall Compliance Status</h3>
            <div id="overallComplianceStatus" class="compliance-status">
                <div class="status-indicator">
                    <span class="status-icon">⏳</span>
                    <span class="status-text">Checking...</span>
                </div>
            </div>
        </div>
        
        <div class="overview-card">
            <h3>Systems Connected</h3>
            <div id="systemsConnected" class="systems-count">
                <div class="count-display">
                    <span class="count-number">0</span>
                    <span class="count-total">/ 9</span>
                </div>
            </div>
        </div>
        
        <div class="overview-card">
            <h3>Integration Health</h3>
            <div id="integrationHealth" class="health-status">
                <div class="health-indicator">
                    <span class="health-text">Pending</span>
                </div>
            </div>
        </div>
    </div>

    <div class="nato-standards">
        <h3>NATO Standards Compliance</h3>
        <div class="standards-grid">
            <div class="standard-card">
                <h4>ATP-3-90.1</h4>
                <p class="standard-title">Tactics</p>
                <div id="atp3901Status" class="standard-status">
                    <span class="status-badge">Checking...</span>
                </div>
                <div class="standard-details">
                    <ul>
                        <li>Tactical principles</li>
                        <li>Decision-making process</li>
                        <li>Force employment</li>
                    </ul>
                </div>
            </div>
            
            <div class="standard-card">
                <h4>ATP-3-90.2</h4>
                <p class="standard-title">Offensive Operations</p>
                <div id="atp3902Status" class="standard-status">
                    <span class="status-badge">Checking...</span>
                </div>
                <div class="standard-details">
                    <ul>
                        <li>Attack types</li>
                        <li>Force ratios</li>
                        <li>Offensive planning</li>
                    </ul>
                </div>
            </div>
            
            <div class="standard-card">
                <h4>ATP-3-90.3</h4>
                <p class="standard-title">Defensive Operations</p>
                <div id="atp3903Status" class="standard-status">
                    <span class="status-badge">Checking...</span>
                </div>
                <div class="standard-details">
                    <ul>
                        <li>Defense types</li>
                        <li>Kill zones</li>
                        <li>Defensive planning</li>
                    </ul>
                </div>
            </div>
            
            <div class="standard-card">
                <h4>ATP-3-90.4</h4>
                <p class="standard-title">Terrain Analysis</p>
                <div id="atp3904Status" class="standard-status">
                    <span class="status-badge">Checking...</span>
                </div>
                <div class="standard-details">
                    <ul>
                        <li>Terrain classification</li>
                        <li>Impact coefficients</li>
                        <li>Terrain factors</li>
                    </ul>
                </div>
            </div>
            
            <div class="standard-card">
                <h4>APP-6</h4>
                <p class="standard-title">Military Symbology</p>
                <div id="app6Status" class="standard-status">
                    <span class="status-badge">Checking...</span>
                </div>
                <div class="standard-details">
                    <ul>
                        <li>Unit symbols</li>
                        <li>Attack symbols</li>
                        <li>Defense symbols</li>
                    </ul>
                </div>
            </div>
            
            <div class="standard-card">
                <h4>NETN-FOM</h4>
                <p class="standard-title">HLA Federation Object Model</p>
                <div id="netnStatus" class="standard-status">
                    <span class="status-badge">Checking...</span>
                </div>
                <div class="standard-details">
                    <ul>
                        <li>Physical entities</li>
                        <li>Aggregate entities</li>
                        <li>Interactions</li>
                    </ul>
                </div>
            </div>
        </div>
    </div>

    <div class="systems-status">
        <h3>Integrated Systems Status</h3>
        <div class="systems-grid" id="systemsGrid">
            <!-- Systems will be loaded here -->
        </div>
    </div>

    <div class="capabilities-matrix">
        <h3>System Capabilities</h3>
        <div class="capabilities-table" id="capabilitiesTable">
            <!-- Capabilities will be loaded here -->
        </div>
    </div>

    <div class="compliance-actions">
        <h3>Actions</h3>
        <div class="action-buttons">
            <button id="btnRefreshCompliance" class="btn btn-primary">
                <i class="fas fa-sync"></i> Refresh Compliance Check
            </button>
            <button id="btnGenerateComplianceReport" class="btn btn-info">
                <i class="fas fa-file-alt"></i> Generate Compliance Report
            </button>
            <button id="btnGenerateHealthReport" class="btn btn-success">
                <i class="fas fa-heartbeat"></i> Generate Health Report
            </button>
            <button id="btnExportReports" class="btn btn-secondary">
                <i class="fas fa-download"></i> Export All Reports
            </button>
        </div>
    </div>

    <div class="compliance-recommendations" id="complianceRecommendations" style="display: none;">
        <h3>Recommendations</h3>
        <div class="recommendations-list" id="recommendationsList">
            <!-- Recommendations will be loaded here -->
        </div>
    </div>
</div>

<!-- Compliance Report Modal -->
<div class="modal fade" id="complianceReportModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">NATO Compliance Report</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div id="complianceReportContent">
                    <!-- Report content will be loaded here -->
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                <button type="button" class="btn btn-primary" id="btnExportComplianceReport">Export Report</button>
            </div>
        </div>
    </div>
</div>

<style>
.nato-compliance-container {
    padding: 20px;
    max-width: 1400px;
    margin: 0 auto;
}

.compliance-header {
    text-align: center;
    margin-bottom: 40px;
}

.compliance-header h1 {
    color: #2c3e50;
    margin-bottom: 10px;
}

.compliance-header p {
    color: #7f8c8d;
    font-size: 1.1em;
}

.compliance-overview {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
    margin-bottom: 40px;
}

.overview-card {
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    color: white;
    padding: 30px;
    border-radius: 10px;
    box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
}

.overview-card h3 {
    margin-bottom: 20px;
    font-size: 1.1em;
    opacity: 0.9;
}

.compliance-status, .systems-count, .health-status {
    text-align: center;
}

.status-indicator {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 10px;
}

.status-icon {
    font-size: 3em;
}

.status-text {
    font-size: 1.3em;
    font-weight: 600;
}

.count-display {
    font-size: 3em;
    font-weight: 600;
}

.count-total {
    font-size: 0.6em;
    opacity: 0.8;
}

.health-indicator {
    font-size: 2em;
}

.health-text {
    font-weight: 600;
}

.nato-standards {
    margin-bottom: 40px;
}

.nato-standards h3 {
    color: #2c3e50;
    margin-bottom: 20px;
    border-bottom: 2px solid #3498db;
    padding-bottom: 10px;
}

.standards-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
}

.standard-card {
    background: #f8f9fa;
    padding: 20px;
    border-radius: 8px;
    border: 1px solid #dee2e6;
    transition: all 0.3s ease;
}

.standard-card:hover {
    box-shadow: 0 4px 8px rgba(0, 0, 0, 0.1);
