}

.report-section {
    margin-bottom: 25px;
    padding: 20px;
    background: #f8f9fa;
    border-radius: 5px;
    border: 1px solid #dee2e6;
}

.report-section h4 {
    color: #2c3e50;
    margin-bottom: 15px;
    border-bottom: 1px solid #dee2e6;
