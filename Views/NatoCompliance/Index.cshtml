}

.report-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 15px;
}

.report-item {
    padding: 10px;
    background: white;
    border-radius: 4px;
    border: 1px solid #dee2e6;
}

.report-item strong {
    color: #2c3e50;
}

.report-list {
    list-style: none;
    padding: 0;
}

.report-list li {
    padding: 8px;
    border-bottom: 1px solid #dee2e6;
    display: flex;
    align-items: center;
    gap: 10px;
}

.report-list li:last-child {
