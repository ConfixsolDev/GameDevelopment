}

@@media (max-width: 1024px) {
    .compliance-overview {
        grid-template-columns: 1fr;
    }
    
    .standards-grid {
        grid-template-columns: repeat(2, 1fr);
    }
    
    .systems-grid {
        grid-template-columns: repeat(2, 1fr);
    }
}

@@media (max-width: 768px) {
    .standards-grid {
        grid-template-columns: 1fr;
    }
    
    .systems-grid {
        grid-template-columns: 1fr;
    }
    
    .report-grid {
        grid-template-columns: 1fr;
    }
    
    .action-buttons {
        flex-direction: column;
    }
    
    .action-buttons .btn {
        width: 100%;
    }
}
</style>

<script>
// NATO Compliance Manager
class NatoComplianceManager {
    constructor() {
        this.complianceData = null;
        this.healthData = null;
        
        this.initializeEventListeners();
        this.runComplianceCheck();
    }

    initializeEventListeners() {
        document.getElementById('btnRefreshCompliance').addEventListener('click', () => this.runComplianceCheck());
        document.getElementById('btnGenerateComplianceReport').addEventListener('click', () => this.generateComplianceReport());
        document.getElementById('btnGenerateHealthReport').addEventListener('click', () => this.generateHealthReport());
        document.getElementById('btnExportReports').addEventListener('click', () => this.exportAllReports());
        document.getElementById('btnExportComplianceReport').addEventListener('click', () => this.exportComplianceReport());
    }

    runComplianceCheck() {
        console.log('🔍 Running NATO compliance check...');
        
        if (!window.natoSystemIntegrator) {
            alert('NATO System Integrator not available');
            return;
        }
        
        // Get integration status
        const integrationStatus = window.natoSystemIntegrator.getIntegrationStatus();
        
        // Get compliance verification
        const complianceCheck = window.natoSystemIntegrator.verifyNatoCompliance();
        
        // Get system health
        const healthReport = window.natoSystemIntegrator.generateSystemHealthReport();
        
        this.complianceData = {
            integrationStatus: integrationStatus,
            complianceCheck: complianceCheck,
            healthReport: healthReport,
            timestamp: new Date().toISOString()
        };
        
        // Display results
        this.displayComplianceStatus();
        this.displaySystemsStatus();
        this.displayCapabilities();
        this.displayRecommendations();
        
        console.log('✅ Compliance check complete');
    }

    displayComplianceStatus() {
        // Overall compliance
        const overallStatus = document.getElementById('overallComplianceStatus');
        const isCompliant = this.complianceData.integrationStatus.natoCompliant;
        
        overallStatus.innerHTML = `
            <div class="status-indicator">
                <span class="status-icon">${isCompliant ? '✅' : '⚠️'}</span>
                <span class="status-text">${isCompliant ? 'NATO COMPLIANT' : 'PARTIAL COMPLIANCE'}</span>
            </div>
        `;
        
        // Systems connected
        const systemsConnected = document.getElementById('systemsConnected');
        const connected = this.complianceData.integrationStatus.systemsConnected;
        const total = this.complianceData.integrationStatus.totalSystems;
        
        systemsConnected.innerHTML = `
            <div class="count-display">
                <span class="count-number">${connected}</span>
                <span class="count-total">/ ${total}</span>
            </div>
        `;
        
        // Integration health
        const integrationHealth = document.getElementById('integrationHealth');
        const health = this.complianceData.healthReport.overallHealth;
        
        integrationHealth.innerHTML = `
            <div class="health-indicator">
                <span class="health-text">${health.toUpperCase()}</span>
            </div>
        `;
        
        // Update standard statuses
        this.updateStandardStatuses();
    }

    updateStandardStatuses() {
        const details = this.complianceData.complianceCheck;
        
        // ATP-3-90.1 (Tactics) - covered by AI and Effectiveness
        const atp3901 = details.ai?.compliant && details.effectiveness?.compliant;
        document.getElementById('atp3901Status').innerHTML = 
            `<span class="status-badge ${atp3901 ? 'compliant' : 'partial'}">${atp3901 ? 'Compliant' : 'Partial'}</span>`;
        
        // ATP-3-90.2 (Offensive) - covered by Effectiveness
        const atp3902 = details.effectiveness?.compliant;
        document.getElementById('atp3902Status').innerHTML = 
            `<span class="status-badge ${atp3902 ? 'compliant' : 'partial'}">${atp3902 ? 'Compliant' : 'Partial'}</span>`;
        
        // ATP-3-90.3 (Defensive) - covered by Effectiveness
        const atp3903 = details.effectiveness?.compliant;
        document.getElementById('atp3903Status').innerHTML = 
            `<span class="status-badge ${atp3903 ? 'compliant' : 'partial'}">${atp3903 ? 'Compliant' : 'Partial'}</span>`;
        
        // ATP-3-90.4 (Terrain) - covered by Terrain
        const atp3904 = details.terrain?.compliant;
        document.getElementById('atp3904Status').innerHTML = 
            `<span class="status-badge ${atp3904 ? 'compliant' : 'partial'}">${atp3904 ? 'Compliant' : 'Partial'}</span>`;
        
        // APP-6 (Symbology) - assumed compliant (already implemented)
        document.getElementById('app6Status').innerHTML = 
            `<span class="status-badge compliant">Compliant</span>`;
        
        // NETN-FOM (HLA) - covered by HLA
        const netn = details.hla?.compliant;
        document.getElementById('netnStatus').innerHTML = 
            `<span class="status-badge ${netn ? 'compliant' : 'partial'}">${netn ? 'Compliant' : 'Partial'}</span>`;
    }

    displaySystemsStatus() {
        const systemsGrid = document.getElementById('systemsGrid');
        const systems = this.complianceData.integrationStatus.systems;
        
        systemsGrid.innerHTML = '';
        
        const systemNames = {
            effectiveness: 'NATO Effectiveness Engine',
            terrain: 'NATO Terrain Engine',
            ai: 'NATO AI Analysis Engine',
            simulation: 'Combat Simulation Engine',
            results: 'Simulation Results Manager',
            hla: 'HLA Integration Adapter',
            terrainIntegration: 'Terrain Integration Service',
            aiIntegration: 'AI Integration Service',
            interoperability: 'Interoperability Service'
        };
        
        Object.entries(systems).forEach(([key, operational]) => {
            const card = document.createElement('div');
            card.className = 'system-card';
            card.innerHTML = `
                <div class="system-info">
                    <div class="system-name">${systemNames[key]}</div>
                    <div class="system-description">${operational ? 'Operational' : 'Unavailable'}</div>
                </div>
                <div class="system-status-indicator">
                    ${operational ? '✅' : '❌'}
                </div>
            `;
            systemsGrid.appendChild(card);
        });
    }

    displayCapabilities() {
        const capabilitiesTable = document.getElementById('capabilitiesTable');
        
        const capabilities = [
            { name: 'Attack Planning', system: 'Effectiveness Engine', status: !!this.complianceData.integrationStatus.systems.effectiveness },
            { name: 'Defense Planning', system: 'Effectiveness Engine', status: !!this.complianceData.integrationStatus.systems.effectiveness },
            { name: 'Terrain Analysis', system: 'Terrain Engine', status: !!this.complianceData.integrationStatus.systems.terrain },
            { name: 'AI Decision Support', system: 'AI Analysis Engine', status: !!this.complianceData.integrationStatus.systems.ai },
            { name: 'Turn-Based Simulation', system: 'Simulation Engine', status: !!this.complianceData.integrationStatus.systems.simulation },
            { name: 'Two-Player Mode', system: 'Simulation Engine', status: !!this.complianceData.integrationStatus.systems.simulation },
            { name: 'Fog of War', system: 'Simulation Engine', status: !!this.complianceData.integrationStatus.systems.simulation },
            { name: 'Results Analysis', system: 'Results Manager', status: !!this.complianceData.integrationStatus.systems.results },
            { name: 'Comparative Analysis', system: 'Results Manager', status: !!this.complianceData.integrationStatus.systems.results },
            { name: 'HLA Interoperability', system: 'HLA Adapter', status: !!this.complianceData.integrationStatus.systems.hla },
            { name: 'NATO Symbology (APP-6)', system: 'Symbol Renderer', status: true },
            { name: 'Attack Symbols', system: 'Symbol Renderer', status: true },
            { name: 'Defense Elements', system: 'Defense Planning', status: true }
        ];
        
        capabilitiesTable.innerHTML = '';
        
        capabilities.forEach(capability => {
            const row = document.createElement('div');
            row.className = 'capability-row';
            row.innerHTML = `
                <div class="capability-name">${capability.name}</div>
                <div class="capability-system">${capability.system}</div>
                <div class="capability-status">
                    ${capability.status ? '✅ Available' : '❌ Unavailable'}
                </div>
            `;
            capabilitiesTable.appendChild(row);
        });
    }

    displayRecommendations() {
        const complianceReport = window.natoSystemIntegrator.generateComplianceReport();
        const recommendations = complianceReport.recommendations;
        
        if (recommendations.length === 0) {
            document.getElementById('complianceRecommendations').style.display = 'none';
            return;
        }
        
        document.getElementById('complianceRecommendations').style.display = 'block';
        
        const recommendationsList = document.getElementById('recommendationsList');
        recommendationsList.innerHTML = '';
        
        recommendations.forEach(recommendation => {
            const item = document.createElement('div');
            item.className = 'recommendation-item';
            item.innerHTML = `
                <div class="recommendation-icon">💡</div>
                <div class="recommendation-text">${recommendation}</div>
            `;
            recommendationsList.appendChild(item);
        });
    }

    generateComplianceReport() {
        if (!window.natoSystemIntegrator) {
            alert('NATO System Integrator not available');
            return;
        }
        
        const report = window.natoSystemIntegrator.generateComplianceReport();
        
        const modal = document.getElementById('complianceReportModal');
        const content = document.getElementById('complianceReportContent');
        
        content.innerHTML = `
            <div class="report-section">
                <h4>Executive Summary</h4>
                <div class="report-content">
                    <div class="report-grid">
                        <div class="report-item">
                            <strong>Report Date:</strong> ${new Date(report.reportDate).toLocaleString()}
                        </div>
                        <div class="report-item">
                            <strong>Report Type:</strong> ${report.reportType}
                        </div>
                        <div class="report-item">
                            <strong>Overall Compliance:</strong> ${report.natoCompliance.overall ? '✅ Compliant' : '⚠️ Partial'}
                        </div>
                        <div class="report-item">
                            <strong>Systems Connected:</strong> ${report.systemStatus.connectionRate}
                        </div>
                    </div>
                </div>
            </div>
            
            <div class="report-section">
                <h4>NATO Standards Compliance</h4>
                <div class="report-content">
                    <ul class="report-list">
                        ${Object.entries(report.standards).map(([code, name]) => {
                            const detail = report.natoCompliance.details;
                            let compliant = false;
                            let className = '';
                            
                            if (code.includes('ATP-3-90')) {
                                if (code === 'ATP-3-90.1') compliant = detail.ai?.compliant || false;
                                else if (code === 'ATP-3-90.2') compliant = detail.effectiveness?.compliant || false;
                                else if (code === 'ATP-3-90.3') compliant = detail.effectiveness?.compliant || false;
                                else if (code === 'ATP-3-90.4') compliant = detail.terrain?.compliant || false;
                            } else if (code === 'APP-6') {
                                compliant = true; // Already implemented
                            } else if (code === 'NETN-FOM') {
                                compliant = detail.hla?.compliant || false;
                            }
                            
                            className = compliant ? '' : 'warning';
                            
                            return `<li class="${className}"><strong>${code}:</strong> ${name} - ${compliant ? 'Compliant' : 'Partial'}</li>`;
                        }).join('')}
                    </ul>
                </div>
            </div>
            
            <div class="report-section">
                <h4>System Capabilities</h4>
                <div class="report-content">
                    <ul class="report-list">
                        ${Object.entries(report.capabilities).map(([capability, available]) => {
                            const className = available ? '' : 'warning';
                            return `<li class="${className}"><strong>${this.formatCapabilityName(capability)}:</strong> ${available ? 'Available' : 'Unavailable'}</li>`;
                        }).join('')}
                    </ul>
                </div>
            </div>
            
            <div class="report-section">
                <h4>Integration Status</h4>
                <div class="report-content">
                    <ul class="report-list">
                        ${Object.entries(report.integration).map(([integration, status]) => {
                            const className = status ? '' : 'warning';
                            return `<li class="${className}"><strong>${this.formatCapabilityName(integration)}:</strong> ${status ? 'Integrated' : 'Not Integrated'}</li>`;
                        }).join('')}
                    </ul>
                </div>
            </div>
            
            <div class="report-section">
                <h4>Recommendations</h4>
                <div class="report-content">
                    <ul class="report-list">
                        ${report.recommendations.map(rec => `<li>${rec}</li>`).join('')}
                    </ul>
                </div>
            </div>
        `;
        
        modal.classList.add('show');
    }

    generateHealthReport() {
        if (!window.natoSystemIntegrator) {
            alert('NATO System Integrator not available');
            return;
        }
        
        const health = window.natoSystemIntegrator.generateSystemHealthReport();
        
        const modal = document.getElementById('complianceReportModal');
        const content = document.getElementById('complianceReportContent');
        
        content.innerHTML = `
            <div class="report-section">
                <h4>System Health Overview</h4>
                <div class="report-content">
                    <div class="report-grid">
                        <div class="report-item">
                            <strong>Overall Health:</strong> ${health.overallHealth.toUpperCase()}
                        </div>
                        <div class="report-item">
                            <strong>Timestamp:</strong> ${new Date(health.timestamp).toLocaleString()}
                        </div>
                    </div>
                </div>
            </div>
            
            <div class="report-section">
                <h4>System Status</h4>
                <div class="report-content">
                    <ul class="report-list">
                        ${Object.entries(health.systems).map(([system, status]) => {
                            const className = status.health === 'healthy' ? '' : 'warning';
                            return `<li class="${className}"><strong>${this.formatCapabilityName(system)}:</strong> ${status.status} (${status.health})</li>`;
                        }).join('')}
                    </ul>
                </div>
            </div>
            
            <div class="report-section">
                <h4>Issues</h4>
                <div class="report-content">
                    ${health.issues.length > 0 ? `
                        <ul class="report-list">
                            ${health.issues.map(issue => `<li class="warning">${issue}</li>`).join('')}
                        </ul>
                    ` : '<p>No issues detected</p>'}
                </div>
            </div>
            
            <div class="report-section">
                <h4>Recommendations</h4>
                <div class="report-content">
                    ${health.recommendations.length > 0 ? `
                        <ul class="report-list">
                            ${health.recommendations.map(rec => `<li>${rec}</li>`).join('')}
                        </ul>
                    ` : '<p>No recommendations</p>'}
                </div>
            </div>
        `;
        
        modal.classList.add('show');
    }

    exportComplianceReport() {
        if (!this.complianceData) {
            alert('No compliance data to export');
            return;
        }
        
        const report = window.natoSystemIntegrator.generateComplianceReport();
        const data = JSON.stringify(report, null, 2);
        const blob = new Blob([data], { type: 'application/json' });
        const url = URL.createObjectURL(blob);
        const a = document.createElement('a');
        a.href = url;
        a.download = `nato_compliance_report_${Date.now()}.json`;
        a.click();
        URL.revokeObjectURL(url);
        
        console.log('📤 Compliance report exported');
    }

    exportAllReports() {
        if (!window.natoSystemIntegrator) {
            alert('NATO System Integrator not available');
            return;
        }
        
        const complianceReport = window.natoSystemIntegrator.generateComplianceReport();
        const healthReport = window.natoSystemIntegrator.generateSystemHealthReport();
        
        const allReports = {
            complianceReport: complianceReport,
            healthReport: healthReport,
            exportTimestamp: new Date().toISOString()
        };
        
        const data = JSON.stringify(allReports, null, 2);
        const blob = new Blob([data], { type: 'application/json' });
        const url = URL.createObjectURL(blob);
        const a = document.createElement('a');
        a.href = url;
        a.download = `nato_all_reports_${Date.now()}.json`;
        a.click();
        URL.revokeObjectURL(url);
        
        console.log('📤 All reports exported');
    }

    formatCapabilityName(name) {
        return name.replace(/([A-Z])/g, ' $1').replace(/^./, str => str.toUpperCase()).trim();
    }
}

// Initialize compliance manager
const natoComplianceManager = new NatoComplianceManager();
console.log('📊 NATO Compliance Manager initialized');

// Close modal functionality
document.querySelectorAll('.btn-close, .modal .btn-secondary').forEach(btn => {
    btn.addEventListener('click', () => {
        document.querySelectorAll('.modal').forEach(modal => {
            modal.classList.remove('show');
        });
    });
});
</script>
