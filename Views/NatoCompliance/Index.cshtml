}

.standard-card h4 {
    color: #3498db;
    margin-bottom: 5px;
}

.standard-title {
    color: #7f8c8d;
    margin-bottom: 15px;
    font-size: 0.9em;
}

.standard-status {
    margin-bottom: 15px;
}

.status-badge {
    display: inline-block;
    padding: 6px 12px;
    border-radius: 4px;
    font-size: 0.85em;
    font-weight: 600;
}

.status-badge.compliant {
    background: #d4edda;
    color: #155724;
    border: 1px solid #c3e6cb;
}

.status-badge.non-compliant {
    background: #f8d7da;
    color: #721c24;
    border: 1px solid #f5c6cb;
}

.status-badge.partial {
    background: #fff3cd;
    color: #856404;
    border: 1px solid #ffeaa7;
}

.standard-details ul {
    list-style: none;
    padding: 0;
    font-size: 0.9em;
    color: #495057;
}

.standard-details li {
    padding: 5px 0;
    border-bottom: 1px solid #dee2e6;
}

.standard-details li:last-child {
    border-bottom: none;
}

.standard-details li::before {
    content: "✓";
    color: #28a745;
    font-weight: bold;
    margin-right: 10px;
}

.systems-status {
    margin-bottom: 40px;
}

.systems-status h3 {
    color: #2c3e50;
    margin-bottom: 20px;
    border-bottom: 2px solid #3498db;
    padding-bottom: 10px;
}

.systems-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 15px;
}

.system-card {
    background: white;
    padding: 15px;
    border-radius: 5px;
    border: 1px solid #dee2e6;
    display: flex;
    justify-content: space-between;
    align-items: center;
}

.system-info {
    flex: 1;
}

.system-name {
    font-weight: 600;
    color: #2c3e50;
    margin-bottom: 5px;
}

.system-description {
    font-size: 0.85em;
    color: #7f8c8d;
}

.system-status-indicator {
    font-size: 1.5em;
}

.capabilities-matrix {
    margin-bottom: 40px;
}

.capabilities-matrix h3 {
    color: #2c3e50;
    margin-bottom: 20px;
    border-bottom: 2px solid #3498db;
    padding-bottom: 10px;
}

.capabilities-table {
    background: white;
    border-radius: 8px;
    overflow: hidden;
}

.capability-row {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr;
    padding: 15px;
    border-bottom: 1px solid #dee2e6;
}

.capability-row:nth-child(even) {
    background: #f8f9fa;
}

.capability-row:hover {
    background: #e9ecef;
}

.capability-name {
    font-weight: 600;
    color: #2c3e50;
}

.capability-system {
    color: #7f8c8d;
    font-size: 0.9em;
}

.capability-status {
    text-align: right;
}

.compliance-actions {
    margin-bottom: 40px;
}

.compliance-actions h3 {
    color: #2c3e50;
    margin-bottom: 20px;
    border-bottom: 2px solid #3498db;
    padding-bottom: 10px;
}

.action-buttons {
    display: flex;
    gap: 15px;
    flex-wrap: wrap;
}

.action-buttons .btn {
    flex: 1;
