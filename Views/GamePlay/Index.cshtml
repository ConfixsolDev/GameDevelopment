        $.get('/DataManagement/GetUnitsByBrigade', { id: brigadeId })
            .done(function(units) {
                const c = $('#tokenUnitsList');
                c.empty();
                if (!units || !units.length) { c.html('<p>No units linked.</p>'); return; }
                units.forEach(u => c.append(`<div>${u.unitType || 'Unit'} - ${u.name || u.unitName || ''}</div>`));
