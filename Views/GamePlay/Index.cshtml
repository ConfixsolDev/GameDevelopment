    // Map Integration Functions
    function addUnitToMap(unit) {
        const position = unit.position || (typeof unit.Position==='string' ? JSON.parse(unit.Position) : unit.Position);
        const icon = L.divIcon({
            className: `unit-marker ${unit.forceType.toLowerCase()}`,
            html: `<div class="unit-marker-content">
                     <i class="fas fa-${getUnitIcon(unit.unitType)}"></i>
                     <span class="unit-name">${unit.unitName}</span>
                   </div>`,
            iconSize: [60, 30],
            iconAnchor: [30, 15]
        });

        const marker = L.marker([position.lat, position.lng], { icon: icon }).addTo((typeof map!=='undefined')?map:gameMap);
         // Unit marker click handler removed (no popup required)

        unit.mapMarker = marker;
    }

    function addBattleToMap(battle) {
        const location = JSON.parse(battle.battleLocation);
        const marker = L.marker([location.lat, location.lng], {
            icon: L.divIcon({
                className: 'battle-marker',
                html: '<i class="fas fa-explosion"></i>',
                iconSize: [30, 30],
                iconAnchor: [15, 15]
            })
        }).addTo((typeof map!=='undefined')?map:gameMap);

         // Battle marker click handler removed (no popup required)

        battle.mapMarker = marker;
    }

    function addObjectiveToMap(objective) {
        const location = objective.objectiveLocation
            || (typeof objective.ObjectiveLocation === 'string' ? JSON.parse(objective.ObjectiveLocation) : objective.ObjectiveLocation);
        const marker = L.marker([location.lat, location.lng], {
            icon: L.divIcon({
                className: `objective-marker ${(objective.assignedToForce || objective.AssignedToForce || '').toLowerCase()}`,
                html: '<i class="fas fa-flag"></i>',
                iconSize: [25, 25],
                iconAnchor: [12, 25]
            })
        }).addTo((typeof map!=='undefined')?map:gameMap);

         // Objective marker click handler removed (no popup required)

        objective.mapMarker = marker;
    }

