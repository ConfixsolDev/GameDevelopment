                const positionText = t.position ? `${t.position.lat.toFixed(4)}, ${t.position.lng.toFixed(4)}` : 'Not placed';
                const statusColor = status === 'created' ? '#f59e0b' : status === 'placed' ? '#10b981' : '#3b82f6';
                
