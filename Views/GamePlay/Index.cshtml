<!-- Objective Creation Modal -->
<div id="objectiveModal" class="gameplay-modal">
    <div class="gameplay-modal-content">
        <div class="gameplay-modal-header">
            <h3><i class="fas fa-flag"></i> Create Objective</h3>
            <button class="gameplay-modal-close" onclick="closeModal('objectiveModal')">&times;</button>
        </div>
        <div class="gameplay-modal-body">
            <form id="objectiveForm">
                <div class="form-group">
                    <label>Objective Name:</label>
                    <input type="text" id="objectiveName" class="form-control" placeholder="Enter objective name...">
                </div>
                <div class="form-group">
                    <label>Description:</label>
                    <textarea id="objectiveDescription" class="form-control" rows="3" placeholder="Describe the objective..."></textarea>
                </div>
                <div class="form-group">
                    <label>Objective Type:</label>
                    <select id="objectiveType" class="form-control">
                        <option value="Capture">Capture Area</option>
                        <option value="Defend">Defend Position</option>
                        <option value="Destroy">Destroy Target</option>
                        <option value="Reach">Reach Location</option>
                    </select>
                </div>
                <div class="form-group">
                    <label>Assigned to Force:</label>
                    <select id="assignedForce" class="form-control">
                        <option value="Blue">Blue Force</option>
                        <option value="Red">Red Force</option>
                    </select>
                </div>
                <div class="form-group">
                    <label>Point Value:</label>
                    <input type="number" id="pointValue" class="form-control" value="100" min="0">
                </div>
                <p><strong>Instructions:</strong> Click on the map to set the objective location.</p>
            </form>
        </div>
        <div class="gameplay-modal-footer">
            <button class="gameplay-btn" onclick="closeModal('objectiveModal')">Cancel</button>
            <button class="gameplay-btn primary" id="createObjectiveBtn" onclick="confirmObjective()" disabled>Create Objective</button>
        </div>
    </div>
</div>

<script>
    let gameMap;
    let currentMode = 'fox-land';
    let tokens = [];
    const tokenIdToMarker = {};
    let isFullscreen = false;

    // Token local storage helpers (tokens only)
    const TOKEN_STORE_KEY = 'leaflet_saved_tokens_v1';
    function loadTokensLocal(defaultValue) {
        try { return JSON.parse(localStorage.getItem(TOKEN_STORE_KEY)) || (defaultValue ?? []); } catch { return defaultValue ?? []; }
    }
    function saveTokensLocal() {
        try {
            const serializable = tokens.map(t => ({ id:t.id, type:t.type, position:t.position, name:t.name||'', notes:t.notes||'', category:t.category||'' }));
            localStorage.setItem(TOKEN_STORE_KEY, JSON.stringify(serializable));
        } catch {}
    }

    // ===== Local Storage model for Data Management & Simulation =====
    const LS_KEYS = {
        BRIGADES: 'sim_brigades_v1',
        INFANTRY: 'sim_infantry_v1',
        ARMOURED: 'sim_armoured_v1',
        ARTILLERY:'sim_artillery_v1',
        SCENARIOS:'sim_scenarios_v1',
        DEPLOYMENTS:'sim_deployments_v1',
        BATTLES: 'sim_battles_v1',
        OBJECTIVES:'sim_objectives_v1',
        MOVEMENTS:'sim_movements_v1',
        INTEL:'sim_intel_v1',
        RECON:'sim_recon_v1',
        TERRAIN:'sim_terrain_v1',
        PROTECTION:'sim_protection_v1'
    };
    function lsRead(key, d){ try{ return JSON.parse(localStorage.getItem(key)) || (d ?? []);}catch{ return d ?? []; } }
    function lsWrite(key, v){ try{ localStorage.setItem(key, JSON.stringify(v)); }catch{} }
    function lsUpsert(key, obj, idField='id'){
        const arr = lsRead(key, []);
        if (!obj[idField]) obj[idField] = localId();
        const i = arr.findIndex(x=> x[idField]===obj[idField]);
        if (i>=0) arr[i] = obj; else arr.push(obj);
        lsWrite(key, arr);
        return obj;
    }
    function lsRemove(key, id, idField='id'){
        const arr = lsRead(key, []);
        const i = arr.findIndex(x=> x[idField]===id);
        if (i>=0){ arr.splice(i,1); lsWrite(key, arr);} 
    }
    function localId(){ return 'ls_' + Date.now().toString(36) + '_' + Math.random().toString(36).slice(2,8); }

    // Wait for jQuery to be available
    function waitForJQuery() {
        if (typeof jQuery !== 'undefined') {
            $(document).ready(function() {
                setupEventListeners();

                // Handle window resize
                $(window).resize(function() {
                    if (gameMap) {
                        setTimeout(function() {
                            gameMap.invalidateSize();
                        }, 100);
                    }
                });
            });
        } else {
            console.log('Waiting for jQuery...');
            setTimeout(waitForJQuery, 100);
        }
    }

    // Start waiting for jQuery
    waitForJQuery();


    function setupEventListeners() {
        // Map control buttons
        $('#dataEntryBtn').click(function() {
            openModal('dataEntryModal');
        });

        $('#tokensBtn').click(function() {
            openModal('tokenManagementModal');
        });

        $('#settingsBtn').click(function() {
            openModal('settingsModal');
        });
    }

    function updateCoordinates() {
        const center = gameMap.getCenter();
        const zoom = gameMap.getZoom();

        $('#currentLat').text(center.lat.toFixed(6));
        $('#currentLng').text(center.lng.toFixed(6));
        $('#currentZoom').text(zoom);
    }

    function onMapClick(e) {
        console.log('Map clicked at:', e.latlng);
        // Only handle clicks when explicitly placing a pre-created token
        if (typeof currentMapMode !== 'undefined' && currentMapMode === 'place-token') {
            placeTokenAtLocation(e.latlng);
        }
        // Ignore all other clicks for token creation/placement
    }

    function placeTokenAtLocation(latlng) {
        // Check if we're placing a specific token
        if (currentMapMode === 'place-token' && window._selectedTokenId) {
            const token = tokens.find(t => t.id === window._selectedTokenId);
            if (!token) {
                showNotification('Token not found', 'error');
                return;
            }
            
            // Enforce token placement inside saved region
            try {
                const regionStr = localStorage.getItem('leaflet_saved_region');
                const region = regionStr ? JSON.parse(regionStr) : null;
                if (!region){
                    showNotification('Save the main region first.', 'error');
                    return;
                }
                if (window.turf){
                    const pt = turf.point([latlng.lng, latlng.lat]);
                    const inside = turf.booleanPointInPolygon(pt, region);
                    if (!inside){
                        showNotification('Token must be inside the saved region.', 'error');
                        return;
                    }
                }
            } catch {}

            // Create token marker
            const marker = L.marker(latlng, {
                icon: L.divIcon({
                    className: 'token-marker ' + token.type,
                    html: '<i class="fas fa-crosshairs"></i>',
                    iconSize: [20, 20],
                    iconAnchor: [10, 10]
                })
            }).addTo((typeof map !== 'undefined') ? map : gameMap);

            // Update token data
            token.position = latlng;
            token.marker = marker;
            token.status = 'placed';
            tokenIdToMarker[token.id] = marker;

            // Attach click => open token info popup
            marker.on('click', function(){
                openTokenInfoPopup(token);
            });

            saveTokensLocal();
            updateTokenCount();
            
            // Reset map mode
            currentMapMode = 'normal';
            window._selectedTokenId = null;
            $('#gameMap').css('cursor', 'grab');
            
            showNotification(`Token "${token.name}" placed successfully`, 'success');
            return;
        }
        // If no explicit token is being placed, do nothing
        showNotification('Select a created token and click "Place on Map" first.', 'error');
    }

    function openTokenInfoPopup(token) {
        const formId = `token-form-${token.id}`;
        const nameId = `token-name-${token.id}`;
        const notesId = `token-notes-${token.id}`;
        const html = `
            <div id="${formId}" class="token-popup">
                <div class="form-group" style="margin-bottom:6px">
                    <label style="display:block;font-size:12px;margin-bottom:2px">Name</label>
                    <input id="${nameId}" type="text" class="form-control" value="${(token.name||'').replace(/"/g,'&quot;')}">
                </div>
                <div class="form-group" style="margin-bottom:6px">
                    <label style="display:block;font-size:12px;margin-bottom:2px">Category</label>
                    <select id="token-category-${token.id}" class="form-control">
                        <option value="" title="Generic marker without classification">Generic</option>
                        <option value="Brigade" title="Brigade-level unit">Brigade unit</option>
                        <option value="Division Infantry" title="Infantry division formation">Div infantry unit</option>
                        <option value="Armoured" title="Armoured regiment/battalion">Armored unit</option>
                        <option value="Artillery" title="Artillery regiment/battery">Artillery unit</option>
                        <option value="Recon" title="Reconnaissance element">Recon unit</option>
                        <option value="HQ" title="Headquarters/Command post">HQ</option>
                        <option value="Supply" title="Logistics or supply node">Supply</option>
                    </select>
                    <small id="token-category-help-${token.id}" style="display:block;opacity:.8;margin-top:2px"></small>
                </div>
                <div class="form-group" style="margin-bottom:6px">
                    <label style="display:block;font-size:12px;margin-bottom:2px">Notes</label>
                    <input id="${notesId}" type="text" class="form-control" value="${(token.notes||'').replace(/"/g,'&quot;')}">
                </div>
                <div style="display:flex;gap:6px;justify-content:flex-end">
                    <button class="btn btn-danger" onclick="window.deleteTokenById('${token.id}')">Delete</button>
                    ${token.status === 'placed' ? `<button class="btn btn-success" onclick="assignTokenToUnit('${token.id}')">Assign to Unit</button>` : ''}
                    <button class="btn" onclick="window.deployFromToken('${token.id}')">Deploy</button>
                    <button class="btn btn-primary" onclick="window.saveTokenInfoById('${token.id}')">Save</button>
                </div>
            </div>`;
        try { token.marker.bindPopup(html, { closeButton:true, autoClose:true }).openPopup(); } catch {}
        // Initialize category selection and hover/help
        try {
            const sel = document.getElementById(`token-category-${token.id}`);
            const help = document.getElementById(`token-category-help-${token.id}`);
            const desc = {
                '': 'Generic marker without classification',
                'Brigade': 'Brigade-level unit',
                'Division Infantry': 'Infantry division formation',
                'Armoured': 'Armoured regiment/battalion',
                'Artillery': 'Artillery regiment/battery',
                'Recon': 'Reconnaissance element',
                'HQ': 'Headquarters/Command post',
                'Supply': 'Logistics or supply node'
            };
            if (sel) {
                sel.value = token.category || (window._tokenTemplate||'');
                if (help) help.textContent = desc[sel.value] || '';
                sel.addEventListener('change', function(){ if (help) help.textContent = desc[this.value] || ''; });
                sel.addEventListener('mouseover', function(){ if (help) help.textContent = desc[this.value] || ''; });
            }
        } catch {}
    }

    window.saveTokenInfoById = function(tokenId){
        const token = tokens.find(t=> t.id===tokenId);
        if (!token) return;
        const nameEl = document.getElementById(`token-name-${tokenId}`);
        const notesEl = document.getElementById(`token-notes-${tokenId}`);
        const catEl = document.getElementById(`token-category-${tokenId}`);
        if (nameEl) token.name = nameEl.value || '';
        if (notesEl) token.notes = notesEl.value || '';
        if (catEl) token.category = catEl.value || '';
        saveTokensLocal();
        showNotification('Token saved locally', 'success');
        try { token.marker && token.marker.closePopup && token.marker.closePopup(); } catch {}
    }

    // Deploy via token only
    window.deployFromToken = function(tokenId){
        const token = tokens.find(t=> t.id===tokenId);
        if (!token) { showNotification('Token not found', 'error'); return; }
        if (!currentScenario) { showNotification('Create/Start a scenario first', 'error'); return; }
        // Choose a unit from local DB
        const all = [
            ...lsRead(LS_KEYS.INFANTRY, []).map(u=> ({...u, unitType:'Infantry'})),
            ...lsRead(LS_KEYS.ARMOURED, []).map(u=> ({...u, unitType:'Armoured'})),
            ...lsRead(LS_KEYS.ARTILLERY, []).map(u=> ({...u, unitType:'Artillery'}))
        ];
        if (!all.length){ showNotification('No units in database', 'error'); return; }
        const list = all.map((u,i)=> `${i+1}. [${u.unitType}] ${u.name}`).join('\n');
        const pick = prompt(`Select unit number to deploy at token:\n${list}`, '1');
        const idx = (parseInt(pick||'1',10)-1);
        if (isNaN(idx) || idx<0 || idx>=all.length){ showNotification('Invalid selection', 'error'); return; }
        const u = all[idx];
        const deployment = {
            id: localId(),
            scenarioId: currentScenario.id,
            unitId: u.id,
            unitType: u.unitType,
            unitName: u.name,
            forceType: u.forceType||'',
            position: token.position,
            formation: 'Line',
            currentStrength: 0,
            maxStrength: 0,
            status: 'Deployed',
            morale: 100
        };
        const ds = lsRead(LS_KEYS.DEPLOYMENTS, []); ds.push(deployment); lsWrite(LS_KEYS.DEPLOYMENTS, ds);
        deployedUnits.push(deployment);
        addUnitToMap(deployment);
        showNotification(`Deployed ${u.name} at token`, 'success');
        try { token.marker && token.marker.closePopup && token.marker.closePopup(); } catch {}
    }

    window.deleteTokenById = function(tokenId){
        // Remove marker from map if present
        try {
            const m = (typeof map !== 'undefined') ? map : gameMap;
            const token = tokens.find(t=> t.id===tokenId);
            const marker = (token && token.marker) || tokenIdToMarker[tokenId];
            if (marker && m && typeof m.removeLayer === 'function'){
                m.removeLayer(marker);
            }
            if (tokenIdToMarker[tokenId]) delete tokenIdToMarker[tokenId];
        } catch {}
        // Remove from in-memory tokens
        const idx = tokens.findIndex(t=> t.id===tokenId);
        if (idx>=0) tokens.splice(idx,1);
        // Remove from localStorage
        try{
            const arr = loadTokensLocal([]).filter(t=> t.id!==tokenId);
            localStorage.setItem(TOKEN_STORE_KEY, JSON.stringify(arr));
        }catch{}
        updateTokenCount();
        showNotification('Token deleted', 'info');
    }

    function updateTokenCount() {
        const count = tokens.filter(t => t.type === currentMode).length;
        $('#tokenCount').text(count);
    }

    function updateTeamDisplay(teamName, status) {
        $('#currentTeamName').text(teamName);
        $('#currentTeamStatus').text(status);
    }

    // Map Control Functions
    function toggleMapLayers() {
        try {
            const order = Object.keys(layers || {});
            if (!order.length) { console.warn('No base layers defined'); return; }
            const current = (typeof readBase === 'function') ? readBase() : order[0];
            const next = order[(order.indexOf(current) + 1) % order.length];
            const m = (typeof map !== 'undefined') ? map : gameMap;
            if (!m) { console.warn('Map not initialized'); return; }
            Object.values(layers).forEach(l => m.removeLayer(l));
            layers[next].addTo(m);
            if (typeof saveBase === 'function') saveBase(next);
            if (typeof setBMActive === 'function') setBMActive(next);
            showNotification(`Basemap: ${next}`, 'info');
        } catch (err) {
            console.warn('toggleMapLayers error', err);
        }
    }




    // Deprecated legacy helper removed: token placement now requires pre-created tokens via placeTokenOnMap()

    function createToken() {
        const tokenType = $('#tokenTemplate').val();
        const tokenName = $('#tokenName').val();
        
        if (!tokenType) {
            $('#tokenCreationStatus').text('Please select a token type').css('color', '#ef4444');
            return;
        }
        
        if (!tokenName || tokenName.trim() === '') {
            $('#tokenCreationStatus').text('Please enter a token name').css('color', '#ef4444');
            return;
        }
        
        // Create token data
        const tokenData = {
            id: 'token_' + Date.now(),
            type: currentMode, // 'fox-land' | 'blue-land'
            category: tokenType,
            name: tokenName.trim(),
            notes: '',
            position: null, // Will be set when placed on map
            marker: null,   // Will be set when placed on map
            timestamp: new Date(),
            status: 'created' // 'created', 'placed', 'assigned'
        };
        
        // Add to tokens array
        tokens.push(tokenData);
        saveTokensLocal();
        
        // Clear form
        $('#tokenTemplate').val('');
        $('#tokenName').val('');
        
        // Show success message
        $('#tokenCreationStatus').text(`Token "${tokenName}" created successfully. Click "Place on Map" to position it.`).css('color', '#10b981');
        
        // Refresh token list
        refreshTokenList();
        
        showNotification(`Token "${tokenName}" created successfully`, 'success');
    }

    function placeTokenOnMap(tokenId) {
        const token = tokens.find(t => t.id === tokenId);
        if (!token) {
            showNotification('Token not found', 'error');
            return;
        }
        
        if (token.status === 'placed') {
            showNotification('Token is already placed on the map', 'info');
            return;
        }
        
        // Set up map click mode for this specific token
        currentMapMode = 'place-token';
        window._selectedTokenId = tokenId;
        
        // Close the modal
        closeModal('tokenManagementModal');
        
        // Guide the user
        showNotification(`Click on the map to place "${token.name}"`, 'info');
        $('#gameMap').css('cursor', 'crosshair');
    }

    function assignTokenToUnit(tokenId) {
        const token = tokens.find(t => t.id === tokenId);
        if (!token) {
            showNotification('Token not found', 'error');
            return;
        }
        
        if (token.status !== 'placed') {
            showNotification('Token must be placed on the map first', 'error');
            return;
        }
        
        // Open the token brigade data modal for assignment
        openTokenBrigadeDataModal(tokenId);
    }

    function editToken(tokenId) {
        const token = tokens.find(t => t.id === tokenId);
        if (!token) {
            showNotification('Token not found', 'error');
            return;
        }
        
        // Open token info popup for editing
        openTokenInfoPopup(token);
    }

    function beginTemplatePlacement(){
        const tpl = $('#tokenTemplate').val();
        if (!tpl){ showNotification('Select a token type first', 'error'); return; }
        window._tokenTemplate = tpl;
        placeToken();
    }

    function selectToken() {
        console.log('Select token mode activated');
        currentMapMode = 'select-token';

        // Change cursor style
        $('#gameMap').css('cursor', 'pointer');

        // Add click handlers to existing token markers
        tokens.forEach(token => {
            if (token.marker) {
                token.marker.off('click').on('click', function(e) {
                    selectTokenForDataEntry(token);
                    e.originalEvent.stopPropagation();
                });
            }
        });

        showNotification('Click on a token to manage its brigade data', 'info');
    }


    function openTokenBrigadeDataModal(tokenId) {
        // Set the token ID for the modal
        $('#tokenBrigadeDataModal').data('token-id', tokenId);

        // Load existing brigade data for this token if any
        loadTokenBrigadeData(tokenId);

        // Show the modal
        $('#tokenBrigadeDataModal').show();

        showNotification('Managing data for token: ' + tokenId, 'success');
    }

    function loadTokenBrigadeData(tokenId) {
        // Populate brigade dropdown from local brigades
        const brigades = lsRead(LS_KEYS.BRIGADES, []);
        const sel = $('#tbBrigadeId');
        sel.empty();
        sel.append('<option value="">Select a brigade…</option>');
        brigades.forEach(b=> sel.append(`<option value="${b.id}">${b.name} (${b.brigadeCode||''})</option>`));
    }

    // Placeholders to prevent runtime errors if backend not ready
    function populateBrigadeForm(data) {
        try {
            if (data && data.id) {
                $('#tbBrigadeId').val(data.id);
            }
            if (data && data.notes) {
                $('#tbNotes').val(data.notes);
            }
        } catch {}
    }


    function saveTokenBrigadeLink() {
        const tokenId = $('#tokenBrigadeDataModal').data('token-id');
        const brigadeId = $('#tbBrigadeId').val();
        const notes = $('#tbNotes').val();
        if (!tokenId || !brigadeId) { showNotification('Select a brigade first', 'error'); return; }
        const token = tokens.find(t=> t.id===tokenId);
        if (!token) { showNotification('Token not found', 'error'); return; }
        token.linkedBrigadeId = brigadeId;
        token.notes = notes || token.notes || '';
        saveTokensLocal();
        showNotification('Token linked to brigade (local)', 'success');
        closeModal('tokenBrigadeDataModal');
    }



    function toggleIntelLayer(btn){
        try{
            const m = (typeof map!=='undefined')?map:gameMap; if(!m) return;
            if (m.hasLayer && m.hasLayer(intelGroup)){
                if (m.hasLayer(intelGroup)){ m.removeLayer(intelGroup); btn && btn.classList.remove('active'); }
                else { intelGroup.addTo(m); btn && btn.classList.add('active'); }
            }
        }catch{}
    }
    function toggleReconLayer(btn){
        try{
            const m = (typeof map!=='undefined')?map:gameMap; if(!m) return;
            if (m.hasLayer && m.hasLayer(reconGroup)){
                if (m.hasLayer(reconGroup)){ m.removeLayer(reconGroup); btn && btn.classList.remove('active'); }
                else { reconGroup.addTo(m); btn && btn.classList.add('active'); }
            }
        }catch{}
    }

    // Modal Functions
    function openModal(modalId) {
        $('#' + modalId).show();
    }

    function closeModal(modalId) {
        $('#' + modalId).hide();
    }


    // Team switching functions (called from layout)
    window.switchToFoxLand = function() {
        currentMode = 'fox-land';
        document.body.classList.remove('blue-land');
        document.body.classList.add('fox-land');
        updateTeamDisplay('Fox Land', 'Attacking');
        updateTokenCount();
        setStatus && setStatus('Fox Land');
    };

    window.switchToBlueLand = function() {
        currentMode = 'blue-land';
        document.body.classList.remove('fox-land');
        document.body.classList.add('blue-land');
        updateTeamDisplay('Blue Land', 'Defending');
        updateTokenCount();
        setStatus && setStatus('Blue Land');
    };

    window.switchToSpectator = function() {
        currentMode = 'spectator';
        updateTeamDisplay('Spectator', 'Observing');
        updateTokenCount();
    };

    window.openDataEntry = function() {
        openModal('dataEntryModal');
        loadDataManagementData();
    };

    window.manageTokens = function() {
        openModal('tokenManagementModal');
        setTimeout(refreshTokenList, 0);
    };

    window.openSettings = function() {
        openModal('settingsModal');
    };

    // Data Management Functions
    let currentEditingId = null;

    function switchTab(tabName) {
        // Hide all tab contents
        $('.tab-content').removeClass('active');
        $('.tab-btn').removeClass('active');

        // Show selected tab content
        $('#' + tabName + '-tab').addClass('active');
        $('button[onclick="switchTab(\'' + tabName + '\')"]').addClass('active');
    }

    function loadDataManagementData() {
        loadBrigades();
        loadInfantryBattalions();
        loadArmouredRegiments();
        loadArtilleryRegiments();
        loadTerrainFactors();
        loadForceProtections();
        loadIntel();
        loadRecon();
    }

    // Brigade Management
    function loadBrigades() {
        const allData = lsRead(LS_KEYS.BRIGADES, []);
        // Filter by current team
        const currentTeam = currentMode === 'fox-land' ? 'Fox' : (currentMode === 'blue-land' ? 'Blue' : 'Fox');
        const data = allData.filter(brigade => brigade.forceType === currentTeam);
        const tbody = $('#brigadesTableBody');
        tbody.empty();
        data.forEach(function(brigade) {
            tbody.append(`
                <tr>
                    <td>${brigade.name}</td>
                    <td>${brigade.brigadeCode}</td>
                    <td>${brigade.forceType}</td>
                    <td>${brigade.strength || 'N/A'}</td>
                    <td>
                        <button class="btn btn-sm btn-primary" onclick="editBrigade('${brigade.id}')">Edit</button>
                        <button class="btn btn-sm btn-danger" onclick="deleteBrigade('${brigade.id}')">Delete</button>
                    </td>
                </tr>
            `);
        });
    }

    function openBrigadeForm() {
        currentEditingId = null;
        $('#brigadeForm')[0].reset();
        // Set force type based on current team mode
        const forceType = currentMode === 'fox-land' ? 'Fox' : (currentMode === 'blue-land' ? 'Blue' : 'Fox');
        $('#brigadeForceType').val(forceType);
        openModal('brigadeFormModal');
    }

    function editBrigade(id) {
        currentEditingId = id;
        const b = lsRead(LS_KEYS.BRIGADES, []).find(x=> x.id===id);
        if (b){
            $('#brigadeName').val(b.name||'');
            $('#brigadeCode').val(b.brigadeCode||'');
            $('#brigadeForceType').val(b.forceType||'');
