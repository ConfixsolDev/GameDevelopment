    function executeMovement() {
        const unitId = $('#movementUnitSelect').val();
        const movementType = $('#movementType').val();
        const terrainType = $('#terrainType').val();

        if (!unitId || !movementDestination) {
            showNotification('Please select a unit and destination', 'error');
            return;
        }

        const unit = deployedUnits.find(u=> u.id===unitId) || lsRead(LS_KEYS.DEPLOYMENTS, []).find(u=> u.id===unitId);
        if (!unit) { showNotification('Deployed unit not found', 'error'); return; }
        // Basic distance (approx haversine simplified)
        function toRad(v){ return v*Math.PI/180; }
        const R = 6371;
        const dLat = toRad(movementDestination.lat - unit.position.lat);
        const dLng = toRad(movementDestination.lng - unit.position.lng);
        const a = Math.sin(dLat/2)**2 + Math.cos(toRad(unit.position.lat))*Math.cos(toRad(movementDestination.lat))*Math.sin(dLng/2)**2;
        const distance = 2*R*Math.asin(Math.sqrt(a));
        const speedMap = { March: 6, Tactical: 3, Combat: 1.5 };
        const terrainFactor = { Plain:1, Forest:0.7, Mountain:0.5, Desert:0.8, Swamp:0.4, Urban:0.6 };
        const base = speedMap[movementType] || 4;
        const eff = base * (terrainFactor[terrainType] || 1);
        const travelTime = distance / Math.max(eff, 0.1);
        const calc = { distance, effectiveSpeed: eff, travelTime, terrainTypes: terrainType };
        // Save order locally
        const orders = lsRead(LS_KEYS.MOVEMENTS, []);
        orders.push({ id: localId(), unitDeploymentId: unit.id, start: unit.position, end: movementDestination, movementType, terrainType, calc });
        lsWrite(LS_KEYS.MOVEMENTS, orders);
        // Update UI
        showMovementCalculation(calc);
        showNotification('Movement order issued (local)', 'success');
        closeModal('movementPlanModal');
        currentMapMode = 'normal';
    }

    function showMovementCalculation(calc) {
        $('#movementCalculation').html(`
            <h5>Movement Calculation</h5>
            <p><strong>Distance:</strong> ${calc.distance.toFixed(2)} km</p>
            <p><strong>Speed:</strong> ${calc.effectiveSpeed.toFixed(2)} km/h</p>
            <p><strong>Travel Time:</strong> ${calc.travelTime.toFixed(2)} hours</p>
            <p><strong>Terrain:</strong> ${calc.terrainTypes}</p>
        `).show();
        $('#executeMovementBtn').prop('disabled', false);
    }

