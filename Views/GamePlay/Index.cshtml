        </div>
        <div class="gameplay-modal-body">
            <div class="simulation-tabs">
                <div class="tab-buttons">
                    <button class="tab-btn active" onclick="switchSimTab('scenario')">
                        <i class="fas fa-map"></i> Scenario
                    </button>
                    <button class="tab-btn" onclick="switchSimTab('units')">
                        <i class="fas fa-chess-knight"></i> Units
                    </button>
                    <button class="tab-btn" onclick="switchSimTab('battles')">
                        <i class="fas fa-crosshairs"></i> Battles
                    </button>
                    <button class="tab-btn" onclick="switchSimTab('objectives')">
                        <i class="fas fa-flag"></i> Objectives
                    </button>
                </div>

                <!-- Scenario Tab -->
                <div id="scenario-sim-tab" class="tab-content active">
                    <div class="sim-section-header">
                        <h4>Current Scenario</h4>
                        <div class="scenario-controls">
                            <button class="btn btn-success" onclick="createNewScenario()">
                                <i class="fas fa-plus"></i> New Scenario
                            </button>
                            <button class="btn btn-primary" id="startScenarioBtn" onclick="startCurrentScenario()">
                                <i class="fas fa-play"></i> Start Scenario
                            </button>
                            <button class="btn" onclick="setScenarioTargetPoints()">
                                <i class="fas fa-bullseye"></i> Set Target Points
                            </button>
                            <button class="btn" onclick="runScenarioPointCheck()">
                                <i class="fas fa-calculator"></i> Check Points
                            </button>
                            <button class="btn" onclick="advanceTime()">
                                <i class="fas fa-forward"></i> Advance Time
                            </button>
                        </div>
                    </div>
                    <div class="scenario-info" id="scenarioInfo">
                        <p>No active scenario. Create a new scenario to begin.</p>
                    </div>
                    <div id="scenarioPoints" style="margin-top:10px; font-size:14px; opacity:.9;">
                        Points: —
                    </div>
                </div>

                <!-- Units Tab -->
                <div id="units-sim-tab" class="tab-content">
                    <div class="sim-section-header">
                        <h4>Deployed Units</h4>
                        <button class="btn btn-primary" onclick="showAvailableUnits()">
                            <i class="fas fa-plus"></i> Deploy Unit
                        </button>
