    // Save functions for modals
    function saveTokenBrigade() {
        const tokenId = $('#brigadeFormModal').data('token-id');
        const editingId = $('#brigadeFormModal').data('editing-id');
        
        if (!tokenId) {
            showNotification('No token selected', 'error');
            return;
        }
        
        const form = $('#brigadeForm')[0];
        if (!form.checkValidity()) {
            form.reportValidity();
            return;
        }
        
        const forceType = currentMode === 'fox-land' ? 'Fox' : (currentMode === 'blue-land' ? 'Blue' : 'Fox');
        
        const brigades = lsRead(`token_${tokenId}_brigades`, []);
        
        if (editingId) {
            // Edit existing brigade
            const index = brigades.findIndex(b => b.id === editingId);
            if (index >= 0) {
                brigades[index] = {
                    id: editingId,
                    name: $('#brigadeName').val(),
                    unitCode: $('#brigadeCode').val(),
                    forceType: forceType,
                    strength: parseInt($('#brigadeStrength').val()) || 0
                };
                showNotification('Brigade updated successfully', 'success');
            }
        } else {
            // Add new brigade
            const brigade = {
                id: 'brigade_' + Date.now() + '_' + Math.random().toString(36).substr(2, 9),
                name: $('#brigadeName').val(),
                unitCode: $('#brigadeCode').val(),
                forceType: forceType,
                strength: parseInt($('#brigadeStrength').val()) || 0
            };
            brigades.push(brigade);
            showNotification('Brigade added successfully', 'success');
        }
        
        lsWrite(`token_${tokenId}_brigades`, brigades);
        
        // Close modal and refresh display
        closeModal('brigadeFormModal');
        loadTokenDataEntryData(tokenId);
    }

