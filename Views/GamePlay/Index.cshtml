    // Utility functions
    function showNotification(message, type) {
        // Simple notification system - can be enhanced
        const notification = $(`
            <div class="notification notification-${type}" style="
                position: fixed; top: 20px; right: 20px; z-index: 9999;
                padding: 15px 20px; border-radius: 5px; color: white;
                background: ${type === 'success' ? '#28a745' : type === 'error' ? '#dc3545' : '#17a2b8'};
                box-shadow: 0 4px 6px rgba(0,0,0,0.1);
            ">
                ${message}
            </div>
        `);

        $('body').append(notification);
        setTimeout(() => notification.fadeOut(), 3000);
    }

    // War Game Simulation Functions
    let currentScenario = null;
    let deployedUnits = [];
    let activeBattles = [];
    let objectives = [];
    let simulationRunning = false;
    let currentMapMode = 'normal'; // normal, deploy, move, battle, objective
    let selectedUnit = null;
    let selectedPosition = null;
    let movementDestination = null;

    // Simulation Tab Management
    function switchSimTab(tabName) {
        $('.tab-content').removeClass('active');
        $('.tab-btn').removeClass('active');

        $('#' + tabName + '-sim-tab').addClass('active');
        $('button[onclick="switchSimTab(\'' + tabName + '\')"]').addClass('active');

        // Load data for the selected tab
        switch(tabName) {
            case 'units':
                loadDeployedUnits();
                break;
            case 'battles':
                loadActiveBattles();
                break;
            case 'objectives':
                loadObjectives();
                break;
        }
    }

    // Scenario Management
    function createNewScenario() {
        const scenarioName = prompt('Enter scenario name:');
        if (!scenarioName) return;

        const scenarioData = {
            Name: scenarioName,
            Description: 'War game simulation scenario',
            ScenarioCode: 'SC_' + Date.now(),
            Status: 'Planning'
        };

        $.ajax({
            url: '/Simulation/CreateScenario',
            method: 'POST',
            contentType: 'application/json',
            data: JSON.stringify(scenarioData)
        })
        .done(function(response) {
            if (response.success) {
                currentScenario = response.data;
                updateScenarioDisplay();
                showNotification('Scenario created successfully', 'success');
            } else {
                showNotification('Error: ' + response.message, 'error');
            }
        })
        .fail(function() {
            showNotification('Failed to create scenario', 'error');
        });
    }

    function startCurrentScenario() {
        if (!currentScenario) {
            showNotification('No scenario selected', 'error');
            return;
        }

        $.ajax({
            url: '/Simulation/StartScenario',
            method: 'POST',
            contentType: 'application/json',
            data: JSON.stringify({ ScenarioId: currentScenario.id })
        })
        .done(function(response) {
            if (response.success) {
                currentScenario.status = 'Active';
                updateScenarioDisplay();
                showNotification('Scenario started', 'success');
            } else {
                showNotification('Error: ' + response.message, 'error');
            }
        })
        .fail(function() {
            showNotification('Failed to start scenario', 'error');
        });
    }

    function updateScenarioDisplay() {
        const scenarioInfo = $('#scenarioInfo');
        if (currentScenario) {
            scenarioInfo.html(`
                <div class="scenario-card">
                    <h5>${currentScenario.name}</h5>
                    <p><strong>Status:</strong> <span class="status-${currentScenario.status.toLowerCase()}">${currentScenario.status}</span></p>
                    <p><strong>Code:</strong> ${currentScenario.scenarioCode}</p>
                    <p><strong>Description:</strong> ${currentScenario.description}</p>
                </div>
            `);
            $('#startScenarioBtn').prop('disabled', currentScenario.status === 'Active');
        } else {
            scenarioInfo.html('<p>No active scenario. Create a new scenario to begin.</p>');
        }
    }

    // Unit Deployment Functions
    function deployUnit() {
        currentMapMode = 'deploy';
        openModal('unitDeploymentModal');
        loadAvailableUnits();
    }

    function loadAvailableUnits() {
        const unitsGrid = $('#availableUnitsGrid');
        unitsGrid.empty();

        // Load all unit types
        Promise.all([
            $.get('/DataManagement/GetInfantryBattalions'),
            $.get('/DataManagement/GetArmouredRegiments'),
            $.get('/DataManagement/GetArtilleryRegiments')
        ]).then(([infantry, armoured, artillery]) => {
            const allUnits = [
                ...infantry.map(u => ({...u, type: 'Infantry'})),
                ...armoured.map(u => ({...u, type: 'Armoured'})),
                ...artillery.map(u => ({...u, type: 'Artillery'}))
            ];

            allUnits.forEach(unit => {
                unitsGrid.append(`
                    <div class="unit-card" onclick="selectUnitForDeployment('${unit.id}', '${unit.type}', '${unit.name}')">
                        <div class="unit-icon">
                            <i class="fas fa-${getUnitIcon(unit.type)}"></i>
                        </div>
                        <div class="unit-info">
                            <h6>${unit.name}</h6>
                            <p>${unit.type} - ${unit.forceType}</p>
                            <p>Strength: ${unit.strength}</p>
                        </div>
                    </div>
                `);
            });
        });
    }

    function selectUnitForDeployment(unitId, unitType, unitName) {
        selectedUnit = { id: unitId, type: unitType, name: unitName };
        $('#selectedUnitName').text(unitName);
        $('#selectUnitStep').hide();
        $('#selectPositionStep').show();
        $('#confirmDeploymentBtn').show();

        showNotification('Click on the map to select deployment position', 'info');
    }

    function confirmDeployment() {
        if (!selectedUnit || !selectedPosition) {
            showNotification('Please select a unit and position', 'error');
            return;
        }

        const deploymentData = {
            ScenarioId: currentScenario?.id,
            UnitId: selectedUnit.id,
            UnitType: selectedUnit.type,
            Position: selectedPosition,
            Formation: $('#deploymentFormation').val()
        };

        $.ajax({
            url: '/Simulation/DeployUnit',
            method: 'POST',
            contentType: 'application/json',
            data: JSON.stringify(deploymentData)
        })
        .done(function(response) {
            if (response.success) {
                deployedUnits.push(response.data);
                addUnitToMap(response.data);
                closeModal('unitDeploymentModal');
                resetDeploymentModal();
                showNotification('Unit deployed successfully', 'success');
            } else {
                showNotification('Error: ' + response.message, 'error');
            }
        })
        .fail(function() {
            showNotification('Failed to deploy unit', 'error');
        });
    }

    function resetDeploymentModal() {
        selectedUnit = null;
        selectedPosition = null;
        currentMapMode = 'normal';
        $('#selectUnitStep').show();
        $('#selectPositionStep').hide();
        $('#confirmDeploymentBtn').hide();
    }

    // Movement Planning Functions
    function planMovement() {
        currentMapMode = 'move';
        openModal('movementPlanModal');
        loadDeployedUnitsForMovement();
    }

    function loadDeployedUnitsForMovement() {
        const unitSelect = $('#movementUnitSelect');
        unitSelect.empty().append('<option value="">Select a deployed unit...</option>');

        deployedUnits.forEach(unit => {
            unitSelect.append(`<option value="${unit.id}">${unit.unitName} (${unit.unitType})</option>`);
        });
    }

    function executeMovement() {
        const unitId = $('#movementUnitSelect').val();
        const movementType = $('#movementType').val();
        const terrainType = $('#terrainType').val();

        if (!unitId || !movementDestination) {
            showNotification('Please select a unit and destination', 'error');
            return;
        }

        const movementData = {
            UnitDeploymentId: unitId,
            EndPosition: movementDestination,
            MovementType: movementType,
            TerrainType: terrainType
        };

        $.ajax({
            url: '/Simulation/IssueMovementOrder',
            method: 'POST',
            contentType: 'application/json',
            data: JSON.stringify(movementData)
        })
        .done(function(response) {
            if (response.success) {
                showMovementCalculation(response.calculation);
                showNotification('Movement order issued', 'success');
                closeModal('movementPlanModal');
                currentMapMode = 'normal';
            } else {
                showNotification('Error: ' + response.message, 'error');
            }
        })
        .fail(function() {
            showNotification('Failed to issue movement order', 'error');
        });
    }

    function showMovementCalculation(calc) {
        $('#movementCalculation').html(`
            <h5>Movement Calculation</h5>
            <p><strong>Distance:</strong> ${calc.distance.toFixed(2)} km</p>
            <p><strong>Speed:</strong> ${calc.effectiveSpeed.toFixed(2)} km/h</p>
            <p><strong>Travel Time:</strong> ${calc.travelTime.toFixed(2)} hours</p>
            <p><strong>Terrain:</strong> ${calc.terrainTypes}</p>
        `).show();
        $('#executeMovementBtn').prop('disabled', false);
    }

    // Battle System Functions
    function initiateBattle() {
        currentMapMode = 'battle';
        openModal('battleModal');
        loadParticipatingUnits();
    }

    function loadParticipatingUnits() {
        const unitsDiv = $('#participatingUnits');
        unitsDiv.empty();

        deployedUnits.forEach(unit => {
            unitsDiv.append(`
                <label class="unit-checkbox">
                    <input type="checkbox" value="${unit.id}">
                    ${unit.unitName} (${unit.unitType}) - ${unit.forceType}
                </label>
            `);
        });
    }

    function confirmBattle() {
        const battleName = $('#battleName').val();
        const battleType = $('#battleType').val();
        const terrainType = $('#battleTerrain').val();
        const weather = $('#weatherConditions').val();
        const participatingUnits = [];

        $('#participatingUnits input:checked').each(function() {
            participatingUnits.push($(this).val());
        });

        if (!battleName || !selectedPosition || participatingUnits.length === 0) {
            showNotification('Please fill all required fields and select units', 'error');
            return;
        }

        const battleData = {
            ScenarioId: currentScenario?.id,
            BattleName: battleName,
            BattleLocation: selectedPosition,
            BattleType: battleType,
            TerrainType: terrainType,
            WeatherConditions: weather,
            ParticipatingUnits: participatingUnits
        };

        $.ajax({
            url: '/Simulation/InitiateBattle',
            method: 'POST',
            contentType: 'application/json',
            data: JSON.stringify(battleData)
        })
        .done(function(response) {
            if (response.success) {
                activeBattles.push(response.data);
                addBattleToMap(response.data);
                closeModal('battleModal');
                showNotification('Battle initiated', 'success');

                // Auto-resolve battle after a moment
                setTimeout(() => resolveBattle(response.data.id), 2000);
            } else {
                showNotification('Error: ' + response.message, 'error');
            }
        })
        .fail(function() {
            showNotification('Failed to initiate battle', 'error');
        });
    }

    function resolveBattle(battleId) {
        $.ajax({
            url: '/Simulation/ResolveBattle',
            method: 'POST',
            contentType: 'application/json',
            data: JSON.stringify({ BattleId: battleId })
        })
        .done(function(response) {
            if (response.success) {
                showBattleResults(response.result);
            }
        });
    }

    function showBattleResults(result) {
        const resultsHtml = `
            <div class="battle-results">
                <h4>Battle Results</h4>
                <p><strong>Victor:</strong> ${result.victor}</p>
                <p><strong>Attacker Casualties:</strong> ${result.attackerCasualties.toFixed(1)}%</p>
                <p><strong>Defender Casualties:</strong> ${result.defenderCasualties.toFixed(1)}%</p>
                <p><strong>Victory Margin:</strong> ${(result.victoryMargin * 100).toFixed(1)}%</p>
            </div>
        `;

        showNotification('Battle resolved: ' + result.victor + ' wins!', 'success');

        // Show detailed results in a modal or notification
        const notification = $(resultsHtml);
        $('body').append(notification);
        setTimeout(() => notification.fadeOut(), 10000);
    }

    // Objective Management
    function createObjective() {
        currentMapMode = 'objective';
        openModal('objectiveModal');
    }

    function confirmObjective() {
        const objectiveName = $('#objectiveName').val();
        const description = $('#objectiveDescription').val();
        const objectiveType = $('#objectiveType').val();
        const assignedForce = $('#assignedForce').val();
        const pointValue = $('#pointValue').val();

        if (!objectiveName || !selectedPosition) {
            showNotification('Please fill required fields and select position', 'error');
            return;
        }

        const objectiveData = {
            ObjectiveName: objectiveName,
            Description: description,
            ScenarioId: currentScenario?.id,
            ObjectiveLocation: JSON.stringify(selectedPosition),
            ObjectiveType: objectiveType,
            AssignedToForce: assignedForce,
            PointValue: parseInt(pointValue)
        };

        $.ajax({
            url: '/Simulation/CreateObjective',
            method: 'POST',
            contentType: 'application/json',
            data: JSON.stringify(objectiveData)
        })
        .done(function(response) {
            if (response.success) {
                objectives.push(response.data);
                addObjectiveToMap(response.data);
                closeModal('objectiveModal');
                showNotification('Objective created', 'success');
            } else {
                showNotification('Error: ' + response.message, 'error');
            }
        })
        .fail(function() {
            showNotification('Failed to create objective', 'error');
        });
    }

    // Map Integration Functions
    function addUnitToMap(unit) {
        const position = JSON.parse(unit.position);
        const icon = L.divIcon({
            className: `unit-marker ${unit.forceType.toLowerCase()}`,
            html: `<div class="unit-marker-content">
                     <i class="fas fa-${getUnitIcon(unit.unitType)}"></i>
                     <span class="unit-name">${unit.unitName}</span>
                   </div>`,
            iconSize: [60, 30],
            iconAnchor: [30, 15]
        });

        const marker = L.marker([position.lat, position.lng], { icon: icon }).addTo(gameMap);
        marker.bindPopup(`
            <strong>${unit.unitName}</strong><br>
            Type: ${unit.unitType}<br>
            Force: ${unit.forceType}<br>
            Strength: ${unit.currentStrength}/${unit.maxStrength}<br>
            Status: ${unit.status}
        `);

        unit.mapMarker = marker;
    }

    function addBattleToMap(battle) {
        const location = JSON.parse(battle.battleLocation);
        const marker = L.marker([location.lat, location.lng], {
            icon: L.divIcon({
                className: 'battle-marker',
                html: '<i class="fas fa-explosion"></i>',
                iconSize: [30, 30],
                iconAnchor: [15, 15]
            })
        }).addTo(gameMap);

        marker.bindPopup(`
            <strong>${battle.battleName}</strong><br>
            Type: ${battle.battleType}<br>
            Status: ${battle.status}
        `);

        battle.mapMarker = marker;
    }

    function addObjectiveToMap(objective) {
        const location = JSON.parse(objective.objectiveLocation);
        const marker = L.marker([location.lat, location.lng], {
            icon: L.divIcon({
                className: `objective-marker ${objective.assignedToForce.toLowerCase()}`,
                html: '<i class="fas fa-flag"></i>',
                iconSize: [25, 25],
                iconAnchor: [12, 25]
            })
        }).addTo(gameMap);

        marker.bindPopup(`
            <strong>${objective.objectiveName}</strong><br>
            Type: ${objective.objectiveType}<br>
            Assigned to: ${objective.assignedToForce}<br>
            Points: ${objective.pointValue}
        `);

        objective.mapMarker = marker;
    }

    // Enhanced map click handler
    function onMapClick(e) {
        console.log('Map clicked at:', e.latlng);

        switch(currentMapMode) {
            case 'deploy':
                selectedPosition = { lat: e.latlng.lat, lng: e.latlng.lng };
                showNotification('Position selected for deployment', 'info');
                break;
            case 'move':
                movementDestination = { lat: e.latlng.lat, lng: e.latlng.lng };
                showNotification('Movement destination selected', 'info');
                break;
            case 'battle':
                selectedPosition = { lat: e.latlng.lat, lng: e.latlng.lng };
                $('#initiateBattleBtn').prop('disabled', false);
                showNotification('Battle location selected', 'info');
                break;
            case 'objective':
                selectedPosition = { lat: e.latlng.lat, lng: e.latlng.lng };
                $('#createObjectiveBtn').prop('disabled', false);
                showNotification('Objective location selected', 'info');
                break;
            default:
                if (currentMode === 'fox-land' || currentMode === 'blue-land') {
                    placeTokenAtLocation(e.latlng);
                }
                break;
        }
    }

    // Simulation Control
    function toggleSimulation() {
        simulationRunning = !simulationRunning;
