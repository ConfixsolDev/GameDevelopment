@inject IUserSessionService _userSessionService;
@{
    var currentUser = _userSessionService.GetCurrentUser();
    Layout = "_GamePlayLayout";
    ViewData["Title"] = "Game Play Arena";
    ViewData["Subtitle"] = "Strategic Command Center - Fox Land vs Blue Land";
}

<div class="gameplay-container">
    <!-- MAIN AREA -->
    <main class="game-main-area">
        <!-- MAP -->
        <div class="game-map-container">
            <div id="gameMap"></div>
        </div>

        <!-- LEFT: Region Panel - Lazy Loaded -->
        <div id="regionPanelContainer">
            <!-- Will be lazy loaded -->
        </div>

        <!-- Overlay Controls - Lazy Loaded -->
        <div id="overlayControlsContainer">
            <!-- Will be lazy loaded -->
        </div>

        <!-- BOTTOM-LEFT: Coordinates -->
        <div class="coordinates-display slide-up" id="coordsBox">
            <div class="coord-item"><span class="coord-label">Lat:</span><span class="coord-value" id="latVal">—</span></div>
            <div class="coord-item"><span class="coord-label">Lng:</span><span class="coord-value" id="lngVal">—</span></div>
            <div class="coord-item"><span class="coord-label">Zoom:</span><span class="coord-value" id="zoomVal">—</span></div>
        </div>

        <!-- BOTTOM-RIGHT: Quick Actions -->
        <div class="quick-actions slide-up">
            <button id="adjudicateMoveBtn" class="action-btn action-btn-primary" title="Adjudicate Military Movements" onclick="runMilitaryAdjudication()">
                <i class="fas fa-chart-line"></i>
            </button>
            <button id="clearSelectionBtn" class="action-btn" title="Clear Selection">
                <i class="fas fa-times-circle"></i>
            </button>
            <button id="centerMapBtn" class="action-btn" title="Center Map">
                <i class="fas fa-crosshairs"></i>
            </button>
            <button id="toggleLayersBtn" class="action-btn" title="Toggle Layers">
                <i class="fas fa-layer-group"></i>
            </button>
            <button id="toggleBoundaryBtn" class="action-btn" title="Toggle Game Area Boundary">
                <i class="fas fa-square"></i>
            </button>
        </div>
    </main>

    <!-- RIGHT SIDEBAR -->
    <aside class="game-sidebar">
        <!-- Will be populated by components -->
    </aside>

    <!-- BOTTOM PANEL -->
    <div class="game-bottom-panel">
        <!-- Will be populated by components -->
    </div>
</div>

<!-- Modal Container - All modals will be lazy loaded here -->
<div id="modalsContainer">
    <!-- Modals will be lazy loaded -->
</div>

<!-- Scripts Container - Lazy Loaded -->
<div id="scriptsContainer">
    <!-- Scripts will be lazy loaded -->
</div>

<!-- Additional Map Libraries -->
<link rel="stylesheet" href="~/lib/leaflet/css/leaflet.css" />
<link rel="stylesheet" href="~/lib/leaflet/css/leaflet.draw.css" />
<link rel="stylesheet" href="~/css/regionControls.css" />
<link rel="stylesheet" href="~/css/militarySymbols.css" />
<link rel="stylesheet" href="~/css/attackSymbols.css" />
<link rel="stylesheet" href="~/css/defenseSymbols.css" />

<!-- Core Scripts -->
<script src="~/lib/jquery/dist/jquery.min.js"></script>

<!-- Map Libraries -->
<script src="~/lib/leaflet/js/leaflet.js"></script>
<script src="~/lib/leaflet/js/leaflet.draw.js"></script>
<script src="~/lib/leaflet/js/turf.min.js"></script>
<script src="~/lib/leaflet/js/leaflet-providers.js"></script>

<!-- GamePlay Arena JavaScript Modules -->
<script src="~/js/tileServerConfig.js"></script>
<script src="~/js/lazy-loader.js"></script>
<script src="~/js/MilitarySymbolRenderer.js"></script>
<script src="~/js/AttackSymbolRenderer.js"></script>
<script src="~/js/DefenseSymbolRenderer.js"></script>
<script src="~/js/DefensePlanningManager.js"></script>
<script src="~/js/NatoEffectivenessEngine.js"></script>
<script src="~/js/CombatSimulationEngine.js"></script>
<script src="~/js/SimulationResultsManager.js"></script>
<script src="~/js/NatoTerrainEngine.js"></script>
<script src="~/js/TerrainIntegrationService.js"></script>
<script src="~/js/NatoAiAnalysisEngine.js"></script>
<script src="~/js/AiIntegrationService.js"></script>
<script src="~/js/HlaIntegrationAdapter.js"></script>
<script src="~/js/InteroperabilityService.js"></script>
<script src="~/js/NatoSystemIntegrator.js"></script>
<script src="~/js/TokenManager.js"></script>
<script src="~/js/TokenPlacementManager.js"></script>
<script src="~/js/suspectedTokenManager.js"></script>
<script src="~/js/TokenActionModeManager.js"></script>
<script src="~/js/AttackVisualizationManager.js"></script>
<script src="~/js/RegionManager.js"></script>
<script src="~/js/regionControls.js"></script>
<script src="~/js/gamePlayManager.js"></script>
<script src="~/js/mapControls.js"></script>
<script src="~/js/scenarioPlanning.js"></script>
<script src="~/js/militaryAdjudication.js"></script>

<!-- Defense Planning Functions -->
<script>
// Global defense planning functions
function startKillZoneDrawing(type) {
    if (window.defensePlanningManager) {
        window.defensePlanningManager.startKillZoneDrawing(type);
        console.log(`🛡️ Started drawing ${type} kill zone`);
    } else {
        console.error('Defense planning manager not available');
    }
}

function startMinefieldDrawing(type) {
    if (window.defensePlanningManager) {
        window.defensePlanningManager.startMinefieldDrawing(type);
        console.log(`🛡️ Started drawing ${type} minefield`);
    } else {
        console.error('Defense planning manager not available');
    }
}

function startObstacleDrawing(type) {
    if (window.defensePlanningManager) {
        window.defensePlanningManager.startObstacleDrawing(type);
        console.log(`🛡️ Started drawing ${type} obstacle`);
    } else {
        console.error('Defense planning manager not available');
    }
}

function placeDefensivePosition(type) {
    if (window.defensePlanningManager) {
        window.defensePlanningManager.placeDefensivePosition(type);
        console.log(`🛡️ Started placing ${type} defensive position`);
    } else {
        console.error('Defense planning manager not available');
    }
}

function startWithdrawalRouteDrawing(type) {
    if (window.defensePlanningManager) {
        window.defensePlanningManager.startWithdrawalRouteDrawing(type);
        console.log(`🛡️ Started drawing ${type} withdrawal route`);
    } else {
        console.error('Defense planning manager not available');
    }
}

function startDefensiveLineDrawing(type) {
    if (window.defensePlanningManager) {
        window.defensePlanningManager.startDefensiveLineDrawing(type);
        console.log(`🛡️ Started drawing ${type} defensive line`);
    } else {
        console.error('Defense planning manager not available');
    }
}

function cancelDefenseDrawing() {
    if (window.defensePlanningManager) {
        window.defensePlanningManager.cancelDrawing();
        console.log('🛡️ Cancelled defense drawing');
    } else {
        console.error('Defense planning manager not available');
    }
}

function clearAllDefenseElements() {
    if (window.defensePlanningManager) {
        if (confirm('Are you sure you want to clear all defense elements?')) {
            window.defensePlanningManager.clearAll();
            console.log('🛡️ Cleared all defense elements');
        }
    } else {
        console.error('Defense planning manager not available');
    }
}
</script>

