<script>
    let gameMap;
      let currentMode = "@currentUser.TeamType";
    let tokens = [];
    const tokenIdToMarker = {};
    let isFullscreen = false;

    // Token database helpers
    async function loadTokensFromDatabase() {
        try {
            const response = await fetch('/GamePlay/GetTeamTokens');
            const result = await response.json();
            
            if (result.success) {
                // Convert database tokens to the format expected by the UI
                return result.tokens.map(token => ({
                    id: token.id,
                    name: token.name,
                    category: token.category || 'Generic',
                    description: token.description || '',
                    tokenGroupId: token.tokenGroupId,
                    tokenGroupName: token.tokenGroupName,
                    isActive: token.isActive,
                    isManualToken: token.isManualToken,
                    lastUsed: token.lastUsed,
                    usageCount: token.usageCount,
                    notes: token.notes || '',
                    createdAt: token.createdAt,
                    status: 'created', // Default status for database tokens
                    type: currentMode, // Set based on current mode
                    position: null // No position initially
                }));
            } else {
                console.error('Failed to load tokens:', result.message);
                return [];
            }
        } catch (error) {
            console.error('Error loading tokens from database:', error);
            return [];
        }
    }

    // Load tokens from database and add them to the map
    async function loadTokensAndAddToMap() {
        try {
            // Load tokens from database
            tokens = await loadTokensFromDatabase();
            const m = (typeof map !== 'undefined') ? map : gameMap;
            
            tokens.forEach(t => {
                // Only add markers for tokens that have positions (placed tokens)
                if (t.position) {
                    const marker = L.marker(t.position, {
                        icon: L.divIcon({
                            className: 'token-marker ' + (t.type || 'blue-land'),
                            html: '<i class="fas fa-crosshairs"></i>',
                            iconSize: [20, 20], iconAnchor: [10, 10]
                        })
                    }).addTo(m);
                    t.marker = marker;
                    marker.on('click', function(){ showTokenDetails(t); });
                }
            });
            updateTokenCount();
        } catch (error) {
            console.error('Error loading tokens and adding to map:', error);
        }
    }

    // Token local storage helpers (for backward compatibility)
    const TOKEN_STORE_KEY = 'leaflet_saved_tokens_v1';
    function loadTokensLocal(defaultValue) {
        try { return JSON.parse(localStorage.getItem(TOKEN_STORE_KEY)) || (defaultValue ?? []); } catch { return defaultValue ?? []; }
    }
    function saveTokensLocal() {
        try {
            const serializable = tokens.map(t => ({ id:t.id, type:t.type, position:t.position, name:t.name||'', notes:t.notes||'', category:t.category||'' }));
            localStorage.setItem(TOKEN_STORE_KEY, JSON.stringify(serializable));
        } catch {}
    }

    // ===== Local Storage model for Data Management & Simulation =====
    const LS_KEYS = {
        BRIGADES: 'sim_brigades_v1',
        INFANTRY: 'sim_infantry_v1',
        ARMOURED: 'sim_armoured_v1',
        ARTILLERY:'sim_artillery_v1',
        SCENARIOS:'sim_scenarios_v1',
        DEPLOYMENTS:'sim_deployments_v1',
        BATTLES: 'sim_battles_v1',
        OBJECTIVES:'sim_objectives_v1',
        MOVEMENTS:'sim_movements_v1',
        INTEL:'sim_intel_v1',
        RECON:'sim_recon_v1',
        TERRAIN:'sim_terrain_v1',
        PROTECTION:'sim_protection_v1'
    };
    function lsRead(key, d){ try{ return JSON.parse(localStorage.getItem(key)) || (d ?? []);}catch{ return d ?? []; } }
    function lsWrite(key, v){ try{ localStorage.setItem(key, JSON.stringify(v)); }catch{} }
    function lsUpsert(key, obj, idField='id'){
        const arr = lsRead(key, []);
        if (!obj[idField]) obj[idField] = localId();
        const i = arr.findIndex(x=> x[idField]===obj[idField]);
        if (i>=0) arr[i] = obj; else arr.push(obj);
        lsWrite(key, arr);
        return obj;
    }
    function lsRemove(key, id, idField='id'){
        const arr = lsRead(key, []);
        const i = arr.findIndex(x=> x[idField]===id);
        if (i>=0){ arr.splice(i,1); lsWrite(key, arr);} 
    }
    function localId(){ return 'ls_' + Date.now().toString(36) + '_' + Math.random().toString(36).slice(2,8); }

    // Wait for jQuery to be available
    function waitForJQuery() {
        if (typeof jQuery !== 'undefined') {
            $(document).ready(function() {
                setupEventListeners();

                // Handle window resize
                $(window).resize(function() {
                    if (gameMap) {
                        setTimeout(function() {
                            gameMap.invalidateSize();
                        }, 100);
                    }
                });
            });
        } else {
            console.log('Waiting for jQuery...');
            setTimeout(waitForJQuery, 100);
        }
    }

    // Start waiting for jQuery
    waitForJQuery();


    function setupEventListeners() {
        // Map control buttons
        $('#tokensBtn').click(function() {
            openModal('tokenManagementModal');
        });

        $('#settingsBtn').click(function() {
            openModal('settingsModal');
        });
    }

    function updateCoordinates() {
        const center = gameMap.getCenter();
        const zoom = gameMap.getZoom();

        $('#currentLat').text(center.lat.toFixed(6));
        $('#currentLng').text(center.lng.toFixed(6));
        $('#currentZoom').text(zoom);
    }

    function onMapClick(e) {
        console.log('Map clicked at:', e.latlng);
        // Only handle clicks when explicitly placing a pre-created token
        if (typeof currentMapMode !== 'undefined' && currentMapMode === 'place-token') {
            placeTokenAtLocation(e.latlng);
        }
        // Ignore all other clicks for token creation/placement
    }

    function placeTokenAtLocation(latlng) {
        // Check if we're placing a specific token
        if (currentMapMode === 'place-token' && window._selectedTokenId) {
            const token = tokens.find(t => t.id === window._selectedTokenId);
            if (!token) {
                showNotification('Token not found', 'error');
                return;
            }
            
            // Enforce token placement inside saved region
            try {
                const regionStr = localStorage.getItem('leaflet_saved_region');
                const region = regionStr ? JSON.parse(regionStr) : null;
                if (!region){
                    showNotification('Save the main region first.', 'error');
                    return;
                }
                if (window.turf){
                    const pt = turf.point([latlng.lng, latlng.lat]);
                    const inside = turf.booleanPointInPolygon(pt, region);
                    if (!inside){
                        showNotification('Token must be inside the saved region.', 'error');
                        return;
                    }
                }
            } catch {}

            // Create token marker
            const marker = L.marker(latlng, {
                icon: L.divIcon({
                    className: 'token-marker ' + token.type,
                    html: '<i class="fas fa-crosshairs"></i>',
                    iconSize: [20, 20],
                    iconAnchor: [10, 10]
                })
            }).addTo((typeof map !== 'undefined') ? map : gameMap);

            // Update token data
            token.position = latlng;
            token.marker = marker;
            token.status = 'placed';
            tokenIdToMarker[token.id] = marker;

             // Attach click => show token details in panel
             marker.on('click', function(){
                     showTokenDetails(token);
             });

            saveTokensLocal();
            updateTokenCount();
            
            // Reset map mode
            currentMapMode = 'normal';
            window._selectedTokenId = null;
            $('#gameMap').css('cursor', 'grab');
            
            showNotification(`Token "${token.name}" placed successfully`, 'success');
            return;
        }
        // If no explicit token is being placed, do nothing
        showNotification('Select a created token and click "Place on Map" first.', 'error');
    }

     function showTokenDetails(token) {
         // Load all token data
         const brigades = lsRead(`token_${token.id}_brigades`, []);
         const infantryBattalions = lsRead(`token_${token.id}_infantry_battalions`, []);
         const armouredRegiments = lsRead(`token_${token.id}_armoured_regiments`, []);
         const artilleryRegiments = lsRead(`token_${token.id}_artillery_regiments`, []);
         const intelligence = lsRead(`token_${token.id}_intelligence`, []);
         const recon = lsRead(`token_${token.id}_recon`, []);
         
         // Create comprehensive details HTML
         let detailsHtml = `
             <div class="token-details-panel">
                 <div class="token-details-header">
                     <h3><i class="fas fa-map-marker-alt"></i> ${token.name || 'Unnamed Token'}</h3>
                     <button class="btn btn-sm btn-secondary" onclick="closeTokenDetails()">Close</button>
                 </div>
                 <div class="token-details-content">
                     <div class="token-info-section">
                         <h4><i class="fas fa-info-circle"></i> Token Information</h4>
                         <div class="info-grid">
                             <div class="info-item">
                                 <label>Token ID:</label>
                                 <span>${token.id}</span>
                             </div>
                             <div class="info-item">
                                 <label>Status:</label>
                                 <span class="status-badge ${token.status}">${token.status}</span>
                             </div>
                             <div class="info-item">
                                 <label>Category:</label>
                                 <span>${token.category || 'Generic'}</span>
                             </div>
                             <div class="info-item">
                                 <label>Position:</label>
                                 <span>${token.position ? `${token.position.lat.toFixed(4)}, ${token.position.lng.toFixed(4)}` : 'Not placed'}</span>
                             </div>
                             <div class="info-item">
                                 <label>Notes:</label>
                                 <span>${token.notes || 'No notes'}</span>
                             </div>
                         </div>
                     </div>
         `;
         
         // Military Units Section
         if (brigades.length > 0) {
             detailsHtml += `
                 <div class="token-data-section">
                     <h4><i class="fas fa-flag"></i> Military Units (${brigades.length} Brigades)</h4>
             `;
             
             brigades.forEach(brigade => {
                 const brigadeUnits = [
                     ...infantryBattalions.filter(unit => unit.brigadeId === brigade.id),
                     ...armouredRegiments.filter(unit => unit.brigadeId === brigade.id),
                     ...artilleryRegiments.filter(unit => unit.brigadeId === brigade.id)
                 ];
                 
                 detailsHtml += `
                     <div class="brigade-details">
                         <h5><i class="fas fa-flag"></i> ${brigade.name} (${brigade.unitCode})</h5>
                         <div class="brigade-info">
                             <span><strong>Force:</strong> ${brigade.forceType}</span>
                             <span><strong>Strength:</strong> ${brigade.strength}</span>
                             <span><strong>Units:</strong> ${brigadeUnits.length}</span>
                         </div>
                 `;
                 
                 if (brigadeUnits.length > 0) {
                     detailsHtml += `<div class="units-list">`;
                     brigadeUnits.forEach(unit => {
                         const unitType = unit.id.startsWith('infantry_') ? 'Infantry Battalion' : 
                                        unit.id.startsWith('armoured_') ? 'Armoured Regiment' : 'Artillery Regiment';
                         detailsHtml += `
                             <div class="unit-item">
                                 <span class="unit-name">${unit.name} (${unit.unitCode})</span>
                                 <span class="unit-details">
                                     ${unitType} | Strength: ${unit.strength}
                                     ${unit.companies ? `| Companies: ${unit.companies}` : ''}
                                     ${unit.squadrons ? `| Squadrons: ${unit.squadrons}` : ''}
                                     ${unit.batteries ? `| Batteries: ${unit.batteries}` : ''}
                                     ${unit.drones > 0 ? `| Drones: ${unit.drones}` : ''}
                                 </span>
                             </div>
                         `;
                     });
                     detailsHtml += `</div>`;
                 }
                 detailsHtml += `</div>`;
             });
             detailsHtml += `</div>`;
         } else {
             detailsHtml += `
                 <div class="token-data-section">
                     <h4><i class="fas fa-flag"></i> Military Units</h4>
                     <p class="no-data">No brigades assigned</p>
                 </div>
             `;
         }
         
         // Intelligence Section
         if (intelligence.length > 0) {
             detailsHtml += `
                 <div class="token-data-section">
                     <h4><i class="fas fa-eye"></i> Intelligence Reports (${intelligence.length})</h4>
                     <div class="intel-list">
             `;
             intelligence.forEach(intel => {
                 detailsHtml += `
                     <div class="intel-item">
                         <span class="intel-title">${intel.title}</span>
                         <span class="intel-details">Priority: ${intel.priority} | Source: ${intel.source}</span>
                         <div class="intel-description">${intel.description}</div>
                     </div>
                 `;
             });
             detailsHtml += `</div></div>`;
         } else {
             detailsHtml += `
                 <div class="token-data-section">
                     <h4><i class="fas fa-eye"></i> Intelligence Reports</h4>
                     <p class="no-data">No intelligence reports</p>
                 </div>
             `;
         }
         
         // Recon Section
         if (recon.length > 0) {
             detailsHtml += `
                 <div class="token-data-section">
                     <h4><i class="fas fa-binoculars"></i> Recon Data (${recon.length})</h4>
                     <div class="recon-list">
             `;
             recon.forEach(reconItem => {
                 detailsHtml += `
                     <div class="recon-item">
                         <span class="recon-type">${reconItem.reconType}</span>
                         <span class="recon-details">Confidence: ${reconItem.confidence} | Location: ${reconItem.location}</span>
                         <div class="recon-description">${reconItem.description}</div>
                     </div>
                 `;
             });
             detailsHtml += `</div></div>`;
         } else {
             detailsHtml += `
                 <div class="token-data-section">
                     <h4><i class="fas fa-binoculars"></i> Recon Data</h4>
                     <p class="no-data">No recon data</p>
                 </div>
             `;
         }
         
         detailsHtml += `
                     <div class="token-actions">
                         <button class="btn btn-primary" onclick="closeTokenDetails(); openTokenDataEntryModal('${token.id}')">
                             <i class="fas fa-edit"></i> Edit Data
                         </button>
                         <button class="btn btn-danger" onclick="deleteTokenById('${token.id}')">
                             <i class="fas fa-trash"></i> Delete Token
                         </button>
                     </div>
                 </div>
             </div>
         `;
         
         // Show the details panel
         $('#tokenDetailsPanel').html(detailsHtml).show();
     }

    function closeTokenDetails() {
        $('#tokenDetailsPanel').hide();
    }

    // Edit Functions for Token Data
    function editTokenBrigade(tokenId, brigadeId) {
        const brigades = lsRead(`token_${tokenId}_brigades`, []);
        const brigade = brigades.find(b => b.id === brigadeId);
        if (!brigade) return;

        // Populate form with existing data
        $('#brigadeName').val(brigade.name || '');
        $('#brigadeCode').val(brigade.unitCode || '');
        $('#brigadeStrength').val(brigade.strength || 0);
        $('#brigadeDescription').val(brigade.description || '');

        // Set editing mode
        $('#brigadeFormModal').data('token-id', tokenId);
        $('#brigadeFormModal').data('editing-id', brigadeId);
        $('#brigadeFormModal').show();
    }

    function editTokenInfantryBattalion(tokenId, battalionId) {
        const battalions = lsRead(`token_${tokenId}_infantry_battalions`, []);
        const battalion = battalions.find(b => b.id === battalionId);
        if (!battalion) return;

        // Populate form with existing data
        $('#battalionName').val(battalion.name || '');
        $('#battalionCode').val(battalion.unitCode || '');
        $('#battalionStrength').val(battalion.strength || 0);
        $('#battalionCompanies').val(battalion.companies || 0);
        $('#battalionTanks').val(battalion.tanks || 0);
        $('#battalionDrones').val(battalion.drones || 0);
        $('#battalionDroneTypes').val(battalion.droneTypes || '');
        
        // Equipment & Weapons
        $('#battalionATGMS').val(battalion.ATGMS || 0);
        $('#battalionRocketLauncher').val(battalion.RocketLauncher || 0);
