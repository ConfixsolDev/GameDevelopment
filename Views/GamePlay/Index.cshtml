    // Export functionality
    function exportTeamData() {
        const payload = {
            brigades: lsRead(LS_KEYS.BRIGADES, []),
            infantry: lsRead(LS_KEYS.INFANTRY, []),
            armoured: lsRead(LS_KEYS.ARMOURED, []),
            artillery: lsRead(LS_KEYS.ARTILLERY, []),
            scenarios: lsRead(LS_KEYS.SCENARIOS, []),
            deployments: lsRead(LS_KEYS.DEPLOYMENTS, []),
            battles: lsRead(LS_KEYS.BATTLES, []),
            objectives: lsRead(LS_KEYS.OBJECTIVES, []),
            tokens: loadTokensLocal([])
        };
        const dataStr = JSON.stringify(payload, null, 2);
        const dataBlob = new Blob([dataStr], {type: 'application/json'});
        const url = URL.createObjectURL(dataBlob);
        const link = document.createElement('a');
        link.href = url;
        link.download = 'wargame-data.json';
        link.click();
        URL.revokeObjectURL(url);
        showNotification('Data exported locally', 'success');
    }

    function importTeamData() {
        const input = document.createElement('input');
        input.type = 'file';
        input.accept = 'application/json';
        input.onchange = e => {
            const file = e.target.files && e.target.files[0];
            if (!file) return;
            const reader = new FileReader();
            reader.onload = () => {
                try {
                    const data = JSON.parse(String(reader.result||'{}'));
                    if (data.brigades) lsWrite(LS_KEYS.BRIGADES, data.brigades);
                    if (data.infantry) lsWrite(LS_KEYS.INFANTRY, data.infantry);
                    if (data.armoured) lsWrite(LS_KEYS.ARMOURED, data.armoured);
                    if (data.artillery) lsWrite(LS_KEYS.ARTILLERY, data.artillery);
                    if (data.scenarios) lsWrite(LS_KEYS.SCENARIOS, data.scenarios);
                    if (data.deployments) lsWrite(LS_KEYS.DEPLOYMENTS, data.deployments);
                    if (data.battles) lsWrite(LS_KEYS.BATTLES, data.battles);
                    if (data.objectives) lsWrite(LS_KEYS.OBJECTIVES, data.objectives);
                    if (data.tokens) localStorage.setItem(TOKEN_STORE_KEY, JSON.stringify(data.tokens));
                    // Refresh visible tables if modal is open
                    loadDataManagementData();
                    showNotification('Data imported locally', 'success');
                } catch(err){
                    showNotification('Import failed: invalid JSON', 'error');
                }
            };
            reader.readAsText(file);
        };
        input.click();
    }

    function runAutomatedTests() {
        const results = [];
        function assert(name, cond){ results.push({ name, ok: !!cond }); }
        try {
            // 1) Brigade CRUD
            const b = { id: localId(), name:'Test Brigade', brigadeCode:'TB-1', forceType:'Blue' };
            lsUpsert(LS_KEYS.BRIGADES, b);
            const bRead = lsRead(LS_KEYS.BRIGADES, []).find(x=> x.id===b.id);
            assert('Brigade saved', !!bRead && bRead.name==='Test Brigade');

            // 2) Infantry Save
            const i = { id: localId(), name:'Test Inf', unitCode:'INF-1', forceType:'Blue', strength:500, companies:3 };
            lsUpsert(LS_KEYS.INFANTRY, i);
            assert('Infantry saved', !!lsRead(LS_KEYS.INFANTRY, []).find(x=> x.id===i.id));

            // 3) Scenario create/start
            const sc = { id: localId(), name:'Test Scenario', scenarioCode:'SC_T', status:'Planning' };
            const scs = lsRead(LS_KEYS.SCENARIOS, []); scs.push(sc); lsWrite(LS_KEYS.SCENARIOS, scs);
            currentScenario = sc; startCurrentScenario();
            assert('Scenario started', currentScenario && currentScenario.status==='Active');

            // 4) Deployment
            const dep = { id: localId(), scenarioId: currentScenario.id, unitId:i.id, unitType:'Infantry', unitName:i.name, forceType:i.forceType, position:{lat:25,lng:51}, formation:'Line', currentStrength:0, maxStrength:0, status:'Deployed', morale:100 };
            const ds = lsRead(LS_KEYS.DEPLOYMENTS, []); ds.push(dep); lsWrite(LS_KEYS.DEPLOYMENTS, ds);
            assert('Deployment saved', !!lsRead(LS_KEYS.DEPLOYMENTS, []).find(x=> x.id===dep.id));

            // 5) Objective
            const obj = { id: localId(), scenarioId: currentScenario.id, objectiveName:'OBJ', description:'', objectiveType:'Capture', assignedToForce:'Blue', pointValue:100, objectiveLocation:{lat:25.1,lng:51.1} };
            const os = lsRead(LS_KEYS.OBJECTIVES, []); os.push(obj); lsWrite(LS_KEYS.OBJECTIVES, os);
            assert('Objective saved', !!lsRead(LS_KEYS.OBJECTIVES, []).find(x=> x.id===obj.id));

            // 6) Battle
            const bt = { id: localId(), scenarioId: currentScenario.id, battleName:'B1', battleLocation:{lat:25.2,lng:51.2}, battleType:'Engagement', terrainType:'Plain', weather:'Clear', participatingUnits:[dep.id], status:'Active' };
            const bs = lsRead(LS_KEYS.BATTLES, []); bs.push(bt); lsWrite(LS_KEYS.BATTLES, bs);
            assert('Battle saved', !!lsRead(LS_KEYS.BATTLES, []).find(x=> x.id===bt.id));
        } catch(err){
            results.push({ name:'Exception', ok:false, error:String(err) });
        }
        // Display summary
        const passed = results.filter(r=> r.ok).length;
        const total = results.length;
        showNotification(`Tests: ${passed}/${total} passed`, passed===total ? 'success' : 'error');
        const list = results.map(r=> `${r.ok?'✔':'✖'} ${r.name}${r.error?(' - '+r.error):''}`).join('<br>');
        const modal = $(`
            <div class="gameplay-modal" id="autoTestModal">
              <div class="gameplay-modal-content">
                <div class="gameplay-modal-header"><h3><i class="fas fa-vial"></i> Automated Tests</h3><button class="gameplay-modal-close" onclick="$('#autoTestModal').remove()">&times;</button></div>
                <div class="gameplay-modal-body">${list}</div>
                <div class="gameplay-modal-footer"><button class="gameplay-btn" onclick="$('#autoTestModal').remove()">Close</button></div>
              </div>
            </div>`);
        $('body').append(modal);
    }

