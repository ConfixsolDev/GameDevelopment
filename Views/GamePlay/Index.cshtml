@inject IUserSessionService _userSessionService;
@{
    var currentUser = _userSessionService.GetCurrentUser();
    Layout = "_GamePlayLayout";
}

<div class="gameplay-container">
    <!-- MAIN AREA -->
    <main class="game-main-area">
        <!-- MAP -->
        <div class="game-map-container">
            <div id="gameMap"></div>
        </div>

        <!-- LEFT: Region Panel - Lazy Loaded -->
        <div id="regionPanelContainer">
            <!-- Will be lazy loaded -->
        </div>

        <!-- Overlay Controls - Lazy Loaded -->
        <div id="overlayControlsContainer">
            <!-- Will be lazy loaded -->
        </div>

        <!-- BOTTOM-LEFT: Coordinates -->
        <div class="coordinates-display slide-up" id="coordsBox">
            <div class="coord-item"><span class="coord-label">Lat:</span><span class="coord-value" id="latVal">—</span></div>
            <div class="coord-item"><span class="coord-label">Lng:</span><span class="coord-value" id="lngVal">—</span></div>
            <div class="coord-item"><span class="coord-label">Zoom:</span><span class="coord-value" id="zoomVal">—</span></div>
        </div>

        <!-- Coordinates Display -->
        <div class="coordinates-display" id="coordinatesDisplay">
            <div class="coord-item">
                <span class="coord-label">Lat:</span>
                <span class="coord-value" id="currentLat">0.000000</span>
            </div>
            <div class="coord-item">
                <span class="coord-label">Lng:</span>
                <span class="coord-value" id="currentLng">0.000000</span>
            </div>
            <div class="coord-item">
                <span class="coord-label">Zoom:</span>
                <span class="coord-value" id="currentZoom">10</span>
            </div>
        </div>
    </main>
</div>

<!-- Modal Containers - Lazy Loaded -->
<div id="modalsContainer">
    <!-- Modals will be lazy loaded when needed -->
</div>

<!-- Scripts Container - Lazy Loaded -->
<div id="scriptsContainer">
    <!-- Scripts will be lazy loaded -->
</div>

<!-- Core Scripts (Immediate Load) -->
<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="~/js/lazy-loader.js"></script>
<script src="~/js/TokenPlacementManager.js"></script>
<script src="~/js/TokenManager.js"></script>

<!-- Map Libraries (Same as _GamePlayLayout) -->
<link href="~/map/css/styles.css" rel="stylesheet" />
<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>

<!-- Leaflet Draw -->
<link rel="stylesheet" href="https://unpkg.com/leaflet-draw@1.0.4/dist/leaflet.draw.css" />
<script src="https://unpkg.com/leaflet-draw@1.0.4/dist/leaflet.draw.js"></script>

<!-- Turf -->
<script src="https://unpkg.com/@@turf/turf@6.5.0/turf.min.js"></script>

<!-- Basemap providers -->
<script src="https://unpkg.com/leaflet-providers@1.13.0/leaflet-providers.js"></script>

<script>
    // GamePlay Arena - Lazy Loading Implementation
    $(document).ready(function() {
        console.log('jQuery loaded successfully');
        console.log('Initializing Game Play Arena...');

        // Initialize lazy loader
        window.gamePlayLoader = {
            initialized: false,
            coreComponents: ['region-panel', 'overlay-controls'],
            modalComponents: [
                'data-entry-modal', 'token-management-modal', 'token-selection-modal',
                'simulation-panel', 'unit-deployment-modal', 'movement-plan-modal',
                'battle-modal', 'objective-modal', 'settings-modal'
            ],

            // Initialize the game play arena
            async init() {
                try {
                    console.log('Loading core components...');
                    
                    // Load core components immediately
                    await this.loadCoreComponents();
                    
                    // Initialize map after core components are loaded
                    await this.initializeMap();
                    
                    // Preload critical modals in background
                    this.preloadCriticalModals();
                    
                    // Setup event handlers
                    this.setupEventHandlers();
                    
                    this.initialized = true;
                    console.log('Game Play Arena initialized successfully');
                    
                } catch (error) {
                    console.error('Failed to initialize Game Play Arena:', error);
                    this.showError('Failed to initialize game. Please refresh the page.');
                }
            },

            // Load core components that are always visible
            async loadCoreComponents() {
                const coreLoads = [
                    lazyLoader.loadPartial('region-panel', '#regionPanelContainer', {
                        onLoaded: () => console.log('Region panel loaded')
                    }),
                    lazyLoader.loadPartial('overlay-controls', '#overlayControlsContainer', {
                        onLoaded: () => this.setupControlHandlers()
                    })
                ];
                
                await Promise.all(coreLoads);
            },

            // Initialize the map
            async initializeMap() {
                // Initialize Leaflet map with Qatar coordinates (matching original)
                if (typeof L !== 'undefined') {
                    window.gameMap = L.map('gameMap').setView([25.2854, 51.5310], 6);
                    window.gameMap.zoomControl.setPosition('bottomright');
                    
                    // Create layer groups (matching original)
                    window.regionGroup = new L.FeatureGroup().addTo(window.gameMap);
                    window.BlueGroup = new L.FeatureGroup().addTo(window.gameMap);
                    window.foxGroup = new L.FeatureGroup().addTo(window.gameMap);
                    window.labelGroup = new L.FeatureGroup().addTo(window.gameMap);
                    window.intelGroup = new L.FeatureGroup().addTo(window.gameMap);
                    window.reconGroup = new L.FeatureGroup().addTo(window.gameMap);
                    
                    // Define base layers (matching original)
                    const layers = {
                        "OSM": L.tileLayer.provider('OpenStreetMap.Mapnik'),
                        "Topo": L.tileLayer.provider('OpenTopoMap'),
                        "Satellite": L.tileLayer.provider('Esri.WorldImagery'),
                        "Streets": L.tileLayer.provider('Esri.WorldStreetMap')
                    };
                    
                    // Add default layer (Satellite)
                    layers.Satellite.addTo(window.gameMap);
                    
                    // Setup map click handler for token placement
                    window.gameMap.on('click', this.handleMapClick.bind(this));
                    
                    console.log('Map initialized with Qatar view and layer groups');
                } else {
                    console.warn('Leaflet not loaded, map initialization skipped');
                }
            },

            // Preload critical modals in background
            preloadCriticalModals() {
                const criticalModals = ['data-entry-modal', 'token-selection-modal'];
                lazyLoader.preloadPartials(criticalModals);
            },

            // Setup event handlers for lazy loading
            setupEventHandlers() {
                // Modal loading handlers
                $(document).on('click', '[data-modal]', this.handleModalOpen.bind(this));
                
                // Button handlers that might need modals
                $(document).on('click', '#btnPlaceToken', () => this.loadModal('token-selection-modal'));
                $(document).on('click', '[onclick*="openDataEntry"]', () => this.loadModal('data-entry-modal'));
                $(document).on('click', '[onclick*="simulationPanel"]', () => this.loadModal('simulation-panel'));
            },

            // Setup control handlers after overlay controls are loaded
            setupControlHandlers() {
                console.log('🔧 Setting up control handlers...');
                
                // Check if button exists
                const placeTokenBtn = document.getElementById('btnPlaceToken');
                console.log('🔍 Place Token button found:', placeTokenBtn ? 'YES' : 'NO');
                
                if (placeTokenBtn) {
                    // Fix the token placement handlers
                    $('#btnPlaceToken').off('click').on('click', (e) => {
                        console.log('🖱️ Place Token button clicked!');
                        e.preventDefault();
                        this.openTokenPlacement();
                    });
                    
                    $('#btnCancelTokenPlacement').off('click').on('click', (e) => {
                        console.log('🖱️ Cancel Token button clicked!');
                        e.preventDefault();
                        this.cancelTokenPlacement();
                    });
                    
                    console.log('✅ Token placement handlers attached');
                } else {
                    console.warn('⚠️ Place Token button not found - handlers not attached');
                }
            },

            // Handle modal opening with lazy loading
            async handleModalOpen(event) {
                const modalName = $(event.target).data('modal');
                if (modalName) {
                    event.preventDefault();
                    await this.loadModal(modalName);
                }
            },

            // Load a modal on demand
            async loadModal(modalName) {
                try {
                    await lazyLoader.loadPartial(modalName, '#modalsContainer', {
                        onLoaded: () => {
                            // Open the modal after loading - use the exact modal name
                            setTimeout(() => {
                                this.openModal(modalName.replace('-modal', ''));
                                
                                // If it's the token selection modal, load tokens
                                if (modalName === 'token-selection-modal') {
                                    this.loadAvailableTokens();
                                }
                            }, 100); // Small delay to ensure DOM is updated
                        }
                    });
                } catch (error) {
                    console.error(`Failed to load modal ${modalName}:`, error);
                    this.showError(`Failed to load ${modalName}. Please try again.`);
                }
            },

            // Open modal (assumes modal HTML is already loaded)
            openModal(modalId) {
                // Handle different modal ID formats
                let modalElement = null;
                
                // First try direct ID
                modalElement = document.getElementById(modalId);
                
                // Try with Modal suffix
                if (!modalElement) {
                    modalElement = document.getElementById(modalId + 'Modal');
                }
                
                // Try converting kebab-case to camelCase
                if (!modalElement && modalId.includes('-')) {
                    const camelCaseId = modalId.replace(/-([a-z])/g, (g) => g[1].toUpperCase()) + 'Modal';
                    modalElement = document.getElementById(camelCaseId);
                    console.log(`Trying camelCase ID: ${camelCaseId}`);
                }
                
                // Debug: List all modals in the container
                if (!modalElement) {
                    const modalsContainer = document.getElementById('modalsContainer');
                    if (modalsContainer) {
                        const allModals = modalsContainer.querySelectorAll('.gameplay-modal');
                        console.log('Available modals:', Array.from(allModals).map(m => m.id));
                    }
                }
                
                if (modalElement) {
                    $(modalElement).addClass('active').show();
                    console.log(`Modal opened: ${modalElement.id}`);
                } else {
                    console.warn(`Modal element not found: ${modalId}. Tried: ${modalId}, ${modalId}Modal, ${modalId.replace(/-([a-z])/g, (g) => g[1].toUpperCase())}Modal`);
                }
            },

            // Close modal
            closeModal(modalId) {
                const modalElement = document.getElementById(modalId + 'Modal') || document.getElementById(modalId);
                if (modalElement) {
                    $(modalElement).removeClass('active');
                }
            },

            // Token placement functionality
            openTokenPlacement() {
                console.log('Opening token placement...');
                console.log('About to load modal: token-selection-modal');
                
                // Check if modal is already loaded
                const existingModal = document.getElementById('tokenSelectionModal');
                if (existingModal) {
                    console.log('Modal already exists, opening directly');
                    this.openModal('token-selection');
                    return;
                }
                
                console.log('Modal not found, loading from server...');
                this.loadModal('token-selection-modal');
            },

            cancelTokenPlacement() {
                console.log('Cancelling token placement...');
                if (window.tokenPlacementManager) {
                    window.tokenPlacementManager.cancelPlacement();
                }
            },

            // Handle map click events
            handleMapClick(e) {
                console.log('Map clicked at:', e.latlng);
                
                // If in token placement mode, place the token
                if (typeof handleMapClick === 'function') {
                    handleMapClick(e);
                }
            },

            // Load available tokens for selection
            async loadAvailableTokens() {
                console.log('🎯 Loading available tokens...');
                try {
                    const response = await fetch('/GamePlay/GetTeamTokens');
                    const data = await response.json();
                    
                    console.log('📋 Token data received:', data);
                    
                    if (data.success) {
                        this.populateTokenSelection(data.tokens || []);
                    } else {
                        console.error('❌ Failed to load tokens:', data.message);
                        this.showTokenError('Failed to load tokens: ' + data.message);
                    }
                } catch (error) {
                    console.error('❌ Error loading tokens:', error);
                    this.showTokenError('Error connecting to server');
                }
            },

            // Populate token selection grid
            populateTokenSelection(tokens) {
                console.log(`🔢 Populating ${tokens.length} tokens`);
                const container = document.getElementById('tokenSelectionGrid');
                if (!container) {
                    console.warn('⚠️ Token selection grid not found');
                    return;
                }
                
                if (tokens.length === 0) {
                    container.innerHTML = `
                        <div class="no-tokens">
                            <i class="fas fa-exclamation-triangle"></i>
                            <p>No tokens available for placement</p>
                        </div>
                    `;
                    return;
                }
                
                container.innerHTML = '';
                
                tokens.forEach((token, index) => {
                    const tokenElement = document.createElement('div');
                    tokenElement.className = 'token-card';
                    tokenElement.dataset.tokenId = token.id;
                    
                    // Get token icon based on type
                    const tokenIcon = this.getTokenIcon(token);
                    
                    // Check if token has an image
                    const hasImage = token.assetImagePath && token.assetImagePath !== null;
                    
                    tokenElement.innerHTML = `
                        <div class="token-card-image">
                            ${hasImage ? 
                                `<img src="${token.assetImagePath}" 
                                     alt="${token.name || 'Token'}" 
                                     class="token-uploaded-image" />` :
                                `<div class="token-fallback-icon">
                                    <div class="token-background" style="${this.getFallbackBackground(token, index)}"></div>
                                    <div class="token-card-icon">
                                        <i class="${this.getTokenIcon(token)}"></i>
                                    </div>
                                </div>`
                            }
                        </div>
                        <div class="token-card-label">
                            ${token.name || `Token ${index + 1}`}
                        </div>
                    `;
                    
                    tokenElement.onclick = () => this.selectTokenForPlacement(token);
                    container.appendChild(tokenElement);
                });
                
                // Setup search functionality
                this.setupTokenSearch(tokens);
                
                console.log('✅ Token grid populated successfully');
            },

            // Get token icon based on type
            getTokenIcon(token) {
                const iconMap = {
                    'infantry': 'fas fa-walking',
                    'tank': 'fas fa-shield-alt',
                    'artillery': 'fas fa-crosshairs',
                    'helicopter': 'fas fa-helicopter',
                    'aircraft': 'fas fa-fighter-jet',
                    'naval': 'fas fa-ship',
                    'command': 'fas fa-star',
                    'supply': 'fas fa-boxes',
                    'medical': 'fas fa-plus-square',
                    'engineer': 'fas fa-tools'
                };
                
                const tokenType = (token.type || token.category || '').toLowerCase();
                return iconMap[tokenType] || 'fas fa-chess-knight';
            },


            // Get fallback background for tokens without images
            getFallbackBackground(token, index) {
                const colorSchemes = [
                    'linear-gradient(135deg, #ff6b6b, #ee5a24)', // Red/Orange
                    'linear-gradient(135deg, #8e44ad, #3742fa)', // Purple/Blue  
                    'linear-gradient(135deg, #00d2d3, #54a0ff)', // Cyan/Blue
                    'linear-gradient(135deg, #2ed573, #1e90ff)', // Green/Blue
                    'linear-gradient(135deg, #ffa502, #ff4757)', // Orange/Red
                    'linear-gradient(135deg, #5f27cd, #00d2d3)', // Purple/Cyan
                ];
                
                if (token.team === 'fox' || token.country === 'Fox Land') {
                    return 'background: linear-gradient(135deg, #ff6b6b, #ee5a24);';
                } else if (token.team === 'blue' || token.country === 'Blue Land') {
                    return 'background: linear-gradient(135deg, #54a0ff, #2f3542);';
                } else {
                    const colorIndex = index % colorSchemes.length;
                    return `background: ${colorSchemes[colorIndex]};`;
                }
            },

            // Setup token search functionality
            setupTokenSearch(tokens) {
                const searchInput = document.getElementById('tokenSearchInput');
                if (!searchInput) return;

                searchInput.addEventListener('input', (e) => {
                    const searchTerm = e.target.value.toLowerCase();
                    const tokenCards = document.querySelectorAll('.token-card');
                    
                    tokenCards.forEach(card => {
                        const tokenName = card.querySelector('.token-card-label').textContent.toLowerCase();
                        const shouldShow = tokenName.includes(searchTerm);
                        card.style.display = shouldShow ? 'block' : 'none';
                    });
                });
            },

            // Show token loading error
            showTokenError(message) {
                const container = document.getElementById('tokenSelectionGrid');
                if (container) {
                    container.innerHTML = `
                        <div class="no-tokens">
                            <i class="fas fa-exclamation-triangle"></i>
                            <p>${message}</p>
                            <button class="btn btn-sm btn-primary" onclick="window.gamePlayLoader.loadAvailableTokens()">
                                <i class="fas fa-refresh"></i> Retry
                            </button>
                        </div>
                    `;
                }
            },

            // Select token for placement
            selectTokenForPlacement(token) {
                console.log('🎯 Selected token for placement:', token.name);
                
                // Close the modal
                this.closeModal('tokenSelectionModal');
                
                // Start placement mode
                if (window.tokenPlacementManager) {
                    window.tokenPlacementManager.startPlacementMode(token);
                } else {
                    console.warn('⚠️ TokenPlacementManager not available');
                }
                
                // Show instruction
                this.showNotification(`Click on the map to place ${token.name}`, 'info');
            },

            // Show notification
            showNotification(message, type = 'info') {
                console.log(`📢 ${type.toUpperCase()}: ${message}`);
                
                // Create a simple notification
                const notification = document.createElement('div');
                notification.className = `notification notification-${type}`;
                notification.innerHTML = `
                    <i class="fas fa-info-circle"></i>
                    <span>${message}</span>
                `;
                
                document.body.appendChild(notification);
                
                setTimeout(() => {
                    notification.remove();
                }, 3000);
            },

            // Show error message
            showError(message) {
                this.showNotification(message, 'error');
            }
        };

        // Start initialization
        window.gamePlayLoader.init();

        // Global functions for backward compatibility
        window.openTokenPlacement = () => window.gamePlayLoader.openTokenPlacement();
        window.cancelTokenPlacement = () => window.gamePlayLoader.cancelTokenPlacement();
        window.openModal = (modalId) => window.gamePlayLoader.openModal(modalId);
        window.closeModal = (modalId) => window.gamePlayLoader.closeModal(modalId);
        window.closeTokenSelectionModal = () => window.gamePlayLoader.closeModal('tokenSelectionModal');
        window.openDataEntry = () => window.gamePlayLoader.loadModal('data-entry-modal');
    });
</script>

<style>
    /* Ensure proper loading states */
    .lazy-loading-indicator {
        display: flex;
        align-items: center;
        justify-content: center;
        min-height: 200px;
        opacity: 0.7;
    }

    .lazy-loading-error {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        min-height: 200px;
        color: #dc3545;
    }

    /* Modal transitions - 60% width max */
    .gameplay-modal {
        display: none;
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background-color: rgba(0, 0, 0, 0.7);
        z-index: 9999;
        transition: opacity 0.3s ease;
    }

    .gameplay-modal.active {
        display: flex !important;
        align-items: center;
        justify-content: center;
        opacity: 1;
    }

    .gameplay-modal-content {
        background: #1a1a1a;
        border: 2px solid #00ff88;
        border-radius: 8px;
        width: 60%;
        max-width: 800px;
        max-height: 80vh;
        overflow-y: auto;
        box-shadow: 0 8px 32px rgba(0, 255, 136, 0.3);
    }

    /* Token grid for your specific layout */
    #tokenSelectionGrid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(120px, 1fr));
        gap: 12px;
        padding: 20px;
    }

    /* Token cards - clean design with overlay text */
    .token-card {
        background: transparent;
        border: none;
        border-radius: 8px;
        cursor: pointer;
        transition: all 0.3s ease;
        overflow: hidden;
        aspect-ratio: 1;
        position: relative;
        display: block;
    }

    .token-card:hover {
        transform: translateY(-3px);
        box-shadow: 0 8px 25px rgba(0, 255, 136, 0.6);
    }

    /* Token card image container */
    .token-card-image {
        width: 100%;
        height: 100%;
        position: relative;
        border-radius: 8px;
        overflow: hidden;
    }

    /* Token uploaded images */
    .token-uploaded-image {
        width: 100%;
        height: 100%;
        object-fit: cover;
        border-radius: 8px;
    }

    /* Token fallback when no image uploaded */
    .token-fallback-icon {
        width: 100%;
        height: 100%;
        position: relative;
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 8px;
        overflow: hidden;
    }

    .token-background {
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        opacity: 0.9;
        border-radius: 8px;
    }

    .token-card-icon {
        position: relative;
        z-index: 2;
        color: white;
        font-size: 32px;
        text-shadow: 2px 2px 4px rgba(0, 0, 0, 0.8);
    }

    /* Token label overlay */
    .token-card-label {
        position: absolute;
        bottom: 0;
        left: 0;
        right: 0;
        background: linear-gradient(180deg, 
            transparent 0%, 
            rgba(0, 0, 0, 0.3) 30%, 
            rgba(0, 0, 0, 0.7) 70%, 
            rgba(0, 0, 0, 0.9) 100%);
        color: #fff;
        padding: 25px 12px 10px 12px;
        text-align: center;
        font-size: 13px;
        font-weight: 700;
        z-index: 10;
        text-shadow: 2px 2px 4px rgba(0, 0, 0, 0.9);
        letter-spacing: 0.5px;
    }
</style>
