    window.deleteTokenById = function(tokenId){
        // Remove marker from map if present
        try {
            const m = (typeof map !== 'undefined') ? map : gameMap;
            const token = tokens.find(t=> t.id===tokenId);
            const marker = (token && token.marker) || tokenIdToMarker[tokenId];
            if (marker && m && typeof m.removeLayer === 'function'){
                m.removeLayer(marker);
            }
            if (tokenIdToMarker[tokenId]) delete tokenIdToMarker[tokenId];
        } catch {}
        // Remove from in-memory tokens
        const idx = tokens.findIndex(t=> t.id===tokenId);
        if (idx>=0) tokens.splice(idx,1);
        // Remove from localStorage
        try{
            const arr = loadTokensLocal([]).filter(t=> t.id!==tokenId);
            localStorage.setItem(TOKEN_STORE_KEY, JSON.stringify(arr));
        }catch{}
        updateTokenCount();
        showNotification('Token deleted', 'info');
    }

    function updateTokenCount() {
        const count = tokens.filter(t => t.type === currentMode).length;
        $('#tokenCount').text(count);
    }

