@inject IUserSessionService _userSessionService;
@{
    var currentUser = _userSessionService.GetCurrentUser();
    Layout = "_GamePlayLayout";
    ViewData["Title"] = "Game Play Arena";
    ViewData["Subtitle"] = "Strategic Command Center - Fox Land vs Blue Land";
}


<div class="gameplay-container">
    <!-- Instruction Banner (shown during attack mode) -->
    <div id="attackInstructionBanner" style="display: none; position: fixed; top: 120px; left: 10px; width: 280px; z-index: 9998; background: #007bff; color: white; padding: 15px 20px; border-radius: 8px; border: 2px solid #87ceeb; box-shadow: 0 4px 15px rgba(0,0,0,0.3); font-size: 16px; font-weight: bold; text-align: left; font-family: sans-serif;">
        <div style="display: flex; align-items: center; justify-content: flex-start; gap: 10px;">
            <div style="width: 24px; height: 24px; background: linear-gradient(90deg, #0056b3 50%, #87ceeb 50%); border-radius: 4px; position: relative; flex-shrink: 0;">
                <div style="position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%); width: 16px; height: 16px; background: white; border-radius: 2px;"></div>
            </div>
            <div style="display: flex; flex-direction: column; align-items: flex-start; min-width: 0;">
                <span style="font-size: 16px; font-weight: bold;">Planning Movement</span>
                <span id="attackInstructionText" style="font-size: 14px; font-weight: normal; word-wrap: break-word;">Click and drag tokens to move them, or click to view details</span>
            </div>
        </div>
    </div>

    <!-- MAIN AREA -->
    <main class="game-main-area">
        <!-- MAP -->
        <div class="game-map-container">
            <div id="gameMap"></div>
        </div>

        <!-- LEFT: Region Panel - Direct Include -->
        <div id="regionPanelContainer">
            @await Html.PartialAsync("Partials/Controls/_RegionPanel")
        </div>

        <!-- Overlay Controls - Direct Include -->
        <div id="overlayControlsContainer">
            @await Html.PartialAsync("Partials/Controls/_OverlayControls")
        </div>

        <!-- BOTTOM-LEFT: Coordinates -->
        <div class="coordinates-display slide-up" id="coordsBox">
            <div class="coord-item"><span class="coord-label">Lat:</span><span class="coord-value" id="latVal">—</span></div>
            <div class="coord-item"><span class="coord-label">Lng:</span><span class="coord-value" id="lngVal">—</span></div>
            <div class="coord-item"><span class="coord-label">Zoom:</span><span class="coord-value" id="zoomVal">—</span></div>
        </div>

        <!-- BOTTOM-RIGHT: Quick Actions -->
        <div class="quick-actions slide-up">
            <button id="adjudicateMoveBtn" class="action-btn action-btn-primary" title="Adjudicate Military Movements" onclick="runMilitaryAdjudication()">
                <i class="fas fa-chart-line"></i>
            </button>
            <button id="clearSelectionBtn" class="action-btn" title="Clear Selection">
                <i class="fas fa-times-circle"></i>
            </button>
            <button id="centerMapBtn" class="action-btn" title="Center Map">
                <i class="fas fa-crosshairs"></i>
            </button>
            <button id="toggleLayersBtn" class="action-btn" title="Toggle Layers">
                <i class="fas fa-layer-group"></i>
            </button>
            <button id="toggleBoundaryBtn" class="action-btn" title="Toggle Game Area Boundary">
                <i class="fas fa-square"></i>
            </button>
        </div>
    </main>

    <!-- RIGHT SIDEBAR -->
    <aside class="game-sidebar">
        <!-- Will be populated by components -->
    </aside>

    <!-- BOTTOM PANEL -->
    <div class="game-bottom-panel">
        <!-- Will be populated by components -->
    </div>
</div>

<!-- Modal Container - All modals directly included for better performance -->
<div id="modalsContainer">
    @await Html.PartialAsync("Partials/Modals/_DataEntryModal")
    @await Html.PartialAsync("Partials/Modals/_TokenSelectionModal")
    @await Html.PartialAsync("Partials/Modals/_SuspectedTokenModal")
    @await Html.PartialAsync("Partials/Modals/_MovementModal")
</div>

<!-- Scripts Container - Lazy Loaded -->
<div id="scriptsContainer">
    <!-- Scripts will be lazy loaded -->
</div>

