    function setScenarioTargetPoints(){
        if (!currentScenario){ showNotification('No active scenario', 'error'); return; }
        const val = prompt('Set target points for this scenario:', currentScenario.targetPoints ?? '1000');
        if (val===null) return;
        const n = parseInt(val);
        if (!isFinite(n) || n<0){ showNotification('Invalid points', 'error'); return; }
        currentScenario.targetPoints = n;
        const arr = lsRead(LS_KEYS.SCENARIOS, []);
        const i = arr.findIndex(s=> s.id===currentScenario.id);
        if (i>=0) arr[i] = currentScenario; else arr.push(currentScenario);
        lsWrite(LS_KEYS.SCENARIOS, arr);
        updateScenarioDisplay();
    }

    function refreshScenarioPoints(){
        const box = document.getElementById('scenarioPoints');
        if (!box){ return; }
        if (!currentScenario){ box.textContent = 'Points: —'; return; }
        const objs = lsRead(LS_KEYS.OBJECTIVES, []).filter(o=> o.scenarioId===currentScenario.id);
        const total = objs.reduce((s,o)=> s + (parseInt(o.pointValue)||0), 0);
        const target = parseInt(currentScenario.targetPoints)||0;
        const missing = Math.max(target - total, 0);
        box.textContent = `Points: total ${total}${target?` / target ${target} (missing ${missing})`:''}`;
    }

    function runScenarioPointCheck(){
        refreshScenarioPoints();
        showNotification('Scenario points recalculated', 'success');
    }

    function advanceTime(){
        // Process movement orders: set unit position to destination instantly for now
        const orders = lsRead(LS_KEYS.MOVEMENTS, []);
        if (!orders.length){ showNotification('No movement orders', 'info'); return; }
        let moved = 0;
        const ds = lsRead(LS_KEYS.DEPLOYMENTS, []);
        orders.forEach(o=>{
            const u = ds.find(d=> d.id===o.unitDeploymentId);
            if (u){
                u.position = o.end;
                moved++;
            }
        });
        lsWrite(LS_KEYS.DEPLOYMENTS, ds);
        // Clear orders after processing
        lsWrite(LS_KEYS.MOVEMENTS, []);
        // Refresh markers if any are on map
        try{
            deployedUnits = ds.filter(d=> !currentScenario || d.scenarioId===currentScenario.id);
            deployedUnits.forEach(u=>{
                if (u.mapMarker){ u.mapMarker.setLatLng([u.position.lat, u.position.lng]); }
            });
        }catch{}
        showNotification(`Advanced time: moved ${moved} unit(s)`, 'success');
    }

