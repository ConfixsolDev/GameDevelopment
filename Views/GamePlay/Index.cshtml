                                <i class="fas fa-bullseye"></i> Set Target Points
                            </button>
                            <button class="btn" onclick="runScenarioPointCheck()">
                                <i class="fas fa-calculator"></i> Check Points
                            </button>
                            <button class="btn" onclick="advanceTime()">
                                <i class="fas fa-forward"></i> Advance Time
                            </button>
