<!-- Global Modal Close Handler - Must be after Bootstrap and TokenManager -->
<script>
    $(document).ready(function () {
        console.log('🎯 Initializing global modal close handlers');
        
        // Ensure ALL [data-dismiss="modal"] buttons work
        $(document).on('click', '[data-dismiss="modal"]', function(e) {
            e.preventDefault();
            e.stopPropagation();
            var $modal = $(this).closest('.modal');
            if ($modal.length) {
                console.log('🔒 Closing modal via data-dismiss:', $modal.attr('id'));
                $modal.modal('hide');
            }
        });
        
        // ESC key handler for modals
        $(document).on('keydown', function(e) {
            if (e.key === 'Escape' || e.keyCode === 27) {
                var $openModals = $('.modal.show');
                if ($openModals.length) {
                    console.log('🔒 Closing modal via ESC key');
                    $openModals.modal('hide');
                }
            }
        });
        
        console.log('✅ Modal close handlers initialized');
    });
</script>

