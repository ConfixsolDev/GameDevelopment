    function clearTokenData() {
        const tokenId = $('#tokenDataEntryModal').data('token-id');
        if (!tokenId) {
            showNotification('No token selected', 'error');
            return;
        }
        
        const token = tokens.find(t => t.id === tokenId);
        if (!token) {
            showNotification('Token not found', 'error');
            return;
        }
        
        // Show confirmation dialog
        const confirmed = confirm(`Are you sure you want to clear ALL data for token "${token.name}"?\n\nThis will permanently delete:\n- All Brigades\n- All Infantry Battalions\n- All Armoured Regiments\n- All Artillery Regiments\n- All Intelligence reports\n- All Recon data\n\nThis action cannot be undone.`);
        
        if (!confirmed) {
            return;
        }
        
        // Clear all token-specific data
        lsWrite(`token_${tokenId}_brigades`, []);
        lsWrite(`token_${tokenId}_infantry_battalions`, []);
        lsWrite(`token_${tokenId}_armoured_regiments`, []);
        lsWrite(`token_${tokenId}_artillery_regiments`, []);
        lsWrite(`token_${tokenId}_intelligence`, []);
        lsWrite(`token_${tokenId}_recon`, []);
        
        // Refresh the data display
        loadTokenDataEntryData(tokenId);
        
        showNotification(`All data cleared for token "${token.name}"`, 'success');
    }


