@inject IUserSessionService _userSessionService;
@{
    var currentUser = _userSessionService.GetCurrentUser();
    Layout = "_GamePlayLayout";
}
<style>
    .team-status-panel {
        max-width: 340px;
    }

        .team-status-panel .panel-toggle {
            margin-left: auto;
            border: 0;
            background: transparent;
            font-size: 18px;
            cursor: pointer;
        }

        .team-status-panel .panel-body {
            margin-top: 12px;
            transition: grid-template-rows .25s ease, opacity .2s ease;
            display: grid;
            grid-template-rows: 1fr;
            overflow: hidden;
        }

        .team-status-panel.collapsed .panel-body {
            grid-template-rows: 0fr;
            opacity: .0;
        }

        .team-status-panel .panel-body > div {
            min-height: 0;
        }


    .team-status-panel2 {
        max-width: 340px;
    }

        .team-status-panel2 .panel-toggle {
            margin-left: auto;
            border: 0;
            background: transparent;
            font-size: 18px;
            cursor: pointer;
        }

        .team-status-panel2 .panel-body {
            margin-top: 12px;
            transition: grid-template-rows .25s ease, opacity .2s ease;
            display: grid;
            grid-template-rows: 1fr;
            overflow: hidden;
        }

        .team-status-panel2.collapsed .panel-body {
            grid-template-rows: 0fr;
            opacity: .0;
        }

        .team-status-panel2 .panel-body > div {
            min-height: 0;
        }



    .control-section {
        border-top: 1px solid rgba(0,0,0,.08);
        padding-top: 10px;
        margin-top: 10px;
    }

        .control-section h6 {
            margin: 0 0 6px;
            font-size: 12px;
            opacity: .8;
            letter-spacing: .04em;
            text-transform: uppercase;
        }

    .control-row {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 8px;
        align-items: center;
    }

    /* Visual feedback for bottom toggles */
    .control-btn.active {
        box-shadow: inset 0 0 0 2px rgba(0,0,0,.2);
        transform: translateY(1px);
    }

    /* Center the toolbar at the top */
    .leaflet-top.leaflet-right {
        left: 50% !important;
        right: auto !important;
        transform: translateX(-50%);
    }

    /* Arrange buttons horizontally */
    .leaflet-draw-toolbar {
        display: flex;
        flex-direction: row;
        justify-content: center;
        align-items: center;
    }

        /* Optional: spacing between buttons */
        .leaflet-draw-toolbar a {
            margin: 0 6px;
        }
    /* Improve Data Entry contrast */
    .gameplay-modal-content {
        background: #0f172a; /* slate-900 */
        color: #e5e7eb;      /* gray-200 */
    }
    .gameplay-modal-header, .gameplay-modal-footer {
        background: #111827; /* gray-900 */
        color: #e5e7eb;
        border-color: #1f2937;
    }
    .data-table thead th { background:#1f2937; color:#e5e7eb; }
    .data-table tbody tr:nth-child(even){ background:#0b1220; }
    .data-table tbody tr:nth-child(odd){ background:#0d1628; }
    .form-control, select.form-control, textarea.form-control {
        background:#0b1220; color:#e5e7eb; border:1px solid #1f2937;
    }
    .btn, .gameplay-btn { background:#334155; color:#e5e7eb; border:1px solid #1f2937; }
    .btn:hover, .gameplay-btn:hover { background:#475569; }
    .btn-primary, .gameplay-btn.primary { background:#1d4ed8; border-color:#1e40af; color:white; }
    .btn-danger, .gameplay-btn.danger { background:#b91c1c; border-color:#7f1d1d; color:white; }
    label { color:#e5e7eb; }
    .tab-btn { background:#0b1220; color:#e5e7eb; border:1px solid #1f2937; }
    .tab-btn.active { background:#1f2937; }

    /* Token Details Panel Styles */
    .token-details-overlay {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: rgba(0, 0, 0, 0.8);
        z-index: 10000;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 20px;
    }

    .token-details-panel {
        background: #1f2937;
        border: 2px solid #374151;
        border-radius: 8px;
        max-width: 800px;
        max-height: 90vh;
        width: 100%;
        overflow-y: auto;
        box-shadow: 0 10px 25px rgba(0, 0, 0, 0.5);
    }

    .token-details-header {
        background: #111827;
        padding: 15px 20px;
        border-bottom: 2px solid #374151;
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .token-details-header h3 {
        color: #e5e7eb;
        margin: 0;
        font-size: 1.2em;
    }

    .token-details-content {
        padding: 20px;
    }

    .token-info-section, .token-data-section {
        margin-bottom: 25px;
        padding: 15px;
        background: #111827;
        border-radius: 6px;
        border: 1px solid #374151;
    }

    .token-info-section h4, .token-data-section h4 {
        color: #60a5fa;
        margin: 0 0 15px 0;
        font-size: 1.1em;
        border-bottom: 1px solid #374151;
        padding-bottom: 8px;
    }

    .info-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
        gap: 10px;
    }

    .info-item {
        display: flex;
        flex-direction: column;
        gap: 4px;
    }

    .info-item label {
        color: #9ca3af;
        font-size: 0.9em;
        font-weight: 600;
    }

    .info-item span {
        color: #e5e7eb;
        font-size: 0.95em;
    }

    .status-badge {
        padding: 2px 8px;
        border-radius: 4px;
        font-size: 0.8em;
        font-weight: 600;
    }

    .status-badge.created { background: #fbbf24; color: #92400e; }
    .status-badge.placed { background: #10b981; color: #064e3b; }

    .brigade-details {
        margin-bottom: 15px;
        padding: 12px;
        background: #0f172a;
        border-radius: 4px;
        border-left: 3px solid #3b82f6;
    }

    .brigade-details h5 {
        color: #e5e7eb;
        margin: 0 0 8px 0;
        font-size: 1em;
    }

    .brigade-info {
        display: flex;
        gap: 15px;
        margin-bottom: 10px;
        flex-wrap: wrap;
    }

    .brigade-info span {
        color: #9ca3af;
        font-size: 0.9em;
    }

    .units-list {
        margin-top: 10px;
    }

    .unit-item {
        padding: 8px 12px;
        background: #1e293b;
        border-radius: 4px;
        margin-bottom: 6px;
        border-left: 2px solid #10b981;
    }

    .unit-name {
        color: #e5e7eb;
        font-weight: 600;
        display: block;
        margin-bottom: 4px;
    }

    .unit-details {
        color: #9ca3af;
        font-size: 0.85em;
    }

    .intel-list, .recon-list {
        display: flex;
        flex-direction: column;
        gap: 10px;
    }

    .intel-item, .recon-item {
        padding: 12px;
        background: #1e293b;
        border-radius: 4px;
        border-left: 3px solid #f59e0b;
    }

    .intel-title, .recon-type {
        color: #e5e7eb;
        font-weight: 600;
        display: block;
        margin-bottom: 4px;
    }

    .intel-details, .recon-details {
        color: #9ca3af;
        font-size: 0.85em;
        margin-bottom: 6px;
    }

    .intel-description, .recon-description {
        color: #d1d5db;
        font-size: 0.9em;
        line-height: 1.4;
    }

    .no-data {
        color: #6b7280;
        font-style: italic;
        text-align: center;
        padding: 20px;
    }

    .token-actions {
        display: flex;
        gap: 10px;
        justify-content: flex-end;
        margin-top: 20px;
        padding-top: 15px;
        border-top: 1px solid #374151;
    }

    .token-actions .btn {
        padding: 8px 16px;
        font-size: 0.9em;
    }

    /* Responsive adjustments */
    @@media (max-width: 768px) {
        .token-details-overlay {
            padding: 10px;
        }
        
        .token-details-panel {
            max-height: 95vh;
        }
        
        .info-grid {
            grid-template-columns: 1fr;
        }
        
        .brigade-info {
            flex-direction: column;
            gap: 8px;
        }
        
        .token-actions {
            flex-direction: column;
        }
    }
</style>


<div class="gameplay-container">

    <!-- MAIN AREA -->
    <main class="game-main-area">
        <!-- MAP -->
        <div class="game-map-container">
            <div id="gameMap"></div>
        </div>

        <!-- LEFT: Unified Region controls (Sectors, Labels, Basemap) -->
        <aside class="team-status-panel slide-up" id="regionPanel">
            <div class="team-status-header">
                <div class="team-status-icon">⚑</div>
                <div class="team-status-info">
                    <h5>Region Controls</h5>
                    <p>One main AO • Mask outside</p>
                </div>
                <button id="toggleRegionPanel" class="panel-toggle" title="Collapse / Expand">▾</button>
            </div>

            <div class="panel-body">
                <div>
                    <!-- Metrics -->
                    <div class="status-metrics mb-10">
                        <div class="metric-item">
                            <span class="metric-value" id="metric-area">—</span>
                            <span class="metric-label">Area (km²)</span>
                        </div>
                        <div class="metric-item">
                            <span class="metric-value" id="metric-sectors">0</span>
                            <span class="metric-label">Sectors</span>
                        </div>
                    </div>

                    <!-- Region actions -->
                    <div class="d-grid gap-10 control-section">
                        <div class="control-row">
                            <button id="btnSaveRegion" class="overlay-btn">Save Region</button>
                            <button id="btnEditRegion" class="overlay-btn">Enable Edit</button>
                        </div>
                        <div class="control-row">
                            <button id="btnFit" class="overlay-btn">Fit to Screen</button>
                            <button id="btnClearSectors" class="overlay-btn">Clear Sectors</button>
                        </div>
                    </div>

                    <!-- Sectors -->
                    <div class="control-section">
                        <h6>Sectors</h6>
                        <div class="control-row">
                            <a id="btnAddBlue" class="overlay-btn"><i>●</i><span>Add Blue</span></a>
                            <a id="btnAddFox" class="overlay-btn"><i>●</i><span>Add Fox</span></a>
                        </div>
                        <div class="control-row">
                            <label class="overlay-btn"><input id="chkShowBlue" type="checkbox" checked /> Show Blue</label>
                            <label class="overlay-btn"><input id="chkShowFox" type="checkbox" checked /> Show Fox</label>
                        </div>
                    </div>

                    <!-- Labels -->
                    <div class="control-section">
                        <h6>Labels</h6>
                        <div class="control-row">
                            <a id="btnAddLabel" class="overlay-btn"><i>⌘</i><span>Add Label</span></a>
                            <a id="btnClearLabels" class="overlay-btn danger"><i>×</i><span>Clear</span></a>
                        </div>
                        <label class="overlay-btn"><input id="chkShowLabels" type="checkbox" checked /> Show Labels</label>
                    </div>

                    <!-- Basemaps -->
                    <div class="control-section">
                        <h6>Basemap</h6>
                        <div class="control-row">
                            <a data-layer="Satellite" class="overlay-btn" id="bmSat">Satellite</a>
                            <a data-layer="Streets" class="overlay-btn" id="bmSt">Streets</a>
                        </div>
                        <div class="control-row">
                            <a data-layer="OSM" class="overlay-btn" id="bmOSM">OSM</a>
                            <a data-layer="Topo" class="overlay-btn" id="bmTopo">Topo</a>
                        </div>
                    </div>

                    <div class="mt-12 gameplay-note" id="saveStatus">Ready</div>
                </div>
            </div>
        </aside>

        <div class="map-overlay-controls">
           

            <div class="overlay-control-group">
                <h6>War Game Tools</h6>
                <div class="control-row">
                    <button class="overlay-btn" onclick="manageTokens()">
                        <i class="fas fa-plus"></i>
                        <span>Place Tokens</span>
                    </button>
                    <button class="overlay-btn" onclick="planMovement()">
                        <i class="fas fa-route"></i>
                        <span>Plan Move</span>
                    </button>
                </div>
                <div class="control-row">
                    <button class="overlay-btn" onclick="createObjective()">
                        <i class="fas fa-flag"></i>
                        <span>Objective</span>
                    </button>
                    <button class="overlay-btn" onclick="initiateBattle()">
                        <i class="fas fa-crosshairs"></i>
                        <span>Battle</span>
                    </button>
                </div>
            </div>

            <div class="overlay-control-group">
                <h6>Simulation</h6>
                <div class="control-row">
                    <button class="overlay-btn" id="simulationToggle" onclick="toggleSimulation()">
                        <i class="fas fa-play"></i>
                        <span>Start Sim</span>
                    </button>
                    <button class="overlay-btn" onclick="openSimulationPanel()">
                        <i class="fas fa-tachometer-alt"></i>
                        <span>Control</span>
                    </button>
                </div>
            </div>


            <div class="overlay-control-group">
                <h6>Tools</h6>
                
                <div class="control-row">
                    <button class="overlay-btn" onclick="advanceTime()">
                        <i class="fas fa-forward"></i>
                        <span>Advance</span>
                    </button>
                    <button class="overlay-btn" onclick="runScenarioPointCheck()">
                        <i class="fas fa-calculator"></i>
                        <span>Points</span>
                    </button>
                </div>
            </div>
        </div>
        <!-- BOTTOM-LEFT: Coordinates -->
        <div class="coordinates-display slide-up" id="coordsBox">
            <div class="coord-item"><span class="coord-label">Lat:</span><span class="coord-value" id="latVal">—</span></div>
            <div class="coord-item"><span class="coord-label">Lng:</span><span class="coord-value" id="lngVal">—</span></div>
            <div class="coord-item"><span class="coord-label">Zoom:</span><span class="coord-value" id="zoomVal">—</span></div>
        </div>

        

        <!-- Coordinates Display -->
        <div class="coordinates-display" id="coordinatesDisplay">
            <div class="coord-item">
                <span class="coord-label">Lat:</span>
                <span class="coord-value" id="currentLat">0.000000</span>
            </div>
            <div class="coord-item">
                <span class="coord-label">Lng:</span>
                <span class="coord-value" id="currentLng">0.000000</span>
            </div>
            <div class="coord-item">
                <span class="coord-label">Zoom:</span>
                <span class="coord-value" id="currentZoom">10</span>
            </div>
        </div>


    </main>

  
</div>


<!-- Data Entry Modal -->
<div id="dataEntryModal" class="gameplay-modal">
    <div class="gameplay-modal-content large">
        <div class="gameplay-modal-header">
            <h3><i class="fas fa-database"></i> Military Data Management</h3>
            <button class="gameplay-modal-close" onclick="closeModal('dataEntryModal')">&times;</button>
        </div>
        <div class="gameplay-modal-body">
            <!-- Data Management Tabs -->
            <div class="data-management-tabs">
                <div class="tab-buttons">
                    <button class="tab-btn active" onclick="switchTab('brigades')">
                        <i class="fas fa-flag"></i> Brigades
                    </button>
                    <button class="tab-btn" onclick="switchTab('infantry')">
                        <i class="fas fa-user-soldier"></i> Infantry Battalions
                    </button>
                    <button class="tab-btn" onclick="switchTab('armoured')">
                        <i class="fas fa-tank"></i> Armoured Regiments
                    </button>
                    <button class="tab-btn" onclick="switchTab('artillery')">
                        <i class="fas fa-bomb"></i> Artillery Regiments
                    </button>
                    <button class="tab-btn" onclick="switchTab('terrain')">
                        <i class="fas fa-mountain"></i> Terrain Factors
                    </button>
                    <button class="tab-btn" onclick="switchTab('protection')">
                        <i class="fas fa-shield-alt"></i> Force Protection
                    </button>
                    <button class="tab-btn" onclick="switchTab('intel')">
                        <i class="fas fa-eye"></i> Intelligence
                    </button>
                    <button class="tab-btn" onclick="switchTab('recon')">
                        <i class="fas fa-binoculars"></i> Recon
                    </button>
                </div>

                <!-- Brigade Tab -->
                <div id="brigades-tab" class="tab-content active">
                    <div class="data-section-header">
                        <h4>Brigade Management</h4>
                        <button class="btn btn-primary" onclick="openBrigadeForm()">
                            <i class="fas fa-plus"></i> Add Brigade
                        </button>
                    </div>
                    <div class="data-table-container">
                        <table class="data-table" id="brigadesTable">
                            <thead>
                                <tr>
                                    <th>Name</th>
                                    <th>Code</th>
                                    <th>Force Type</th>
                                    <th>Strength</th>
                                    <th>Actions</th>
                                </tr>
                            </thead>
                            <tbody id="brigadesTableBody">
                                <!-- Data will be loaded here -->
                            </tbody>
                        </table>
                    </div>
                </div>

                <!-- Infantry Battalion Tab -->
                <div id="infantry-tab" class="tab-content">
                    <div class="data-section-header">
                        <h4>Infantry Battalion Management</h4>
                        <button class="btn btn-primary" onclick="openInfantryForm()">
                            <i class="fas fa-plus"></i> Add Infantry Battalion
                        </button>
                    </div>
                    <div class="data-table-container">
                        <table class="data-table" id="infantryTable">
                            <thead>
                                <tr>
                                    <th>Name</th>
                                    <th>Code</th>
                                    <th>Force Type</th>
                                    <th>Strength</th>
                                    <th>Companies</th>
                                    <th>Tanks</th>
                                    <th>Actions</th>
                                </tr>
                            </thead>
                            <tbody id="infantryTableBody">
                                <!-- Data will be loaded here -->
                            </tbody>
                        </table>
                    </div>
                </div>

                <!-- Armoured Regiment Tab -->
                <div id="armoured-tab" class="tab-content">
                    <div class="data-section-header">
                        <h4>Armoured Regiment Management</h4>
                        <button class="btn btn-primary" onclick="openArmouredForm()">
                            <i class="fas fa-plus"></i> Add Armoured Regiment
                        </button>
                    </div>
                    <div class="data-table-container">
                        <table class="data-table" id="armouredTable">
                            <thead>
                                <tr>
                                    <th>Name</th>
                                    <th>Code</th>
                                    <th>Force Type</th>
                                    <th>Strength</th>
                                    <th>Squadrons</th>
                                    <th>Tanks</th>
                                    <th>Actions</th>
                                </tr>
                            </thead>
                            <tbody id="armouredTableBody">
                                <!-- Data will be loaded here -->
                            </tbody>
                        </table>
                    </div>
                </div>

                <!-- Artillery Regiment Tab -->
                <div id="artillery-tab" class="tab-content">
                    <div class="data-section-header">
                        <h4>Artillery Regiment Management</h4>
                        <button class="btn btn-primary" onclick="openArtilleryForm()">
                            <i class="fas fa-plus"></i> Add Artillery Regiment
                        </button>
                    </div>
                    <div class="data-table-container">
                        <table class="data-table" id="artilleryTable">
                            <thead>
                                <tr>
                                    <th>Name</th>
                                    <th>Code</th>
                                    <th>Force Type</th>
                                    <th>Strength</th>
                                    <th>Batteries</th>
                                    <th>Guns</th>
                                    <th>Range (km)</th>
                                    <th>Actions</th>
                                </tr>
                            </thead>
                            <tbody id="artilleryTableBody">
                                <!-- Data will be loaded here -->
                            </tbody>
                        </table>
                    </div>
                </div>

                <!-- Terrain Factors Tab -->
                <div id="terrain-tab" class="tab-content">
                    <div class="data-section-header">
                        <h4>Terrain Mobility Factors</h4>
                        <button class="btn btn-primary" onclick="openTerrainForm()">
                            <i class="fas fa-plus"></i> Add Terrain Factor
                        </button>
                    </div>
                    <div class="data-table-container">
                        <table class="data-table" id="terrainTable">
                            <thead>
                                <tr>
                                    <th>Terrain Type</th>
                                    <th>X Factor</th>
                                    <th>Tank PSI Range</th>
                                    <th>APC PSI Range</th>
                                    <th>Actions</th>
                                </tr>
                            </thead>
                            <tbody id="terrainTableBody">
                                <!-- Data will be loaded here -->
                            </tbody>
                        </table>
                    </div>
                </div>

                <!-- Force Protection Tab -->
                <div id="protection-tab" class="tab-content">
                    <div class="data-section-header">
                        <h4>Force Protection Systems</h4>
                        <button class="btn btn-primary" onclick="openProtectionForm()">
                            <i class="fas fa-plus"></i> Add Protection Type
                        </button>
                    </div>
                    <div class="data-table-container">
                        <table class="data-table" id="protectionTable">
                            <thead>
                                <tr>
                                    <th>Force Type</th>
                                    <th>Protection Type</th>
                                    <th>Degree of Prep</th>
                                    <th>Protection Factor</th>
                                    <th>Actions</th>
                                </tr>
                            </thead>
                            <tbody id="protectionTableBody">
                                <!-- Data will be loaded here -->
                            </tbody>
                        </table>
                    </div>
                </div>

                <!-- Intelligence Tab -->
                <div id="intel-tab" class="tab-content">
                    <div class="data-section-header">
                        <h4>Intelligence Reports</h4>
                        <button class="btn btn-primary" onclick="openIntelForm()">
                            <i class="fas fa-plus"></i> Add Report
                        </button>
                    </div>
                    <div class="data-table-container">
                        <table class="data-table" id="intelTable">
                            <thead>
                                <tr>
                                    <th>Title</th>
                                    <th>Summary</th>
                                    <th>Priority</th>
                                    <th>Actions</th>
                                </tr>
                            </thead>
                            <tbody id="intelTableBody"></tbody>
                        </table>
                    </div>
                </div>

                <!-- Recon Tab -->
                <div id="recon-tab" class="tab-content">
                    <div class="data-section-header">
                        <h4>Recon Units / Sightings</h4>
                        <button class="btn btn-primary" onclick="openReconForm()">
                            <i class="fas fa-plus"></i> Add Recon Entry
                        </button>
                    </div>
                    <div class="data-table-container">
                        <table class="data-table" id="reconTable">
                            <thead>
                                <tr>
                                    <th>Type</th>
                                    <th>Description</th>
                                    <th>Confidence</th>
                                    <th>Actions</th>
                                </tr>
                            </thead>
                            <tbody id="reconTableBody"></tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
        <div class="gameplay-modal-footer">
            <button class="gameplay-btn" onclick="exportTeamData()">
                <i class="fas fa-download"></i> Export Data
            </button>
            <button class="gameplay-btn" onclick="importTeamData()">
                <i class="fas fa-upload"></i> Import Data
            </button>
            <button class="gameplay-btn" onclick="runAutomatedTests()">
                <i class="fas fa-vial"></i> Run Auto Tests
            </button>
            <button class="gameplay-btn" onclick="closeModal('dataEntryModal')">Close</button>
        </div>
    </div>
</div>

<!-- Token Management Modal -->
<div id="tokenManagementModal" class="gameplay-modal">
    <div class="gameplay-modal-content">
