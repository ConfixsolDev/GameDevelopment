    function placeToken() {
        // Ensure team mode is active for token styling
        if (typeof currentMode !== 'string' || (currentMode !== 'fox-land' && currentMode !== 'blue-land')) {
            if (typeof window.switchToFoxLand === 'function') window.switchToFoxLand();
        }
        // Enter token placement mode and avoid edit conflicts
        if (typeof currentMapMode !== 'undefined') currentMapMode = 'token';
        if (typeof addLabelMode !== 'undefined') addLabelMode = false;
        try {
            if (typeof currentRegion !== 'undefined' && currentRegion && currentRegion.editing && currentRegion.editing.enabled && currentRegion.editing.enabled()){
                currentRegion.editing.disable();
                if (typeof btnEditRegion !== 'undefined' && btnEditRegion) btnEditRegion.textContent='Enable Edit';
            }
        } catch {}
        // Guide the user
        showNotification('Click on the map to place a token.', 'info');
        $('#gameMap').css('cursor', 'crosshair');
        // Ensure a one-time placement even if other handlers exist
        try {
            const m = (typeof map !== 'undefined') ? map : gameMap;
            if (m && typeof m.once === 'function') {
                m.once('click', function(e){
                    placeTokenAtLocation(e.latlng);
                });
