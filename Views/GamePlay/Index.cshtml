<script>
    let gameMap;
    let currentMode = 'fox-land';
    let tokens = [];
    let isFullscreen = false;

    // Wait for jQuery to be available
    function waitForJQuery() {
        if (typeof jQuery !== 'undefined') {
            $(document).ready(function() {
                initializeGameMap();
                setupEventListeners();
                
                // Handle window resize
                $(window).resize(function() {
                    if (gameMap) {
                        setTimeout(function() {
                            gameMap.invalidateSize();
                        }, 100);
                    }
                });
            });
        } else {
            console.log('Waiting for jQuery...');
            setTimeout(waitForJQuery, 100);
        }
    }
    
    // Start waiting for jQuery
    waitForJQuery();

    function initializeGameMap() {
        try {
            // Check if Leaflet is loaded
            if (typeof L === 'undefined') {
                console.error('Leaflet library not loaded');
                $('#gameMap').html('<div style="display: flex; align-items: center; justify-content: center; height: 100%; color: var(--gameplay-primary); font-family: Orbitron, sans-serif; font-size: 18px;">Loading Map Library...</div>');
                return;
            }

            // Initialize Leaflet map
            gameMap = L.map('gameMap', {
                zoomControl: true,
                attributionControl: true
            }).setView([51.505, -0.09], 13);

            // Add OpenStreetMap tiles
            L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
                attribution: '© OpenStreetMap contributors',
                maxZoom: 19,
                minZoom: 1
            }).addTo(gameMap);

            // Add map event listeners
            gameMap.on('moveend', updateCoordinates);
            gameMap.on('zoomend', updateCoordinates);
            gameMap.on('click', onMapClick);

            // Initial coordinate update
            updateCoordinates();
            
            // Force map to resize after initialization
            setTimeout(function() {
                if (gameMap) {
                    gameMap.invalidateSize();
                }
            }, 100);

            console.log('Map initialized successfully');
        } catch (error) {
            console.error('Error initializing map:', error);
            $('#gameMap').html('<div style="display: flex; align-items: center; justify-content: center; height: 100%; color: var(--gameplay-accent); font-family: Orbitron, sans-serif; font-size: 18px;">Map Initialization Error</div>');
        }
    }

    function setupEventListeners() {
        // Map control buttons
        $('#dataEntryBtn').click(function() {
            openModal('dataEntryModal');
        });

        $('#tokensBtn').click(function() {
            openModal('tokenManagementModal');
        });

        $('#settingsBtn').click(function() {
            openModal('settingsModal');
        });
    }

    function updateCoordinates() {
        const center = gameMap.getCenter();
        const zoom = gameMap.getZoom();
        
        $('#currentLat').text(center.lat.toFixed(6));
        $('#currentLng').text(center.lng.toFixed(6));
        $('#currentZoom').text(zoom);
    }

    function onMapClick(e) {
        console.log('Map clicked at:', e.latlng);
        
        if (currentMode === 'fox-land' || currentMode === 'blue-land') {
            placeTokenAtLocation(e.latlng);
        }
    }

    function placeTokenAtLocation(latlng) {
        const tokenId = 'token_' + Date.now();
        const tokenType = currentMode;
        
        // Create token marker
        const marker = L.marker(latlng, {
            icon: L.divIcon({
                className: 'token-marker ' + tokenType,
                html: '<i class="fas fa-crosshairs"></i>',
                iconSize: [20, 20],
                iconAnchor: [10, 10]
            })
        }).addTo(gameMap);

        // Store token data
        const tokenData = {
            id: tokenId,
            type: tokenType,
            position: latlng,
            marker: marker,
            timestamp: new Date()
        };
        
        tokens.push(tokenData);
        updateTokenCount();
        
        console.log('Token placed:', tokenData);
    }

    function updateTokenCount() {
        const count = tokens.filter(t => t.type === currentMode).length;
        $('#tokenCount').text(count);
    }

    function updateTeamDisplay(teamName, status) {
        $('#currentTeamName').text(teamName);
        $('#currentTeamStatus').text(status);
    }

    // Map Control Functions
    function toggleMapLayers() {
        console.log('Toggling map layers...');
        // TODO: Implement layer toggle
    }

    function toggleFullscreen() {
        if (!isFullscreen) {
            if (document.documentElement.requestFullscreen) {
                document.documentElement.requestFullscreen();
            }
        } else {
            if (document.exitFullscreen) {
                document.exitFullscreen();
            }
        }
        isFullscreen = !isFullscreen;
    }

    function resetMapView() {
        gameMap.setView([51.505, -0.09], 13);
    }

    function toggleCoordinates() {
        $('#coordinatesDisplay').toggle();
    }

    function placeToken() {
        console.log('Place token mode activated');
        // TODO: Implement token placement mode
    }

    function selectToken() {
        console.log('Select token mode activated');
        currentMapMode = 'select-token';
        
        // Change cursor style
        $('#mapContainer').css('cursor', 'pointer');
        
        // Add click handlers to existing token markers
        tokens.forEach(token => {
            if (token.marker) {
                token.marker.off('click').on('click', function(e) {
                    selectTokenForDataEntry(token);
                    e.originalEvent.stopPropagation();
                });
            }
        });
        
        showNotification('Click on a token to manage its brigade data', 'info');
    }

    function selectTokenForDataEntry(token) {
        console.log('Token selected for data entry:', token);
        selectedToken = token;
        
        // Reset map mode
        currentMapMode = 'normal';
        $('#mapContainer').css('cursor', 'grab');
        
        // Open the token brigade data modal
        openTokenBrigadeDataModal(token.id);
    }

    function openTokenBrigadeDataModal(tokenId) {
        // Set the token ID for the modal
        $('#tokenBrigadeDataModal').data('token-id', tokenId);
        
        // Load existing brigade data for this token if any
        loadTokenBrigadeData(tokenId);
        
        // Show the modal
        $('#tokenBrigadeDataModal').show();
        
        showNotification('Managing data for token: ' + tokenId, 'success');
    }

    function loadTokenBrigadeData(tokenId) {
        // Load existing brigade data associated with this token
        $.ajax({
            url: '/DataManagement/GetBrigadeByToken',
            type: 'GET',
            data: { tokenId: tokenId },
            success: function(response) {
                if (response.success && response.data) {
                    // Populate the brigade form with existing data
                    populateBrigadeForm(response.data);
                    // Load associated military units
                    loadTokenMilitaryUnits(response.data.id);
                } else {
                    // No existing data, start fresh
                    clearBrigadeForm();
                }
            },
            error: function(xhr, status, error) {
                console.error('Error loading token brigade data:', error);
                showNotification('Error loading brigade data', 'error');
            }
        });
    }

    function measureDistance() {
        console.log('Measure distance mode activated');
        // TODO: Implement distance measurement
    }

    function drawArea() {
        console.log('Draw area mode activated');
        // TODO: Implement area drawing
    }

    // Modal Functions
    function openModal(modalId) {
        $('#' + modalId).show();
    }

    function closeModal(modalId) {
        $('#' + modalId).hide();
    }

    function saveData() {
        console.log('Saving data...');
        // TODO: Implement data saving
        closeModal('dataEntryModal');
    }

    // Team switching functions (called from layout)
    window.switchToFoxLand = function() {
        currentMode = 'fox-land';
        updateTeamDisplay('Fox Land', 'Attacking');
        updateTokenCount();
    };

    window.switchToBlueLand = function() {
        currentMode = 'blue-land';
        updateTeamDisplay('Blue Land', 'Defending');
        updateTokenCount();
    };

    window.switchToSpectator = function() {
        currentMode = 'spectator';
        updateTeamDisplay('Spectator', 'Observing');
        updateTokenCount();
    };

    window.openDataEntry = function() {
        openModal('dataEntryModal');
        loadDataManagementData();
    };

    window.manageTokens = function() {
        openModal('tokenManagementModal');
    };

    window.openSettings = function() {
        openModal('settingsModal');
    };

    // Data Management Functions
    let currentEditingId = null;

    function switchTab(tabName) {
        // Hide all tab contents
        $('.tab-content').removeClass('active');
        $('.tab-btn').removeClass('active');
        
        // Show selected tab content
        $('#' + tabName + '-tab').addClass('active');
        $('button[onclick="switchTab(\'' + tabName + '\')"]').addClass('active');
    }

    function loadDataManagementData() {
        loadBrigades();
        loadInfantryBattalions();
        loadArmouredRegiments();
        loadArtilleryRegiments();
        loadTerrainFactors();
        loadForceProtections();
    }

    // Brigade Management
    function loadBrigades() {
        $.get('/DataManagement/GetBrigades')
            .done(function(data) {
                const tbody = $('#brigadesTableBody');
                tbody.empty();
                data.forEach(function(brigade) {
                    tbody.append(`
                        <tr>
                            <td>${brigade.name}</td>
                            <td>${brigade.brigadeCode}</td>
                            <td>${brigade.forceType}</td>
                            <td>${brigade.strength || 'N/A'}</td>
                            <td>
                                <button class="btn btn-sm btn-primary" onclick="editBrigade('${brigade.id}')">Edit</button>
                                <button class="btn btn-sm btn-danger" onclick="deleteBrigade('${brigade.id}')">Delete</button>
                            </td>
                        </tr>
                    `);
                });
            })
            .fail(function() {
                console.error('Failed to load brigades');
            });
    }

    function openBrigadeForm() {
        currentEditingId = null;
        $('#brigadeForm')[0].reset();
        openModal('brigadeFormModal');
    }

    function editBrigade(id) {
        currentEditingId = id;
        // Load brigade data and populate form
        // Implementation would load data and open form
        openModal('brigadeFormModal');
    }

    function saveBrigade() {
        const formData = {
            Name: $('#brigadeName').val(),
            BrigadeCode: $('#brigadeCode').val(),
            ForceType: $('#brigadeForceType').val(),
            Description: $('#brigadeDescription').val()
        };

        const url = currentEditingId ? '/DataManagement/UpdateBrigade' : '/DataManagement/CreateBrigade';
        if (currentEditingId) formData.Id = currentEditingId;

        $.ajax({
            url: url,
            method: currentEditingId ? 'PUT' : 'POST',
            contentType: 'application/json',
            data: JSON.stringify(formData)
        })
        .done(function(response) {
            if (response.success) {
                closeModal('brigadeFormModal');
                loadBrigades();
                showNotification('Brigade saved successfully', 'success');
            } else {
                showNotification('Error: ' + response.message, 'error');
            }
        })
        .fail(function() {
            showNotification('Failed to save brigade', 'error');
        });
