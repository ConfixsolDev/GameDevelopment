        deployedUnits.forEach(unit => {
            grid.append(`
                <div class="deployed-unit-card">
                    <h6>${unit.unitName}</h6>
                    <p>${unit.unitType} - ${unit.forceType}</p>
                    <p>Strength: ${unit.currentStrength}/${unit.maxStrength}</p>
                    <p>Status: ${unit.status}</p>
                    <p>Morale: ${unit.morale}%</p>
                </div>
            `);
        });
    }

    function loadActiveBattles() {
        if (!currentScenario) return;
        activeBattles = lsRead(LS_KEYS.BATTLES, []).filter(b=> b.scenarioId===currentScenario.id);
        // Optionally render a list here
    }

    function loadObjectives() {
        if (!currentScenario) return;
        objectives = lsRead(LS_KEYS.OBJECTIVES, []).filter(o=> o.scenarioId===currentScenario.id);
        const list = $('#objectivesList');
        list.empty();
        objectives.forEach(obj => {
            list.append(`
                <div class="objective-card">
                    <h6>${obj.objectiveName}</h6>
                    <p>${obj.description||''}</p>
                    <p>Type: ${obj.objectiveType}</p>
                    <p>Assigned to: ${obj.assignedToForce}</p>
                    <p>Points: ${obj.pointValue}</p>
                </div>
            `);
            // If not already on map, add marker
            if (!obj.mapMarker && obj.objectiveLocation){ addObjectiveToMap(obj); }
        });
        refreshScenarioPoints();
    }
</script>
  <script>
        /* ====== Silence Leaflet-Draw _flat deprecation ====== */
        if (window.L && L.LineUtil) { L.LineUtil._flat = L.LineUtil.isFlat || L.LineUtil._flat; }

        /* ====== CONFIG ====== */
        const API_BASE = ''; // e.g., 'http://localhost:5187' (leave empty to disable server saving)
        const API_PATH = '/api/region';

        /* ====== LocalStorage Keys ====== */
        const STORE_REGION   = 'leaflet_saved_region';
        const STORE_SECTORS  = 'leaflet_saved_sectors_fc';
        const STORE_LABELS   = 'leaflet_saved_labels_fc';
        const BASE_KEY       = 'map_base_layer';
        const PANEL_KEY      = 'region_panel_collapsed';

        const readJSON = (k,d=null)=>{ try{return JSON.parse(localStorage.getItem(k)) ?? d;}catch{return d;} };
        const writeJSON=(k,v)=> localStorage.setItem(k, JSON.stringify(v));
        const saveBase = n => localStorage.setItem(BASE_KEY, n);
        const readBase = ()=> localStorage.getItem(BASE_KEY) || 'Satellite';

        const statusText   = document.getElementById('statusText');
        const saveStatus   = document.getElementById('saveStatus');
        const setStatus    = s => statusText.textContent = s;
        const setSaveStatus= s => saveStatus.textContent = s;

        /* ====== Collapsible panel wiring ====== */
        const regionPanel = document.getElementById('regionPanel');
        const toggleBtn   = document.getElementById('toggleRegionPanel');
        function setCollapsed(collapsed){
          regionPanel.classList.toggle('collapsed', !!collapsed);
          toggleBtn.textContent = collapsed ? '▸' : '▾';
          localStorage.setItem(PANEL_KEY, collapsed ? '1' : '0');
        }
        toggleBtn.addEventListener('click', ()=> setCollapsed(!regionPanel.classList.contains('collapsed')));
        // restore state
        setCollapsed(localStorage.getItem(PANEL_KEY) === '1');

        /* ====== Map ====== */
        const map = L.map('gameMap').setView([25.2854, 51.5310], 6);
        map.zoomControl.setPosition('bottomright');

        const layers = {
          "OSM":       L.tileLayer.provider('OpenStreetMap.Mapnik'),
          "Topo":      L.tileLayer.provider('OpenTopoMap'),
          "Satellite": L.tileLayer.provider('Esri.WorldImagery'),
          "Streets":   L.tileLayer.provider('Esri.WorldStreetMap')
        };
        (layers[readBase()] || layers.Satellite).addTo(map);
        map.on('baselayerchange', e => saveBase(e.name));

        // Basemap quick buttons highlight
        const bmButtons = { Satellite: 'bmSat', Streets: 'bmSt', OSM: 'bmOSM', Topo: 'bmTopo' };
        const setBMActive = (name)=>{
          Object.entries(bmButtons).forEach(([k,id])=>{
            const el = document.getElementById(id);
            if(!el) return;
            el.classList.toggle('active', k===name);
          });
        };
        setBMActive(readBase());
        Object.entries(bmButtons).forEach(([k,id])=>{
          const el = document.getElementById(id);
          el && el.addEventListener('click', ()=>{
            Object.values(layers).forEach(l=> map.removeLayer(l));
            layers[k].addTo(map);
            saveBase(k);
            setBMActive(k);
          });
        });

        // Groups
        const regionGroup = new L.FeatureGroup().addTo(map);
        const BlueGroup   = new L.FeatureGroup().addTo(map);
        const foxGroup    = new L.FeatureGroup().addTo(map);
        const labelGroup  = new L.FeatureGroup().addTo(map);
        const intelGroup  = new L.FeatureGroup().addTo(map);
        const reconGroup  = new L.FeatureGroup().addTo(map);

        // Draw controls
        const drawCtl = new L.Control.Draw({
          position:'topright',
          draw:{ polygon:true, rectangle:true, polyline:false, circle:false, marker:false, circlemarker:false },
          edit:false
        });
        map.addControl(drawCtl);

        // Outside mask
        map.createPane('maskPane'); map.getPane('maskPane').style.zIndex = 450;
        const maskLayer = L.featureGroup([], { pane:'maskPane' }).addTo(map);

        // State
        let currentRegion = null;
        let savedRegion = readJSON(STORE_REGION, null);
        let drawSectorLandType = null;   // 'Blue' | 'fox'
        let addLabelMode = false;

        // UI refs
        const btnSaveRegion   = document.getElementById('btnSaveRegion');
        const btnEditRegion   = document.getElementById('btnEditRegion');
        const btnFit          = document.getElementById('btnFit');
        const btnAddBlue      = document.getElementById('btnAddBlue');
        const btnAddFox       = document.getElementById('btnAddFox');
        const btnClearSectors = document.getElementById('btnClearSectors');
        const chkShowBlue     = document.getElementById('chkShowBlue');
        const chkShowFox      = document.getElementById('chkShowFox');
        const chkShowLabels   = document.getElementById('chkShowLabels');
        const lblLat          = document.getElementById('latVal');
        const lblLng          = document.getElementById('lngVal');
        const lblZoom         = document.getElementById('zoomVal');
        const metricArea      = document.getElementById('metric-area');
        const metricSectors   = document.getElementById('metric-sectors');

        /* ====== Styles ====== */
        const styleRegion = { color:'#111827', fillColor:'#a3a3a3', weight:3, fillOpacity:.15 };
        const styleBlue   = { color:'#0000A3', fillColor:'#0000D1', weight:2, fillOpacity:.35 };
        const styleFox    = { color:'#b91c1c', fillColor:'#dc2626', weight:2, fillOpacity:.35 };
        const styleForType = t => t==='fox' ? styleFox : styleBlue;

        /* ====== Helpers ====== */
        function updateMetrics(){
          if (savedRegion) {
            const km2 = (savedRegion.properties.area_m2 || 0) / 1e6;
            metricArea.textContent = km2 ? km2.toFixed(2) : '—';
          } else {
            metricArea.textContent = '—';
          }
          const count = BlueGroup.getLayers().length + foxGroup.getLayers().length;
          metricSectors.textContent = count;
        }

        function setCurrentRegion(layer){
          regionGroup.clearLayers();
          regionGroup.addLayer(layer);
          currentRegion = layer;
          layer.setStyle && layer.setStyle(styleRegion);
          // Only auto-enable editing when not in token placement mode
          if (typeof currentMapMode === 'undefined' || currentMapMode !== 'token'){
          if (layer.editing && !layer.editing.enabled) {
            // nothing
          } else if (layer.editing && !layer.editing.enabled()){
            layer.editing.enable();
            }
          } else {
            try { layer.editing && layer.editing.disable && layer.editing.disable(); } catch {}
          }
          btnEditRegion.textContent = 'Disable Edit';
        }

        function applyLock(feature){
          const world = turf.bboxPolygon([-179.999,-89.999,179.999,89.999]);
          let diff = null; try{ diff = turf.difference(world, feature);}catch{diff=null;}
          maskLayer.clearLayers();
          if (diff) L.geoJSON(diff,{pane:'maskPane', style:{color:'#000',weight:0,fillColor:'#000',fillOpacity:.4}, interactive:true}).addTo(maskLayer);
          const b = turf.bbox(feature), pad = 0.01;
          const bounds = [[b[1]-pad,b[0]-pad],[b[3]+pad,b[2]+pad]];
          map.setMaxBounds(bounds); map.fitBounds(bounds);
        }

        function sectorsToFC(){
          const feats = [];
          [ ['Blue',BlueGroup], ['fox',foxGroup] ].forEach(([t,g])=>{
            g.eachLayer(l=> feats.push({type:'Feature', geometry:l.toGeoJSON().geometry, properties:{land_type:t}}));
          });
          return { type:'FeatureCollection', features:feats };
        }

        function makeLabelIcon(text){
          const html = `<div class="map-label">${(text||'').replace(/</g,'&lt;').replace(/>/g,'&gt;')}</div>`;
          return L.divIcon({ html, className:'', iconSize:null });
        }

        function labelsToFC(){
          const feats = [];
          labelGroup.eachLayer(m=>{
            const p = m.getLatLng();
            feats.push({ type:'Feature', geometry:{type:'Point',coordinates:[p.lng,p.lat]}, properties:{ text: m._labelText || '' }});
          });
          return { type:'FeatureCollection', features:feats };
        }

        function addSectorLayer(type, feature){
          const layer = L.geoJSON(feature,{style:styleForType(type)}).getLayers()[0];
          layer._land_type = type; layer.feature = feature;
          layer.on('click', ()=>{
            // During token mode, do not toggle sector editing
        // prevent accidental placements if legacy token mode is referenced
        if (typeof currentMapMode !== 'undefined' && currentMapMode === 'token') return;
            if (!layer.editing) return;
            layer.editing.enabled() ? layer.editing.disable() : layer.editing.enable();
          });
          (type==='fox' ? foxGroup : BlueGroup).addLayer(layer);
          writeJSON(STORE_SECTORS, sectorsToFC());
          updateMetrics();
        }

        function addLabelMarker(latlng, text){
          const marker = L.marker(latlng,{ icon: makeLabelIcon(text), draggable:true });
          marker._labelText = text || '';
          marker.on('dragend', ()=> writeJSON(STORE_LABELS, labelsToFC()));
          labelGroup.addLayer(marker);
          writeJSON(STORE_LABELS, labelsToFC());
        }

        /* ====== Save (API with fallback) — FIXED to prefer live layer ====== */
        async function saveAllDual(){
          if (!currentRegion && !savedRegion){
            alert('Draw/select the main region first.'); return;
          }
          // finalize editing
          if (currentRegion && currentRegion.editing && currentRegion.editing.enabled && currentRegion.editing.enabled()){
            currentRegion.editing.disable(); btnEditRegion.textContent='Enable Edit';
          }

          const base = readBase();

          // ✅ Prefer the live on-map geometry; fall back to savedRegion
          const regionLayer = currentRegion || (savedRegion ? L.geoJSON(savedRegion).getLayers()[0] : null);
          if (!regionLayer){ alert('No region to save.'); return; }

          const gj   = regionLayer.toGeoJSON();
          const feat = turf.feature(gj.geometry);
          const regionEnriched = {
            type:'Feature',
            geometry: gj.geometry,
            properties:{
              id:'region_single',
              name:'Main Region',
              area_m2: turf.area(feat),
              centroid: turf.centroid(feat).geometry.coordinates,
              bbox: turf.bbox(feat),
              base_layer: base
            }
          };

          // Always write to localStorage first (so we never lose work)
          writeJSON(STORE_REGION, regionEnriched);
          writeJSON(STORE_SECTORS, sectorsToFC());
          writeJSON(STORE_LABELS, labelsToFC());
          savedRegion = regionEnriched;   // ✅ keep in sync with the latest
          updateMetrics();

          // Lock outside
          applyLock(savedRegion);

          // Try API (if API_BASE set)
          if (!API_BASE){
            setSaveStatus('Saved locally (API disabled).');
            return { ok:false, localOnly:true };
          }

          setSaveStatus('Saving to server…');

          // fetch with timeout (8s)
          const controller = new AbortController();
          const to = setTimeout(()=> controller.abort(), 8000);

          const payload = {
            region:  regionEnriched,
            sectors: readJSON(STORE_SECTORS),
            labels:  readJSON(STORE_LABELS),
            base_layer: base,
            updated_at: new Date().toISOString()
          };

          try{
            const res = await fetch(`${API_BASE}${API_PATH}`, {
              method:'POST',
              headers:{ 'Content-Type':'application/json' },
              body: JSON.stringify(payload),
              signal: controller.signal
            });
            clearTimeout(to);
            if (!res.ok) throw new Error(`HTTP ${res.status}`);
            await res.json().catch(()=> ({}));
            setSaveStatus('Saved to server ✔ (and cached locally)');
            return { ok:true };
          }catch(err){
            console.warn('Server save failed; using local cache only.', err);
            setSaveStatus('Server failed; saved locally ✔');
            return { ok:false, localOnly:true, error:String(err) };
          }
        }

        /* ====== HUD ====== */
        function updateHUD(e){
          const c = e && e.latlng ? e.latlng : map.getCenter();
          document.getElementById('latVal').textContent = c.lat.toFixed(5);
          document.getElementById('lngVal').textContent = c.lng.toFixed(5);
          document.getElementById('zoomVal').textContent = map.getZoom();
        }
        map.on('mousemove', updateHUD);
        map.on('zoomend moveend', updateHUD);
        updateHUD({latlng: map.getCenter()});
        // Global gameplay click handler (token placement, etc.)
        if (typeof onMapClick === 'function') {
          map.on('click', onMapClick);
        }

        /* ====== Visibility Sync (checkboxes <-> bottom buttons) ====== */
        function refreshVisibility(){
          if (chkShowBlue.checked){ map.addLayer(BlueGroup); } else { map.removeLayer(BlueGroup); }
          if (chkShowFox.checked){ map.addLayer(foxGroup); } else { map.removeLayer(foxGroup); }
          if (chkShowLabels.checked){ map.addLayer(labelGroup); } else { map.removeLayer(labelGroup); }
          // reflect in bottom button active states
        }

        // Bottom buttons toggle like Show Blue/Show Fox

        /* ====== Events ====== */
        // Draw created
        map.on(L.Draw.Event.CREATED, e=>{
          const gj = e.layer.toGeoJSON();

          if (drawSectorLandType){
            if (!savedRegion){ alert('Save a main region first.'); return; }
            const ok = turf.booleanWithin(gj, savedRegion) || turf.booleanContains(savedRegion, gj);
            if (!ok){ alert('Sector must be fully inside the saved region.'); return; }
            const feat = { type:'Feature', geometry: gj.geometry, properties:{ land_type: drawSectorLandType } };
            addSectorLayer(drawSectorLandType, feat);
            return;
          }

          setCurrentRegion(e.layer);
        });

        // Label click placement
        map.on('click', (e)=>{
          if (!addLabelMode) return;
          if (!savedRegion){ alert('Save a main region first.'); return; }
          const pt = turf.point([e.latlng.lng, e.latlng.lat]);
          if (!turf.booleanPointInPolygon(pt, savedRegion)){ alert('Label must be inside the saved region.'); return; }
          const text = prompt('Label text:', '');
          if (text===null) return;
          addLabelMarker(e.latlng, (text||'').trim());
          addLabelMode = false;
          setStatus('Ready');
        });

        // Buttons
        btnEditRegion.onclick = ()=>{
          if (!currentRegion){ alert('Draw/select region first.'); return; }
          if (!currentRegion.editing || !currentRegion.editing.enable){
            alert('Edit handler not available.'); return;
          }
          if (currentRegion.editing.enabled()){
            currentRegion.editing.disable(); btnEditRegion.textContent='Enable Edit';
          } else {
            currentRegion.editing.enable();  btnEditRegion.textContent='Disable Edit';
          }
        };

        btnFit.onclick = ()=>{
          if (savedRegion){
            const l = L.geoJSON(savedRegion).getLayers()[0]; if(l) map.fitBounds(l.getBounds());
          } else if (currentRegion){ map.fitBounds(currentRegion.getBounds()); }
          else if (BlueGroup.getLayers().length || foxGroup.getLayers().length){
            const g = new L.FeatureGroup([...BlueGroup.getLayers(), ...foxGroup.getLayers()]);
            map.fitBounds(g.getBounds());
          } else alert('Nothing to fit.');
        };

        btnSaveRegion.onclick = ()=>{ saveAllDual(); };

        // Sector buttons (draw new)
        btnAddBlue.onclick = ()=>{
          if (!savedRegion){ alert('Save the main region first.'); return; }
          drawSectorLandType = 'Blue'; new L.Draw.Polygon(map).enable();
        };
        btnAddFox.onclick = ()=>{
          if (!savedRegion){ alert('Save the main region first.'); return; }
          drawSectorLandType = 'fox'; new L.Draw.Polygon(map).enable();
        };
        btnClearSectors.onclick = ()=>{
          if (!confirm('Remove ALL sectors?')) return;
          BlueGroup.clearLayers(); foxGroup.clearLayers();
          writeJSON(STORE_SECTORS, { type:'FeatureCollection', features:[] });
          updateMetrics();
        };

        // Labels controls
        const btnAddLabel   = document.getElementById('btnAddLabel');
        const btnClearLabels= document.getElementById('btnClearLabels');
        btnAddLabel.onclick = ()=>{
          if (!savedRegion){ alert('Save the main region first.'); return; }
          addLabelMode = true; setStatus('Click on the map to place the label.');
        };
        btnClearLabels.onclick = ()=>{
          if (!confirm('Remove ALL labels?')) return;
          labelGroup.clearLayers();
          writeJSON(STORE_LABELS, { type:'FeatureCollection', features:[] });
        };

        // Checkbox changes
        chkShowBlue.addEventListener('change', refreshVisibility);
        chkShowFox.addEventListener('change', refreshVisibility);
        chkShowLabels.addEventListener('change', refreshVisibility);

        /* ====== Restore on load ====== */
        // Region
        if (savedRegion){
          const layer = L.geoJSON(savedRegion, { style: styleRegion }).getLayers()[0];
          if (layer){ setCurrentRegion(layer); applyLock(savedRegion); }
        }
        // Sectors
        (readJSON(STORE_SECTORS, {type:'FeatureCollection',features:[]}).features||[]).forEach(f=>{
          const t = (f.properties && f.properties.land_type) || 'Blue';
          addSectorLayer(t, f);
        });
        // Labels
        (readJSON(STORE_LABELS, {type:'FeatureCollection',features:[]}).features||[]).forEach(f=>{
          if (!f.geometry || f.geometry.type!=='Point') return;
          const [lng,lat] = f.geometry.coordinates;
          addLabelMarker([lat,lng], (f.properties && f.properties.text) || '');
        });
        // Tokens (load from database)
        loadTokensAndAddToMap();

        refreshVisibility();
        updateMetrics();
        setStatus('Ready');
    </script>