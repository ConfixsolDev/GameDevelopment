// DEBUG: Test API routing
async function testApiRouting() {
    console.log('🧪 Testing API routing...');
    
    try {
        // Test a known working endpoint first
        console.log('1. Testing known working endpoint (GetPlacedTokens)...');
        const placedResponse = await fetch('/GamePlay/GetPlacedTokens');
        console.log('📡 GetPlacedTokens status:', placedResponse.status);
        
        if (placedResponse.status === 200) {
            console.log('✅ GetPlacedTokens works - routing is functional');
        } else {
            console.error('❌ GetPlacedTokens failed - routing issue');
            return null;
        }
        
        // Test the simple test endpoint
        console.log('2. Testing TestApi endpoint...');
        const testResponse = await fetch('/GamePlay/TestApi');
        console.log('📡 TestApi status:', testResponse.status);
        
        if (testResponse.status === 200) {
            const testData = await testResponse.json();
            console.log('✅ TestApi response:', testData);
        } else {
            console.error('❌ TestApi failed with status:', testResponse.status);
        }
        
        // Now test the GetCurrentTeamInfo endpoint
        console.log('3. Testing GetCurrentTeamInfo API...');
        const teamResponse = await fetch('/GamePlay/GetCurrentTeamInfo');
        console.log('📡 GetCurrentTeamInfo status:', teamResponse.status);
        
        if (teamResponse.status === 404) {
            console.error('❌ GetCurrentTeamInfo endpoint not found (404)');
            return null;
        } else if (teamResponse.status === 200) {
            const teamData = await teamResponse.json();
            console.log('✅ GetCurrentTeamInfo response:', teamData);
            return teamData;
        } else {
            console.error('❌ GetCurrentTeamInfo failed with status:', teamResponse.status);
            const errorText = await teamResponse.text();
            console.error('Error response:', errorText);
            return null;
        }
    } catch (error) {
        console.error('❌ Error testing API routing:', error);
        return null;
    }
}

