@{
    Layout = "_GamePlayLayout";
}

<style>
    .team-status-panel {
        max-width: 340px;
    }

        .team-status-panel .panel-toggle {
            margin-left: auto;
            border: 0;
            background: transparent;
            font-size: 18px;
            cursor: pointer;
        }

        .team-status-panel .panel-body {
            margin-top: 12px;
            transition: grid-template-rows .25s ease, opacity .2s ease;
            display: grid;
            grid-template-rows: 1fr;
            overflow: hidden;
        }

        .team-status-panel.collapsed .panel-body {
            grid-template-rows: 0fr;
            opacity: .0;
        }

        .team-status-panel .panel-body > div {
            min-height: 0;
        }


    .team-status-panel2 {
        max-width: 340px;
    }

        .team-status-panel2 .panel-toggle {
            margin-left: auto;
            border: 0;
            background: transparent;
            font-size: 18px;
            cursor: pointer;
        }

        .team-status-panel2 .panel-body {
            margin-top: 12px;
            transition: grid-template-rows .25s ease, opacity .2s ease;
            display: grid;
            grid-template-rows: 1fr;
            overflow: hidden;
        }

        .team-status-panel2.collapsed .panel-body {
            grid-template-rows: 0fr;
            opacity: .0;
        }

        .team-status-panel2 .panel-body > div {
            min-height: 0;
        }



    .control-section {
        border-top: 1px solid rgba(0,0,0,.08);
        padding-top: 10px;
        margin-top: 10px;
    }

        .control-section h6 {
            margin: 0 0 6px;
            font-size: 12px;
            opacity: .8;
            letter-spacing: .04em;
            text-transform: uppercase;
        }

    .control-row {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 8px;
        align-items: center;
    }

    /* Visual feedback for bottom toggles */
    .control-btn.active {
        box-shadow: inset 0 0 0 2px rgba(0,0,0,.2);
        transform: translateY(1px);
    }

    /* Center the toolbar at the top */
    .leaflet-top.leaflet-right {
        left: 50% !important;
        right: auto !important;
        transform: translateX(-50%);
    }

    /* Arrange buttons horizontally */
    .leaflet-draw-toolbar {
        display: flex;
        flex-direction: row;
        justify-content: center;
        align-items: center;
    }

        /* Optional: spacing between buttons */
        .leaflet-draw-toolbar a {
            margin: 0 6px;
        }
</style>


<div class="gameplay-container">

    <!-- MAIN AREA -->
    <main class="game-main-area">
        <!-- MAP -->
        <div class="game-map-container">
            <div id="gameMap"></div>
        </div>

        <!-- LEFT: Unified Region controls (Sectors, Labels, Basemap) -->
        <aside class="team-status-panel slide-up" id="regionPanel">
            <div class="team-status-header">
                <div class="team-status-icon">⚑</div>
                <div class="team-status-info">
                    <h5>Region Controls</h5>
                    <p>One main AO • Mask outside</p>
                </div>
                <button id="toggleRegionPanel" class="panel-toggle" title="Collapse / Expand">▾</button>
            </div>

            <div class="panel-body">
                <div>
                    <!-- Metrics -->
                    <div class="status-metrics mb-10">
                        <div class="metric-item">
                            <span class="metric-value" id="metric-area">—</span>
                            <span class="metric-label">Area (km²)</span>
                        </div>
                        <div class="metric-item">
                            <span class="metric-value" id="metric-sectors">0</span>
                            <span class="metric-label">Sectors</span>
                        </div>
                    </div>

                    <!-- Region actions -->
                    <div class="d-grid gap-10 control-section">
                        <div class="control-row">
                            <button id="btnSaveRegion" class="gameplay-btn primary">Save Region</button>
                            <button id="btnEditRegion" class="gameplay-btn">Enable Edit</button>
                        </div>
                        <div class="control-row">
                            <button id="btnFit" class="gameplay-btn">Fit to Screen</button>
                            <button id="btnClearSectors" class="gameplay-btn danger">Clear Sectors</button>
                        </div>
                    </div>

                    <!-- Sectors -->
                    <div class="control-section">
                        <h6>Sectors</h6>
                        <div class="control-row">
                            <a id="btnAddBlue" class="overlay-btn"><i>●</i><span>Add Blue</span></a>
                            <a id="btnAddFox" class="overlay-btn"><i>●</i><span>Add Fox</span></a>
                        </div>
                        <div class="control-row">
                            <label class="overlay-btn"><input id="chkShowBlue" type="checkbox" checked /> Show Blue</label>
                            <label class="overlay-btn"><input id="chkShowFox" type="checkbox" checked /> Show Fox</label>
                        </div>
                    </div>

                    <!-- Labels -->
                    <div class="control-section">
                        <h6>Labels</h6>
                        <div class="control-row">
                            <a id="btnAddLabel" class="overlay-btn"><i>⌘</i><span>Add Label</span></a>
                            <a id="btnClearLabels" class="overlay-btn danger"><i>×</i><span>Clear</span></a>
                        </div>
                        <label class="overlay-btn"><input id="chkShowLabels" type="checkbox" checked /> Show Labels</label>
                    </div>

                    <!-- Basemaps -->
                    <div class="control-section">
                        <h6>Basemap</h6>
                        <div class="control-row">
                            <a data-layer="Satellite" class="overlay-btn" id="bmSat">Satellite</a>
                            <a data-layer="Streets" class="overlay-btn" id="bmSt">Streets</a>
                        </div>
                        <div class="control-row">
                            <a data-layer="OSM" class="overlay-btn" id="bmOSM">OSM</a>
                            <a data-layer="Topo" class="overlay-btn" id="bmTopo">Topo</a>
                        </div>
                    </div>

                    <div class="mt-12 gameplay-note" id="saveStatus">Ready</div>
                </div>
            </div>
        </aside>

        <div class="map-overlay-controls">
            <div class="overlay-control-group">
                <h6>Map Controls</h6>
                <div class="control-row">
                    <button class="overlay-btn" onclick="toggleMapLayers()">
                        <i class="fas fa-layer-group"></i>
                        <span>Layers</span>
                    </button>
                    <button class="overlay-btn" onclick="toggleFullscreen()">
                        <i class="fas fa-expand"></i>
                        <span>Fullscreen</span>
                    </button>
                </div>
                <div class="control-row">
                    <button class="overlay-btn" onclick="resetMapView()">
                        <i class="fas fa-home"></i>
                        <span>Reset</span>
                    </button>
                    <button class="overlay-btn" onclick="toggleCoordinates()">
                        <i class="fas fa-crosshairs"></i>
                        <span>Coords</span>
                    </button>
                </div>
            </div>

            <div class="overlay-control-group">
                <h6>Game Tools</h6>
                <div class="control-row">
                    <button class="overlay-btn" onclick="placeToken()">
                        <i class="fas fa-plus"></i>
                        <span>Place Token</span>
                    </button>
                    <button class="overlay-btn" onclick="selectToken()">
                        <i class="fas fa-mouse-pointer"></i>
                        <span>Select</span>
                    </button>
                </div>
                <div class="control-row">
                    <button class="overlay-btn" onclick="measureDistance()">
                        <i class="fas fa-ruler"></i>
                        <span>Measure</span>
                    </button>
                    <button class="overlay-btn" onclick="drawArea()">
                        <i class="fas fa-draw-polygon"></i>
                        <span>Draw Area</span>
                    </button>
                </div>
            </div>

            <div class="overlay-control-group">
                <h6>War Game Tools</h6>
                <div class="control-row">
                    <button class="overlay-btn" onclick="deployUnit()">
                        <i class="fas fa-chess-knight"></i>
                        <span>Deploy Unit</span>
                    </button>
                    <button class="overlay-btn" onclick="planMovement()">
                        <i class="fas fa-route"></i>
                        <span>Plan Move</span>
                    </button>
                </div>
                <div class="control-row">
                    <button class="overlay-btn" onclick="createObjective()">
                        <i class="fas fa-flag"></i>
                        <span>Objective</span>
                    </button>
                    <button class="overlay-btn" onclick="initiateBattle()">
                        <i class="fas fa-crosshairs"></i>
                        <span>Battle</span>
                    </button>
                </div>
            </div>

            <div class="overlay-control-group">
                <h6>Simulation</h6>
                <div class="control-row">
                    <button class="overlay-btn" id="simulationToggle" onclick="toggleSimulation()">
                        <i class="fas fa-play"></i>
                        <span>Start Sim</span>
                    </button>
                    <button class="overlay-btn" onclick="openSimulationPanel()">
                        <i class="fas fa-tachometer-alt"></i>
                        <span>Control</span>
                    </button>
                </div>
            </div>
        </div>
        <!-- BOTTOM-LEFT: Coordinates -->
        <div class="coordinates-display slide-up" id="coordsBox">
            <div class="coord-item"><span class="coord-label">Lat:</span><span class="coord-value" id="latVal">—</span></div>
            <div class="coord-item"><span class="coord-label">Lng:</span><span class="coord-value" id="lngVal">—</span></div>
            <div class="coord-item"><span class="coord-label">Zoom:</span><span class="coord-value" id="zoomVal">—</span></div>
        </div>

        <div class="team-status-panel2">
            <div class="team-status-header">
                <div class="team-status-icon">
                    <i class="fas fa-shield-alt"></i>
                </div>
                <div class="team-status-info">
                    <h5 id="currentTeamName">Alpha Team</h5>
                    <p id="currentTeamStatus">Ready for Battle</p>
                </div>
            </div>
            <div class="status-metrics">
                <div class="metric-item">
                    <span class="metric-value" id="tokenCount">0</span>
                    <span class="metric-label">Tokens</span>
                </div>
                <div class="metric-item">
                    <span class="metric-value" id="areaCovered">0%</span>
                    <span class="metric-label">Area</span>
                </div>
                <div class="metric-item">
                    <span class="metric-value" id="score">0</span>
                    <span class="metric-label">Score</span>
                </div>
                <div class="metric-item">
                    <span class="metric-value" id="timeRemaining">∞</span>
                    <span class="metric-label">Time</span>
                </div>
            </div>
        </div>

        <!-- Coordinates Display -->
        <div class="coordinates-display" id="coordinatesDisplay">
            <div class="coord-item">
                <span class="coord-label">Lat:</span>
                <span class="coord-value" id="currentLat">0.000000</span>
            </div>
            <div class="coord-item">
                <span class="coord-label">Lng:</span>
                <span class="coord-value" id="currentLng">0.000000</span>
            </div>
            <div class="coord-item">
                <span class="coord-label">Zoom:</span>
                <span class="coord-value" id="currentZoom">10</span>
            </div>
        </div>

        <!-- BOTTOM CONTROL BAR -->
        <nav class="gameplay-control-panel">
            <div class="control-panel-content">
                <div class="team-logo-section">
                    <div class="team-logo">AO</div>
                    <div class="team-info">
                        <div class="team-name">Operational Map</div>
                        <div class="team-status" id="statusText">Ready</div>
                    </div>
                </div>
                <div class="control-menu">
                    <a href="#" class="control-btn fox-land active" id="quickAddFox" onclick="switchToFoxLand()">
                        <i class="fas fa-fire"></i>
                        <span>Fox Land</span>
                    </a>
                    <a href="#" class="control-btn blue-land" id="quickAddBlue" onclick="switchToBlueLand()">
                        <i class="fas fa-water"></i>
                        <span>Blue Land</span>
                    </a>
                    <a href="#" class="control-btn spectator" id="spectatorBtn" onclick="switchToSpectator()">
                        <i class="fas fa-eye"></i>
                        <span>Control</span>
                    </a>
                    <a href="#" class="control-btn spectator" id="spectatorBtn" onclick="switchToSpectator()">
                        <i class="fas fa-user-tie"></i>
                        <span>Director</span>
                    </a>
                    <a class="control-btn spectator" id="quickAddLabel" style="display:none">
                        <i class="fas fa-tag"></i>
                        <span>Label</span>
                    </a>
                    <a class="control-btn" id="quickFit" style="display:none">
                        <i class="fas fa-tag"></i><span>Fit</span>
                    </a>
                    <a href="#" class="control-btn" id="dataEntryBtn" onclick="openDataEntry()">
                        <i class="fas fa-database"></i>
                        <span>Data Entry</span>
                    </a>
                    <a href="#" class="control-btn" id="tokensBtn" onclick="manageTokens()">
                        <i class="fas fa-crosshairs"></i>
                        <span>Tokens</span>
                    </a>
                    <a href="#" class="control-btn" id="settingsBtn" onclick="openSettings()">
                        <i class="fas fa-cog"></i>
                        <span>Settings</span>
                    </a>
                </div>
            </div>
        </nav>


    </main>

  
</div>


<!-- Data Entry Modal -->
<div id="dataEntryModal" class="gameplay-modal">
    <div class="gameplay-modal-content large">
        <div class="gameplay-modal-header">
            <h3><i class="fas fa-database"></i> Military Data Management</h3>
            <button class="gameplay-modal-close" onclick="closeModal('dataEntryModal')">&times;</button>
        </div>
        <div class="gameplay-modal-body">
            <!-- Data Management Tabs -->
            <div class="data-management-tabs">
                <div class="tab-buttons">
                    <button class="tab-btn active" onclick="switchTab('brigades')">
                        <i class="fas fa-flag"></i> Brigades
                    </button>
                    <button class="tab-btn" onclick="switchTab('infantry')">
                        <i class="fas fa-user-soldier"></i> Infantry Battalions
                    </button>
                    <button class="tab-btn" onclick="switchTab('armoured')">
                        <i class="fas fa-tank"></i> Armoured Regiments
                    </button>
                    <button class="tab-btn" onclick="switchTab('artillery')">
                        <i class="fas fa-bomb"></i> Artillery Regiments
                    </button>
                    <button class="tab-btn" onclick="switchTab('terrain')">
                        <i class="fas fa-mountain"></i> Terrain Factors
                    </button>
                    <button class="tab-btn" onclick="switchTab('protection')">
                        <i class="fas fa-shield-alt"></i> Force Protection
                    </button>
                </div>

                <!-- Brigade Tab -->
                <div id="brigades-tab" class="tab-content active">
                    <div class="data-section-header">
                        <h4>Brigade Management</h4>
                        <button class="btn btn-primary" onclick="openBrigadeForm()">
                            <i class="fas fa-plus"></i> Add Brigade
                        </button>
                    </div>
                    <div class="data-table-container">
                        <table class="data-table" id="brigadesTable">
                            <thead>
                                <tr>
                                    <th>Name</th>
                                    <th>Code</th>
                                    <th>Force Type</th>
                                    <th>Strength</th>
                                    <th>Actions</th>
                                </tr>
                            </thead>
                            <tbody id="brigadesTableBody">
                                <!-- Data will be loaded here -->
                            </tbody>
                        </table>
                    </div>
                </div>

                <!-- Infantry Battalion Tab -->
                <div id="infantry-tab" class="tab-content">
                    <div class="data-section-header">
                        <h4>Infantry Battalion Management</h4>
                        <button class="btn btn-primary" onclick="openInfantryForm()">
                            <i class="fas fa-plus"></i> Add Infantry Battalion
                        </button>
                    </div>
                    <div class="data-table-container">
                        <table class="data-table" id="infantryTable">
                            <thead>
                                <tr>
                                    <th>Name</th>
                                    <th>Code</th>
                                    <th>Force Type</th>
                                    <th>Strength</th>
                                    <th>Companies</th>
                                    <th>Tanks</th>
                                    <th>Actions</th>
                                </tr>
                            </thead>
                            <tbody id="infantryTableBody">
                                <!-- Data will be loaded here -->
                            </tbody>
                        </table>
                    </div>
                </div>

                <!-- Armoured Regiment Tab -->
                <div id="armoured-tab" class="tab-content">
                    <div class="data-section-header">
                        <h4>Armoured Regiment Management</h4>
                        <button class="btn btn-primary" onclick="openArmouredForm()">
                            <i class="fas fa-plus"></i> Add Armoured Regiment
                        </button>
                    </div>
                    <div class="data-table-container">
                        <table class="data-table" id="armouredTable">
                            <thead>
                                <tr>
                                    <th>Name</th>
                                    <th>Code</th>
                                    <th>Force Type</th>
                                    <th>Strength</th>
                                    <th>Squadrons</th>
                                    <th>Tanks</th>
                                    <th>Actions</th>
                                </tr>
                            </thead>
                            <tbody id="armouredTableBody">
                                <!-- Data will be loaded here -->
                            </tbody>
                        </table>
                    </div>
                </div>

                <!-- Artillery Regiment Tab -->
                <div id="artillery-tab" class="tab-content">
                    <div class="data-section-header">
                        <h4>Artillery Regiment Management</h4>
                        <button class="btn btn-primary" onclick="openArtilleryForm()">
                            <i class="fas fa-plus"></i> Add Artillery Regiment
                        </button>
                    </div>
                    <div class="data-table-container">
                        <table class="data-table" id="artilleryTable">
                            <thead>
                                <tr>
                                    <th>Name</th>
                                    <th>Code</th>
                                    <th>Force Type</th>
                                    <th>Strength</th>
                                    <th>Batteries</th>
                                    <th>Guns</th>
                                    <th>Range (km)</th>
                                    <th>Actions</th>
                                </tr>
                            </thead>
                            <tbody id="artilleryTableBody">
                                <!-- Data will be loaded here -->
                            </tbody>
                        </table>
                    </div>
                </div>

                <!-- Terrain Factors Tab -->
                <div id="terrain-tab" class="tab-content">
                    <div class="data-section-header">
                        <h4>Terrain Mobility Factors</h4>
                        <button class="btn btn-primary" onclick="openTerrainForm()">
                            <i class="fas fa-plus"></i> Add Terrain Factor
                        </button>
                    </div>
                    <div class="data-table-container">
                        <table class="data-table" id="terrainTable">
                            <thead>
                                <tr>
                                    <th>Terrain Type</th>
                                    <th>X Factor</th>
                                    <th>Tank PSI Range</th>
                                    <th>APC PSI Range</th>
                                    <th>Actions</th>
                                </tr>
                            </thead>
                            <tbody id="terrainTableBody">
                                <!-- Data will be loaded here -->
                            </tbody>
                        </table>
                    </div>
                </div>

                <!-- Force Protection Tab -->
                <div id="protection-tab" class="tab-content">
                    <div class="data-section-header">
                        <h4>Force Protection Systems</h4>
                        <button class="btn btn-primary" onclick="openProtectionForm()">
                            <i class="fas fa-plus"></i> Add Protection Type
                        </button>
                    </div>
                    <div class="data-table-container">
                        <table class="data-table" id="protectionTable">
                            <thead>
                                <tr>
                                    <th>Force Type</th>
                                    <th>Protection Type</th>
                                    <th>Degree of Prep</th>
                                    <th>Protection Factor</th>
                                    <th>Actions</th>
                                </tr>
                            </thead>
                            <tbody id="protectionTableBody">
                                <!-- Data will be loaded here -->
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
        <div class="gameplay-modal-footer">
            <button class="gameplay-btn" onclick="exportTeamData()">
                <i class="fas fa-download"></i> Export Data
            </button>
            <button class="gameplay-btn" onclick="closeModal('dataEntryModal')">Close</button>
        </div>
    </div>
</div>

<!-- Token Management Modal -->
<div id="tokenManagementModal" class="gameplay-modal">
    <div class="gameplay-modal-content">
        <div class="gameplay-modal-header">
            <h3><i class="fas fa-crosshairs"></i> Token Management</h3>
            <button class="gameplay-modal-close" onclick="closeModal('tokenManagementModal')">&times;</button>
        </div>
        <div class="gameplay-modal-body">
            <p>Token management functionality will be implemented here.</p>
            <!-- TODO: Add token management interface -->
        </div>
        <div class="gameplay-modal-footer">
            <button class="gameplay-btn" onclick="closeModal('tokenManagementModal')">Close</button>
        </div>
    </div>
</div>

<!-- Token Brigade Data Modal (missing earlier) -->
<div id="tokenBrigadeDataModal" class="gameplay-modal" style="display:none;">
    <div class="gameplay-modal-content large">
        <div class="gameplay-modal-header">
            <h3><i class="fas fa-crosshairs"></i> Token Brigade Data</h3>
            <button class="gameplay-modal-close" onclick="closeModal('tokenBrigadeDataModal')">&times;</button>
        </div>
        <div class="gameplay-modal-body">
            <div class="data-section-header">
                <h4>Linked Brigade</h4>
            </div>
            <form id="tokenBrigadeForm">
                <div class="form-row">
                    <div class="form-group col-md-6">
                        <label for="tbBrigadeId">Brigade</label>
                        <select id="tbBrigadeId" class="form-control">
                            <option value="">Select a brigade…</option>
                        </select>
                    </div>
                    <div class="form-group col-md-6">
                        <label for="tbNotes">Notes</label>
                        <input type="text" id="tbNotes" class="form-control" placeholder="Optional notes">
                    </div>
                </div>
            </form>
            <div class="mt-2">
                <h5>Associated Units</h5>
                <div id="tokenUnitsList" class="data-table-container"></div>
            </div>
        </div>
        <div class="gameplay-modal-footer">
            <button class="gameplay-btn" onclick="closeModal('tokenBrigadeDataModal')">Close</button>
            <button class="gameplay-btn primary" onclick="saveTokenBrigadeLink()">Save</button>
        </div>
    </div>
    
</div>

<!-- Settings Modal -->
<div id="settingsModal" class="gameplay-modal">
    <div class="gameplay-modal-content">
        <div class="gameplay-modal-header">
            <h3><i class="fas fa-cog"></i> Game Settings</h3>
            <button class="gameplay-modal-close" onclick="closeModal('settingsModal')">&times;</button>
        </div>
        <div class="gameplay-modal-body">
            <p>Game settings will be implemented here.</p>
            <!-- TODO: Add settings interface -->
        </div>
        <div class="gameplay-modal-footer">
            <button class="gameplay-btn" onclick="closeModal('settingsModal')">Close</button>
        </div>
    </div>
</div>

<!-- Brigade Form Modal -->
<div id="brigadeFormModal" class="gameplay-modal">
    <div class="gameplay-modal-content">
        <div class="gameplay-modal-header">
            <h3><i class="fas fa-flag"></i> Brigade Form</h3>
            <button class="gameplay-modal-close" onclick="closeModal('brigadeFormModal')">&times;</button>
        </div>
        <div class="gameplay-modal-body">
            <form id="brigadeForm">
                <div class="form-group">
                    <label for="brigadeName">Brigade Name *</label>
                    <input type="text" id="brigadeName" name="Name" required class="form-control">
                </div>
                <div class="form-group">
                    <label for="brigadeCode">Brigade Code *</label>
                    <input type="text" id="brigadeCode" name="BrigadeCode" required class="form-control">
                </div>
                <div class="form-group">
                    <label for="brigadeForceType">Force Type *</label>
                    <select id="brigadeForceType" name="ForceType" required class="form-control">
                        <option value="">Select Force Type</option>
                        <option value="Blue">Blue Force</option>
                        <option value="Red">Red Force</option>
                    </select>
                </div>
                <div class="form-group">
                    <label for="brigadeDescription">Description</label>
                    <textarea id="brigadeDescription" name="Description" class="form-control" rows="3"></textarea>
                </div>
            </form>
        </div>
        <div class="gameplay-modal-footer">
            <button class="gameplay-btn" onclick="closeModal('brigadeFormModal')">Cancel</button>
            <button class="gameplay-btn primary" onclick="saveBrigade()">Save Brigade</button>
        </div>
    </div>
</div>

<!-- Infantry Battalion Form Modal -->
<div id="infantryFormModal" class="gameplay-modal">
