<script>
// Token Management Functions for GamePlay Arena

// Global variables for token management
if (typeof tokenPlacementManager === 'undefined') {
    var tokenPlacementManager = null;
}
if (typeof selectedTokenForPlacement === 'undefined') {
    var selectedTokenForPlacement = null;
}
if (typeof isTokenPlacementMode === 'undefined') {
    var isTokenPlacementMode = false;
}
if (typeof availableTokens === 'undefined') {
    var availableTokens = [];
}

// Initialize token placement manager
function initializeTokenManager() {
    if (window.gameMap && typeof TokenPlacementManager !== 'undefined') {
        tokenPlacementManager = new TokenPlacementManager(window.gameMap, showNotification);
        console.log('TokenPlacementManager initialized');
    } else {
        console.warn('Cannot initialize TokenPlacementManager - map or class not available');
    }
}

// Token placement functions
function openTokenPlacement() {
    console.log('Opening token placement...');
    
    if (!tokenPlacementManager) {
        initializeTokenManager();
    }
    
    // Load available tokens and show selection modal
    loadAvailableTokens().then(() => {
        openModal('tokenSelectionModal');
    });
}

function cancelTokenPlacement() {
    console.log('Cancelling token placement...');
    
    if (tokenPlacementManager) {
        tokenPlacementManager.cancelPlacement();
    }
    
    cleanupTokenPlacementMode();
}

// Load available tokens from server
async function loadAvailableTokens() {
    try {
        const response = await fetch('/GamePlay/GetTeamTokens');
        const data = await response.json();
        
        if (data.success) {
            availableTokens = data.tokens;
            populateTokenSelection();
        } else {
            showNotification('Failed to load tokens: ' + data.message, 'error');
        }
    } catch (error) {
        console.error('Error loading tokens:', error);
        showNotification('Error loading tokens', 'error');
    }
}

// Populate token selection modal
function populateTokenSelection() {
    const container = document.getElementById('tokenSelectionGrid');
    if (!container) return;
    
    container.innerHTML = '';
    
    availableTokens.forEach(token => {
        const tokenElement = document.createElement('div');
        tokenElement.className = 'token-option';
        
        // Create military symbol icon matching map tokens
        const militaryIcon = createTokenIconHTML(token);
        
        tokenElement.innerHTML = `
            <div class="token-icon-military">
                ${militaryIcon}
            </div>
            <div class="token-info">
                <h5>${token.name}</h5>
                <p>${token.unitDesignation || token.type || 'Unit'}</p>
                <span class="token-force-type">${getForceTypeDisplayName(token.forceType)}</span>
            </div>
        `;
        tokenElement.onclick = () => selectTokenForPlacement(token);
        container.appendChild(tokenElement);
    });
}

// Create token icon HTML matching map display
function createTokenIconHTML(token) {
    // Determine force class and frame type
    const forceType = token.forceType || '';
    const forceTypeLower = forceType.toLowerCase();
    
    let forceClass = 'force-unknown';
    let frameType = 'frame-unknown';
    let borderColor = '#FFAA00'; // Default yellow for unknown
    
    if (forceTypeLower.includes('fox') || forceTypeLower.includes('hostile') || forceTypeLower.includes('red')) {
        forceClass = 'force-hostile';
        frameType = 'frame-hostile';
        borderColor = '#ff0000'; // Red
    } else if (forceTypeLower.includes('blue') || forceTypeLower.includes('friendly')) {
        forceClass = 'force-friendly';
        frameType = 'frame-friendly';
        borderColor = '#0000ff'; // Blue
    } else if (forceTypeLower.includes('neutral') || forceTypeLower.includes('green')) {
        forceClass = 'force-neutral';
        frameType = 'frame-neutral';
        borderColor = '#00AA00'; // Green
    }
    
    // Get organization symbol
    const orgLevel = token.organizationLevel || '';
    let orgSymbol = '●';
    if (orgLevel.includes('Brigade') || orgLevel.includes('Brigade')) orgSymbol = '✕✕';
    else if (orgLevel.includes('Division')) orgSymbol = '✕✕✕';
    else if (orgLevel.includes('Corps')) orgSymbol = '✕✕✕✕';
    else if (orgLevel.includes('Army')) orgSymbol = '✕✕✕✕✕';
    else if (orgLevel.includes('Battalion')) orgSymbol = '|||';
    else if (orgLevel.includes('Company')) orgSymbol = '|';
    else if (orgLevel.includes('Platoon')) orgSymbol = '●●●';
    else if (orgLevel.includes('Squad')) orgSymbol = '●';
    
    // Get unit type symbol
    const unitType = token.unitType || 'Infantry';
    let unitSymbol = '○'; // Infantry default
    if (unitType.includes('Armoured') || unitType.includes('Armor')) unitSymbol = '⊗';
    else if (unitType.includes('Artillery')) unitSymbol = '◆';
    else if (unitType.includes('Aviation')) unitSymbol = '▲';
    else if (unitType.includes('Engineer')) unitSymbol = '⚒';
    else if (unitType.includes('Mechanized')) unitSymbol = '⊕';
    
    const unitDesignation = token.unitDesignation || 'N/A';
    
    return `
        <div class="military-token-small nato-standard ${forceClass}">
            <div class="nato-frame-small ${frameType}">
                ${forceClass === 'force-hostile' ? '<div class="hostile-content-frame-small">' : ''}
                    <div class="org-level-top-small">
                        <div class="org-symbol-small">${orgSymbol}</div>
                    </div>
                    <div class="unit-symbol-center-small">
                        <div class="unit-symbol-small">${unitSymbol}</div>
                        <div class="unit-designation-right-small">
                            <div class="unit-designation-small">${unitDesignation}</div>
                        </div>
                    </div>
                ${forceClass === 'force-hostile' ? '</div>' : ''}
            </div>
        </div>
    `;
}

// Get display name for force type
function getForceTypeDisplayName(forceType) {
    if (!forceType) return 'Unknown';
    
    const forceTypeLower = forceType.toLowerCase();
    
    // Return the actual force type name
    if (forceTypeLower.includes('fox')) return 'Fox Land';
    if (forceTypeLower.includes('blue')) return 'Blue Land';
    if (forceTypeLower.includes('neutral')) return 'Neutral';
    if (forceTypeLower.includes('hostile')) return 'Hostile';
    if (forceTypeLower.includes('friendly')) return 'Friendly';
    
    // Return as-is if no match
    return forceType;
}

// Select token for placement
function selectTokenForPlacement(token) {
    selectedTokenForPlacement = token;
    isTokenPlacementMode = true;
    
    if (tokenPlacementManager) {
        tokenPlacementManager.startPlacementMode(token);
    }
    
    closeModal('tokenSelectionModal');
    showNotification(`Click on the map to place ${token.name}`, 'info');
    
    // Change cursor
    $('#gameMap').css('cursor', 'crosshair');
    
    // Create cursor indicator
    createTokenCursorIndicator(token);
}

// Create cursor indicator for token placement
function createTokenCursorIndicator(token) {
    // Remove existing indicator
    $('.token-cursor-indicator').remove();
    
    // Create military symbol for cursor
    const militaryIcon = createTokenIconHTML(token);
    
    // Create new indicator with military symbol
    const indicator = $(`
        <div class="token-cursor-indicator">
            <div class="cursor-token-preview">
                ${militaryIcon}
            </div>
            <div class="cursor-token-name">${token.name}</div>
        </div>
    `);
    
    $('body').append(indicator);
    
    // Track mouse movement
    $(document).on('mousemove.tokenPlacement', function(e) {
        if (isTokenPlacementMode && selectedTokenForPlacement) {
            indicator.css({
                left: e.pageX + 15,
                top: e.pageY - 15
            });
        }
    });
}

// Clean up token placement mode
function cleanupTokenPlacementMode() {
    isTokenPlacementMode = false;
    selectedTokenForPlacement = null;
    $('#gameMap').css('cursor', 'default');
    $('.token-cursor-indicator').remove();
    $(document).off('mousemove.tokenPlacement');
}

// Place token at location
async function placeTokenAtLocation(latlng) {
    if (!selectedTokenForPlacement) {
        console.warn('No token selected for placement');
        return;
    }
    
    try {
        const response = await fetch('/GamePlay/PlaceToken', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
            },
            body: JSON.stringify({
                TokenId: selectedTokenForPlacement.id,
                Latitude: latlng.lat,
                Longitude: latlng.lng
            })
        });
        
        const data = await response.json();
        
        if (data.success) {
            showNotification(`${selectedTokenForPlacement.name} placed successfully`, 'success');
            
            // Add token to map if tokenPlacementManager is available
            if (tokenPlacementManager) {
                tokenPlacementManager.addTokenToMap(selectedTokenForPlacement, latlng);
            }
            
            // Update token count
            updateTokenCount();
        } else {
            showNotification('Failed to place token: ' + data.message, 'error');
        }
    } catch (error) {
        console.error('Error placing token:', error);
        showNotification('Error placing token', 'error');
    }
    
    // Clean up placement mode
    cleanupTokenPlacementMode();
}

// Update token count display
function updateTokenCount() {
    // Update any token count displays
    const countElement = document.getElementById('tokenCount');
    if (countElement && availableTokens) {
        countElement.textContent = availableTokens.length;
    }
}

// Close token selection modal
function closeTokenSelectionModal() {
    closeModal('tokenSelectionModal');
    selectedTokenForPlacement = null;
    isTokenPlacementMode = false;
    $('#gameMap').css('cursor', 'default');
}

// Handle map clicks for token placement
function handleMapClick(e) {
    console.log('Map clicked at:', e.latlng);
    
    if (isTokenPlacementMode && selectedTokenForPlacement) {
        placeTokenAtLocation(e.latlng);
    }
}

// Initialize token scripts when document is ready
$(document).ready(function() {
    // Initialize token manager when map is available
    if (window.gameMap) {
        initializeTokenManager();
    } else {
        // Wait for map to be initialized
        const mapCheck = setInterval(() => {
            if (window.gameMap) {
                initializeTokenManager();
                clearInterval(mapCheck);
            }
        }, 100);
    }
    
    // Handle Escape key to cancel token placement
    $(document).on('keydown', function(e) {
        if (e.key === 'Escape' && isTokenPlacementMode) {
            cleanupTokenPlacementMode();
            showNotification('Token placement cancelled', 'info');
        }
    });
});

// Notification function (fallback if not defined elsewhere)
if (typeof showNotification === 'undefined') {
    window.showNotification = function(message, type = 'info') {
        console.log(`[${type.toUpperCase()}] ${message}`);
        
        // Create a simple notification
        const notification = $(`
            <div class="notification notification-${type}">
                <i class="fas fa-info-circle"></i>
                <span>${message}</span>
            </div>
        `);
        
        $('body').append(notification);
        
        setTimeout(() => {
            notification.fadeOut(() => notification.remove());
        }, 3000);
    };
}
</script>

