        cursor: pointer;
        transition: background-color 0.2s;
    }
    
    .token-option:hover {
        background-color: #f5f5f5;
    }
    
    .token-icon {
        margin-right: 10px;
        font-size: 24px;
        color: #007bff;
    }
    
    .token-info h5 {
        margin: 0;
        font-size: 14px;
    }
    
    .token-info p {
        margin: 0;
        font-size: 12px;
        color: #666;
    }
    
    .token-cursor-indicator {
        position: fixed;
        pointer-events: none;
        z-index: 9999;
        background: rgba(0, 123, 255, 0.9);
        color: white;
        padding: 4px 8px;
        border-radius: 4px;
        font-size: 12px;
        white-space: nowrap;
    }
    
    .notification {
        position: fixed;
        top: 20px;
        right: 20px;
        z-index: 9999;
        padding: 10px 15px;
        border-radius: 5px;
        color: white;
        font-size: 14px;
    }
    
    .notification-info { background-color: #17a2b8; }
    .notification-success { background-color: #28a745; }
    .notification-error { background-color: #dc3545; }
    .notification-warning { background-color: #ffc107; color: #212529; }
</style>
