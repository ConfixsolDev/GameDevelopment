                                    <th>Reliability</th>
                                    <th>Date</th>
                                    <th>Status</th>
                                    <th>Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                <!-- Intelligence data will be loaded here -->
                            </tbody>
                        </table>
                    </div>
                </div>

                <!-- Recon Tab -->
                <div id="recon-tab" class="tab-content">
                    <div class="tab-header">
                        <h4>Reconnaissance Management</h4>
                        <button class="btn btn-primary" onclick="addRecon()">
                            <i class="fas fa-plus"></i> Add Recon
                        </button>
                    </div>
                    <div class="data-table-container">
                        <table class="data-table" id="reconTable">
                            <thead>
                                <tr>
                                    <th>Unit</th>
                                    <th>Mission</th>
                                    <th>Area</th>
                                    <th>Duration</th>
                                    <th>Status</th>
                                    <th>Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                <!-- Recon data will be loaded here -->
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
        <div class="modal-footer">
            <button type="button" class="btn btn-info" onclick="exportDataManagement()">
                <i class="fas fa-download"></i> Export Data
            </button>
            <button type="button" class="btn btn-info" onclick="importDataManagement()">
                <i class="fas fa-upload"></i> Import Data
            </button>
            <button type="button" class="btn btn-secondary" data-dismiss="modal">
                <i class="fas fa-times"></i> Close
            </button>
        </div>
    </div>
    </div>
</div>
