                    </div>
                    <div class="data-table-container">
                        <table class="data-table" id="artilleryTable">
                            <thead>
                                <tr>
                                    <th>Regiment</th>
                                    <th>Brigade</th>
                                    <th>Gun Type</th>
                                    <th>Ammunition</th>
                                    <th>Range</th>
                                    <th>Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                <!-- Artillery data will be loaded here -->
                            </tbody>
                        </table>
                    </div>
                </div>

                <!-- Terrain Tab -->
                <div id="terrain-tab" class="tab-content">
