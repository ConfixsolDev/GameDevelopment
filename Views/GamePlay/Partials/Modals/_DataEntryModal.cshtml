                                    <th>Type</th>
                                    <th>Modifier</th>
                                    <th>Description</th>
                                    <th>Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                <!-- Terrain data will be loaded here -->
                            </tbody>
                        </table>
                    </div>
                </div>

                <!-- Protection Tab -->
                <div id="protection-tab" class="tab-content">
                    <div class="tab-header">
                        <h4>Force Protection Management</h4>
                        <button class="btn btn-primary" onclick="addProtectionMeasure()">
                            <i class="fas fa-plus"></i> Add Measure
                        </button>
                    </div>
                    <div class="data-table-container">
                        <table class="data-table" id="protectionTable">
                            <thead>
                                <tr>
                                    <th>Measure</th>
                                    <th>Type</th>
                                    <th>Effectiveness</th>
                                    <th>Status</th>
                                    <th>Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                <!-- Protection data will be loaded here -->
                            </tbody>
                        </table>
                    </div>
                </div>

                <!-- Intelligence Tab -->
                <div id="intel-tab" class="tab-content">
                    <div class="tab-header">
                        <h4>Intelligence Management</h4>
