<!-- Token Selection Modal for Placing Tokens -->
<div id="tokenSelectionModal" class="gameplay-modal" style="display: none;">
    <div class="gameplay-modal-content">
        <div class="gameplay-modal-header">
            <h3><i class="fas fa-crosshairs"></i> Click Token to Place on Map</h3>
            <button class="gameplay-modal-close" onclick="closeTokenSelectionModal()">&times;</button>
        </div>
        <div class="gameplay-modal-body">
            <div class="token-selection-container">
                <div class="token-search-container">
                    <input type="text" id="tokenSearchInput" placeholder="Search tokens..." class="form-control" />
                </div>
                <div id="tokenSelectionGrid" class="token-selection-grid">
                    <!-- Token options will be populated here -->
                    <div class="loading-tokens">
                        <i class="fas fa-spinner fa-spin"></i>
                        <p>Loading available tokens...</p>
                    </div>
                </div>
            </div>
        </div>
        <div class="gameplay-modal-footer">
            <button class="gameplay-btn" onclick="closeTokenSelectionModal()">Cancel</button>
        </div>
    </div>
</div>
