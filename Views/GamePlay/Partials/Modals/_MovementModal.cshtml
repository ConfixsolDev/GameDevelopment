<script>
// Movement Modal JavaScript
if (typeof currentSelectedUnit === 'undefined') {
    var currentSelectedUnit = null;
}
if (typeof currentWaypoints === 'undefined') {
    var currentWaypoints = [];
}
if (typeof currentRouteCost === 'undefined') {
    var currentRouteCost = 0;
}

function openMovementModal(unitId) {
    console.log('Movement modal disabled - feature not ready yet');
    
    // DISABLED: Movement modal is temporarily disabled
    // Uncomment below when ready to enable
    /*
    console.log('Opening movement modal for unit:', unitId);
    
    // Load unit data
    loadUnitData(unitId);
    
    // Show Bootstrap modal with forced display
    $('#movementModal').css({
        'display': 'block',
        'opacity': '1',
        'visibility': 'visible'
    }).addClass('show').removeClass('fade');
    
    $('#movementModal').modal({
        backdrop: false,
        keyboard: true,
        show: true
    });
    
    // Initialize route planning
    initializeRoutePlanning();
    */
}

function closeMovementModal() {
    $('#movementModal').hide().removeClass('show');
    $('.modal-backdrop').remove();
    $('body').removeClass('modal-open');
    currentSelectedUnit = null;
    currentWaypoints = [];
    currentRouteCost = 0;
}

// Event delegation for close buttons
$(document).off('click', '#movementModal .close, #movementModal [data-dismiss="modal"]');
$(document).on('click', '#movementModal .close, #movementModal [data-dismiss="modal"]', function(e) {
    e.preventDefault();
    closeMovementModal();
});

function loadUnitData(unitId) {
    // This would typically load from an API endpoint
    // For now, we'll use mock data
    const mockUnit = {
        id: unitId,
        name: "7th Armoured Brigade",
        type: "Armoured Regiment",
        currentTerrain: "OPEN",
        supplyState: "Green",
        movementBudget: 30,
        combatPower: 0.85
    };
    
    currentSelectedUnit = mockUnit;
    
    // Update UI
    document.getElementById('selectedUnitName').textContent = mockUnit.name;
    document.getElementById('selectedUnitType').textContent = mockUnit.type;
    document.getElementById('currentTerrain').textContent = mockUnit.currentTerrain;
    document.getElementById('supplyState').textContent = mockUnit.supplyState;
    document.getElementById('supplyState').className = `status-value supply-indicator ${mockUnit.supplyState.toLowerCase()}`;
    document.getElementById('movementBudget').textContent = `${mockUnit.movementBudget} km`;
    document.getElementById('combatPower').textContent = mockUnit.combatPower.toFixed(2);
    document.getElementById('availableMovement').textContent = `${mockUnit.movementBudget} points`;
}

function updateActionType(actionType) {
    console.log('Action type changed to:', actionType);
    
    const title = document.getElementById('movementModalTitle');
    if (actionType === 'assembly') {
        title.textContent = 'Plan Assembly';
    } else {
        title.textContent = 'Plan Movement';
    }
    
    // Recalculate route costs
    calculateRouteCost();
}

function addWaypoint() {
    // This would typically open a map interface to select waypoints
    // For now, we'll add mock waypoints
    const waypointNumber = currentWaypoints.length + 1;
    const mockWaypoint = {
        id: waypointNumber,
        lat: 33.7219 + (Math.random() - 0.5) * 0.01,
        lng: 73.0589 + (Math.random() - 0.5) * 0.01,
        terrain: document.getElementById('terrainType').value,
        movementType: document.getElementById('movementType').value
    };
    
    currentWaypoints.push(mockWaypoint);
    updateWaypointsDisplay();
    calculateRouteCost();
}

function removeWaypoint(waypointId) {
    currentWaypoints = currentWaypoints.filter(wp => wp.id !== waypointId);
    updateWaypointsDisplay();
    calculateRouteCost();
}

function updateWaypointsDisplay() {
    const waypointsList = document.getElementById('waypointsList');
    waypointsList.innerHTML = '';
    
    currentWaypoints.forEach((waypoint, index) => {
        const waypointElement = document.createElement('div');
        waypointElement.className = 'waypoint-item';
        waypointElement.innerHTML = `
            <div class="waypoint-number">${index + 1}</div>
            <div class="waypoint-coords">${waypoint.lat.toFixed(4)}, ${waypoint.lng.toFixed(4)}</div>
            <div class="waypoint-actions">
                <button class="btn btn-sm btn-outline-danger" onclick="removeWaypoint(${waypoint.id})">
                    <i class="fas fa-trash"></i>
                </button>
            </div>
        `;
        waypointsList.appendChild(waypointElement);
    });
}

function calculateRouteCost() {
    if (!currentSelectedUnit || currentWaypoints.length === 0) {
        updateRouteStats(0, 0, 0);
        return;
    }
    
    // Calculate total distance (simplified)
    let totalDistance = currentWaypoints.length * 10; // Mock: 10km per waypoint
    
    // Calculate movement cost based on terrain and movement type
    const terrainType = document.getElementById('terrainType').value;
    const movementType = document.getElementById('movementType').value;
    
    // Mock terrain multipliers
    const terrainMultipliers = {
        'OPEN': { 'road': 1.0, 'cross_country': 1.2 },
        'FOREST': { 'road': 1.2, 'cross_country': 1.6 },
        'MOUNTAIN': { 'road': 1.6, 'cross_country': 2.2 },
        'RIVER': { 'road': 2.0, 'cross_country': 3.0 }
    };
    
    const multiplier = terrainMultipliers[terrainType][movementType];
    const movementCost = Math.ceil(totalDistance * multiplier);
    
    // Calculate ETA (mock: 1 hour per 10km)
    const eta = new Date();
    eta.setHours(eta.getHours() + (totalDistance / 10));
    
    // Calculate supply impact
    let supplyImpact = 'None';
    if (movementCost > 20) supplyImpact = 'Light';
    if (movementCost > 40) supplyImpact = 'Moderate';
    if (movementCost > 60) supplyImpact = 'Heavy';
    
    currentRouteCost = movementCost;
    updateRouteStats(totalDistance, movementCost, eta, supplyImpact);
    validateMovement();
}

function updateRouteStats(distance, cost, eta, supplyImpact = 'None') {
    document.getElementById('totalDistance').textContent = `${distance.toFixed(1)} km`;
    document.getElementById('movementCost').textContent = `${cost} points`;
    document.getElementById('eta').textContent = eta ? eta.toLocaleTimeString() : '—';
    document.getElementById('supplyImpact').textContent = supplyImpact;
    
    // Update budget comparison
    if (currentSelectedUnit) {
        const available = currentSelectedUnit.movementBudget;
        const remaining = available - cost;
        
        document.getElementById('requiredMovement').textContent = `${cost} points`;
        document.getElementById('remainingMovement').textContent = `${remaining} points`;
        
        // Color code the remaining movement
        const remainingElement = document.getElementById('remainingMovement');
        if (remaining < 0) {
            remainingElement.style.color = '#dc3545';
        } else if (remaining < 5) {
            remainingElement.style.color = '#ffc107';
        } else {
            remainingElement.style.color = '#28a745';
        }
    }
}

function validateMovement() {
    const validation = document.getElementById('movementValidation');
    const commitBtn = document.getElementById('commitMoveBtn');
    const message = document.getElementById('validationMessage');
    
    if (!currentSelectedUnit || currentWaypoints.length === 0) {
        validation.style.display = 'none';
        commitBtn.disabled = true;
        return;
    }
    
    const available = currentSelectedUnit.movementBudget;
    const required = currentRouteCost;
    const remaining = available - required;
    
    if (remaining < 0) {
        validation.style.display = 'block';
        message.textContent = `Insufficient movement points. Need ${required}, have ${available}.`;
        commitBtn.disabled = true;
    } else if (remaining < 5) {
        validation.style.display = 'block';
        message.textContent = `Warning: Low remaining movement points (${remaining}). Consider shorter route.`;
        commitBtn.disabled = false;
    } else {
        validation.style.display = 'none';
        commitBtn.disabled = false;
    }
}

function initializeRoutePlanning() {
    currentWaypoints = [];
    updateWaypointsDisplay();
    calculateRouteCost();
}

function saveRouteDraft() {
    if (!currentSelectedUnit || currentWaypoints.length === 0) {
        alert('Please add waypoints to create a route.');
        return;
    }
    
    // This would typically save to the database via API
    console.log('Saving route draft:', {
        unitId: currentSelectedUnit.id,
        waypoints: currentWaypoints,
        actionType: document.querySelector('input[name="actionType"]:checked').value,
        terrainType: document.getElementById('terrainType').value,
        movementType: document.getElementById('movementType').value,
        totalCost: currentRouteCost
    });
    
    alert('Route draft saved successfully!');
}

function commitMovement() {
    if (!validateMovement()) {
        return;
    }
    
    const actionType = document.querySelector('input[name="actionType"]:checked').value;
    
    // This would typically commit the movement via API
    console.log('Committing movement:', {
        unitId: currentSelectedUnit.id,
        actionType: actionType,
        waypoints: currentWaypoints,
        totalCost: currentRouteCost
    });
    
    alert(`${actionType === 'assembly' ? 'Assembly' : 'Movement'} committed successfully!`);
    closeMovementModal();
}

// Global functions for button access
window.openMovementModal = openMovementModal;
window.closeMovementModal = closeMovementModal;
window.updateActionType = updateActionType;
window.addWaypoint = addWaypoint;
window.removeWaypoint = removeWaypoint;
window.calculateRouteCost = calculateRouteCost;
window.saveRouteDraft = saveRouteDraft;
window.commitMovement = commitMovement;
</script>
