@*
    Phase 01: Move / Assembly Modal - Bootstrap Modal
    Implements the MoveConfirmModal with all required controls per Phase 01 specification
*@

<!-- Movement/Assembly Modal - Bootstrap Modal -->
<div class="modal fade" id="movementModal" tabindex="-1" role="dialog" aria-labelledby="movementModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-xl" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="movementModalLabel">
                    <i class="fas fa-route"></i>
                    <span id="movementModalTitle">Plan Movement / Assembly</span>
                </h5>
                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                    <i class="fas fa-times"></i>
                </button>
            </div>
        
        <div class="modal-body">
            <!-- Unit Information -->
            <div class="unit-info-section">
                <div class="unit-display">
                    <div class="unit-details">
                        <h4 id="selectedUnitName">—</h4>
                        <p class="text-muted" id="selectedUnitType">—</p>
                        <div class="unit-status-grid">
                            <div class="status-item">
                                <span class="status-label">Current Terrain:</span>
                                <span class="status-value" id="currentTerrain">—</span>
                            </div>
                            <div class="status-item">
                                <span class="status-label">Supply State:</span>
                                <span class="status-value supply-indicator" id="supplyState">—</span>
                            </div>
                            <div class="status-item">
                                <span class="status-label">Movement Budget:</span>
                                <span class="status-value" id="movementBudget">—</span>
                            </div>
                            <div class="status-item">
                                <span class="status-label">Combat Power:</span>
                                <span class="status-value" id="combatPower">—</span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Action Type Selection -->
            <div class="form-section">
                <h5><i class="fas fa-tasks"></i> Action Type</h5>
                <div class="action-type-selection">
                    <div class="radio-group">
                        <label class="radio-option">
                            <input type="radio" name="actionType" value="move" checked onchange="updateActionType('move')">
                            <span class="radio-custom"></span>
                            <div class="option-content">
                                <i class="fas fa-walking"></i>
                                <span>Move</span>
                                <small>Relocate unit to new position</small>
                            </div>
                        </label>
                        <label class="radio-option">
                            <input type="radio" name="actionType" value="assembly" onchange="updateActionType('assembly')">
                            <span class="radio-custom"></span>
                            <div class="option-content">
                                <i class="fas fa-users"></i>
                                <span>Assembly</span>
                                <small>Gather forces at location</small>
                            </div>
                        </label>
                    </div>
                </div>
            </div>

            <!-- Route Planning Section -->
            <div class="form-section">
                <h5><i class="fas fa-map-marked-alt"></i> Route Planning</h5>
                
                <!-- Terrain Selection -->
                <div class="form-row">
                    <div class="form-group">
                        <label for="terrainType">Terrain Type</label>
                        <select id="terrainType" class="form-control" onchange="calculateRouteCost()">
                            <option value="OPEN">Open Terrain</option>
                            <option value="FOREST">Forest</option>
                            <option value="MOUNTAIN">Mountain</option>
                            <option value="RIVER">River</option>
                        </select>
                    </div>
                    <div class="form-group">
                        <label for="movementType">Movement Type</label>
                        <select id="movementType" class="form-control" onchange="calculateRouteCost()">
                            <option value="road">Road</option>
                            <option value="cross_country">Cross Country</option>
                        </select>
                    </div>
                </div>

                <!-- Waypoint Management -->
                <div class="waypoint-section">
                    <div class="waypoint-header">
                        <h6>Route Waypoints</h6>
                        <button class="btn btn-sm btn-outline-primary" onclick="addWaypoint()">
                            <i class="fas fa-plus"></i> Add Waypoint
                        </button>
                    </div>
                    <div id="waypointsList" class="waypoints-list">
                        <!-- Waypoints will be added dynamically -->
                    </div>
                </div>

                <!-- Route Preview -->
                <div class="route-preview-section">
                    <h6>Route Preview</h6>
                    <div class="route-stats">
                        <div class="stat-item">
                            <span class="stat-label">Total Distance:</span>
                            <span class="stat-value" id="totalDistance">0 km</span>
                        </div>
                        <div class="stat-item">
                            <span class="stat-label">Movement Cost:</span>
                            <span class="stat-value" id="movementCost">0 points</span>
                        </div>
                        <div class="stat-item">
                            <span class="stat-label">ETA:</span>
                            <span class="stat-value" id="eta">—</span>
                        </div>
                        <div class="stat-item">
                            <span class="stat-label">Supply Impact:</span>
                            <span class="stat-value" id="supplyImpact">None</span>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Validation and Warnings -->
            <div id="movementValidation" class="validation-section" style="display: none;">
                <div class="alert alert-warning">
                    <i class="fas fa-exclamation-triangle"></i>
                    <span id="validationMessage">—</span>
                </div>
            </div>

            <!-- Budget Comparison -->
            <div class="budget-comparison">
                <div class="budget-item">
                    <span class="budget-label">Available Movement Points:</span>
                    <span class="budget-value" id="availableMovement">—</span>
                </div>
                <div class="budget-item">
                    <span class="budget-label">Required Movement Points:</span>
                    <span class="budget-value" id="requiredMovement">—</span>
                </div>
                <div class="budget-item budget-remaining">
                    <span class="budget-label">Remaining After Move:</span>
                    <span class="budget-value" id="remainingMovement">—</span>
                </div>
            </div>
        </div>

        <div class="modal-footer">
            <button type="button" class="btn btn-secondary" data-dismiss="modal">
                <i class="fas fa-times"></i> Cancel
            </button>
            <button type="button" class="btn btn-outline-primary" onclick="saveRouteDraft()" id="saveDraftBtn">
                <i class="fas fa-save"></i> Save Draft
            </button>
            <button type="button" class="btn btn-primary" onclick="commitMovement()" id="commitMoveBtn" disabled>
                <i class="fas fa-check"></i> Commit Move
            </button>
        </div>
    </div>
    </div>
</div>

