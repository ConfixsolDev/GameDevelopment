<script>
// Offline Controls JavaScript
document.addEventListener('DOMContentLoaded', function() {
    initializeOfflineControls();
});

function initializeOfflineControls() {
    console.log('🔧 Initializing offline controls...');
    
    // Event listeners
    document.getElementById('saveVisibleTiles').addEventListener('click', saveVisibleTiles);
    document.getElementById('saveAreaTiles').addEventListener('click', saveAreaTiles);
    document.getElementById('saveToFolder').addEventListener('click', saveToFolder);
    document.getElementById('exportTiles').addEventListener('click', exportTiles);
    document.getElementById('storageSettings').addEventListener('click', showStorageSettings);
    document.getElementById('clearCache').addEventListener('click', clearCache);
    document.getElementById('verifyOffline').addEventListener('click', verifyOfflineFunctionality);
    document.getElementById('testOfflineMode').addEventListener('click', testOfflineMode);
    document.getElementById('exportCache').addEventListener('click', exportCache);
    
    // Settings listeners
    document.getElementById('autoCacheTiles').addEventListener('change', updateAutoCacheSetting);
    document.getElementById('showOfflineOnly').addEventListener('change', updateOfflineIndicatorSetting);
    document.getElementById('maxCacheZoom').addEventListener('change', updateMaxCacheZoom);
    
    // Initialize tile server mode selector
    initializeTileServerModeSelector();
    
    // Update status periodically
    setInterval(updateCacheStatus, 5000);
    updateCacheStatus();
    
    console.log('✅ Offline controls initialized');
}

function saveVisibleTiles() {
    console.log('💾 Saving visible tiles...');
    
    if (!window.gameMap) {
        alert('Map not available');
        return;
    }
    
    const progressDiv = document.getElementById('cacheProgress');
    const progressFill = document.getElementById('progressFill');
    const progressText = document.getElementById('progressText');
    
    progressDiv.style.display = 'block';
    
    // Get all offline layers
    const offlineLayers = [];
    window.gameMap.eachLayer(layer => {
        if (layer instanceof L.TileLayer.Offline) {
            offlineLayers.push(layer);
        }
    });
    
    if (offlineLayers.length === 0) {
        alert('No offline-capable layers found');
        progressDiv.style.display = 'none';
        return;
    }
    
    let totalTiles = 0;
    let savedTiles = 0;
    
    // Calculate total tiles
    offlineLayers.forEach(layer => {
        const bounds = window.gameMap.getBounds();
        const zoom = Math.min(window.gameMap.getZoom(), parseInt(document.getElementById('maxCacheZoom').value));
        const tiles = calculateTilesInBounds(bounds, zoom);
        totalTiles += tiles.length;
    });
    
    progressText.textContent = `0 / ${totalTiles}`;
    
    // Save tiles for each layer
    offlineLayers.forEach(layer => {
        layer.saveVisibleTiles().then(saved => {
            savedTiles += saved.length;
            const progress = Math.min((savedTiles / totalTiles) * 100, 100);
            progressFill.style.width = progress + '%';
            progressText.textContent = `${savedTiles} / ${totalTiles}`;
            
            if (savedTiles >= totalTiles) {
                setTimeout(() => {
                    progressDiv.style.display = 'none';
                    updateCacheStatus();
                    alert(`Successfully saved ${savedTiles} tiles!`);
                }, 1000);
            }
        }).catch(error => {
            console.error('Error saving tiles:', error);
            progressDiv.style.display = 'none';
            alert('Error saving tiles: ' + error.message);
        });
    });
}

function saveAreaTiles() {
    const bounds = prompt('Enter area bounds (lat1,lng1,lat2,lng2):');
    if (!bounds) return;
    
    try {
        const [lat1, lng1, lat2, lng2] = bounds.split(',').map(Number);
        const areaBounds = L.latLngBounds([lat1, lng1], [lat2, lng2]);
        
        // Fit map to area
        window.gameMap.fitBounds(areaBounds);
        
        // Save tiles after a short delay
        setTimeout(() => {
            saveVisibleTiles();
        }, 1000);
        
    } catch (error) {
        alert('Invalid bounds format. Use: lat1,lng1,lat2,lng2');
    }
}

async function saveToFolder() {
    console.log('📁 Saving tiles to folder...');
    
    // Check if File System Access API is available
    if (!('showDirectoryPicker' in window)) {
        alert('File System Access API not available. Please use Chrome or Edge browser.');
        return;
    }
    
    try {
        // Let user choose a folder
        const dirHandle = await window.showDirectoryPicker({
            mode: 'readwrite',
            startIn: 'documents'
        });
        
        console.log('📁 Selected folder:', dirHandle.name);
        
        // Create map-tiles directory in the chosen folder
        const tilesDir = await dirHandle.getDirectoryHandle('map-tiles', { create: true });
        
        // Get current map bounds and zoom level
        const bounds = window.gameMap.getBounds();
        const zoom = window.gameMap.getZoom();
        const layerName = 'satellite'; // Default layer name
        
        // Calculate tiles to save
        const tiles = calculateTilesInBounds(bounds, zoom);
        
        if (tiles.length === 0) {
            alert('No tiles to save in current view');
            return;
        }
        
        // Show progress
        showProgress(`Saving ${tiles.length} tiles to folder...`);
        
        // Save tiles one by one
        let savedCount = 0;
        for (const tile of tiles) {
            try {
                await saveTileToFolder(tilesDir, layerName, tile, zoom);
                savedCount++;
                
                // Update progress
                const progress = (savedCount / tiles.length * 100).toFixed(1);
                updateProgress(progress, `Saved ${savedCount}/${tiles.length} tiles`);
                
            } catch (error) {
                console.error('Error saving tile:', error);
            }
        }
        
        hideProgress();
        alert(`Successfully saved ${savedCount} tiles to folder!\nLocation: ${dirHandle.name}/map-tiles/`);
        
    } catch (error) {
        console.error('Error saving to folder:', error);
        hideProgress();
        
        if (error.name === 'AbortError') {
            alert('Save cancelled by user');
        } else {
            alert('Error saving to folder: ' + error.message);
        }
    }
}

function calculateTilesInBounds(bounds, zoom) {
    const tiles = [];
    
    // Convert bounds to tile coordinates
    const nw = window.gameMap.project(bounds.getNorthWest(), zoom);
    const se = window.gameMap.project(bounds.getSouthEast(), zoom);
    
    const tileSize = 256;
    const minX = Math.floor(nw.x / tileSize);
    const maxX = Math.floor(se.x / tileSize);
    const minY = Math.floor(nw.y / tileSize);
    const maxY = Math.floor(se.y / tileSize);
    
    for (let x = minX; x <= maxX; x++) {
        for (let y = minY; y <= maxY; y++) {
            tiles.push({ x, y, z: zoom });
        }
    }
    
    return tiles;
}

async function saveTileToFolder(dirHandle, layerName, tile, zoom) {
    try {
        // Create directory structure: layerName/z/x/
        const layerDir = await dirHandle.getDirectoryHandle(layerName, { create: true });
        const zDir = await layerDir.getDirectoryHandle(tile.z.toString(), { create: true });
        const xDir = await zDir.getDirectoryHandle(tile.x.toString(), { create: true });
        
        // Download tile image
        const tileUrl = `https://server.arcgisonline.com/ArcGIS/rest/services/World_Imagery/MapServer/tile/${tile.z}/${tile.y}/${tile.x}`;
        
        const response = await fetch(tileUrl);
        if (!response.ok) {
            throw new Error(`Failed to download tile: ${response.status}`);
        }
        
        const blob = await response.blob();
        
        // Save tile file
        const fileName = `${tile.y}.png`;
        const fileHandle = await xDir.getFileHandle(fileName, { create: true });
        const writable = await fileHandle.createWritable();
        
        await writable.write(blob);
        await writable.close();
        
        console.log(`💾 Saved tile: ${layerName}/${tile.z}/${tile.x}/${tile.y}.png`);
        
    } catch (error) {
        console.error(`Error saving tile ${tile.x}/${tile.y}/${tile.z}:`, error);
        throw error;
    }
}

function showProgress(message) {
    const progressDiv = document.getElementById('cacheProgress');
    if (progressDiv) {
        progressDiv.style.display = 'block';
        const label = progressDiv.querySelector('.progress-label');
        if (label) label.textContent = message;
    }
}

function updateProgress(percentage, message) {
    const progressDiv = document.getElementById('cacheProgress');
    if (progressDiv) {
        const label = progressDiv.querySelector('.progress-label');
        const bar = progressDiv.querySelector('.progress-bar');
        
        if (label) label.textContent = message;
        if (bar) {
            bar.style.width = percentage + '%';
            bar.setAttribute('aria-valuenow', percentage);
        }
    }
}

function hideProgress() {
    const progressDiv = document.getElementById('cacheProgress');
    if (progressDiv) {
        progressDiv.style.display = 'none';
    }
}

function clearCache() {
    if (confirm('Are you sure you want to clear all cached tiles?')) {
        console.log('🗑️ Clearing cache...');
        
        const offlineLayers = [];
        window.gameMap.eachLayer(layer => {
            if (layer instanceof L.TileLayer.Offline) {
                offlineLayers.push(layer);
            }
        });
        
        Promise.all(offlineLayers.map(layer => layer.clearOfflineTiles())).then(() => {
            updateCacheStatus();
            alert('Cache cleared successfully!');
        }).catch(error => {
            console.error('Error clearing cache:', error);
            alert('Error clearing cache: ' + error.message);
        });
    }
}

function exportTiles() {
    console.log('📦 Exporting tiles...');
    
    const offlineLayers = [];
    window.gameMap.eachLayer(layer => {
        if (layer instanceof L.TileLayer.Offline) {
            offlineLayers.push(layer);
        }
    });
    
    if (offlineLayers.length > 0) {
        offlineLayers[0].exportTilesAsZip().then(() => {
            alert('Tiles exported successfully!');
        }).catch(error => {
            console.error('Error exporting tiles:', error);
            alert('Error exporting tiles: ' + error.message);
        });
    } else {
        alert('No offline layers found');
    }
}

function showStorageSettings() {
    // Check if storage modal already exists
    const existingModal = document.querySelector('.offline-storage-modal');
    if (existingModal) {
        existingModal.remove();
    }
    
    // Create storage settings modal
    const modal = document.createElement('div');
    modal.className = 'offline-storage-modal';
    modal.style.cssText = `
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: rgba(0, 0, 0, 0.8);
        z-index: 10000;
        display: flex;
        align-items: center;
        justify-content: center;
        color: white;
        font-family: Arial, sans-serif;
    `;
    
    // Get storage backends info
    const backends = window.TileStorage ? window.TileStorage.backends : {
        indexeddb: { name: 'IndexedDB', available: true },
        filesystem: { name: 'File System', available: false },
        server: { name: 'Server Storage', available: false }
    };
    
    const currentStorage = window.TileStorage ? window.TileStorage.storageType : 'indexeddb';
    
    modal.innerHTML = `
        <div style="background: #2a2a2a; padding: 30px; border-radius: 10px; max-width: 600px; width: 90%; max-height: 80vh; overflow-y: auto;">
            <h2 style="margin-top: 0; color: #fff;">🗄️ Storage Settings</h2>
            
            <div style="margin-bottom: 20px;">
                <h3>Current Storage: ${backends[currentStorage]?.name || 'Unknown'}</h3>
                <p style="color: #ccc;">Choose how map tiles are stored for offline use:</p>
            </div>
            
            <div style="margin-bottom: 20px;">
                ${Object.entries(backends).map(([key, backend]) => `
                    <label style="display: block; margin-bottom: 15px; padding: 15px; background: ${key === currentStorage ? '#007bff' : '#444'}; border-radius: 8px; cursor: pointer; border: 2px solid ${key === currentStorage ? '#007bff' : 'transparent'};">
                        <input type="radio" name="storage" value="${key}" ${key === currentStorage ? 'checked' : ''} 
                               style="margin-right: 10px; transform: scale(1.2);">
                        <strong style="font-size: 16px;">${backend.name}</strong>
                        <div style="font-size: 13px; color: #ccc; margin-top: 8px; line-height: 1.4;">
                            ${getStorageDescription(key)}
                        </div>
                        <div style="font-size: 12px; color: ${backend.available ? '#28a745' : '#dc3545'}; margin-top: 5px;">
                            ${backend.available ? '✅ Available' : '❌ Not Available'}
                        </div>
                    </label>
                `).join('')}
            </div>
            
            <div style="margin-bottom: 20px; padding: 15px; background: #333; border-radius: 8px;">
                <h4 style="margin-top: 0;">💡 Storage Tips:</h4>
                <ul style="margin: 10px 0; padding-left: 20px; color: #ccc; font-size: 13px;">
                    <li><strong>IndexedDB:</strong> Fast but limited by browser quota (~500MB-2GB)</li>
                    <li><strong>File System:</strong> Permanent storage on your computer, requires permission</li>
                    <li><strong>Server:</strong> Stored on game server, accessible from any device</li>
                    <li><strong>Hybrid:</strong> Saves to multiple locations for maximum reliability</li>
                </ul>
            </div>
            
            <div style="text-align: right;">
                <button id="saveStorageSettings" style="background: #28a745; color: white; border: none; padding: 12px 24px; border-radius: 6px; margin-right: 10px; cursor: pointer; font-size: 14px;">
                    Save Settings
                </button>
                <button id="closeStorageModal" style="background: #6c757d; color: white; border: none; padding: 12px 24px; border-radius: 6px; cursor: pointer; font-size: 14px;">
                    Close
                </button>
            </div>
        </div>
    `;
    
    // Add event listeners
    modal.querySelector('#closeStorageModal').onclick = () => modal.remove();
    modal.querySelector('#saveStorageSettings').onclick = () => {
        const selected = modal.querySelector('input[name="storage"]:checked');
        if (selected && window.TileStorage) {
            window.TileStorage.storageType = selected.value;
            console.log(`Storage type changed to: ${selected.value}`);
            alert(`Storage type changed to: ${backends[selected.value].name}`);
        }
        modal.remove();
    };
    
    // Close on background click
    modal.onclick = (e) => {
        if (e.target === modal) modal.remove();
    };
    
    document.body.appendChild(modal);
}

function getStorageDescription(storageType) {
    const descriptions = {
        'indexeddb': 'Fast browser storage, automatically available. Limited by browser quota but works offline immediately.',
        'filesystem': 'Saves tiles to your computer as actual files. Permanent storage but requires permission each time.',
        'server': 'Uploads tiles to the game server. Accessible from any device but requires internet connection.',
        'hybrid': 'Saves to multiple locations simultaneously for maximum reliability and backup.'
    };
    return descriptions[storageType] || 'Unknown storage type';
}

function verifyOfflineFunctionality() {
    console.log('🧪 Starting offline verification...');
    
    if (window.offlineVerifier) {
        window.offlineVerifier.runAllTests();
    } else {
        alert('Offline verification not available. Please refresh the page.');
    }
}

function testOfflineMode() {
    console.log('🧪 Testing offline mode...');
    
    // Simulate offline mode by blocking network requests
    const originalFetch = window.fetch;
    window.fetch = function() {
        return Promise.reject(new Error('Simulated offline mode'));
    };
    
    alert('Offline mode activated! Map tiles will be loaded from cache only.');
    
    // Restore after 30 seconds
    setTimeout(() => {
        window.fetch = originalFetch;
        alert('Online mode restored.');
    }, 30000);
}

