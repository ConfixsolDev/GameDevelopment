// Initialize tile server mode selector
function initializeTileServerModeSelector() {
    const selector = document.getElementById('tileServerMode');
    if (!selector) return;
    
    // Load saved preference
    const savedMode = localStorage.getItem('tileServerMode') || 'local';
    selector.value = savedMode;
    
    // Apply saved mode
    if (savedMode === 'external') {
        if (window.TileServerConfig) {
            window.TileServerConfig.useExternalServer('http://localhost:8080');
        }
    } else {
        if (window.TileServerConfig) {
            window.TileServerConfig.useLocalServer();
        }
    }
    
    // Handle changes
    selector.addEventListener('change', (e) => {
        const newMode = e.target.value;
        
        if (newMode === 'external') {
            // Check if external server is running
            fetch('http://localhost:8080/')
                .then(response => {
                    if (response.ok) {
                        if (window.TileServerConfig) {
                            window.TileServerConfig.useExternalServer('http://localhost:8080');
                        }
                        localStorage.setItem('tileServerMode', 'external');
                        
                        if (typeof toastr !== 'undefined') {
                            toastr.success('Switched to TileServer-GL (Faster)', 'Tile Server');
                        }
                        
                        // Reload current map if one is loaded
                        if (window.gamePlayManager && window.gamePlayManager.currentTileLayer) {
                            const currentMapPath = document.getElementById('mapSelector')?.value;
                            if (currentMapPath) {
                                window.switchGamePlayMap(currentMapPath);
                            }
                        }
                    } else {
                        throw new Error('Server responded but not OK');
                    }
                })
                .catch(err => {
                    console.error('External tile server not reachable:', err);
                    selector.value = 'local';
                    
                    if (typeof toastr !== 'undefined') {
                        toastr.error('TileServer-GL not running on port 8080. Start it first.', 'Connection Error');
                    } else {
                        alert('TileServer-GL not running on port 8080. Please start the tile server first.');
                    }
                });
        } else {
            if (window.TileServerConfig) {
                window.TileServerConfig.useLocalServer();
            }
            localStorage.setItem('tileServerMode', 'local');
            
            if (typeof toastr !== 'undefined') {
                toastr.info('Switched to C# Server', 'Tile Server');
            }
            
            // Reload current map
            if (window.gamePlayManager && window.gamePlayManager.currentTileLayer) {
                const currentMapPath = document.getElementById('mapSelector')?.value;
                if (currentMapPath) {
                    window.switchGamePlayMap(currentMapPath);
                }
            }
        }
    });
    
    console.log('✅ Tile server mode selector initialized:', savedMode);
}

function updateCacheStatus() {
    if (!window.gameMap) return;
    
    const offlineLayers = [];
    window.gameMap.eachLayer(layer => {
        if (layer instanceof L.TileLayer.Offline) {
            offlineLayers.push(layer);
        }
    });
    
    if (offlineLayers.length > 0) {
        Promise.all(offlineLayers.map(layer => layer.getOfflineTileCount())).then(counts => {
            const total = counts.reduce((sum, count) => sum + count, 0);
            document.getElementById('cachedTilesCount').textContent = total;
            document.getElementById('totalTiles').textContent = total;
            
            // Estimate storage (rough calculation: ~20KB per tile)
            const storageMB = (total * 20 / 1024).toFixed(1);
            document.getElementById('storageUsed').textContent = storageMB + ' MB';
            
            // Update last updated time
            if (total > 0) {
                document.getElementById('lastUpdated').textContent = new Date().toLocaleString();
            }
        }).catch(error => {
            console.error('Error updating cache status:', error);
        });
    }
    
    // Update connection status
    const connectionStatus = document.getElementById('connectionStatus');
    if (navigator.onLine) {
        connectionStatus.innerHTML = '<i class="fas fa-wifi"></i> Online';
        connectionStatus.className = 'status-value online';
    } else {
        connectionStatus.innerHTML = '<i class="fas fa-wifi-slash"></i> Offline';
        connectionStatus.className = 'status-value offline';
    }
}

function calculateTilesInBounds(bounds, zoom) {
    const tiles = [];
    const west = Math.floor(bounds.getWest());
    const east = Math.ceil(bounds.getEast());
    const south = Math.floor(bounds.getSouth());
    const north = Math.ceil(bounds.getNorth());
    
    for (let x = west; x <= east; x++) {
        for (let y = south; y <= north; y++) {
            tiles.push({ z: zoom, x: x, y: y });
        }
    }
    
    return tiles;
}

function toggleOfflinePanel() {
    const panel = document.getElementById('offlineControlsPanel');
    panel.classList.toggle('show');
}

// Make toggle function globally available
window.toggleOfflinePanel = toggleOfflinePanel;
