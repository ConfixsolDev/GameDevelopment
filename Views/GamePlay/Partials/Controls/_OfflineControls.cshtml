<!-- Offline Map Controls -->
<div class="offline-controls-panel" id="offlineControlsPanel">
    <div class="panel-header">
        <h4><i class="fas fa-wifi-slash"></i> Offline Map</h4>
        <button class="close-btn" onclick="toggleOfflinePanel()">
            <i class="fas fa-times"></i>
        </button>
    </div>
    
    <div class="panel-content">
        <!-- Connection Status -->
        <div class="status-section">
            <div class="status-item">
                <span class="status-label">Connection:</span>
                <span class="status-value" id="connectionStatus">
                    <i class="fas fa-wifi"></i> Online
                </span>
            </div>
            <div class="status-item">
                <span class="status-label">Cached Tiles:</span>
                <span class="status-value" id="cachedTilesCount">0</span>
            </div>
        </div>
        
        <!-- Cache Management -->
        <div class="cache-section">
            <h5><i class="fas fa-database"></i> Tile Cache</h5>
            
        <div class="cache-actions">
            <button class="btn btn-primary" id="saveVisibleTiles">
                <i class="fas fa-download"></i> Save Visible Tiles
