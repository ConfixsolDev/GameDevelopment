            <button class="btn btn-primary" id="saveToFolder">
                <i class="fas fa-folder-open"></i> Save to Folder
            </button>
            
            <button class="btn btn-success" id="exportTiles">
                <i class="fas fa-file-archive"></i> Export Tiles
            </button>
            
            <button class="btn btn-secondary" id="storageSettings">
                <i class="fas fa-cog"></i> Storage Settings
            </button>
            
            <button class="btn btn-warning" id="clearCache">
                <i class="fas fa-trash"></i> Clear Cache
            </button>
            
            <button class="btn btn-dark" id="verifyOffline">
                <i class="fas fa-check-circle"></i> Verify Offline
            </button>
        </div>
            
            <!-- Cache Progress -->
            <div class="cache-progress" id="cacheProgress" style="display: none;">
                <div class="progress-label">Saving tiles...</div>
                <div class="progress-bar">
                    <div class="progress-fill" id="progressFill"></div>
                </div>
                <div class="progress-text" id="progressText">0 / 0</div>
            </div>
        </div>
        
        <!-- Offline Settings -->
        <div class="settings-section">
            <h5><i class="fas fa-cog"></i> Offline Settings</h5>
            
            <div class="setting-item">
                <label>
                    <input type="checkbox" id="autoCacheTiles" checked>
                    Auto-cache tiles on view
                </label>
            </div>
            
            <div class="setting-item">
                <label>
                    <input type="checkbox" id="showOfflineOnly" checked>
                    Show offline indicator
                </label>
            </div>
            
            <div class="setting-item">
                <label>Max Zoom Level:</label>
                <select id="maxCacheZoom">
                    <option value="15">15 (Low Detail)</option>
                    <option value="16" selected>16 (Medium Detail)</option>
                    <option value="17">17 (High Detail)</option>
                    <option value="18">18 (Very High Detail)</option>
                </select>
            </div>
            
            <div class="setting-item">
                <label for="tileServerMode">
                    <i class="fas fa-server"></i> Tile Server Mode
                </label>
                <select id="tileServerMode" class="form-control">
                    <option value="local">Local (C# Server)</option>
                    <option value="external">External (TileServer-GL - Faster ⚡)</option>
                </select>
                <small style="display: block; margin-top: 5px; color: #999; font-size: 11px;">
                    External server provides 10-50x faster tile loading. Requires TileServer-GL running on port 8080.
                </small>
            </div>
        </div>
        
        <!-- Cache Statistics -->
        <div class="stats-section">
            <h5><i class="fas fa-chart-bar"></i> Cache Statistics</h5>
            
            <div class="stat-item">
                <span class="stat-label">Total Tiles:</span>
                <span class="stat-value" id="totalTiles">0</span>
            </div>
            
            <div class="stat-item">
                <span class="stat-label">Storage Used:</span>
                <span class="stat-value" id="storageUsed">0 MB</span>
            </div>
            
            <div class="stat-item">
                <span class="stat-label">Last Updated:</span>
                <span class="stat-value" id="lastUpdated">Never</span>
            </div>
        </div>
        
        <!-- Quick Actions -->
        <div class="quick-actions">
            <button class="btn btn-success" id="testOfflineMode">
                <i class="fas fa-wifi-slash"></i> Test Offline Mode
            </button>
            
            <button class="btn btn-secondary" id="exportCache">
                <i class="fas fa-download"></i> Export Cache
            </button>
        </div>
    </div>
</div>

