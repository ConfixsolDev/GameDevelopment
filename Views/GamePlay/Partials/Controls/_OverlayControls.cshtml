@using Microsoft.EntityFrameworkCore
@inject IUserSessionService _userSessionService
@inject TechWebSol.Data.ApplicationDbContext _context
@{
    var currentUser = _userSessionService.GetCurrentUser();
    bool isControlUser = (currentUser?.TeamId == null || currentUser?.TeamId == Guid.Empty);

    var TeamName = "CONTROL";
    var TeamColor = "#888888";
    var TeamIcon = "fa-shield-alt";

    if (currentUser != null && currentUser.TeamId != null && currentUser.TeamId != Guid.Empty)
    {
        var forceType = currentUser.ForceType;

        if (string.IsNullOrEmpty(forceType))
        {
            var team = _context.Teams.AsNoTracking().FirstOrDefault(t => t.Id == currentUser.TeamId);
            forceType = team?.ForceType;
        }

        if (!string.IsNullOrEmpty(forceType))
        {
            var forceTypeLower = forceType.ToLower().Trim();

            if (forceTypeLower.Contains("fox") || forceTypeLower.Contains("red"))
            {
                TeamName = "FOX LAND";
                TeamColor = "#ff0000";
                TeamIcon = "fa-chess-rook";
            }
            else if (forceTypeLower.Contains("blue"))
            {
                TeamName = "BLUE LAND";
                TeamColor = "#0080ff";
                TeamIcon = "fa-shield-alt";
            }
            else if (forceTypeLower.Contains("neutral") || forceTypeLower.Contains("un"))
            {
                TeamName = "NEUTRAL";
                TeamColor = "#00AA00";
                TeamIcon = "fa-balance-scale";
            }
            else
            {
                TeamName = forceType.ToUpper();
            }
        }
    }
}

<div class="map-overlay-controls">
    <!-- Team Command Badge -->
    <div class="team-badge-overlay" style="background: linear-gradient(135deg, @TeamColor 0%, @(TeamColor)ee 100%); box-shadow: 0 0 15px @(TeamColor)66; border: 2px solid @(TeamColor);">
        <i class="fas @TeamIcon"></i>
        <span style="color: @TeamColor; text-shadow: 0 0 8px @(TeamColor)66;">@TeamName</span>
    </div>

    <div class="overlay-control-group">
        <h6 class="collapsible-header" data-section="war-game-tools" onclick="toggleSection('war-game-tools')">
            <i class="fas fa-chevron-right chevron-icon"></i> War Game Tools
        </h6>
        <!-- Token Actions Section -->
        <div class="collapsible-content" id="war-game-tools-content" style="display: none;">
            <div class="token-actions-section">
                <div class="control-row">
                    <button class="overlay-btn token-action-btn" id="btnPlanAttack" data-mode="attack">
                        <i class="fas fa-crosshairs"></i>
                        <span>Plan Attack</span>
                    </button>
                    <button hidden class="overlay-btn token-action-btn" id="btnPanAttack" data-mode="pan-attack">
                        <i class="fas fa-bullseye"></i>
                        <span>Pan Attack</span>
                    </button>
                    <button class="overlay-btn" id="btnReloadAttackLines" onclick="reloadAttackLines()" title="Reload Attack Lines">
                        <i class="fas fa-sync-alt"></i>
                        <span>Reload Attacks</span>
                    </button>

                    <button hidden class="overlay-btn" id="btnCheckAttackLines" onclick="checkAttackLines()" title="Check Attack Lines Status">
                        <i class="fas fa-info-circle"></i>
                        <span>Check Status</span>
                    </button>
                    <button class="overlay-btn token-action-btn" id="btnPlanMove" data-mode="move">
                        <i class="fas fa-route"></i>
                        <span>Plan Move</span>
                    </button>
                </div>

                <div class="control-row" hidden>
                    <button class="overlay-btn token-action-btn" id="btnSelectToken" data-mode="select">
                        <i class="fas fa-hand-pointer"></i>
                        <span>Select Token</span>
                    </button>
                </div>
                <div class="control-row">
                    <button class="overlay-btn token-action-btn" id="btnPlaceToken" data-mode="place">
                        <i class="fas fa-plus"></i>
                        <span>Place Token</span>
                    </button>
                    <button class="overlay-btn" onclick="openDataEntry()">
                        <i class="fas fa-database"></i>
                        <span>Token Preperation</span>
                    </button>
                    <button class="overlay-btn" id="btnCancelMode" onclick="cancelTokenMode()">
                        <i class="fas fa-times"></i>
                        <span>Cancel Mode</span>
                    </button>
                </div>
            </div>
        </div>
      


        @*  
                  <button class="overlay-btn" onclick="createObjective()">
                    <i class="fas fa-flag"></i>
                    <span>Objective</span>
                </button>
                <button class="overlay-btn" onclick="openAssemblyPlanning()">
                    <i class="fas fa-users"></i>
                    <span>Assembly</span>
                </button>
                <button class="overlay-btn" onclick="showUnitStatus()">
                    <i class="fas fa-chart-line"></i>
                    <span>Unit Status</span>
                </button> *@
    </div>


    <div class="overlay-control-group">
        <div class="defense-planning-section">
