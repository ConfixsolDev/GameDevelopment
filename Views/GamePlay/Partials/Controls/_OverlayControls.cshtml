<script>
    /**
     * Region Settings Manager - Moved from _RegionPanel
     */
    class RegionSettingsManager {
        constructor() {
            this.storageKey = 'ksagame_region_settings';
            this.defaultSettings = {
                defaultZoomLevel: 15,
                basemapStyle: 'map',
                showRegions: true,
                showLabels: true
            };
            this.settings = this.loadSettings();
            this.initializeSettings();
        }

        loadSettings() {
            try {
                const stored = localStorage.getItem(this.storageKey);
                if (stored) {
                    const parsed = JSON.parse(stored);
                    console.log('🔧 Region settings loaded:', parsed);
                    return { ...this.defaultSettings, ...parsed };
                }
            } catch (error) {
                console.warn('⚠️ Failed to load settings:', error);
            }
            return { ...this.defaultSettings };
        }

        saveSettings() {
            try {
                localStorage.setItem(this.storageKey, JSON.stringify(this.settings));
                console.log('💾 Settings saved');
            } catch (error) {
                console.error('❌ Failed to save settings:', error);
            }
        }

        initializeSettings() {
            const zoomDropdown = document.getElementById('defaultZoomLevel');
            if (zoomDropdown) {
                zoomDropdown.value = this.settings.defaultZoomLevel;
            }
            const basemapDropdown = document.getElementById('basemapDropdown');
            if (basemapDropdown) {
                basemapDropdown.value = this.settings.basemapStyle;
            }
        }

        updateDefaultZoomLevel(zoomLevel) {
            const level = parseInt(zoomLevel);
            this.settings.defaultZoomLevel = level;
            this.saveSettings();
            console.log(`🔧 Zoom level: ${level}`);
            if (window.gamePlayManager) {
                window.gamePlayManager.defaultZoomLevel = level;
            }
        }

        getDefaultZoomLevel() {
            return this.settings.defaultZoomLevel || 14;
        }

        getBasemapStyle() {
            return this.settings.basemapStyle || 'map';
        }

        updateBasemapStyle(style) {
            this.settings.basemapStyle = style;
            this.saveSettings();
            console.log(`🔧 Basemap: ${style}`);
        }

        resetToDefaults() {
            this.settings = { ...this.defaultSettings };
            this.saveSettings();
            this.initializeSettings();
            console.log('🔧 Region settings reset to defaults');

            if (typeof showNotification === 'function') {
                showNotification('Region settings reset to defaults', 'info');
            }
        }
    }

    function updateDefaultZoomLevel(zoomLevel) {
        if (window.regionSettingsManager) {
            window.regionSettingsManager.updateDefaultZoomLevel(zoomLevel);
        }
    }

    function changeBasemap(style) {
        try {
            if (window.regionSettingsManager) {
                window.regionSettingsManager.updateBasemapStyle(style);
            }
            // Determine target map path from defaults; fallback to sibling file in same folder
            const defaults = window.defaultMapSettings || {};
            let targetPath = (style === 'satellite') ? (defaults.satellite || '') : (defaults.street || '');
            if (!targetPath) {
                const current = document.getElementById('currentMapPath') ? document.getElementById('currentMapPath').value : '';
                if (current) {
                    const parts = current.split('/');
                    if (parts.length > 0) {
                        parts[parts.length - 1] = (style === 'satellite') ? 'satellite.mbtiles' : 'street.mbtiles';
                        targetPath = parts.join('/');
                    }
                }
            }
            if (targetPath && typeof window.switchGamePlayMap === 'function') {
                window.switchGamePlayMap(targetPath);
            } else {
                console.warn('Basemap change skipped - targetPath not resolved or switchGamePlayMap not available');
            }
        } catch (e) {
            console.warn('Basemap change failed:', e);
        }
    }

    function initializeTileServerModeSelector() {
        const selector = document.getElementById('tileServerMode');
        if (!selector) return;

        // Default to external (TileServer-GL) for better performance
        const savedMode = 'external';
        selector.value = savedMode;
        localStorage.setItem('tileServerMode', savedMode);

        // Initialize TileServer-GL as default only on HTTP to avoid HTTPS mixed content
        if (window.TileServerConfig) {
            if (location.protocol === 'http:') {
                window.TileServerConfig.useExternalServer('http://localhost:8080');
            } else {
                // Stay on local endpoints under HTTPS
                window.TileServerConfig.useLocalServer();
            }
        }

        selector.addEventListener('change', (e) => {
            const newMode = e.target.value;
            localStorage.setItem('tileServerMode', newMode);
            console.log('🔧 Tile server mode:', newMode);
        });

        console.log('🔧 Tile Server GL selected by default (hidden from UI)');
    }

    /**
     * Collapsible Sections Manager
     */
    class CollapsibleSectionsManager {
        constructor() {
            this.storageKey = 'ksagame_collapsible_sections';
            this.sections = {
                'war-game-tools': true,
                'defense-planning': false,
                'enemy-intelligence': false,
                'view-controls': false
            };
            this.loadState();
            this.initializeSections();
        }

        loadState() {
            try {
                const stored = localStorage.getItem(this.storageKey);
                if (stored) {
                    const parsed = JSON.parse(stored);
                    this.sections = { ...this.sections, ...parsed };
                    console.log('🔧 Collapsible sections state loaded:', this.sections);
                }
            } catch (error) {
                console.warn('⚠️ Failed to load collapsible sections state:', error);
            }
        }

        saveState() {
            try {
                localStorage.setItem(this.storageKey, JSON.stringify(this.sections));
                console.log('💾 Collapsible sections state saved:', this.sections);
            } catch (error) {
                console.error('❌ Failed to save collapsible sections state:', error);
            }
        }

        initializeSections() {
            Object.keys(this.sections).forEach(sectionId => {
                const content = document.getElementById(`${sectionId}-content`);
                const header = document.querySelector(`[data-section="${sectionId}"]`);

                if (content && header) {
                    if (this.sections[sectionId]) {
                        content.style.display = 'block';
                        header.classList.add('expanded');
                    } else {
                        content.style.display = 'none';
                        header.classList.remove('expanded');
                    }
                }
            });
        }

        toggleSection(sectionId) {
            if (!this.sections.hasOwnProperty(sectionId)) return;

            const content = document.getElementById(`${sectionId}-content`);
            const header = document.querySelector(`[data-section="${sectionId}"]`);

            if (!content || !header) return;

            const isExpanded = this.sections[sectionId];
            this.sections[sectionId] = !isExpanded;

            if (this.sections[sectionId]) {
                content.style.display = 'block';
                header.classList.add('expanded');
            } else {
                content.style.display = 'none';
                header.classList.remove('expanded');
            }

            this.saveState();
            console.log(`🔧 ${sectionId} ${this.sections[sectionId] ? 'expanded' : 'collapsed'}`);
        }
    }

    // Global function for onclick handlers
    function toggleSection(sectionId) {
        if (window.collapsibleSectionsManager) {
            window.collapsibleSectionsManager.toggleSection(sectionId);
        }
    }

    document.addEventListener('DOMContentLoaded', function() {
        window.regionSettingsManager = new RegionSettingsManager();
        window.collapsibleSectionsManager = new CollapsibleSectionsManager();
        initializeTileServerModeSelector();
    });

    if (document.readyState !== 'loading') {
        window.regionSettingsManager = new RegionSettingsManager();
        window.collapsibleSectionsManager = new CollapsibleSectionsManager();
        initializeTileServerModeSelector();
    }
</script>
