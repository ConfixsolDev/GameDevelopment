<div class="map-overlay-controls">
    <div class="overlay-control-group">
        <h6>War Game Tools</h6>
        <div class="control-row">
            <button class="overlay-btn" id="btnPlaceToken">
                <i class="fas fa-plus"></i>
                <span>Place Token</span>
            </button>
            <button class="overlay-btn" onclick="openDataEntry()">
                <i class="fas fa-database"></i>
                <span>Military Units</span>
            </button>
        </div>
        <div class="control-row">
            <button class="overlay-btn" onclick="planMovement()">
                <i class="fas fa-route"></i>
                <span>Plan Move</span>
            </button>
            <button class="overlay-btn" onclick="createObjective()">
                <i class="fas fa-flag"></i>
                <span>Objective</span>
            </button>
        </div>
        <div class="control-row">
            <button class="overlay-btn" onclick="initiateBattle()">
                <i class="fas fa-crosshairs"></i>
                <span>Battle</span>
            </button>
        </div>
    </div>

    <div class="overlay-control-group">
        <h6>Game Controls</h6>
        <div class="control-row">
            <button class="overlay-btn" onclick="advanceTime()">
                <i class="fas fa-forward"></i>
                <span>Advance</span>
            </button>
            <button class="overlay-btn" onclick="runScenarioPointCheck()">
                <i class="fas fa-calculator"></i>
                <span>Points</span>
            </button>
        </div>
        <div class="control-row">
            <button class="overlay-btn" onclick="openModal('simulationPanel')">
                <i class="fas fa-cog"></i>
                <span>Simulation</span>
            </button>
            <button class="overlay-btn" onclick="openModal('settingsModal')">
                <i class="fas fa-sliders-h"></i>
                <span>Settings</span>
            </button>
        </div>
    </div>

    <div class="overlay-control-group">
        <h6>View Controls</h6>
        <div class="control-row">
            <button class="overlay-btn" onclick="toggleFullscreen()">
                <i class="fas fa-expand"></i>
                <span>Fullscreen</span>
            </button>
            <button class="overlay-btn" onclick="resetMapView()">
                <i class="fas fa-home"></i>
                <span>Reset View</span>
            </button>
        </div>
        <div class="control-row">
            <button class="overlay-btn" onclick="showLayerPanel()">
                <i class="fas fa-layer-group"></i>
                <span>Layers</span>
            </button>
        </div>
    </div>

    <!-- Layer Toggle Panel (hidden by default) -->
    <div id="layerPanel" class="overlay-control-group" style="display: none;">
        <h6>Layer Visibility</h6>
        <div class="control-row">
            <label class="overlay-btn">
                <input id="chkShowBlue" type="checkbox" checked onchange="toggleLayer('blue')" />
                <span>Show Blue</span>
            </label>
            <label class="overlay-btn">
                <input id="chkShowFox" type="checkbox" checked onchange="toggleLayer('fox')" />
                <span>Show Fox</span>
            </label>
        </div>
        <div class="control-row">
            <label class="overlay-btn">
                <input id="chkShowLabels" type="checkbox" checked onchange="toggleLayer('labels')" />
                <span>Show Labels</span>
            </label>
            <label class="overlay-btn">
                <input id="chkShowTokens" type="checkbox" checked onchange="toggleLayer('tokens')" />
                <span>Show Tokens</span>
            </label>
        </div>
    </div>
</div>
