                    <button class="overlay-btn defense-btn defensezone-btn" id="btnDefenseZonePrimary" onclick="startDefenseZoneDrawing('primary')" title="Primary Defense Zone">
                        <i class="fas fa-shield"></i>
                        <span>Primary Zone</span>
                    </button>
                    <button class="overlay-btn defense-btn defensezone-btn" id="btnDefenseZoneSecondary" onclick="startDefenseZoneDrawing('secondary')" title="Secondary Defense Zone">
                        <i class="fas fa-shield-alt"></i>
                        <span>Secondary Zone</span>
                    </button>
                    <button class="overlay-btn defense-btn defensezone-btn" id="btnDefenseZoneSupport" onclick="startDefenseZoneDrawing('support')" title="Support Defense Zone">
                        <i class="fas fa-shield-virus"></i>
                        <span>Support Zone</span>
                    </button>
                </div>

