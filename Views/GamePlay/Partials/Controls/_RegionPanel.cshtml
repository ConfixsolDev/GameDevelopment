<!-- LEFT: Unified Region controls (Sectors, Labels, Basemap) -->
<aside class="team-status-panel slide-up" id="regionPanel">
    <div class="team-status-header">
        <div class="team-status-icon">⚑</div>
        <div class="team-status-info">
            <h5>Region Controls</h5>
            <p>One main AO • Mask outside</p>
        </div>
        <button id="toggleRegionPanel" class="panel-toggle" title="Collapse / Expand">▾</button>
    </div>

    <div class="panel-body">
        <div>
            <!-- Metrics -->
            <div class="status-metrics mb-10">
                <div class="metric-item">
                    <span class="metric-value" id="metric-area">—</span>
                    <span class="metric-label">Area (km²)</span>
                </div>
                <div class="metric-item">
                    <span class="metric-value" id="metric-sectors">0</span>
                    <span class="metric-label">Sectors</span>
                </div>
            </div>

            <!-- Edit Mode Toggle -->
            <div class="d-grid gap-10 control-section">
                <div class="control-row">
                    <button id="btnEditMode" class="overlay-btn" onclick="toggleEditMode()">
                        <i class="fas fa-edit"></i>
                        <span>Edit Mode</span>
                    </button>
                </div>
            </div>

            <!-- Edit Mode Controls (hidden by default) -->
            <div class="d-grid gap-10 control-section edit-mode-control" style="display: none;">
                <div class="control-row">
                    <button id="btnSaveRegion" class="overlay-btn">Save Region</button>
                    <button id="btnClearSectors" class="overlay-btn">Clear Sectors</button>
                </div>
            </div>

            <!-- Sectors -->
            <div class="control-section edit-mode-control" style="display: none;">
                <h6>Sectors</h6>
                <div class="control-row">
                    <a id="btnAddBlue" class="overlay-btn"><i>●</i><span>Add Blue</span></a>
                    <a id="btnAddFox" class="overlay-btn"><i>●</i><span>Add Fox</span></a>
                </div>
            </div>

            <!-- Labels -->
            <div class="control-section edit-mode-control" style="display: none;">
                <h6>Labels</h6>
                <div class="control-row">
                    <a id="btnAddLabel" class="overlay-btn"><i>⌘</i><span>Add Label</span></a>
                    <a id="btnClearLabels" class="overlay-btn danger"><i>×</i><span>Clear</span></a>
                </div>
            </div>

            <!-- Basemap Dropdown -->
            <div class="control-section">
                <h6>Basemap</h6>
                <div class="control-row">
                    <select id="basemapDropdown" class="overlay-btn" onchange="changeBasemap(this.value)" style="width: 100%; padding: 8px; border: 1px solid #444; background: #2d3748; color: #e2e8f0; border-radius: 4px;">
                        <option value="Satellite" selected>Satellite</option>
                        <option value="Streets">Streets</option>
                        <option value="OSM">OSM</option>
                        <option value="Topo">Topo</option>
                    </select>
                </div>
            </div>

            <div class="mt-12 gameplay-note" id="saveStatus">Ready</div>
        </div>
    </div>
</aside>
