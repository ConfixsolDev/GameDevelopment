<!-- LEFT: Unified Region controls (Sectors, Labels, Basemap) -->
<aside class="team-status-panel slide-up" id="regionPanel">
    <div class="team-status-header">
        <div class="team-status-icon">⚑</div>
        <div class="team-status-info">
            <h5>Region Controls</h5>
            <p>One main AO • Mask outside</p>
        </div>
        <button id="toggleRegionPanel" class="panel-toggle" title="Collapse / Expand">▾</button>
    </div>

    <div class="panel-body">
        <div>
            <!-- Metrics -->
            <div class="status-metrics mb-10">
                <div class="metric-item">
                    <span class="metric-value" id="metric-area">—</span>
                    <span class="metric-label">Area (km²)</span>
                </div>
                <div class="metric-item">
                    <span class="metric-value" id="metric-sectors">0</span>
                    <span class="metric-label">Sectors</span>
                </div>
            </div>

            <!-- Edit Mode Toggle -->
            <div class="d-grid gap-10 control-section">
                <div class="control-row">
                    <button id="btnEditMode" class="overlay-btn" onclick="toggleEditMode()">
                        <i class="fas fa-edit"></i>
                        <span>Edit Mode</span>
                    </button>
                </div>
            </div>

            <!-- Force Selection (hidden by default) -->
            <div class="control-section edit-mode-control" style="display: none;">
                <h6><i class="fas fa-flag"></i> Force Selection</h6>
                <div class="control-row">
                    <button id="btnSelectBlue" class="overlay-btn force-btn active" onclick="selectForce('blue')">
                        <i class="fas fa-circle" style="color: #00d4ff;"></i>
                        <span>Blue Land</span>
                    </button>
                    <button id="btnSelectFox" class="overlay-btn force-btn" onclick="selectForce('fox')">
                        <i class="fas fa-circle" style="color: #ff6b6b;"></i>
                        <span>Fox Land</span>
                    </button>
                </div>
            </div>


            <!-- Map Regions -->
            <div class="control-section edit-mode-control" style="display: none;">
                <h6><i class="fas fa-map-marked-alt"></i> Map Regions</h6>
                <div class="control-row">
                    <button id="btnCreateRegion" class="overlay-btn" onclick="startRegionDrawing()">
                        <i class="fas fa-draw-polygon"></i>
                        <span>Create Region</span>
                    </button>
                </div>
                <div class="control-row">
                    <button id="btnClearRegions" class="overlay-btn danger" onclick="clearAllRegions()">
                        <i class="fas fa-trash"></i>
                        <span>Clear All</span>
                    </button>
                </div>
            </div>

            <!-- Map Labels -->
            <div class="control-section edit-mode-control" style="display: none;">
                <h6><i class="fas fa-tags"></i> Map Labels</h6>
                <div class="control-row">
                    <button id="btnAddLabel" class="overlay-btn" onclick="addMapLabel()">
                        <i class="fas fa-tag"></i>
                        <span>Add Label</span>
                    </button>
                </div>
                <div class="control-row">
                    <button id="btnClearLabels" class="overlay-btn danger" onclick="clearAllLabels()">
                        <i class="fas fa-times"></i>
                        <span>Clear Labels</span>
                    </button>
                </div>
            </div>

            <!-- Basemap Dropdown -->
            <div class="control-section">
                <h6><i class="fas fa-globe"></i> Basemap</h6>
                <div class="control-row">
                    <select id="basemapDropdown" class="overlay-btn" onchange="changeBasemap(this.value)" style="width: 100%; padding: 8px; border: 1px solid #444; background: #2d3748; color: #e2e8f0; border-radius: 4px;">
                        <option value="Satellite" selected>Satellite</option>
                        <option value="Streets">Streets</option>
                        <option value="OSM">OSM</option>
                        <option value="Topo">Topo</option>
                    </select>
                </div>
            </div>

            <!-- Layer Visibility -->
            <div class="control-section">
                <h6><i class="fas fa-eye"></i> Layer Visibility</h6>
                <div class="control-row">
                    <label class="overlay-btn">
                        <input id="chkShowRegions" type="checkbox" checked onchange="toggleLayer('regions')" />
                        <span><i class="fas fa-map-marked-alt"></i> Regions</span>
                    </label>
                    <label class="overlay-btn">
                        <input id="chkShowLabels" type="checkbox" checked onchange="toggleLayer('labels')" />
                        <span><i class="fas fa-tags"></i> Labels</span>
                    </label>
                </div>
                <div class="control-row">
                    <label class="overlay-btn">
                        <input id="chkShowTokens" type="checkbox" checked onchange="toggleLayer('tokens')" />
                        <span><i class="fas fa-map-pin"></i> Tokens</span>
                    </label>
                </div>
            </div>

            <div class="mt-12 gameplay-note" id="saveStatus">Ready</div>
        </div>
    </div>
</aside>
