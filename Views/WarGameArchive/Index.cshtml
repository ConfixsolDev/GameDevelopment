@inject IUserSessionService _userSessionService;
@{
    var currentUser = _userSessionService.GetCurrentUser();
    Layout = "_Layout";
    ViewData["Title"] = "War Game Archive";
    ViewData["Subtitle"] = "Browse Historical War Games";
}

<div class="container-fluid py-4">
    <div class="row">
        <div class="col-12">
            <div class="card">
                <div class="card-header bg-primary text-white">
                    <h4 class="mb-0">
                        <i class="fas fa-archive"></i> War Game Archive
                    </h4>
                </div>
                <div class="card-body">
                    <div class="table-responsive">
                        <table id="archivesTable" class="table table-striped table-bordered" style="width:100%">
                            <thead>
                                <tr>
                                    <th>Game Title</th>
                                    <th>Game Code</th>
                                    <th>Month</th>
                                    <th>Year</th>
                                    <th>Turn</th>
                                    <th>Status</th>
                                    <th>Saved By</th>
                                    <th>Saved Date</th>
                                    <th>Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                <!-- Archives will be loaded via AJAX -->
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
    $(document).ready(function() {
        // Load archives
        loadArchives();
        
        // Initialize DataTable
        $('#archivesTable').DataTable({
            "processing": true,
            "serverSide": false,
            "ajax": {
                "url": "/WarGameArchive/GetArchives",
                "type": "GET",
                "dataSrc": function(json) {
                    if (json.success && json.archives) {
                        return json.archives.map(function(archive) {
                            return [
                                archive.gameTitle || '—',
                                archive.gameCode || '—',
                                archive.gameMonth || '—',
                                archive.gameYear || '—',
                                `${archive.currentTurn || 0} / ${archive.totalTurns || 0}`,
                                archive.status || '—',
                                archive.savedBy || '—',
                                archive.savedDate ? new Date(archive.savedDate).toLocaleDateString() : '—',
                                `<a href="/WarGameArchive/ViewArchive/${archive.id}" class="btn btn-sm btn-primary">
                                    <i class="fas fa-eye"></i> View
                                </a>`
                            ];
                        });
                    }
                    return [];
                }
            },
            "columns": [
                { "title": "Game Title" },
                { "title": "Game Code" },
                { "title": "Month" },
                { "title": "Year" },
                { "title": "Turn" },
                { "title": "Status" },
                { "title": "Saved By" },
                { "title": "Saved Date" },
                { "title": "Actions", "orderable": false }
            ],
            "order": [[7, "desc"]], // Sort by saved date descending
            "pageLength": 25
        });
    });

    async function loadArchives() {
        try {
            const response = await fetch('/WarGameArchive/GetArchives');
            const result = await response.json();
            
            if (result.success && result.archives) {
                console.log(`✅ Loaded ${result.archives.length} archives`);
            } else {
                console.error('❌ Failed to load archives:', result.message);
            }
        } catch (error) {
            console.error('❌ Error loading archives:', error);
        }
    }
</script>
}
