<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - FML</title>
    <link rel="shortcut icon" href="~/assets/images/favicon.ico">

    <link href="~/assets/print/bootstrap.min.css" rel="stylesheet" />
    <script src="~/assets/print/bootstrap.bundle.min.js"></script>
    <script src="~/assets/print/jquery.min.js"></script>
    <!-- Styles -->
    <style>
        .card-body {
            overflow-y: auto; /* Enable vertical scrolling within the card-body if content exceeds */
        }
    </style>
</head>
<body>

    @RenderBody()
    @await RenderSectionAsync("Scripts", required: false)

    <footer>
    </footer>

</body>
</html>