<script src="~/js/datatable.site.js"></script>


<script>
    $(document).ready(() => {
        $(document).on('keypress', function (event) {
            var code = event.keyCode || event.which;

            if (code === 13) {
                $("#searchBtn").click();
            } else if (code === 127) {
                $("#resetBtn").click();
            }
        });
    });

    function resetFields() {
        $('#formContainer :input').val('');
        refreshGrid();
    }

    function refreshGrid() {
        // Use DataTable API to clear search and redraw
        $('#dataTableGrid12').DataTable().search('').draw();
    }

</script>