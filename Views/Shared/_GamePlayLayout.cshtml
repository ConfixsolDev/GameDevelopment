@using Microsoft.AspNetCore.Identity
@inject UserManager<ApplicationUser> _userManager
@{
    var ShortName = "";
    var DisplayName = "";
    var user = await _userManager.GetUserAsync(User);
    if (user != null)
    {
        DisplayName = user.FullName;
        string[] nameParts = user.FullName.Split(' ');
        ShortName = nameParts[0].Substring(0, 1) + nameParts[1].Substring(0, 1);
    }
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Game Play Arena</title>
    <link rel="shortcut icon" href="~/assets/images/favicon.ico">
    
    <!-- Core CSS -->
    <link href="~/assets/css/bootstrap.min.css" rel="stylesheet">
    <link href="~/assets/css/icons.min.css" rel="stylesheet">
    <link href="~/assets/css/WarGameStyle.css" rel="stylesheet" asp-append-version="true">
    
    <!-- External Libraries -->
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@400;700;900&family=Roboto:wght@300;400;500;700;900&display=swap" rel="stylesheet">
    
    <!-- Map Libraries -->
    <link href="~/map/css/styles.css" rel="stylesheet" />
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
    
    <!-- Game Play Styles -->
    <link href="~/css/GamePlay.css" rel="stylesheet" asp-append-version="true" />
    
    
    @await RenderSectionAsync("Styles", required: false)
</head>
<body class="gameplay-layout">
    <!-- Loading Overlay -->
    <div class="loading-overlay" id="loadingOverlay">
        <div class="loading-spinner"></div>
        <div class="loading-text">INITIALIZING WARGAME ARENA...</div>
    </div>

    <!-- Main Game Container -->
    <div class="gameplay-container">
        <!-- Super Admin Button -->
        <div class="super-admin-button" id="superAdminBtn">
            <i class="fas fa-crown"></i>
            <span>SUPER ADMIN</span>
        </div>

        <!-- Main Game Area -->
        <div class="game-main-area">
            @RenderBody()
        </div>

        <!-- Bottom Control Panel -->
        <div class="gameplay-control-panel" id="bottomControlPanel">
            <div class="control-panel-content">
                <!-- Team Logo Section -->
                <div class="team-logo-section">
                    <div class="team-logo" id="teamLogo">
                        <i class="fas fa-shield-alt"></i>
                    </div>
                    <div class="team-info">
                        <div class="team-name" id="teamName">SELECT TEAM</div>
                        <div class="team-status" id="teamStatus">Ready for Battle</div>
                    </div>
                </div>

                <!-- Control Menu -->
                <div class="control-menu">
                    <a href="#" class="control-btn fox-land active" id="foxLandBtn" onclick="switchToFoxLand()">
                        <i class="fas fa-fire"></i>
                        <span>Fox Land</span>
                    </a>
                    <a href="#" class="control-btn blue-land" id="blueLandBtn" onclick="switchToBlueLand()">
                        <i class="fas fa-water"></i>
                        <span>Blue Land</span>
                    </a>
                    <a href="#" class="control-btn spectator" id="spectatorBtn" onclick="switchToSpectator()">
                        <i class="fas fa-eye"></i>
                        <span>Spectator</span>
                    </a>
                    <a href="#" class="control-btn" id="dataEntryBtn" onclick="openDataEntry()">
                        <i class="fas fa-database"></i>
                        <span>Data Entry</span>
                    </a>
                    <a href="#" class="control-btn" id="tokensBtn" onclick="manageTokens()">
                        <i class="fas fa-crosshairs"></i>
                        <span>Tokens</span>
                    </a>
                    <a href="#" class="control-btn" id="settingsBtn" onclick="openSettings()">
                        <i class="fas fa-cog"></i>
                        <span>Settings</span>
                    </a>
                </div>
            </div>
        </div>
    </div>
    
    <!-- Scripts -->
    <script src="~/assets/js/jquery.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
    
    <!-- jQuery Fallback -->
    <script>
        if (typeof jQuery === 'undefined') {
            console.error('jQuery not loaded from local file, loading from CDN...');
            var script = document.createElement('script');
            script.src = 'https://code.jquery.com/jquery-3.6.0.min.js';
            script.onload = function() {
                console.log('jQuery loaded from CDN');
                initializeGamePlayScripts();
            };
            document.head.appendChild(script);
        } else {
            console.log('jQuery loaded successfully');
            initializeGamePlayScripts();
        }
        
        function initializeGamePlayScripts() {
        $(document).ready(function() {
            // Hide loading overlay after page load
            setTimeout(function() {
                $('#loadingOverlay').fadeOut(1000);
            }, 2000);

            // Initialize game state
            initializeGamePlay();
            
            // Super Admin button functionality
            $('#superAdminBtn').click(function() {
                toggleBottomMenu();
            });
        });

        function initializeGamePlay() {
            // Initialize map and game components
            console.log('Initializing Game Play Arena...');
            
            // Set default team
            updateTeamDisplay('ALPHA', 'Alpha Team', 'active');
        }

        function switchToFoxLand() {
            updateActiveMode('fox-land');
            updateTeamDisplay('FOX', 'Fox Land', 'attacking');
            console.log('Switched to Fox Land mode');
        }

        function switchToBlueLand() {
            updateActiveMode('blue-land');
            updateTeamDisplay('BLUE', 'Blue Land', 'defending');
            console.log('Switched to Blue Land mode');
        }

        function switchToSpectator() {
            updateActiveMode('spectator');
            updateTeamDisplay('OBS', 'Spectator', 'observing');
            console.log('Switched to Spectator mode');
        }

        function updateActiveMode(mode) {
            // Remove active class from all buttons
            $('.control-btn').removeClass('active');
            
            // Add active class to current mode
            $('#' + mode + 'Btn').addClass('active');
        }

        function updateTeamDisplay(code, name, status) {
            $('#teamLogo').html('<i class="fas fa-shield-alt"></i>');
            $('#teamName').text(name);
            $('#teamStatus').text(status.charAt(0).toUpperCase() + status.slice(1));
        }

        function openDataEntry() {
            console.log('Opening Data Entry modal...');
            // TODO: Implement data entry modal
        }

        function manageTokens() {
            console.log('Opening Token Management...');
            // TODO: Implement token management
        }

        function openSettings() {
            console.log('Opening Settings...');
            // TODO: Implement settings modal
        }

        function toggleBottomMenu() {
            const panel = $('#bottomControlPanel');
            const button = $('#superAdminBtn');
            
            if (panel.hasClass('hidden')) {
                // Show menu
                panel.removeClass('hidden').addClass('slide-up');
                button.addClass('active');
                console.log('Bottom menu shown');
            } else {
                // Hide menu
                panel.addClass('hidden').removeClass('slide-up');
                button.removeClass('active');
                console.log('Bottom menu hidden');
            }
        }
        }
    </script>
    
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
