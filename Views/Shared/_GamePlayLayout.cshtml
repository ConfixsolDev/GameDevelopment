@using Microsoft.AspNetCore.Identity
@using Microsoft.EntityFrameworkCore
@inject UserManager<ApplicationUser> _userManager
@inject IUserSessionService _userSessionService
@inject TechWebSol.Data.ApplicationDbContext _context
@{
    var ShortName = "";
    var DisplayName = "";
    var RoleLabel = "USER";
    var TeamName = "Control";
    var TeamColor = "#888888";
    var TeamIcon = "fa-shield-alt";
    
    var user = await _userManager.GetUserAsync(User);
    if (user != null)
    {
        DisplayName = user.FullName;
        string[] nameParts = user.FullName.Split(' ');
        ShortName = nameParts[0].Substring(0, 1) + nameParts[1].Substring(0, 1);
        var roles = await _userManager.GetRolesAsync(user);
        if (roles != null && roles.Count > 0)
        {
            RoleLabel = roles[0];
        }
    }
    
    // Get team information from session
    var currentUser = _userSessionService.GetCurrentUser();
    
    // Only show force type if user has TeamId (not Director/Super Admin)
    if (currentUser != null && currentUser.TeamId != null && currentUser.TeamId != Guid.Empty)
    {
        // Try to get ForceType from User first, if empty then get from Team
        var forceType = currentUser.ForceType;
        
        if (string.IsNullOrEmpty(forceType))
        {
            // ForceType not set on user, get it from Team
            var team = _context.Teams.AsNoTracking().FirstOrDefault(t => t.Id == currentUser.TeamId);
            forceType = team?.ForceType;
        }
        
        if (!string.IsNullOrEmpty(forceType))
        {
            var forceTypeLower = forceType.ToLower().Trim();
            
            if (forceTypeLower.Contains("fox") || forceTypeLower.Contains("red"))
            {
                TeamName = "FOX LAND";
                TeamColor = "#ff0000";
                TeamIcon = "fa-chess-rook";
            }
            else if (forceTypeLower.Contains("blue"))
            {
                TeamName = "BLUE LAND";
                TeamColor = "#0080ff";
                TeamIcon = "fa-shield-alt";
            }
            else if (forceTypeLower.Contains("neutral") || forceTypeLower.Contains("un"))
            {
                TeamName = "NEUTRAL";
                TeamColor = "#00AA00";
                TeamIcon = "fa-balance-scale";
            }
            else
            {
                // Fallback: use the actual ForceType value
                TeamName = forceType.ToUpper();
            }
        }
        else
        {
            // Has TeamId but no ForceType on User or Team - fallback to CONTROL
            TeamName = "CONTROL";
        }
    }
    // If no TeamId (Director/Super Admin), default to CONTROL
}
<!DOCTYPE html>
<html lang="en" data-theme="dark">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#1a1a1a" />
    <title>@ViewData["Title"] - Game Play Arena</title>
    <link rel="shortcut icon" href="~/favicon.ico" type="image/x-icon">

    <!-- Critical CSS - Inline for instant dark theme (prevents white flash) -->
    <style>
        :root, html, body {
            background-color: #0a0a0a !important;
            color: #ffffff !important;
            margin: 0;
            padding: 0;
        }
        html[data-theme="dark"] {
            background-color: #0a0a0a;
        }
        .gameplay-container {
            background: #1a1a1a;
            min-height: 100vh;
        }
    </style>

    <!-- Core CSS -->
    <link href="~/assets/css/bootstrap.min.css" rel="stylesheet">
    <link href="~/assets/css/icons.min.css" rel="stylesheet">
    <link href="~/assets/css/WarGameStyle.css" rel="stylesheet" asp-append-version="true">
    <link href="~/css/phase01-movement.css" rel="stylesheet" asp-append-version="true">

    <!-- Font Awesome - Local -->
    <link href="~/assets/css/fontawesome.min.css" rel="stylesheet">

    <!-- Map Libraries CSS ONLY - Scripts moved to bottom for faster page load -->
    <link rel="stylesheet" href="~/map/css/leaflet.css" />
    <link rel="stylesheet" href="~/map/css/leaflet.draw.css" />

    <!-- Game Play Specific Styles -->
    <link href="~/css/GamePlay.css" rel="stylesheet" asp-append-version="true" />
    <link href="~/css/DataManagement.css" rel="stylesheet" asp-append-version="true" />
    <link href="~/css/combatSimulation.css" rel="stylesheet" asp-append-version="true" />
    <link href="~/css/regionControls.css" rel="stylesheet" asp-append-version="true" />
    <link href="~/css/militarySymbols.css" rel="stylesheet" asp-append-version="true" />
    <link href="~/css/attackSymbols.css" rel="stylesheet" asp-append-version="true" />
    <link href="~/css/defenseSymbols.css" rel="stylesheet" asp-append-version="true" />
    
    <!-- Unified Dark Theme - Single Source of Truth -->
    <link href="~/css/unified-dark-theme.css" rel="stylesheet" asp-append-version="true">
    
    <!-- Google Fonts for Professional Typography -->
    @* Google Fonts - DISABLED FOR OFFLINE USE
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500;600&display=swap" rel="stylesheet">
    *@

    @await RenderSectionAsync("Styles", required: false)
</head>
<body class="gameplay-layout">
    <!-- Simple Google-style Loader -->
    <div class="simple-loader" id="simpleLoader" style="display: none;"></div>

    <!-- Main Game Container -->
    <div class="gameplay-container">
        <!-- Main Game Area -->
        <div class="game-main-area">
            @RenderBody()
        </div>
    </div>



    <!-- Scripts - Local versions -->
    <script src="~/assets/js/jquery.min.js"></script>
    <script src="~/assets/js/bootstrap.bundle.min.js"></script>
    

    <!-- Map Libraries - Moved from head for better performance -->
    <script src="~/map/js/leaflet.js"></script>
    <script defer src="~/map/js/leaflet.draw.js"></script>
    <script defer src="~/map/js/turf.min.js"></script>
    <script defer src="~/map/js/leaflet-providers.js"></script>

    <!-- Initialize Game Play Scripts -->
    <script>
        console.log('jQuery loaded successfully from local file');
        initializeGamePlayScripts();

        function initializeGamePlayScripts() {
        $(document).ready(function() {
            // Loading overlay will be hidden by GamePlayManager after initialization
            
            // Initialize game state
            initializeGamePlay();

            // Team display badge (disabled - no click functionality)
            // Super admin functionality has been replaced with team display
        });

        function initializeGamePlay() {
            // Initialize map and game components
            console.log('Initializing Game Play Arena...');

            // Set default team
            updateTeamDisplay('ALPHA', 'Alpha Team', 'active');
        }

        function switchToFoxLand() {
            updateActiveMode('fox-land');
            updateTeamDisplay('FOX', 'Fox Land', 'attacking');
            console.log('Switched to Fox Land mode');
        }

        function switchToBlueLand() {
            updateActiveMode('blue-land');
            updateTeamDisplay('BLUE', 'Blue Land', 'defending');
            console.log('Switched to Blue Land mode');
        }

        function switchToSpectator() {
            updateActiveMode('spectator');
            updateTeamDisplay('OBS', 'Spectator', 'observing');
            console.log('Switched to Spectator mode');
        }

        function updateActiveMode(mode) {
            // Remove active class from all buttons
            $('.control-btn').removeClass('active');

            // Add active class to current mode
            $('#' + mode + 'Btn').addClass('active');
        }

        function updateTeamDisplay(code, name, status) {
            $('#teamLogo').html('<i class="fas fa-shield-alt"></i>');
            $('#teamName').text(name);
            $('#teamStatus').text(status.charAt(0).toUpperCase() + status.slice(1));
        }

        function openDataEntry() {
            console.log('Opening Data Entry modal...');
            // Opens the data entry modal for military unit management
        }

        function openTokenPlacement() {
            console.log('Opening Token Placement...');
            // Opens the token placement modal for placing tokens on map
        }

        function manageTokens() {
            console.log('Opening Token Management...');
            // Legacy function - kept for backward compatibility
        }

        function openSettings() {
            console.log('Opening Settings...');
            // TODO: Implement settings modal
        }

        function toggleBottomMenu() {
            // DISABLED: Bottom menu toggle functionality removed
            console.log('Bottom menu toggle disabled');
        }
        }
    </script>

    <!-- Simple Loader Functions -->
    <script>
        // Simple loader functions
        function showLoader() {
            document.getElementById('simpleLoader').style.display = 'block';
        }
        
        function hideLoader() {
            document.getElementById('simpleLoader').style.display = 'none';
        }
        
        // Make functions globally available
        window.showLoader = showLoader;
        window.hideLoader = hideLoader;
    </script>

    <!-- Global Modal Configuration -->
    <script>
        $(document).ready(function() {
            // Remove backdrop AFTER modal is shown (not before/during)
            $(document).on('shown.bs.modal', '.modal', function () {
                // Only remove backdrop after modal is fully displayed
                setTimeout(() => {
                    $('.modal-backdrop').remove();
                }, 50);
            });
            
            // Clean up backdrop on hide
            $(document).on('hidden.bs.modal', '.modal', function () {
                $('.modal-backdrop').remove();
                $('body').removeClass('modal-open').css('padding-right', '');
            });
        });
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
