@using Microsoft.AspNetCore.Identity
@inject UserManager<ApplicationUser> _userManager
@{
    var ShortName = "";
    var DisplayName = "";
    var user = await _userManager.GetUserAsync(User);
    if (user?.FullName != null)
    {
        DisplayName = user.FullName;
        var parts = user.FullName.Split(' ', StringSplitOptions.RemoveEmptyEntries);
        var first = parts.Length > 0 ? parts[0] : "";
        var second = parts.Length > 1 ? parts[1] : "";
        var c1 = string.IsNullOrEmpty(first) ? "" : first.Substring(0, 1);
        var c2 = string.IsNullOrEmpty(second) ? "" : second.Substring(0, 1);
        ShortName = (c1 + c2).ToUpperInvariant();
    }
}
<!DOCTYPE html>
<html lang="en">
<head>

    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - IDS</title>
    <link rel="shortcut icon" href="~/assets/images/favicon.ico">

    <!-- Keep your theme CSS; ensure it matches your Bootstrap JS version -->
    <link href="~/assets/css/bootstrap.min.css" rel="stylesheet">
    <link href="~/cdn_local/daterangepicker.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/css/select2.min.css" rel="stylesheet" />
    <link href="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.css" rel="stylesheet">
    <link href="~/assets/css/icons.min.css" rel="stylesheet">
    <link href="~/assets/css/app.min.css" id="app-style" rel="stylesheet">
    <link href="~/assets/css/custom.css" rel="stylesheet" asp-append-version="true">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/metismenu/dist/metisMenu.min.css">

    <!-- Sweetalert / Fonts / Icons -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Roboto:ital,wght@0,300;0,400;0,500;0,700;0,900;1,400&display=swap" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.1/css/all.min.css" rel="stylesheet">

    <!-- Core scripts (order matters) -->
    <script src="~/assets/js/jquery.min.js"></script>
    <!-- Bootstrap 5 bundle (includes Popper + Modal plugin) -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/bootstrap/5.3.2/js/bootstrap.bundle.min.js"></script>


    <style>
        .Brudcrum {
            display: flex;
            align-items: start;
            width: 100%;
        }

        .page-title-box {
            flex-grow: 1;
            min-width: 0;
        }
    </style>

    @await RenderSectionAsync("Styles", required: false)
</head>
<body data-sidebar="dark">
    <!-- start .layout-wrapper -->
    <div id="layout-wrapper">
        <!-- start header -->
        <header id="page-topbar">
            <div class="navbar-header">
                <div class="d-flex">
                    <!-- LOGO -->
                    <div class="navbar-brand-box">
                        <a href="/Home/Index" class="logo logo-light">
                            <span class="logo-sm">
                                <img src="~/assets/images/logo-sm.png" alt="" width="32">
                            </span>
                            <span class="logo-lg" style="font-size: xx-large;">
                                <img src="~/assets/images/logo-sm.png" alt="" width="32"><span style="color:white">HCM</span>
                            </span>
                        </a>
                    </div>
                    <button type="button" class="btn btn-sm px-3 font-size-24 header-item" id="vertical-menu-btn">
                        <i class="mdi mdi-menu"></i>
                    </button>
                </div>

                <div class="d-flex Brudcrum align-items-start">
                    <div class="page-title-box flex-grow-1">
                        <h1 class="page-title">@ViewData["Title"]</h1>
                        <ol class="breadcrumb m-0">
                            @RenderSection("Breadcrump", false)
                        </ol>
                    </div>
                </div>

                <div class="d-flex">
                    <div class="dropdown d-inline-block">
                        <button type="button" class="btn header-item noti-icon Helpinfo">
                            <i class="mdi mdi-help-circle-outline"></i>
                        </button>
                    </div>

                    <div class="dropdown d-inline-block">
                        <button type="button" class="btn header-item" id="page-header-user-dropdown"
                                data-bs-toggle="dropdown" aria-haspopup="true" aria-expanded="false">
                            <span class="rounded-circle">@ShortName</span>
                        </button>

                        <div class="dropdown-menu dropdown-menu-end">
                            <a class="dropdown-item d-flex align-items-center" href="#"><i class="fas fa-user"></i><span>@DisplayName</span></a>
                            <a class="dropdown-item d-flex align-items-center" href="~/Identity/AccountAdmin/SetUserUrl"><i class="fas fa-home"></i><span>Settings</span></a>
                            <a class="dropdown-item d-flex align-items-center action_link" href="~/Identity/AccountAdmin/PasswordReset"><i class="fas fa-key"></i><span>Change Password</span></a>
                            <div class="dropdown-divider"></div>
                            <a asp-area="" asp-controller="Account" asp-action="Logout" class="dropdown-item"><i class="fas fa-sign-out-alt"></i><span>Logout</span></a>
                        </div>
                    </div>
                </div>
            </div>
        </header>
        <!-- end header -->
        @await Component.InvokeAsync("Sidebar")

        <div class="main-content">
            <div class="page-content">
                <div class="container-fluid" style="margin-top:15px">
                    @RenderBody()
                </div>
            </div>
            @await Component.InvokeAsync("Footer")
        </div>
    </div>

    <!-- Libraries -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/js/toastr.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/metismenu"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/simplebar/5.3.6/simplebar.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <script src="~/cdn_local/fullcalendar@6.1.15/index.global.min.js"></script>
    <script src="~/cdn_local/fullcalendar@6.1.15/moment.min.js"></script>
    <script src="~/cdn_local/fullcalendar@6.1.15/daterangepicker.min.js"></script>

    <script src="~/js/jquery.serializejson.min.js"></script>

    <!-- API Configuration -->
    <script src="~/js/api-config.js" asp-append-version="true"></script>

    <!-- Custom scripts for all pages -->
    <script src="~/assets/js/app.js" asp-append-version="true"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    <!-- UNIVERSAL modal helper: works with Bootstrap 5, Bootstrap 4 (jQuery), or no plugin -->
    <script>
        (function (w) {
          function hasB5() { return !!(w.bootstrap && w.bootstrap.Modal); }
          function hasJqModal(el) { return w.$ && typeof w.$(el).modal === 'function'; }

          function ensureBackdrop() {
            if (!document.querySelector('.modal-backdrop')) {
              const bd = document.createElement('div');
              bd.className = 'modal-backdrop fade show';
              document.body.appendChild(bd);
            }
          }
          function removeBackdrop() {
            document.querySelectorAll('.modal-backdrop').forEach(b => b.remove());
          }

          function show(id) {
            const el = document.getElementById(id);
            if (!el) return;
            if (hasB5()) { w.bootstrap.Modal.getOrCreateInstance(el).show(); return; }
            if (hasJqModal(el)) { $(el).modal('show'); return; }
            // Manual fallback
            el.style.display = 'block';
            el.removeAttribute('aria-hidden');
            el.classList.add('show');
            document.body.classList.add('modal-open');
            ensureBackdrop();
          }

          function hide(id) {
            const el = document.getElementById(id);
            if (!el) return;
            // Try a dismiss control first
            const dismiss = el.querySelector('[data-bs-dismiss="modal"], .btn-close, [data-dismiss="modal"]');
            if (dismiss) { dismiss.click(); return; }
            if (hasB5()) { w.bootstrap.Modal.getOrCreateInstance(el).hide(); return; }
            if (hasJqModal(el)) { $(el).modal('hide'); return; }
            // Manual fallback
            el.classList.remove('show');
            el.style.display = 'none';
            el.setAttribute('aria-hidden', 'true');
            document.body.classList.remove('modal-open');
            removeBackdrop();
          }

          w.ModalHelper = { show, hide };
        })(window);
    </script>

    <script type="text/javascript">
        $(document).ready(function () {
            $('.select2').select2({
                search: true,
                width: '100%',
                placeholder: "Select",
                allowClear: true,
            });
            $('.select2-multiple').select2();
        });
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
