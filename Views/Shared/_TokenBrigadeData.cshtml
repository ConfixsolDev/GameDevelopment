<!-- Token Brigade Data Entry Partial View - Bootstrap Modal -->
<div class="modal fade" id="tokenBrigadeDataModal" tabindex="-1" role="dialog" aria-labelledby="tokenBrigadeDataModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-xl" role="document">
