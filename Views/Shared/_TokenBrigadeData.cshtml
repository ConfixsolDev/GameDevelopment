<script>
    if (typeof currentTokenId === 'undefined') {
        var currentTokenId = null;
    }
    if (typeof currentBrigadeData === 'undefined') {
        var currentBrigadeData = null;
    }

    function openTokenBrigadeData(tokenId, tokenName) {
        currentTokenId = tokenId;
        $('#selectedTokenName').text(tokenName);
        $('#selectedTokenId').text(tokenId);
        $('#brigadeTokenId').val(tokenId);
        
        loadTokenBrigadeData(tokenId);
        $('#tokenBrigadeDataModal').modal('show');
    }

    function closeTokenBrigadeModal() {
        $('#tokenBrigadeDataModal').modal('hide');
        currentTokenId = null;
        currentBrigadeData = null;
    }

    function switchBrigadeTab(tabName) {
        $('.tab-content').removeClass('active');
        $('.tab-btn').removeClass('active');
        
        $('#' + tabName + '-tab').addClass('active');
        $('button[onclick="switchBrigadeTab(\'' + tabName + '\')"]').addClass('active');
        
        if (tabName === 'summary') {
            updateSummaryTab();
        }
    }

    function loadTokenBrigadeData(tokenId) {
        // Load existing brigade + units for this token using GetTokenSummary
        $.get(`/DataManagement/GetTokenSummary?tokenId=${tokenId}`)
            .done(function(response) {
                if (response && response.success && response.data) {
                    const brigades = response.data.brigades || [];
                    if (brigades.length > 0) {
                        const brigade = brigades[0]; // Use first brigade linked to this token
                        populateBrigadeForm(brigade);
                        currentBrigadeData = response.data;

                        // Load units that are already filtered by token in GetTokenSummary
                        loadInfantryBattalions(response.data.infantryBattalions || []);
                        loadArmouredRegiments(response.data.armouredRegiments || []);
                        loadArtilleryRegiments(response.data.artilleryRegiments || []);
                    } else {
                        // No brigade linked to this token yet
                        resetBrigadeForm();
                    }
                } else {
                    resetBrigadeForm();
                }
            })
            .fail(function() {
                // No existing data, start fresh
                resetBrigadeForm();
            });
    }

    function populateBrigadeForm(brigade) {
        $('#tokenBrigadeId').val(brigade.id);
        $('#tokenBrigadeName').val(brigade.name);
        $('#tokenBrigadeCode').val(brigade.brigadeCode);
        $('#tokenBrigadeForceType').val(brigade.forceType);
        $('#tokenBrigadeStrength').val(brigade.totalStrength);
        $('#tokenBrigadeStatus').val(brigade.status);
        $('#tokenBrigadeDescription').val(brigade.description);
    }

    function resetBrigadeForm() {
        $('#tokenBrigadeForm')[0].reset();
        $('#brigadeTokenId').val(currentTokenId);
        $('#infantryBattalionsList').empty();
        $('#armouredRegimentsList').empty();
        $('#artilleryRegimentsList').empty();
    }

    function addInfantryBattalion() {
        const template = $('#infantryBattalionTemplate').html();
        $('#infantryBattalionsList').append(template);
    }

    function addArmouredRegiment() {
        const template = $('#armouredRegimentTemplate').html();
        $('#armouredRegimentsList').append(template);
    }

    function addArtilleryRegiment() {
        const template = $('#artilleryRegimentTemplate').html();
        $('#artilleryRegimentsList').append(template);
    }

    function removeInfantryBattalion(btn) {
        $(btn).closest('.unit-form-card').remove();
        updateBrigadeTotalStrength();
    }

    function removeArmouredRegiment(btn) {
        $(btn).closest('.unit-form-card').remove();
        updateBrigadeTotalStrength();
    }

    function removeArtilleryRegiment(btn) {
        $(btn).closest('.unit-form-card').remove();
        updateBrigadeTotalStrength();
    }

    function updateBrigadeTotalStrength() {
        let totalStrength = 0;
        
        // Sum all unit strengths
        $('#infantryBattalionsList input[name="Strength"]').each(function() {
            totalStrength += parseInt($(this).val()) || 0;
        });
        $('#armouredRegimentsList input[name="Strength"]').each(function() {
            totalStrength += parseInt($(this).val()) || 0;
        });
        $('#artilleryRegimentsList input[name="Strength"]').each(function() {
            totalStrength += parseInt($(this).val()) || 0;
        });
        
        $('#tokenBrigadeStrength').val(totalStrength);
    }

    function updateSummaryTab() {
        // Update summary information
        $('#summaryBrigadeName').text($('#tokenBrigadeName').val() || 'Not Set');
        $('#summaryBrigadeCode').text($('#tokenBrigadeCode').val() || 'Not Set');
        $('#summaryForceType').text($('#tokenBrigadeForceType').val() || 'Not Set');
        $('#summaryTotalStrength').text($('#tokenBrigadeStrength').val() || '0');
        
        // Count units
        const infantryCount = $('#infantryBattalionsList .unit-form-card').length;
        const armouredCount = $('#armouredRegimentsList .unit-form-card').length;
        const artilleryCount = $('#artilleryRegimentsList .unit-form-card').length;
        
        $('#summaryInfantryCount').text(infantryCount);
        $('#summaryArmouredCount').text(armouredCount);
        $('#summaryArtilleryCount').text(artilleryCount);
        
        // Calculate equipment totals
        let totalTanks = 0, totalATGMS = 0, totalArtilleryGuns = 0, totalMortars = 0, totalHMG = 0, totalMANPADS = 0;
        
        $('#armouredRegimentsList input[name="Tanks"]').each(function() {
            totalTanks += parseInt($(this).val()) || 0;
        });
        $('#infantryBattalionsList input[name="ATGMS"], #armouredRegimentsList input[name="ATGMS"]').each(function() {
            totalATGMS += parseInt($(this).val()) || 0;
        });
        $('#artilleryRegimentsList input[name="Guns"]').each(function() {
            totalArtilleryGuns += parseInt($(this).val()) || 0;
        });
        $('#infantryBattalionsList input[name="Mortars81mm"], #infantryBattalionsList input[name="Mortars120mm"], #armouredRegimentsList input[name="Mortars120mm"]').each(function() {
            totalMortars += parseInt($(this).val()) || 0;
        });
        $('#infantryBattalionsList input[name="HMG_AGL"], #armouredRegimentsList input[name="HMG"], #artilleryRegimentsList input[name="HMG"]').each(function() {
            totalHMG += parseInt($(this).val()) || 0;
        });
        $('#infantryBattalionsList input[name="MANPADS"]').each(function() {
            totalMANPADS += parseInt($(this).val()) || 0;
        });
        
        $('#summaryTanks').text(totalTanks);
        $('#summaryATGMS').text(totalATGMS);
        $('#summaryArtilleryGuns').text(totalArtilleryGuns);
        $('#summaryMortars').text(totalMortars);
        $('#summaryHMG').text(totalHMG);
        $('#summaryMANPADS').text(totalMANPADS);
    }

    function saveBrigadeInfo() {
        const formData = {
            Id: $('#tokenBrigadeId').val() || null,
            TokenId: currentTokenId,
            Name: $('#tokenBrigadeName').val(),
            BrigadeCode: $('#tokenBrigadeCode').val(),
            ForceType: $('#tokenBrigadeForceType').val(),
            TotalStrength: $('#tokenBrigadeStrength').val(),
            Status: $('#tokenBrigadeStatus').val(),
            Description: $('#tokenBrigadeDescription').val()
        };

        const isUpdate = !!formData.Id;
        const url = isUpdate ? '/DataManagement/UpdateTokenBrigade' : '/DataManagement/CreateTokenBrigade';
        const method = isUpdate ? 'PUT' : 'POST';

        $.ajax({
            url: url,
            method: method,
            contentType: 'application/json',
            data: JSON.stringify(formData)
        })
        .done(function(response) {
            if (response.success) {
                if (!formData.Id && response.data && response.data.id) {
                    $('#tokenBrigadeId').val(response.data.id);
                }
                showNotification('Brigade information saved', 'success');
            } else {
                showNotification('Error: ' + response.message, 'error');
            }
        })
        .fail(function() {
            showNotification('Failed to save brigade information', 'error');
        });
    }

    async function saveAllBrigadeData() {
        // First ensure brigade exists
        if (!$('#tokenBrigadeId').val()) {
            // Create brigade first
            const brigadePayload = {
                TokenId: currentTokenId,
                Name: $('#tokenBrigadeName').val(),
                BrigadeCode: $('#tokenBrigadeCode').val(),
                ForceType: $('#tokenBrigadeForceType').val(),
                TotalStrength: $('#tokenBrigadeStrength').val(),
                Status: $('#tokenBrigadeStatus').val(),
                Description: $('#tokenBrigadeDescription').val()
            };

            try {
                const brigadeResponse = await $.ajax({
                    url: '/DataManagement/CreateTokenBrigade',
                    method: 'POST',
                    contentType: 'application/json',
                    data: JSON.stringify(brigadePayload)
                });

                if (brigadeResponse.success && brigadeResponse.data && brigadeResponse.data.id) {
                    $('#tokenBrigadeId').val(brigadeResponse.data.id);
                } else {
                    showNotification('Failed to create brigade. Cannot save units.', 'error');
                    return;
                }
            } catch (error) {
                showNotification('Failed to create brigade. Cannot save units.', 'error');
                return;
            }
        }

        const brigadeId = $('#tokenBrigadeId').val();
        if (!brigadeId) {
            showNotification('Please save brigade information first.', 'warning');
            return;
        }

        const forceType = $('#tokenBrigadeForceType').val();
        let allSuccess = true;

        // Helper function to post data
        async function postData(url, data) {
            try {
                const response = await $.ajax({
                    url: url,
                    method: 'POST',
                    contentType: 'application/json',
                    data: JSON.stringify(data)
                });
                return response.success;
            } catch (error) {
                return false;
            }
        }

        // Save infantry battalions
        const infantryBattalions = [];
        $('#infantryBattalionsList .unit-form-card').each(function() {
            const battalion = {};
            $(this).find('input').each(function() {
                const name = $(this).attr('name');
                const value = $(this).val();
                if (name && value) {
                    battalion[name] = isNaN(value) ? value : (name.includes('Speed') || name.includes('Range') ? parseFloat(value) : parseInt(value));
                }
            });
            battalion.ForceType = forceType;
            battalion.BrigadeId = brigadeId;
            infantryBattalions.push(battalion);
        });

        for (const battalion of infantryBattalions) {
            const success = await postData('/DataManagement/CreateTokenInfantryBattalion', battalion);
            if (!success) allSuccess = false;
        }

        // Save armoured regiments
        const armouredRegiments = [];
        $('#armouredRegimentsList .unit-form-card').each(function() {
            const regiment = {};
            $(this).find('input').each(function() {
                const name = $(this).attr('name');
                const value = $(this).val();
                if (name && value) {
                    regiment[name] = isNaN(value) ? value : (name.includes('Speed') || name.includes('Range') ? parseFloat(value) : parseInt(value));
                }
            });
            regiment.ForceType = forceType;
            regiment.BrigadeId = brigadeId;
            armouredRegiments.push(regiment);
        });

        for (const regiment of armouredRegiments) {
            const success = await postData('/DataManagement/CreateTokenArmouredRegiment', regiment);
            if (!success) allSuccess = false;
        }

        // Save artillery regiments
        const artilleryRegiments = [];
        $('#artilleryRegimentsList .unit-form-card').each(function() {
            const regiment = {};
            $(this).find('input').each(function() {
                const name = $(this).attr('name');
                const value = $(this).val();
                if (name && value) {
                    regiment[name] = isNaN(value) ? value : (name.includes('Speed') || name.includes('Range') ? parseFloat(value) : parseInt(value));
                }
            });
            regiment.ForceType = forceType;
            regiment.BrigadeId = brigadeId;
            artilleryRegiments.push(regiment);
        });

        for (const regiment of artilleryRegiments) {
            const success = await postData('/DataManagement/CreateTokenArtilleryRegiment', regiment);
            if (!success) allSuccess = false;
        }

        if (allSuccess) {
            showNotification('All brigade data saved successfully', 'success');
            closeTokenBrigadeModal();
        } else {
            showNotification('Some data failed to save. Please review and try again.', 'warning');
        }
    }

    function exportBrigadeData() {
        if (!currentTokenId) return;
        
        $.get(`/DataManagement/ExportTokenBrigadeData?tokenId=${currentTokenId}`)
            .done(function(response) {
                if (response.success) {
                    const dataStr = JSON.stringify(response.data, null, 2);
                    const dataBlob = new Blob([dataStr], {type: 'application/json'});
                    const url = URL.createObjectURL(dataBlob);
                    const link = document.createElement('a');
                    link.href = url;
                    link.download = `brigade-${currentTokenId}-data.json`;
                    link.click();
                    URL.revokeObjectURL(url);
                    showNotification('Brigade data exported', 'success');
                }
            });
    }

    function loadInfantryBattalions(battalions) {
        $('#infantryBattalionsList').empty();
        battalions.forEach(battalion => {
            addInfantryBattalion();
            const lastCard = $('#infantryBattalionsList .unit-form-card').last();
            Object.keys(battalion).forEach(key => {
                lastCard.find(`input[name="${key}"]`).val(battalion[key]);
            });
        });
    }

    function loadArmouredRegiments(regiments) {
        $('#armouredRegimentsList').empty();
        regiments.forEach(regiment => {
            addArmouredRegiment();
            const lastCard = $('#armouredRegimentsList .unit-form-card').last();
            Object.keys(regiment).forEach(key => {
                lastCard.find(`input[name="${key}"]`).val(regiment[key]);
            });
        });
    }

    function loadArtilleryRegiments(regiments) {
        $('#artilleryRegimentsList').empty();
        regiments.forEach(regiment => {
            addArtilleryRegiment();
            const lastCard = $('#artilleryRegimentsList .unit-form-card').last();
            Object.keys(regiment).forEach(key => {
                lastCard.find(`input[name="${key}"]`).val(regiment[key]);
            });
        });
    }
</script>
