@{
    ViewData["Title"] = "Token Management";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container-fluid">
    <div class="row">
        <div class="col-12">
            <div class="card">
                <div class="card-header d-flex align-items-center justify-content-between">
                    <h3 class="card-title mb-0">
                        <i class="fas fa-key"></i> Token Management
                    </h3>
                    <div class="card-tools d-flex gap-2">
                        <a type="button" class="btn btn-primary" asp-action="Create" asp-controller="AdminToken">
                            <i class="fas fa-plus"></i> New Token
                        </a>
                        <button type="button" class="btn btn-outline-secondary" id="refreshTokensBtn">
                            <i class="fas fa-sync"></i> Refresh
                        </button>
                    </div>
                </div>
                <div class="card-body">
                    <div class="table-responsive">
                        <table id="tokensTable" class="table table-bordered table-striped align-middle">
                            <thead>
                                <tr>
                                    <th>Name</th>
                                    <th>Category</th>
                                    <th>Group</th>
                                    <th>Status</th>
                                    <th>Manual?</th>
                                    <th>Last Used</th>
                                    <th>Usage</th>
                                    <th>Notes</th>
                                    <th style="width:180px">Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                <!-- Data will be loaded via JavaScript -->
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Create / Edit Token Modal -->
<div class="modal fade" id="createTokenModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="tokenModalTitle">New Token</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <form id="tokenForm">
                    <input type="hidden" id="tokenId" />
                    <div class="mb-3">
                        <label for="tokenName" class="form-label">Name *</label>
                        <input type="text" class="form-control" id="tokenName" maxlength="100" required>
                    </div>
                    <div class="mb-3">
                        <label for="tokenCategory" class="form-label">Category</label>
                        <input type="text" class="form-control" id="tokenCategory" maxlength="50">
                    </div>
                    <div class="mb-3">
                        <label for="tokenGroup" class="form-label">Token Group</label>
                        <select class="form-select" id="tokenGroup">
                            <!-- options loaded via JS -->
                        </select>
                        <div class="form-text">Optional: assign this token to a group.</div>
                    </div>
                    <div class="mb-3">
                        <label for="tokenDescription" class="form-label">Description</label>
                        <textarea class="form-control" id="tokenDescription" rows="3" maxlength="500"></textarea>
                    </div>
                    <div class="form-check mb-3">
                        <input class="form-check-input" type="checkbox" id="isManualToken">
                        <label class="form-check-label" for="isManualToken">Manual Token</label>
                    </div>
                    <div class="mb-3">
                        <label for="tokenNotes" class="form-label">Notes</label>
                        <textarea class="form-control" id="tokenNotes" rows="2" maxlength="1000"></textarea>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-primary" id="saveTokenBtn">
                    <i class="fas fa-save"></i> Save
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
                $(document).ready(function () {
                    loadTokens();
                    loadTokenGroups();

                    $('#refreshTokensBtn').on('click', loadTokens);
                    $('#saveTokenBtn').on('click', saveToken);
                });

                function loadTokens() {
                    debugger
                    $.get(getApiUrl('AdminToken', 'GetTokens'))
                        .done(function (tokens) {
                            const tbody = $('#tokensTable tbody');
                            tbody.empty();

                            if (!Array.isArray(tokens)) tokens = [];

                            tokens.forEach(function (t) {
                                const statusBadge = t.isActive
                                    ? '<span class="badge bg-success">Active</span>'
                                    : '<span class="badge bg-secondary">Inactive</span>';

                                const manualBadge = t.isManualToken
                                    ? '<span class="badge bg-info">Yes</span>'
                                    : '<span class="badge bg-light text-muted">No</span>';

                                const lastUsed = t.lastUsed
                                    ? new Date(t.lastUsed).toLocaleString()
                                    : '—';

                                const notes = t.notes ? $('<div>').text(t.notes).html() : '';

                                const row = `
                                    <tr>
                                        <td>${t.name}</td>
                                        <td>${t.category ?? ''}</td>
                                        <td>${t.tokenGroupName ?? ''}</td>
                                        <td>${statusBadge}</td>
                                        <td>${manualBadge}</td>
                                        <td>${lastUsed}</td>
                                        <td><span class="badge bg-primary">${t.usageCount ?? 0}</span></td>
                                        <td class="text-truncate" style="max-width: 240px;" title="${notes}">${notes}</td>
                                        <td>
                                            <div class="btn-group" role="group">
                                                <button class="btn btn-sm btn-outline-primary" onclick="openEditToken(${t.id})">
                                                    <i class="fas fa-edit"></i>
                                                </button>
                                                ${t.isActive
                                                    ? `<button class="btn btn-sm btn-outline-danger" onclick="toggleActive(${t.id}, false)"><i class=\"fas fa-ban\"></i></button>`
                                                    : `<button class="btn btn-sm btn-outline-success" onclick="toggleActive(${t.id}, true)"><i class=\"fas fa-check\"></i></button>`}
                                            </div>
                                        </td>
                                    </tr>`;

                                tbody.append(row);
                            });
                        })
                        .fail(function () {
                            showAlert('Error loading tokens', 'danger');
                        });
                }

                function loadTokenGroups() {
                    $.get(getApiUrl('AdminToken', 'Groups'))
                        .done(function (groups) {
                            const sel = $('#tokenGroup');
                            sel.empty();
                            sel.append('<option value="">-- None --</option>');
                            (groups || []).forEach(g => sel.append(`<option value="${g.id}">${g.name}</option>`));
                        })
                        .fail(function () { /* silent */ });
                }

                function saveToken() {
                    const id = $('#tokenId').val();
                    const payload = {
                        id: id ? Number(id) : null,
                        name: $('#tokenName').val(),
                        category: $('#tokenCategory').val(),
                        tokenGroupId: $('#tokenGroup').val() || null,
                        description: $('#tokenDescription').val(),
                        isManualToken: $('#isManualToken').is(':checked'),
                        notes: $('#tokenNotes').val()
                    };

                    const url = id ? getApiUrl('AdminToken', 'update') : getApiUrl('AdminToken', 'create');

                    postJson(url, payload)
                        .done(function (res) {
                            if (res.success) {
                                showAlert(res.message || 'Token saved', 'success');
                                $('#createTokenModal').modal('hide');
                                $('#tokenForm')[0].reset();
                                $('#tokenId').val('');
                                loadTokens();
                            } else {
                                showAlert(res.message || 'Unable to save token', 'danger');
                            }
                        })
                        .fail(function (xhr) {
                            const message = xhr.responseJSON?.message || 'Error saving token';
                            showAlert(message, 'danger');
                        });
                }

                function toggleActive(id, makeActive) {
                    const msg = makeActive
                        ? 'Activate this token?'
                        : 'Deactivate this token?';

                    if (!confirm(msg)) return;

                    postJson(getApiUrlWithParams('AdminToken', 'toggleActive', { id: id, active: makeActive }), {})
                        .done(function (res) {
                            if (res.success) {
                                showAlert(res.message || 'Status updated', 'success');
                                loadTokens();
                            } else {
                                showAlert(res.message || 'Unable to update status', 'danger');
                            }
                        })
                        .fail(function () {
                            showAlert('Error updating status', 'danger');
                        });
                }

                function openEditToken(id) {
                    $.get(getApiUrlWithParams('AdminToken', 'byId', { id }))
                        .done(function (t) {
                            if (!t) return;
                            $('#tokenModalTitle').text('Edit Token');
                            $('#tokenId').val(t.id);
                            $('#tokenName').val(t.name);
                            $('#tokenCategory').val(t.category ?? '');
                            $('#tokenGroup').val(t.tokenGroupId ?? '');
                            $('#tokenDescription').val(t.description ?? '');
                            $('#isManualToken').prop('checked', !!t.isManualToken);
                            $('#tokenNotes').val(t.notes ?? '');
                            const modal = new bootstrap.Modal(document.getElementById('createTokenModal'));
                            modal.show();
                        })
                        .fail(function () { showAlert('Error loading token', 'danger'); });
                }

                function getApiUrl(controller, action) {
            return `/${controller}/${action}`;
        }

        function getApiUrlWithParams(controller, action, params) {
            const query = new URLSearchParams(params).toString();
            return `/${controller}/${action}?${query}`;
        }

    </script>
}