@{
    ViewData["Title"] = "Admin Token Management";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container-fluid">
    <div class="row">
        <div class="col-12">
            <div class="card">
                <div class="card-header">
                    <h3 class="card-title">
                        <i class="fas fa-cogs"></i> Admin Token Management
                    </h3>
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-6">
                            <div class="card bg-primary text-white">
                                <div class="card-body">
                                    <div class="d-flex justify-content-between">
                                        <div>
                                            <h4 class="card-title">Token Groups</h4>
                                            <p class="card-text">Manage token groups and categories</p>
                                        </div>
                                        <div class="align-self-center">
                                            <i class="fas fa-layer-group fa-3x"></i>
                                        </div>
                                    </div>
                                    <a href="/AdminToken/ManageTokenGroups" class="btn btn-light">
                                        <i class="fas fa-arrow-right"></i> Manage Groups
                                    </a>
                                </div>
                            </div>
                        </div>
                        
                        <div class="col-md-6">
                            <div class="card bg-success text-white">
                                <div class="card-body">
                                    <div class="d-flex justify-content-between">
                                        <div>
                                            <h4 class="card-title">Create Token</h4>
                                            <p class="card-text">Create tokens for teams</p>
                                        </div>
                                        <div class="align-self-center">
                                            <i class="fas fa-plus-circle fa-3x"></i>
                                        </div>
                                    </div>
                                    <a href="/AdminToken/Create" class="btn btn-light">
                                        <i class="fas fa-arrow-right"></i> Create Token
                                    </a>
                                </div>
                            </div>
                        </div>
                    </div>
                    
                    <div class="row mt-4">
                        <div class="col-12">
                            <div class="card">
                                <div class="card-header">
                                    <h5 class="card-title">Quick Stats</h5>
                                </div>
                                <div class="card-body">
                                    <div class="row">
                                        <div class="col-md-3">
                                            <div class="text-center">
                                                <h3 class="text-primary" id="totalGroups">-</h3>
                                                <p>Total Groups</p>
                                            </div>
                                        </div>
                                        <div class="col-md-3">
                                            <div class="text-center">
                                                <h3 class="text-success" id="totalTokens">-</h3>
                                                <p>Total Tokens</p>
                                            </div>
                                        </div>
                                        <div class="col-md-3">
                                            <div class="text-center">
                                                <h3 class="text-info" id="activeTokens">-</h3>
                                                <p>Active Tokens</p>
                                            </div>
                                        </div>
                                        <div class="col-md-3">
                                            <div class="text-center">
                                                <h3 class="text-warning" id="manualTokens">-</h3>
                                                <p>Tokens</p>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function() {
            loadStats();
        });

        function loadStats() {
            // Load token groups count
            $.get(getApiUrl('AdminToken', 'groups'))
                .done(function(groups) {
                    $('#totalGroups').text(groups.length);
                })
                .fail(function() {
                    $('#totalGroups').text('0');
                });

            // Load teams count
            $.get(getApiUrl('AdminToken', 'teams'))
                .done(function(teams) {
                    // You can add more stats here based on your needs
                })
                .fail(function() {
                    // Handle error
                });
        }
    </script>
}
