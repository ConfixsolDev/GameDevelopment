@model TechWebSol.ViewModels.CreateTokenViewModel
@{
    ViewData["Title"] = "Create Token";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container-fluid">
    <div class="row">
        <div class="col-12">
            <div class="card">
                <div class="card-header">
                    <h3 class="card-title">
                        <i class="fas fa-plus-circle"></i> Create Token
                    </h3>
                    <div class="card-tools">
                        <a href="/AdminToken/ManageTokenGroups" class="btn btn-secondary">
                            <i class="fas fa-arrow-left"></i> Back to Group Management
                        </a>
                    </div>
                </div>
                <div class="card-body">
                    @if (TempData["SuccessMessage"] != null)
                    {
                        <div class="alert alert-success alert-dismissible fade show" role="alert">
                            <i class="fas fa-check-circle"></i> @TempData["SuccessMessage"]
                            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                        </div>
                    }

                    <div class="row">
                        <div class="col-md-8">
                            <form asp-action="Create" asp-controller="AdminToken" method="post" enctype="multipart/form-data">
                                @Html.AntiForgeryToken()
                                
                                <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>
                                
                                <div class="mb-3">
                                    <label asp-for="Name" class="form-label">Token Name</label>
                                    <input asp-for="Name" class="form-control" placeholder="Enter token name (e.g., Unit Alpha-1, Asset Beta-2)" />
                                    <span asp-validation-for="Name" class="text-danger"></span>
                                    <div class="form-text">Enter a descriptive name for the token</div>
                                </div>
                                
                                <div class="mb-3">
                                    <label asp-for="TokenGroupId" class="form-label">Token Group</label>
                                    <select asp-for="TokenGroupId" class="form-control" asp-items="@(new SelectList(Model.AvailableTokenGroups ?? new List<TechWebSol.Models.TokenGroup>(), "Id", "Name", Model.TokenGroupId))">
                                        <option value="">-- Select Group (Optional) --</option>
                                    </select>
                                    <span asp-validation-for="TokenGroupId" class="text-danger"></span>
                                    <div class="form-text">Assign to a specific group for organization</div>
                                </div>
                                
                                <div class="mb-3">
                                    <label asp-for="AssetImage" class="form-label">Token Image/Symbol</label>
                                    <input asp-for="AssetImage" class="form-control" type="file" accept="image/*" />
                                    <span asp-validation-for="AssetImage" class="text-danger"></span>
                                    <div class="form-text">Upload image or symbol for the token (PNG, JPG, GIF)</div>
                                </div>
                                
                                <div class="mb-3">
                                    <h5 class="mb-3">
                                        <i class="fas fa-crosshairs"></i> Coverage Configuration
                                    </h5>
                                    
                                    <!-- Oval coverage -->
                                    <div class="row">
                                        <div class="col-md-4">
                                            <div class="mb-3">
                                                <label asp-for="FrontCoverageKm" class="form-label">Front Coverage (km)</label>
                                                <input asp-for="FrontCoverageKm" class="form-control" type="number" step="0.1" min="0.1" max="1000" placeholder="e.g., 8.0" />
                                                <span asp-validation-for="FrontCoverageKm" class="text-danger"></span>
                                                <div class="form-text">Forward coverage distance</div>
                                            </div>
                                        </div>
                                        <div class="col-md-4">
                                            <div class="mb-3">
                                                <label asp-for="RearCoverageKm" class="form-label">Rear Coverage (km)</label>
                                                <input asp-for="RearCoverageKm" class="form-control" type="number" step="0.1" min="0.1" max="1000" placeholder="e.g., 3.0" />
                                                <span asp-validation-for="RearCoverageKm" class="text-danger"></span>
                                                <div class="form-text">Rearward coverage distance</div>
                                            </div>
                                        </div>
                                        <div class="col-md-4">
                                            <div class="mb-3">
                                                <label asp-for="SideCoverageKm" class="form-label">Side Coverage (km)</label>
                                                <input asp-for="SideCoverageKm" class="form-control" type="number" step="0.1" min="0.1" max="1000" placeholder="e.g., 5.0" />
                                                <span asp-validation-for="SideCoverageKm" class="text-danger"></span>
                                                <div class="form-text">Lateral coverage distance</div>
                                            </div>
                                        </div>
                                    </div>
                                    
                                    <div class="alert alert-info">
                                        <i class="fas fa-info-circle"></i>
                                        <strong>Oval Coverage:</strong> Creates an elliptical coverage area with different front/rear distances. 
                                        If only front and rear are specified, side coverage will be calculated automatically.
                                    </div>
                                </div>
                                
                                <div class="mb-3">
                                    <button type="submit" class="btn btn-primary">
                                        <i class="fas fa-save"></i> Create Token
                                    </button>
                                    <button type="button" class="btn btn-secondary" id="resetFormBtn">
                                        <i class="fas fa-undo"></i> Reset Form
                                    </button>
                                    <a href="@Url.Action("Index", "AdminToken")" class="btn btn-outline-secondary">
                                        <i class="fas fa-arrow-left"></i> Back to Dashboard
                                    </a>
                                </div>
                            </form>
                        </div>
                        
                        <div class="col-md-4">
                            <div class="card">
                                <div class="card-header">
                                    <h5 class="card-title">
                                        <i class="fas fa-info-circle"></i> Token Info
                                    </h5>
                                </div>
                                <div class="card-body">
                                    <p><strong>What is a Token?</strong></p>
                                    <p>A token is a digital representation on the map that can be:</p>
                                    <ul>
                                        <li>Positioned and moved on the tactical map</li>
                                        <li>Assigned coverage/operational areas</li>
                                        <li>Linked to detailed data entries later</li>
                                        <li>Organized into groups for better management</li>
                                    </ul>
                                    
                                    <hr>
                                    
                                    <p><strong>Two-Phase Approach:</strong></p>
                                    <ol>
                                        <li><strong>Create Token</strong> - Basic map representation (this form)</li>
                                        <li><strong>Add Data Entry</strong> - Detailed specifications (DroneUnit, VehicleUnit, etc.)</li>
                                    </ol>
                                    
                                    <p class="text-muted">This keeps the map simple while allowing detailed military data when needed.</p>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            // Reset form functionality
            const resetBtn = document.getElementById('resetFormBtn');
            if (resetBtn) {
                resetBtn.addEventListener('click', function() {
                    if (confirm('Are you sure you want to reset the form? All entered data will be lost.')) {
                        document.querySelector('form').reset();
                    }
                });
            }
        });
    </script>
}