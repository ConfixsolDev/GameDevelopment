@model TechWebSol.ViewModels.CreateTokenViewModel
@{
    ViewData["Title"] = "Create Token";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container-fluid">
    <div class="row">
        <div class="col-12">
            <div class="card">
                <div class="card-header">
                    <h3 class="card-title">
                        <i class="fas fa-plus-circle"></i> Create Token
                    </h3>
                    <div class="card-tools">
                        <a href="/AdminToken/ManageTokenGroups" class="btn btn-secondary">
                            <i class="fas fa-arrow-left"></i> Back to Group Management
                        </a>
                    </div>
                </div>
                <div class="card-body">
                    @if (TempData["SuccessMessage"] != null)
                    {
                        <div class="alert alert-success alert-dismissible fade show" role="alert">
                            <i class="fas fa-check-circle"></i> @TempData["SuccessMessage"]
                            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                        </div>
                    }

                    <div class="row">
                        <div class="col-md-8">
                            <form asp-action="Create" asp-controller="AdminToken" method="post">
                                @Html.AntiForgeryToken()
                                
                                <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>
                                
                                <div class="mb-3">
                                    <label asp-for="Name" class="form-label"></label>
                                    <input asp-for="Name" class="form-control" placeholder="Enter a descriptive name for the token" />
                                    <span asp-validation-for="Name" class="text-danger"></span>
                                    <div class="form-text">Enter a descriptive name for the token</div>
                                </div>
                                
                                <div class="mb-3">
                                    <label asp-for="Description" class="form-label"></label>
                                    <textarea asp-for="Description" class="form-control" rows="3" placeholder="Optional description of the token's purpose"></textarea>
                                    <span asp-validation-for="Description" class="text-danger"></span>
                                    <div class="form-text">Optional description of the token's purpose</div>
                                </div>
                                
                                <div class="mb-3">
                                    <label asp-for="Category" class="form-label"></label>
                                    <input asp-for="Category" class="form-control" placeholder="e.g., Vehicle, Equipment, Personnel" />
                                    <span asp-validation-for="Category" class="text-danger"></span>
                                    <div class="form-text">Optional category to help organize tokens</div>
                                </div>
                                
                                <div class="mb-3">
                                    <label asp-for="TokenGroupId" class="form-label"></label>
                                    <select asp-for="TokenGroupId" class="form-control" asp-items="@(new SelectList(Model.AvailableTokenGroups ?? new List<TechWebSol.Models.TokenGroup>(), "Id", "Name", Model.TokenGroupId))">
                                        <option value="">-- Select Group (Optional) --</option>
                                    </select>
                                    <span asp-validation-for="TokenGroupId" class="text-danger"></span>
                                    <div class="form-text">Assign this token to a specific group for better organization</div>
                                </div>
                                
                                <div class="mb-3">
                                    <button type="submit" class="btn btn-primary">
                                        <i class="fas fa-save"></i> Create Token
                                    </button>
                                    <button type="button" class="btn btn-secondary" id="resetFormBtn">
                                        <i class="fas fa-undo"></i> Reset Form
                                    </button>
                                    <a href="@Url.Action("Index", "AdminToken")" class="btn btn-outline-secondary">
                                        <i class="fas fa-arrow-left"></i> Back to Dashboard
                                    </a>
                                </div>
                            </form>
                        </div>
                        
                        <div class="col-md-4">
                            <div class="card">
                                <div class="card-header">
                                    <h5 class="card-title">
                                        <i class="fas fa-info-circle"></i> Token Info
                                    </h5>
                                </div>
                                <div class="card-body">
                                    <p><strong>What is a Token?</strong></p>
                                    <p>A token is a digital entity that exists in the system and can be:</p>
                                    <ul>
                                        <li>Created by administrators</li>
                                        <li>Assigned to token groups</li>
                                        <li>Converted to physical tokens later by adding touch data</li>
                                        <li>Used for planning and organization</li>
                                    </ul>
                                    
                                    <hr>
                                    
                                    <p><strong>Token Groups:</strong></p>
                                    <p>Token groups help organize tokens by:</p>
                                    <ul>
                                        <li>Company (e.g., "Company A")</li>
                                        <li>Brigade (e.g., "Brigade 1")</li>
                                        <li>Department (e.g., "Department Alpha")</li>
                                        <li>Unit (e.g., "Unit Bravo")</li>
                                    </ul>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            // Reset form functionality
            const resetBtn = document.getElementById('resetFormBtn');
            if (resetBtn) {
                resetBtn.addEventListener('click', function() {
                    if (confirm('Are you sure you want to reset the form? All entered data will be lost.')) {
                        document.querySelector('form').reset();
                    }
                });
            }
        });
    </script>
}

