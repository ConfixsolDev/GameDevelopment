@{
    ViewData["Title"] = "Token Group Management";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container-fluid">
    <div class="row">
        <div class="col-12">
            <div class="card">
                <div class="card-header">
                    <h3 class="card-title">
                        <i class="fas fa-layer-group"></i> Token Group Management
                    </h3>
                    <div class="card-tools">
                        <button type="button" class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#createGroupModal">
                            <i class="fas fa-plus"></i> Create New Group
                        </button>
                    </div>
                </div>
                <div class="card-body">
                    <div class="table-responsive">
                        <table id="tokenGroupsTable" class="table table-bordered table-striped">
                            <thead>
                                <tr>
                                    <th>Name</th>
                                    <th>Code</th>
                                    <th>Category</th>
                                    <th>Description</th>
                                    <th>Token Count</th>
                                    <th>Created By</th>
                                    <th>Created At</th>
                                    <th>Status</th>
                                    <th>Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                <!-- Data will be loaded via JavaScript -->
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Assignment Management Section -->
    <div class="row mt-4">
        <div class="col-12">
            <div class="card">
                <div class="card-header">
                    <h3 class="card-title">
                        <i class="fas fa-users"></i> Team Assignments
                    </h3>
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-6">
                            <label for="groupSelect">Select Token Group:</label>
                            <select id="groupSelect" class="form-control">
                                <option value="">-- Select Group --</option>
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label for="teamSelect">Select Team:</label>
                            <select id="teamSelect" class="form-control">
                                <option value="">-- Select Team --</option>
                            </select>
                        </div>
                    </div>
                    <div class="row mt-3">
                        <div class="col-12">
                            <button type="button" class="btn btn-success" id="assignGroupBtn">
                                <i class="fas fa-link"></i> Assign Group to Team
                            </button>
                        </div>
                    </div>
                    <div class="row mt-3">
                        <div class="col-12">
                            <h5>Current Assignments:</h5>
                            <div id="assignmentsList">
                                <!-- Assignments will be loaded here -->
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Create Group Modal -->
<div class="modal fade" id="createGroupModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Create Token Group</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <form id="createGroupForm">
                    <div class="mb-3">
                        <label for="groupName" class="form-label">Group Name *</label>
                        <input type="text" class="form-control" id="groupName" required>
                    </div>
                    <div class="mb-3">
                        <label for="groupCode" class="form-label">Group Code *</label>
                        <input type="text" class="form-control" id="groupCode" required>
                        <div class="form-text">Unique identifier (e.g., COMP_A, BRIG_1)</div>
                    </div>
                    <div class="mb-3">
                        <label for="groupCategory" class="form-label">Category</label>
                        <select class="form-control" id="groupCategory">
                            <option value="">-- Select Category --</option>
                            <option value="Company">Company</option>
                            <option value="Brigade">Brigade</option>
                            <option value="Department">Department</option>
                            <option value="Unit">Unit</option>
                        </select>
                    </div>
                    <div class="mb-3">
                        <label for="groupDescription" class="form-label">Description</label>
                        <textarea class="form-control" id="groupDescription" rows="3"></textarea>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-primary" id="saveGroupBtn">Create Group</button>
            </div>
        </div>
    </div>
</div>

<!-- Manual Token Creation Modal -->
<div class="modal fade" id="createManualTokenModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Create Manual Token</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <form id="createManualTokenForm">
                    <div class="mb-3">
                        <label for="tokenName" class="form-label">Token Name *</label>
                        <input type="text" class="form-control" id="tokenName" required>
                    </div>
                    <div class="mb-3">
                        <label for="tokenDescription" class="form-label">Description</label>
                        <textarea class="form-control" id="tokenDescription" rows="3"></textarea>
                    </div>
                    <div class="mb-3">
                        <label for="tokenCategory" class="form-label">Category</label>
                        <input type="text" class="form-control" id="tokenCategory">
                    </div>
                    <div class="mb-3">
                        <label for="tokenGroupSelect" class="form-label">Token Group</label>
                        <select class="form-control" id="tokenGroupSelect">
                            <option value="">-- Select Group (Optional) --</option>
                        </select>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-primary" id="saveManualTokenBtn">Create Token</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function() {
            loadTokenGroups();
            loadTeams();
            loadGroupsForDropdown();

            // Create Group functionality
            $('#saveGroupBtn').click(function() {
                createTokenGroup();
            });

            // Assign Group functionality
            $('#assignGroupBtn').click(function() {
                assignGroupToTeam();
            });

            // Create Manual Token functionality
            $('#saveManualTokenBtn').click(function() {
                createManualToken();
            });

            // Show manual token creation modal
            $(document).on('click', '.create-manual-token', function() {
                $('#createManualTokenModal').modal('show');
            });
        });

        function loadTokenGroups() {
            $.get('/api/admin/AdminToken/groups')
                .done(function(groups) {
                    const tbody = $('#tokenGroupsTable tbody');
                    tbody.empty();
                    
                    groups.forEach(function(group) {
                        const row = `
                            <tr>
                                <td>${group.name}</td>
                                <td><span class="badge bg-info">${group.groupCode}</span></td>
                                <td>${group.category || 'N/A'}</td>
                                <td>${group.description || 'N/A'}</td>
                                <td><span class="badge bg-success">${group.tokenCount}</span></td>
                                <td>${group.createdByUserName || 'N/A'}</td>
                                <td>${new Date(group.createdAt).toLocaleDateString()}</td>
                                <td>${group.isActive ? '<span class="badge bg-success">Active</span>' : '<span class="badge bg-danger">Inactive</span>'}</td>
                                <td>
                                    <button class="btn btn-sm btn-info create-manual-token" data-group-id="${group.id}">
                                        <i class="fas fa-plus"></i> Add Token
                                    </button>
                                    <button class="btn btn-sm btn-warning" onclick="viewAssignments(${group.id})">
                                        <i class="fas fa-users"></i> Assignments
                                    </button>
                                </td>
                            </tr>
                        `;
                        tbody.append(row);
                    });
                })
                .fail(function() {
                    showAlert('Error loading token groups', 'danger');
                });
        }

        function loadTeams() {
            $.get('/api/admin/AdminToken/teams')
                .done(function(teams) {
                    const select = $('#teamSelect');
                    select.empty().append('<option value="">-- Select Team --</option>');
                    
                    teams.forEach(function(team) {
                        select.append(`<option value="${team.teamId}">${team.teamName} (${team.memberCount} members)</option>`);
                    });
                })
                .fail(function() {
                    showAlert('Error loading teams', 'danger');
                });
        }

        function loadGroupsForDropdown() {
            $.get('/api/admin/AdminToken/groups')
                .done(function(groups) {
                    const select = $('#groupSelect');
                    select.empty().append('<option value="">-- Select Group --</option>');
                    
                    groups.forEach(function(group) {
                        select.append(`<option value="${group.id}">${group.name} (${group.groupCode})</option>`);
                    });

                    // Also populate manual token group dropdown
                    const tokenGroupSelect = $('#tokenGroupSelect');
                    tokenGroupSelect.empty().append('<option value="">-- Select Group (Optional) --</option>');
                    
                    groups.forEach(function(group) {
                        tokenGroupSelect.append(`<option value="${group.id}">${group.name} (${group.groupCode})</option>`);
                    });
                })
                .fail(function() {
                    showAlert('Error loading groups', 'danger');
                });
        }

        function createTokenGroup() {
            const data = {
                name: $('#groupName').val(),
                groupCode: $('#groupCode').val(),
                category: $('#groupCategory').val(),
                description: $('#groupDescription').val()
            };

            $.post('/api/admin/AdminToken/create-group', data)
                .done(function(response) {
                    if (response.success) {
                        showAlert('Token group created successfully', 'success');
                        $('#createGroupModal').modal('hide');
                        $('#createGroupForm')[0].reset();
                        loadTokenGroups();
                        loadGroupsForDropdown();
                    } else {
                        showAlert(response.message, 'danger');
                    }
                })
                .fail(function(xhr) {
                    const message = xhr.responseJSON?.message || 'Error creating token group';
                    showAlert(message, 'danger');
                });
        }

        function assignGroupToTeam() {
            const groupId = $('#groupSelect').val();
            const teamId = $('#teamSelect').val();

            if (!groupId || !teamId) {
                showAlert('Please select both group and team', 'warning');
                return;
            }

            const data = {
                tokenGroupId: parseInt(groupId),
                teamId: teamId
            };

            $.post('/api/admin/AdminToken/assign-group-to-team', data)
                .done(function(response) {
                    if (response.success) {
                        showAlert('Group assigned to team successfully', 'success');
                        $('#groupSelect').val('');
                        $('#teamSelect').val('');
                        viewAssignments(groupId);
                    } else {
                        showAlert(response.message, 'danger');
                    }
                })
                .fail(function(xhr) {
                    const message = xhr.responseJSON?.message || 'Error assigning group to team';
                    showAlert(message, 'danger');
                });
        }

        function createManualToken() {
            const data = {
                name: $('#tokenName').val(),
                description: $('#tokenDescription').val(),
                category: $('#tokenCategory').val(),
                tokenGroupId: $('#tokenGroupSelect').val() ? parseInt($('#tokenGroupSelect').val()) : null
            };

            $.post('/api/admin/AdminToken/create-manual-token', data)
                .done(function(response) {
                    if (response.success) {
                        showAlert('Manual token created successfully', 'success');
                        $('#createManualTokenModal').modal('hide');
                        $('#createManualTokenForm')[0].reset();
                        loadTokenGroups();
                    } else {
                        showAlert(response.message, 'danger');
                    }
                })
                .fail(function(xhr) {
                    const message = xhr.responseJSON?.message || 'Error creating manual token';
                    showAlert(message, 'danger');
                });
        }

        function viewAssignments(groupId) {
            $.get(`/api/admin/AdminToken/group-assignments/${groupId}`)
                .done(function(assignments) {
                    const container = $('#assignmentsList');
                    container.empty();
                    
                    if (assignments.length === 0) {
                        container.html('<p class="text-muted">No assignments found for this group.</p>');
                        return;
                    }

                    assignments.forEach(function(assignment) {
                        const assignmentDiv = `
                            <div class="card mb-2">
                                <div class="card-body py-2">
                                    <div class="row">
                                        <div class="col-md-6">
                                            <strong>Team:</strong> ${assignment.teamId}
                                        </div>
                                        <div class="col-md-4">
                                            <strong>Assigned:</strong> ${new Date(assignment.assignedAt).toLocaleDateString()}
                                        </div>
                                        <div class="col-md-2">
                                            <button class="btn btn-sm btn-danger" onclick="removeAssignment(${assignment.id})">
                                                <i class="fas fa-trash"></i> Remove
                                            </button>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        `;
                        container.append(assignmentDiv);
                    });
                })
                .fail(function() {
                    showAlert('Error loading assignments', 'danger');
                });
        }

        function removeAssignment(assignmentId) {
            if (confirm('Are you sure you want to remove this assignment?')) {
                $.ajax({
                    url: `/api/admin/AdminToken/remove-assignment/${assignmentId}`,
                    type: 'DELETE'
                })
                .done(function(response) {
                    if (response.success) {
                        showAlert('Assignment removed successfully', 'success');
                        const groupId = $('#groupSelect').val();
                        if (groupId) {
                            viewAssignments(groupId);
                        }
                    } else {
                        showAlert(response.message, 'danger');
                    }
                })
                .fail(function() {
                    showAlert('Error removing assignment', 'danger');
                });
            }
        }

        function showAlert(message, type) {
            const alertDiv = `
                <div class="alert alert-${type} alert-dismissible fade show" role="alert">
                    ${message}
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            `;
            $('.container-fluid').prepend(alertDiv);
            
            // Auto-remove after 5 seconds
            setTimeout(function() {
                $('.alert').fadeOut();
            }, 5000);
        }
    </script>
}
