@model TechWebSol.ViewModels.TokenGroupIndexViewModel
@{
    ViewData["Title"] = "Token Group Management";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container-fluid">
    <div class="row">
        <div class="col-12">
            <div class="card">
                <div class="card-header">
                    <h3 class="card-title">
                        <i class="fas fa-layer-group"></i> Token Group Management
                    </h3>
                    <div class="card-tools">
                        <a href="@Url.Action("CreateTokenGroup", "AdminToken")" class="btn btn-primary">
                            <i class="fas fa-plus"></i> Create New Group
                        </a>
                    </div>
                </div>
                <div class="card-body">
                    @if (TempData["SuccessMessage"] != null)
                    {
                        <div class="alert alert-success alert-dismissible fade show" role="alert">
                            <i class="fas fa-check-circle"></i> @TempData["SuccessMessage"]
                            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                        </div>
                    }
                    
                    @if (TempData["ErrorMessage"] != null)
                    {
                        <div class="alert alert-danger alert-dismissible fade show" role="alert">
                            <i class="fas fa-exclamation-circle"></i> @TempData["ErrorMessage"]
                            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                        </div>
                    }

                    <!-- Search and Filter Section -->
                    <div class="row mb-3">
                        <div class="col-12">
                            <form method="get" class="row g-3">
                                <div class="col-md-4">
                                    <label for="searchTerm" class="form-label">Search</label>
                                    <input type="text" class="form-control" id="searchTerm" name="searchTerm" 
                                           value="@Model.SearchTerm" placeholder="Search by name, code, or description">
                                </div>
                                <div class="col-md-3">
                                    <label for="categoryFilter" class="form-label">Category</label>
                                    <select class="form-control" id="categoryFilter" name="categoryFilter">
                                        <option value="">All Categories</option>
                                        @foreach (var category in Model.AvailableCategories)
                                        {
                                            <option value="@category" selected="@(Model.CategoryFilter == category)">@category</option>
                                        }
                                    </select>
                                </div>
                                <div class="col-md-3">
                                    <label for="statusFilter" class="form-label">Status</label>
                                    <select class="form-control" id="statusFilter" name="statusFilter">
                                        <option value="">All Status</option>
                                        <option value="true" selected="@(Model.StatusFilter == true)">Active</option>
                                        <option value="false" selected="@(Model.StatusFilter == false)">Inactive</option>
                                    </select>
                                </div>
                                <div class="col-md-2">
                                    <label class="form-label">&nbsp;</label>
                                    <div class="d-grid">
                                        <button type="submit" class="btn btn-outline-primary">
                                            <i class="fas fa-search"></i> Search
                                        </button>
                                    </div>
                                </div>
                            </form>
                        </div>
                    </div>

                    <!-- Token Groups Table -->
                    <div class="table-responsive">
                        <table class="table table-bordered table-striped">
                            <thead>
                                <tr>
                                    <th>Name</th>
                                    <th>Code</th>
                                    <th>Category</th>
                                    <th>Description</th>
                                    <th>Token Count</th>
                                    <th>Team Assignments</th>
                                    <th>Created By</th>
                                    <th>Created At</th>
                                    <th>Status</th>
                                    <th>Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (Model.TokenGroups.Any())
                                {
                                    @foreach (var group in Model.TokenGroups)
                                    {
                                        <tr>
                                            <td>
                                                <strong>@group.Name</strong>
                                            </td>
                                            <td>
                                                <span class="badge bg-info">@group.GroupCode</span>
                                            </td>
                                            <td>@(group.Category ?? "N/A")</td>
                                            <td>@(group.Description ?? "N/A")</td>
                                            <td>
                                                <span class="badge bg-success">@group.TokenCount</span>
                                            </td>
                                            <td>
                                                <span class="badge bg-primary">@group.TeamAssignmentCount</span>
                                            </td>
                                            <td>@(group.CreatedByUserName ?? "N/A")</td>
                                            <td>@group.CreatedAt.ToString("MMM dd, yyyy")</td>
                                            <td>
                                                @if (group.IsActive)
                                                {
                                                    <span class="badge bg-success">Active</span>
                                                }
                                                else
                                                {
                                                    <span class="badge bg-danger">Inactive</span>
                                                }
                                            </td>
                                            <td>
                                                <div class="btn-group" role="group">
                                                    <a href="@Url.Action("TokenGroupDetails", "AdminToken", new { id = group.Id })" 
                                                       class="btn btn-sm btn-info" title="View Details">
                                                        <i class="fas fa-eye"></i>
                                                    </a>
                                                    <a href="@Url.Action("EditTokenGroup", "AdminToken", new { id = group.Id })" 
                                                       class="btn btn-sm btn-warning" title="Edit">
                                                        <i class="fas fa-edit"></i>
                                                    </a>
                                                    <form method="post" action="@Url.Action("DeleteTokenGroup", "AdminToken")" 
                                                          class="d-inline" onsubmit="return confirm('Are you sure you want to delete this token group?');">
                                                        @Html.AntiForgeryToken()
                                                        <input type="hidden" name="id" value="@group.Id" />
                                                        <button type="submit" class="btn btn-sm btn-danger" title="Delete">
                                                            <i class="fas fa-trash"></i>
                                                        </button>
                                                    </form>
                                                </div>
                                            </td>
                                        </tr>
                                    }
                                }
                                else
                                {
                                    <tr>
                                        <td colspan="10" class="text-center text-muted">
                                            <i class="fas fa-info-circle"></i> No token groups found.
                                            <a href="@Url.Action("CreateTokenGroup", "AdminToken")" class="btn btn-link">Create your first token group</a>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>

                    <!-- Summary Information -->
                    @if (Model.TokenGroups.Any())
                    {
                        <div class="row mt-3">
                            <div class="col-12">
                                <div class="alert alert-info">
                                    <i class="fas fa-info-circle"></i>
                                    <strong>Summary:</strong> 
                                    @Model.TokenGroups.Count token group(s) found
                                    (@Model.TokenGroups.Count(g => g.IsActive) active, 
                                    @Model.TokenGroups.Count(g => !g.IsActive) inactive)
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            // Auto-submit form on filter change
            const filterSelects = document.querySelectorAll('#categoryFilter, #statusFilter');
            filterSelects.forEach(select => {
                select.addEventListener('change', function() {
                    this.form.submit();
                });
            });
        });
    </script>
}