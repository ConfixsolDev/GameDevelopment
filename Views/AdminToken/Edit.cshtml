@model TechWebSol.ViewModels.CreateTokenViewModel
@{
    ViewData["Title"] = "Edit Token";
    var tokenId = ViewData["TokenId"];
    var currentImagePath = ViewData["CurrentImagePath"] as string;
}

<div class="container-fluid">
    <div class="row">
        <div class="col-12">
            <div class="card">
                <div class="card-header">
                    <h3 class="card-title">
                        <i class="fas fa-edit"></i> Edit Token: @Model.Name
                    </h3>
                    <div class="card-tools">
                        <a href="/AdminToken/Index" class="btn btn-secondary">
                            <i class="fas fa-arrow-left"></i> Back to Token List
                        </a>
                    </div>
                </div>
                <div class="card-body">
                    @if (TempData["SuccessMessage"] != null)
                    {
                        <div class="alert alert-success alert-dismissible fade show" role="alert">
                            <i class="fas fa-check-circle"></i> @TempData["SuccessMessage"]
                            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                        </div>
                    }

                    @if (TempData["ErrorMessage"] != null)
                    {
                        <div class="alert alert-danger alert-dismissible fade show" role="alert">
                            <i class="fas fa-exclamation-circle"></i> @TempData["ErrorMessage"]
                            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                        </div>
                    }

                    <div class="row">
                        <div class="col-md-8">
                            <form asp-action="Edit" asp-controller="AdminToken" asp-route-id="@tokenId" method="post" >
                                @Html.AntiForgeryToken()
                                
                                <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>
                                
                                <div class="mb-3">
                                    <label asp-for="Name" class="form-label">Token Name</label>
                                    <input asp-for="Name" class="form-control" placeholder="Enter token name (e.g., Unit Alpha-1, Asset Beta-2)" />
                                    <span asp-validation-for="Name" class="text-danger"></span>
                                    <div class="form-text">Enter a descriptive name for the token</div>
                                </div>
                                
                                <div class="mb-3">
                                    <label asp-for="TokenGroupId" class="form-label">Token Group</label>
                                    <select asp-for="TokenGroupId" class="form-control" asp-items="@(new SelectList(Model.AvailableTokenGroups ?? new List<TechWebSol.Models.TokenGroup>(), "Id", "Name", Model.TokenGroupId))">
                                        <option value="">-- Select Group (Optional) --</option>
                                    </select>
                                    <span asp-validation-for="TokenGroupId" class="text-danger"></span>
                                    <div class="form-text">Assign to a specific group for organization</div>
                                </div>

                                <!-- Military Unit Classification -->
                                <div class="mb-3">
                                    <h5 class="mb-3">
                                        <i class="fas fa-flag"></i> Military Unit Classification
                                    </h5>
                                    
                                    <div class="row">
                                        <div class="col-md-4">
                                            <div class="mb-3">
                                                <label asp-for="OrganizationLevel" class="form-label">Organization Level</label>
                                                <select asp-for="OrganizationLevel" class="form-control">
                                                    <option value="">-- Select Level --</option>
                                                    <option value="1">Squad (8-13 personnel)</option>
                                                    <option value="2">Platoon (26-64 personnel)</option>
                                                    <option value="3">Company (80-250 personnel)</option>
                                                    <option value="4">Battalion (300-1,000 personnel)</option>
                                                    <option value="5">Regiment (1,000-3,000 personnel)</option>
                                                    <option value="6">Brigade (3,000-5,000 personnel)</option>
                                                    <option value="7">Division (10,000-25,000 personnel)</option>
                                                    <option value="8">Corps (20,000-45,000 personnel)</option>
                                                    <option value="9">Army (50,000+ personnel)</option>
                                                </select>
                                                <span asp-validation-for="OrganizationLevel" class="text-danger"></span>
                                                <div class="form-text">Unit size/hierarchy level</div>
                                            </div>
                                        </div>
                                        <div class="col-md-4">
                                            <div class="mb-3">
                                                <label asp-for="UnitType" class="form-label">Unit Type</label>
                                                <select asp-for="UnitType" class="form-control">
                                                    <option value="">-- Select Type --</option>
                                                    <option value="0">Infantry</option>
                                                    <option value="1">Armoured</option>
                                                    <option value="2">Mechanized</option>
                                                    <option value="3">Artillery</option>
                                                    <option value="4">Aviation</option>
                                                    <option value="5">Air Defense</option>
                                                    <option value="6">Engineers</option>
                                                    <option value="7">Signals</option>
                                                    <option value="8">Logistics</option>
                                                    <option value="9">Medical</option>
                                                    <option value="10">Reconnaissance</option>
                                                    <option value="11">Special Forces</option>
                                                    <option value="12">Airborne/Paratroop</option>
                                                    <option value="13">Marines</option>
                                                    <option value="14">Cavalry</option>
                                                    <option value="15">Headquarters/Command</option>
                                                    <option value="16">Intelligence</option>
                                                    <option value="17">Military Police</option>
                                                    <option value="18">CBRN</option>
                                                    <option value="19">Maintenance</option>
                                                    <option value="20">Cyber</option>
                                                </select>
                                                <span asp-validation-for="UnitType" class="text-danger"></span>
                                                <div class="form-text">Functional unit type</div>
                                            </div>
                                        </div>
                                        <div class="col-md-4">
                                            <div class="mb-3">
                                                <label asp-for="UnitDesignation" class="form-label">Unit Designation</label>
                                                <input asp-for="UnitDesignation" class="form-control" placeholder="e.g., 29, Alpha, 1st" />
                                                <span asp-validation-for="UnitDesignation" class="text-danger"></span>
                                                <div class="form-text">Unit number or identifier</div>
                                            </div>
                                        </div>
                                    </div>
                                    
                                    <div class="row">
                                        <div class="col-md-6">
                                            <div class="mb-3">
                                                <label asp-for="ForceType" class="form-label">Force Type</label>
                                                <select asp-for="ForceType" class="form-control">
                                                    <option value="">-- Select Force Type --</option>
                                                    <option value="Friendly">Friendly (Blue)</option>
                                                    <option value="Hostile">Hostile (Red)</option>
                                                    <option value="Neutral">Neutral (Green)</option>
                                                    <option value="Unknown">Unknown (Yellow)</option>
                                                </select>
                                                <span asp-validation-for="ForceType" class="text-danger"></span>
                                                <div class="form-text">Force affiliation for color coding</div>
                                            </div>
                                        </div>
                                    </div>
                                    
                                    <div class="alert alert-info">
                                        <i class="fas fa-info-circle"></i>
                                        <strong>Military Classification:</strong> These fields determine how the token appears on the map as a professional military symbol. 
                                        Leave empty for simple token display.
                                    </div>
                                </div>
                                
                                <div class="mb-3">
                                    <label asp-for="AssetImage" class="form-label">Token Image/Symbol</label>
                                    
                                    @if (!string.IsNullOrEmpty(currentImagePath))
                                    {
                                        <div class="mb-2">
                                            <small class="text-muted">Current image:</small><br>
                                            <img src="@currentImagePath" alt="Current token image" class="img-thumbnail token-current-image">
                                        </div>
                                    }
                                    
                                    <input asp-for="AssetImage" class="form-control" type="file" accept="image/*" />
                                    <span asp-validation-for="AssetImage" class="text-danger"></span>
                                    <div class="form-text">
                                        Upload new image or symbol for the token (PNG, JPG, GIF). 
                                        @if (!string.IsNullOrEmpty(currentImagePath))
                                        {
                                            <span>Leave empty to keep current image.</span>
                                        }
                                    </div>
                                </div>
                                
                                <div class="mb-3">
                                    <h5 class="mb-3">
                                        <i class="fas fa-crosshairs"></i> Coverage Configuration
                                    </h5>
                                    
                                    <!-- Oval coverage -->
                                    <div class="row">
                                        <div class="col-md-4">
                                            <div class="mb-3">
                                                <label asp-for="FrontCoverageKm" class="form-label">Front Coverage (km)</label>
                                                <input asp-for="FrontCoverageKm" class="form-control" type="number" step="0.1" min="0.1" max="1000" placeholder="e.g., 8.0" />
                                                <span asp-validation-for="FrontCoverageKm" class="text-danger"></span>
                                                <div class="form-text">Forward coverage distance</div>
                                            </div>
                                        </div>
                                        <div class="col-md-4">
                                            <div class="mb-3">
                                                <label asp-for="RearCoverageKm" class="form-label">Rear Coverage (km)</label>
                                                <input asp-for="RearCoverageKm" class="form-control" type="number" step="0.1" min="0.1" max="1000" placeholder="e.g., 3.0" />
                                                <span asp-validation-for="RearCoverageKm" class="text-danger"></span>
                                                <div class="form-text">Rearward coverage distance</div>
                                            </div>
                                        </div>
                                        <div class="col-md-4">
                                            <div class="mb-3">
                                                <label asp-for="SideCoverageKm" class="form-label">Side Coverage (km)</label>
                                                <input asp-for="SideCoverageKm" class="form-control" type="number" step="0.1" min="0.1" max="1000" placeholder="e.g., 5.0" />
                                                <span asp-validation-for="SideCoverageKm" class="text-danger"></span>
                                                <div class="form-text">Lateral coverage distance</div>
                                            </div>
                                        </div>
                                    </div>
                                    
                                    <div class="alert alert-info">
                                        <i class="fas fa-info-circle"></i>
                                        <strong>Oval Coverage:</strong> Creates an elliptical coverage area with different front/rear distances. 
                                        If only front and rear are specified, side coverage will be calculated automatically.
                                    </div>
                                </div>
                                
                                <div class="mb-3">
                                    <button type="submit" class="btn btn-primary">
                                        <i class="fas fa-save"></i> Update Token
                                    </button>
                                    <button type="button" class="btn btn-warning" id="resetFormBtn">
                                        <i class="fas fa-undo"></i> Reset Changes
                                    </button>
                                </div>
                            </form>
                        </div>
                        
                        <div class="col-md-4">
                            <div class="card">
                                <div class="card-header">
                                    <h5 class="card-title">
                                        <i class="fas fa-info-circle"></i> Edit Token
                                    </h5>
                                </div>
                                <div class="card-body">
                                    <p><strong>What you can edit:</strong></p>
                                    <ul>
                                        <li><strong>Name</strong> - Update the token display name</li>
                                        <li><strong>Group</strong> - Change token organization</li>
                                        <li><strong>Military Classification</strong> - Organization level, unit type, designation, and force type</li>
                                        <li><strong>Image</strong> - Replace the token symbol/image</li>
                                        <li><strong>Coverage</strong> - Adjust operational radius</li>
                                        <li><strong>Position</strong> - Update current coordinates</li>
                                    </ul>
                                    
                                    <hr>
                                    
                                    <p><strong>Position & Coverage Updates:</strong></p>
                                    <p class="text-muted small">When you change the position or coverage radius, the system will automatically update the token's operational area on the map.</p>
                                    
                                    <hr>
                                    
                                    <p><strong>Image Replacement:</strong></p>
                                    <p class="text-muted small">Uploading a new image will replace the current one. Leave the image field empty to keep the existing image.</p>
                                </div>
                            </div>

                            @if (!string.IsNullOrEmpty(currentImagePath))
                            {
                                <div class="card mt-3">
                                    <div class="card-header">
                                        <h5 class="card-title">
                                            <i class="fas fa-image"></i> Current Image
                                        </h5>
                                    </div>
                                    <div class="card-body text-center">
                                        <img src="@currentImagePath" alt="@Model.Name" class="img-fluid token-preview-image">
                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
} 
    
