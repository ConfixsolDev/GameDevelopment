    height: 40px;
    border-radius: 6px;
    background: linear-gradient(135deg, #2196f3 0%, #1976d2 100%);
    display: flex;
    align-items: center;
    justify-content: center;
    color: white;
    font-size: 18px;
    font-weight: bold;
}

.token-title-section {
    flex: 1;
    min-width: 0;
}

.token-name {
    margin: 0;
    font-size: 16px;
