// Load brigade units list using GET endpoints (Index page pattern)
function loadBrigadeUnits(brigadeId, unitType) {
    console.log('🔄 Loading brigade units:', unitType, 'for brigade:', brigadeId);
    showLoader();
    
    let endpoint = '';
    let listId = '';
    
    switch(unitType.toString().toLowerCase()) {
        case 'infantry':
            endpoint = '/DataManagement/GetInfantryBattalions';
            listId = '#infantry-units-list';
            break;
        case 'armoured':
            endpoint = '/DataManagement/GetArmouredRegiments';
            listId = '#armoured-units-list';
            break;
        case 'artillery':
            endpoint = '/DataManagement/GetArtilleryRegiments';
            listId = '#artillery-units-list';
            break;
        case 'recon':
            endpoint = '/DataManagement/GetReconUnits';
            listId = '#recon-units-list';
            break;
        case 'logistics':
            endpoint = '/DataManagement/GetLogisticsUnits';
            listId = '#logistics-units-list';
            break;
        case 'engineering':
            endpoint = '/DataManagement/GetEngineeringCompanies';
            listId = '#engineering-units-list';
            break;
        default:
            console.error('❌ Unknown unit type:', unitType);
            hideLoader();
            return;
    }
    
    $.get(endpoint, { brigadeId: brigadeId })
        .done(function(data) {
            console.log('✅ Received units data:', data.length, 'units');
            renderBrigadeUnitsList(data, unitType, listId);
            hideLoader();
        })
        .fail(function(xhr, status, error) {
            console.error('❌ Error loading units:', error);
            $(listId).html('<div class="no-units-message text-danger">Failed to load units. Please try again.</div>');
            hideLoader();
        });
}

// Render the brigade units list HTML
function renderBrigadeUnitsList(units, unitType, listId) {
    const container = $(listId);
    container.empty();
    
    if (!units || units.length === 0) {
        let unitTypeName = '';
        switch(unitType.toString().toLowerCase()) {
            case 'infantry': unitTypeName = 'infantry battalions'; break;
            case 'armoured': unitTypeName = 'armoured regiments'; break;
            case 'artillery': unitTypeName = 'artillery regiments'; break;
            case 'recon': unitTypeName = 'recon units'; break;
            case 'logistics': unitTypeName = 'logistics units'; break;
            case 'engineering': unitTypeName = 'engineering companies'; break;
        }
        container.html(`<div class="no-units-message">No ${unitTypeName} found. Click "+ Add New" to create one.</div>`);
        return;
    }
    
    units.forEach(function(unit) {
        let detailsHtml = '';
        let deleteFunctionName = '';
        let editFunctionName = '';
        
        switch(unitType.toString().toLowerCase()) {
            case 'infantry':
                detailsHtml = `Code: ${unit.unitCode || 'N/A'} | Strength: ${unit.strength || 0} | Companies: ${unit.companies || 0}`;
                deleteFunctionName = 'deleteBrigadeInfantry';
                editFunctionName = 'editBrigadeInfantry';
                break;
            case 'armoured':
                detailsHtml = `Code: ${unit.unitCode || 'N/A'} | Strength: ${unit.strength || 0} | Tanks: ${unit.tanks || 0}`;
                deleteFunctionName = 'deleteBrigadeArmoured';
                editFunctionName = 'editBrigadeArmoured';
                break;
            case 'artillery':
                detailsHtml = `Code: ${unit.unitCode || 'N/A'} | Strength: ${unit.strength || 0} | Guns: ${unit.guns || 0}`;
                deleteFunctionName = 'deleteBrigadeArtillery';
                editFunctionName = 'editBrigadeArtillery';
                break;
            case 'recon':
                detailsHtml = `Type: ${unit.reconType || 'N/A'} | Confidence: ${unit.confidence || 0}% | Location: ${unit.location || 'Unknown'}`;
                deleteFunctionName = 'deleteBrigadeRecon';
                editFunctionName = 'editBrigadeRecon';
                break;
            case 'logistics':
                detailsHtml = `Code: ${unit.unitCode || 'N/A'} | Strength: ${unit.strength || 0} | Trucks: ${(unit.supplyTrucks || 0) + (unit.fuelTrucks || 0)}`;
                deleteFunctionName = 'deleteBrigadeLogistics';
                editFunctionName = 'editBrigadeLogistics';
                break;
            case 'engineering':
                detailsHtml = `Code: ${unit.unitCode || 'N/A'} | Strength: ${unit.strength || 0} | Platoons: ${unit.platoons || 0}`;
                deleteFunctionName = 'deleteBrigadeEngineering';
                editFunctionName = 'editBrigadeEngineering';
                break;
        }
        
        const unitHtml = `
            <div class="unit-item">
                <div class="unit-info">
                    <div class="unit-name">${unit.name || (unit.reconType ? 'Recon: ' + unit.reconType : 'Unnamed Unit')}</div>
                    <div class="unit-details">${detailsHtml}</div>
                </div>
                <div class="unit-actions">
                    <button class="btn btn-sm btn-outline-secondary" onclick="${editFunctionName}('${unit.id}')">
                        <i class="fas fa-edit"></i> Edit
                    </button>
                    <button class="btn btn-sm btn-outline-danger" onclick="${deleteFunctionName}('${unit.id}')">
                        <i class="fas fa-trash"></i> Delete
                    </button>
                </div>
            </div>
        `;
        
        container.append(unitHtml);
    });
}

// Make function globally available
window.loadBrigadeUnits = loadBrigadeUnits;
