@using static TechWebSol.Controllers.DataManagementController
@model UnitsDataEntryViewModel

<!-- Brigade Unit Form Modal - Matches Direct Unit Style - Bootstrap Modal -->
<div class="modal fade" id="brigadeUnitModal" tabindex="-1" role="dialog" aria-labelledby="brigadeUnitModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-xl" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="brigadeUnitModalLabel">
                    <i class="fas fa-users"></i> Brigade Unit Entry - @Model.Brigade.BrigadeCode
                </h5>
                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <div class="modal-body">
                <!-- Hidden fields -->
                <input type="hidden" id="tokenId" value="@Model.Token.Id" />
                <input type="hidden" id="brigadeId" value="@Model.Brigade.Id" />
                <input type="hidden" id="teamId" value="@Model.Brigade.TeamId" />
                <input type="hidden" id="forceType" value="@Model.Brigade.ForceType" />
                <input type="hidden" id="currentUnitType" value="" />

                <!-- Compact Token & Brigade Information -->
                <div class="compact-token-info">
                    <div class="token-header-bar brigade-style">
                        <div class="token-icon-wrapper">
                            @if (!string.IsNullOrEmpty(Model.Token.AssetImagePath))
                            {
                                <img src="@Model.Token.AssetImagePath" alt="@Model.Token.Name" class="token-mini-icon">
                            }
                            else
                            {
                                <div class="token-mini-placeholder">
                                    <i class="fas fa-hashtag"></i>
                                </div>
                            }
                        </div>
                        <div class="token-title-section">
                            <h6 class="token-name">Brigade @Model.Brigade.BrigadeCode</h6>
                            <span class="token-subtitle">Token: @Model.Token.Name</span>
                        </div>
                        <div class="token-badges">
                            <span class="badge badge-info">@Model.Token.Name</span>
                            <span class="badge badge-primary">@Model.Brigade.ForceType.ToUpper()</span>
                        </div>
                    </div>
                    <div class="compact-info-bar brigade-bar">
                        <i class="fas fa-check-circle text-primary"></i>
                        <span><strong>Brigade Selected:</strong> Manage military units for Brigade @Model.Brigade.BrigadeCode</span>
                    </div>
                </div>

                <!-- Unit Type Tabs -->
                <div class="unit-type-section compact-tabs">
                    <div class="unit-type-buttons">
                        <button type="button" class="unit-type-btn active" data-unit-type="infantry" onclick="showBrigadeUnitType('infantry')">
                            <i class="fas fa-user-shield"></i>
                            <span>Infantry</span>
                            @if (Model.ExistingInfantryList != null && Model.ExistingInfantryList.Any())
                            {
                                <span class="badge badge-light">@Model.ExistingInfantryList.Count</span>
                            }
                        </button>
                        <button type="button" class="unit-type-btn" data-unit-type="armoured" onclick="showBrigadeUnitType('armoured')">
                            <i class="fas fa-shield-alt"></i>
                            <span>Armoured</span>
                            @if (Model.ExistingArmouredList != null && Model.ExistingArmouredList.Any())
                            {
                                <span class="badge badge-light">@Model.ExistingArmouredList.Count</span>
                            }
                        </button>
                        <button type="button" class="unit-type-btn" data-unit-type="artillery" onclick="showBrigadeUnitType('artillery')">
                            <i class="fas fa-crosshairs"></i>
                            <span>Artillery</span>
                            @if (Model.ExistingArtilleryList != null && Model.ExistingArtilleryList.Any())
                            {
                                <span class="badge badge-light">@Model.ExistingArtilleryList.Count</span>
                            }
                        </button>
                        <button type="button" class="unit-type-btn" data-unit-type="recon" onclick="showBrigadeUnitType('recon')">
                            <i class="fas fa-binoculars"></i>
                            <span>Recon</span>
                            @if (Model.ExistingReconList != null && Model.ExistingReconList.Any())
                            {
                                <span class="badge badge-light">@Model.ExistingReconList.Count</span>
                            }
                        </button>
                        <button type="button" class="unit-type-btn" data-unit-type="logistics" onclick="showBrigadeUnitType('logistics')">
                            <i class="fas fa-truck"></i>
                            <span>Logistics</span>
                            @if (Model.ExistingLogisticsList != null && Model.ExistingLogisticsList.Any())
                            {
                                <span class="badge badge-light">@Model.ExistingLogisticsList.Count</span>
                            }
                        </button>
                        <button type="button" class="unit-type-btn" data-unit-type="engineering" onclick="showBrigadeUnitType('engineering')">
                            <i class="fas fa-hard-hat"></i>
                            <span>Engineering</span>
                            @if (Model.ExistingEngineeringList != null && Model.ExistingEngineeringList.Any())
                            {
                                <span class="badge badge-light">@Model.ExistingEngineeringList.Count</span>
                            }
                        </button>
                    </div>
                </div>

                <!-- Infantry Units -->
                <div class="existing-units-section" id="infantry-units" style="display: block;">
                    <h6><i class="fas fa-user-shield"></i> Infantry Battalions</h6>
                    <div class="units-list" id="infantry-units-list">
                        @if (Model.ExistingInfantryList != null && Model.ExistingInfantryList.Any())
                        {
                            @foreach (var unit in Model.ExistingInfantryList)
                            {
                                <div class="unit-item">
                                    <div class="unit-info">
                                        <div class="unit-name">@unit.Name</div>
                                        <div class="unit-details">Code: @unit.UnitCode | Strength: @unit.Strength | Companies: @unit.Companies</div>
                                    </div>
                                    <div class="unit-actions">
                                        <button class="btn btn-sm btn-outline-secondary" onclick="editBrigadeInfantry('@unit.Id')">
                                            <i class="fas fa-edit"></i> Edit
                                        </button>
                                        <button class="btn btn-sm btn-outline-danger" onclick="deleteBrigadeInfantry('@unit.Id')">
                                            <i class="fas fa-trash"></i> Delete
                                        </button>
                                    </div>
                                </div>
                            }
                        }
                        else
                        {
                            <div class="no-units-message">No infantry battalions found. Click "+ Add New" to create one.</div>
                        }
                    </div>
                    <div class="add-unit-button">
                        <button type="button" class="btn btn-primary" onclick="openInfantryBattalionForm('@Model.Token.Id', '@Model.Brigade.Id')">
                            <i class="fas fa-plus"></i> Add New Infantry Battalion
                        </button>
                    </div>
                </div>

                <!-- Armoured Units -->
                <div class="existing-units-section" id="armoured-units" style="display: none;">
                    <h6><i class="fas fa-shield-alt"></i> Armoured Regiments</h6>
                    <div class="units-list" id="armoured-units-list">
                        @if (Model.ExistingArmouredList != null && Model.ExistingArmouredList.Any())
                        {
                            @foreach (var unit in Model.ExistingArmouredList)
                            {
                                <div class="unit-item">
                                    <div class="unit-info">
                                        <div class="unit-name">@unit.Name</div>
                                        <div class="unit-details">Code: @unit.UnitCode | Strength: @unit.Strength | Tanks: @unit.Tanks</div>
                                    </div>
                                    <div class="unit-actions">
                                        <button class="btn btn-sm btn-outline-secondary" onclick="editBrigadeArmoured('@unit.Id')">
                                            <i class="fas fa-edit"></i> Edit
                                        </button>
                                        <button class="btn btn-sm btn-outline-danger" onclick="deleteBrigadeArmoured('@unit.Id')">
                                            <i class="fas fa-trash"></i> Delete
                                        </button>
                                    </div>
                                </div>
                            }
                        }
                        else
                        {
                            <div class="no-units-message">No armoured regiments found. Click "+ Add New" to create one.</div>
                        }
                    </div>
                    <div class="add-unit-button">
                        <button type="button" class="btn btn-primary" onclick="openArmouredRegimentForm('@Model.Token.Id', '@Model.Brigade.Id')">
                            <i class="fas fa-plus"></i> Add New Armoured Regiment
                        </button>
                    </div>
                </div>

                <!-- Artillery Units -->
                <div class="existing-units-section" id="artillery-units" style="display: none;">
                    <h6><i class="fas fa-crosshairs"></i> Artillery Regiments</h6>
                    <div class="units-list" id="artillery-units-list">
                        @if (Model.ExistingArtilleryList != null && Model.ExistingArtilleryList.Any())
                        {
                            @foreach (var unit in Model.ExistingArtilleryList)
                            {
                                <div class="unit-item">
                                    <div class="unit-info">
                                        <div class="unit-name">@unit.Name</div>
                                        <div class="unit-details">Code: @unit.UnitCode | Strength: @unit.Strength | Guns: @unit.Guns</div>
                                    </div>
                                    <div class="unit-actions">
                                        <button class="btn btn-sm btn-outline-secondary" onclick="editBrigadeArtillery('@unit.Id')">
                                            <i class="fas fa-edit"></i> Edit
                                        </button>
                                        <button class="btn btn-sm btn-outline-danger" onclick="deleteBrigadeArtillery('@unit.Id')">
                                            <i class="fas fa-trash"></i> Delete
                                        </button>
                                    </div>
                                </div>
                            }
                        }
                        else
                        {
                            <div class="no-units-message">No artillery regiments found. Click "+ Add New" to create one.</div>
                        }
                    </div>
                    <div class="add-unit-button">
                        <button type="button" class="btn btn-primary" onclick="openArtilleryRegimentForm('@Model.Token.Id', '@Model.Brigade.Id')">
                            <i class="fas fa-plus"></i> Add New Artillery Regiment
                        </button>
                    </div>
                </div>

                <!-- Recon Units -->
                <div class="existing-units-section" id="recon-units" style="display: none;">
                    <h6><i class="fas fa-binoculars"></i> Reconnaissance Units</h6>
                    <div class="units-list" id="recon-units-list">
                        @if (Model.ExistingReconList != null && Model.ExistingReconList.Any())
                        {
                            @foreach (var unit in Model.ExistingReconList)
                            {
                                <div class="unit-item">
                                    <div class="unit-info">
                                        <div class="unit-name">@unit.ReconType</div>
                                        <div class="unit-details">Location: @unit.Location | Confidence: @unit.Confidence</div>
                                    </div>
                                    <div class="unit-actions">
                                        <button class="btn btn-sm btn-outline-secondary" onclick="editBrigadeRecon('@unit.Id')">
                                            <i class="fas fa-edit"></i> Edit
                                        </button>
                                        <button class="btn btn-sm btn-outline-danger" onclick="deleteBrigadeRecon('@unit.Id')">
                                            <i class="fas fa-trash"></i> Delete
                                        </button>
                                    </div>
                                </div>
                            }
                        }
                        else
                        {
                            <div class="no-units-message">No recon units found. Click "+ Add New" to create one.</div>
                        }
                    </div>
                    <div class="add-unit-button">
                        <button type="button" class="btn btn-primary" onclick="openReconForm('@Model.Token.Id', '@Model.Brigade.Id')">
                            <i class="fas fa-plus"></i> Add New Recon Unit
                        </button>
                    </div>
                </div>

                <!-- Logistics Units -->
                <div class="existing-units-section" id="logistics-units" style="display: none;">
                    <h6><i class="fas fa-truck"></i> Logistics Units</h6>
                    <div class="units-list" id="logistics-units-list">
                        @if (Model.ExistingLogisticsList != null && Model.ExistingLogisticsList.Any())
                        {
                            @foreach (var unit in Model.ExistingLogisticsList)
                            {
                                <div class="unit-item">
                                    <div class="unit-info">
                                        <div class="unit-name">@unit.Name</div>
                                        <div class="unit-details">Code: @unit.UnitCode | Supply Trucks: @unit.SupplyTrucks | Fuel Trucks: @unit.FuelTrucks</div>
                                    </div>
                                    <div class="unit-actions">
                                        <button class="btn btn-sm btn-outline-secondary" onclick="editBrigadeLogistics('@unit.Id')">
                                            <i class="fas fa-edit"></i> Edit
                                        </button>
                                        <button class="btn btn-sm btn-outline-danger" onclick="deleteBrigadeLogistics('@unit.Id')">
                                            <i class="fas fa-trash"></i> Delete
                                        </button>
                                    </div>
                                </div>
                            }
                        }
                        else
                        {
                            <div class="no-units-message">No logistics units found. Click "+ Add New" to create one.</div>
                        }
                    </div>
                    <div class="add-unit-button">
                        <button type="button" class="btn btn-primary" onclick="openLogisticsForm('@Model.Token.Id', '@Model.Brigade.Id')">
                            <i class="fas fa-plus"></i> Add New Logistics Unit
                        </button>
                    </div>
                </div>

                <!-- Engineering Units -->
                <div class="existing-units-section" id="engineering-units" style="display: none;">
                    <h6><i class="fas fa-hard-hat"></i> Combat Engineering Companies</h6>
                    <div class="units-list" id="engineering-units-list">
                        @if (Model.ExistingEngineeringList != null && Model.ExistingEngineeringList.Any())
                        {
                            @foreach (var unit in Model.ExistingEngineeringList)
                            {
                                <div class="unit-item">
                                    <div class="unit-info">
                                        <div class="unit-name">@unit.Name</div>
                                        <div class="unit-details">Code: @unit.UnitCode | Bulldozers: @unit.Bulldozers | Excavators: @unit.Excavators</div>
                                    </div>
                                    <div class="unit-actions">
                                        <button class="btn btn-sm btn-outline-secondary" onclick="editBrigadeEngineering('@unit.Id')">
                                            <i class="fas fa-edit"></i> Edit
                                        </button>
                                        <button class="btn btn-sm btn-outline-danger" onclick="deleteBrigadeEngineering('@unit.Id')">
                                            <i class="fas fa-trash"></i> Delete
                                        </button>
                                    </div>
                                </div>
                            }
                        }
                        else
                        {
                            <div class="no-units-message">No engineering companies found. Click "+ Add New" to create one.</div>
                        }
                    </div>
                    <div class="add-unit-button">
                        <button type="button" class="btn btn-primary" onclick="openEngineeringForm('@Model.Token.Id', '@Model.Brigade.Id')">
                            <i class="fas fa-plus"></i> Add New Engineering Company
                        </button>
                    </div>
                </div>

            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-dismiss="modal">
                    <i class="fas fa-times"></i> Close
                </button>
            </div>
        </div>
    </div>
</div>

<style>
