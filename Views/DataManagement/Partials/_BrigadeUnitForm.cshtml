    background: linear-gradient(135deg, #e3f2fd 0%, #f1f8ff 100%);
    border-left: 4px solid #2196f3;
    border-radius: 6px;
    margin-bottom: 20px;
    overflow: hidden;
}

.token-header-bar {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 12px 15px;
    background: rgba(255, 255, 255, 0.7);
    border-bottom: 1px solid #e0e0e0;
}

.token-header-bar.brigade-style {
    background: rgba(33, 150, 243, 0.05);
}

.token-icon-wrapper {
    flex-shrink: 0;
}

.token-mini-icon {
