// Global brigade unit edit function (with all parameters)
function editBrigadeUnit(unitType, tokenId, brigadeId, unitId) {
    console.log('✏️ Editing brigade unit:', { unitType, tokenId, brigadeId, unitId });
    
    showLoader();
    
    const params = {
        unitType: unitType,
        tokenId: tokenId,
        brigadeId: brigadeId,
        unitId: unitId
    };
    
    $.get('/DataManagement/BrigadeUnitCreationForm', params, function(data) {
        $('#brigadeUnitCreationModal').remove();
        $('body').append(data);
        $('#brigadeUnitCreationModal').modal('show');
        hideLoader();
    }).fail(function(xhr, status, error) {
        hideLoader();
        console.error('❌ Error loading unit form:', error);
        alert('Failed to load unit form: ' + error);
    });
}

// Global brigade unit delete function (with all parameters)
function deleteBrigadeUnit(unitType, unitId, tokenId, brigadeId) {
    const unitTypeNames = {
        'infantry': 'Infantry Battalion',
        'armoured': 'Armoured Regiment',
        'artillery': 'Artillery Regiment',
        'logistics': 'Logistics Unit',
        'engineering': 'Engineering Company',
        'recon': 'Recon Unit'
    };
    
    const unitName = unitTypeNames[unitType] || 'Unit';
    
    if (!confirm(`Are you sure you want to delete this ${unitName}?`)) return;
    
    const endpoints = {
        'infantry': '/DataManagement/DeleteTokenInfantryBattalion',
        'armoured': '/DataManagement/DeleteTokenArmouredRegiment',
        'artillery': '/DataManagement/DeleteTokenArtilleryRegiment',
        'logistics': '/DataManagement/DeleteTokenLogisticsUnit',
        'engineering': '/DataManagement/DeleteTokenCombatEngineeringCompany',
        'recon': '/DataManagement/DeleteTokenRecon'
    };
    
    const endpoint = endpoints[unitType];
    
    showLoader();
    
    $.ajax({
        url: endpoint,
        type: 'DELETE',
        contentType: 'application/json',
        data: JSON.stringify({ Id: unitId }),
        success: function(response) {
            console.log(`✅ ${unitName} deleted`);
            
            // Reload the token data entry modal to show updated units
            $.get('/DataManagement/TokenDataEntryForm', { tokenId: tokenId }, function(data) {
                $('#tokenDataEntryModal .modal-content').html($(data).find('.modal-content').html());
                hideLoader();
            }).fail(function() {
                hideLoader();
                alert('Deleted but failed to refresh. Please close and reopen the modal.');
            });
        },
        error: function(xhr, status, error) {
            hideLoader();
            alert(`Failed to delete ${unitName}: ` + error);
        }
    });
}

// Brigade unit form opening functions (missing from TokenDataEntryForm)
function openInfantryBattalionForm(tokenId, brigadeId, unitId = null) {
