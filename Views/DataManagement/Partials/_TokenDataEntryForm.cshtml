    display: none;
    padding: 20px;
    border: 1px solid #333;
    border-radius: 8px;
    background: #2a2a2a;
    margin-top: 10px;
}

.data-tab-content.active {
    display: block;
}

.tab-content-header {
    margin-bottom: 15px;
    padding-bottom: 10px;
    border-bottom: 1px solid #444;
}

.tab-content-header h6 {
    color: #00d4ff;
    margin: 0 0 5px 0;
    font-weight: 600;
}

.tab-content-header .text-muted {
    color: #888 !important;
    font-size: 13px;
}

