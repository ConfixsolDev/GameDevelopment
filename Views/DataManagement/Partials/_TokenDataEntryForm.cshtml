@using static TechWebSol.Controllers.DataManagementController
@model TokenDataEntryViewModel

<!-- Token Data Entry Form Modal - Simple and Clean -->
<div id="tokenDataEntryModal" class="gameplay-modal" style="display: none;">
    <div class="gameplay-modal-content">
        <div class="gameplay-modal-header">
            <h3><i class="fas fa-database"></i> Data Entry - @Model.Token.Name</h3>
            <button class="gameplay-modal-close" onclick="closeTokenDataEntryModal()">&times;</button>
        </div>
        <div class="gameplay-modal-body">
            <div class="data-entry-container">
                <!-- Data Entry Form -->
                <div class="data-entry-form-section">
                    @if (Model.ExistingBrigade != null)
                    {
                        <!-- Edit Existing Brigade Data -->
                        <div class="brigade-header-section">
                            <div class="brigade-name-display">
                                <h5>Brigade @Model.ExistingBrigade.BrigadeCode Information</h5>
                                <button type="button" class="btn btn-sm btn-outline-primary" onclick="editBrigadeCode()">
                                    <i class="fas fa-edit"></i> Edit Code
                                </button>
                            </div>
                        </div>
                        
                        <div class="brigade-data-form">
                            <!-- Comprehensive Data Entry Tabs -->
                            <div class="data-entry-tabs">
                                <button type="button" class="data-tab active" onclick="showDataTab('infantry')">
                                    <i class="fas fa-user-shield"></i> Infantry Battalion
                                </button>
                                <button type="button" class="data-tab" onclick="showDataTab('armoured')">
                                    <i class="fas fa-shield-alt"></i> Armoured Regiment
                                </button>
                                <button type="button" class="data-tab" onclick="showDataTab('artillery')">
                                    <i class="fas fa-crosshairs"></i> Artillery Regiment
                                </button>
                                <button type="button" class="data-tab" onclick="showDataTab('logistics')">
                                    <i class="fas fa-truck"></i> Logistics Unit
                                </button>
                                <button type="button" class="data-tab" onclick="showDataTab('engineering')">
                                    <i class="fas fa-hard-hat"></i> Combat Engineering
                                </button>
                                <button type="button" class="data-tab" onclick="showDataTab('recon')">
                                    <i class="fas fa-binoculars"></i> Reconnaissance
                                </button>
                            </div>
                            
                            <div id="infantry-data" class="data-tab-content active">
                                <div class="tab-content-header">
                                    <h6><i class="fas fa-user-shield"></i> Infantry Battalions</h6>
                                    <p class="text-muted">Manage infantry battalions for Brigade @Model.ExistingBrigade.BrigadeCode</p>
                                </div>
                                
                                <!-- Existing Infantry Battalions List -->
                                <div id="infantryBattalionsList" class="units-list">
                                    @if (Model.ExistingInfantry != null && Model.ExistingInfantry.Any())
                                    {
                                        @foreach (var battalion in Model.ExistingInfantry)
                                        {
                                            var battalionData = (dynamic)battalion;
                                            <div class="unit-item">
                                                <div class="unit-info">
                                                    <div class="unit-name1">@battalionData.Name</div>
                                                    <div class="unit-details">Code: @battalionData.UnitCode | Strength: @battalionData.Strength | Companies: @battalionData.Companies</div>
                                                </div>
                                                <div class="unit-actions">
                                                    <button class="btn btn-sm btn-outline-secondary" onclick="editInfantryBattalion('@battalionData.Id')">
                                                        <i class="fas fa-edit"></i> Edit
                                                    </button>
                                                    <button class="btn btn-sm btn-outline-danger" onclick="deleteInfantryBattalion('@battalionData.Id')">
                                                        <i class="fas fa-trash"></i> Delete
                                                    </button>
                                                </div>
                                            </div>
                                        }
                                    }
                                    else
                                    {
                                        <div class="no-units-message">No infantry battalions found. Click "Add New" to create one.</div>
                                    }
                                </div>
                                
                                <!-- Add New Button -->
                                <div class="add-unit-section">
                                    <button type="button" class="btn btn-primary" onclick="openInfantryBattalionForm('@Model.Token.Id', '@Model.ExistingBrigade.Id')">
                                        <i class="fas fa-plus"></i> Add New Infantry Battalion
                                    </button>
                                </div>
                            </div>
                            <div id="armoured-data" class="data-tab-content">
                                <div class="tab-content-header">
                                    <h6><i class="fas fa-shield-alt"></i> Armoured Regiments</h6>
                                    <p class="text-muted">Manage armoured regiments for Brigade @Model.ExistingBrigade.BrigadeCode</p>
                                </div>
                                
                                <div id="armouredRegimentsList" class="units-list">
                                    @if (Model.ExistingArmoured != null && Model.ExistingArmoured.Any())
                                    {
                                        @foreach (var regiment in Model.ExistingArmoured)
                                        {
                                            var regimentData = (dynamic)regiment;
                                            <div class="unit-item">
                                                <div class="unit-info">
                                                    <div class="unit-name1">@regimentData.Name</div>
                                                    <div class="unit-details">Code: @regimentData.UnitCode | Strength: @regimentData.Strength | Tanks: @regimentData.Tanks</div>
                                                </div>
                                                <div class="unit-actions">
                                                    <button class="btn btn-sm btn-outline-secondary" onclick="editArmouredRegiment('@regimentData.Id')">
                                                        <i class="fas fa-edit"></i> Edit
                                                    </button>
                                                    <button class="btn btn-sm btn-outline-danger" onclick="deleteArmouredRegiment('@regimentData.Id')">
                                                        <i class="fas fa-trash"></i> Delete
                                                    </button>
                                                </div>
                                            </div>
                                        }
                                    }
                                    else
                                    {
                                        <div class="no-units-message">No armoured regiments found. Click "Add New" to create one.</div>
                                    }
                                </div>
                                
                                <div class="add-unit-section">
                                    <button type="button" class="btn btn-primary" onclick="openArmouredRegimentForm('@Model.Token.Id', '@Model.ExistingBrigade.Id')">
                                        <i class="fas fa-plus"></i> Add New Armoured Regiment
                                    </button>
                                </div>
                            </div>
                            <div id="artillery-data" class="data-tab-content">
                                <div class="tab-content-header">
                                    <h6><i class="fas fa-crosshairs"></i> Artillery Regiments</h6>
                                    <p class="text-muted">Manage artillery regiments for Brigade @Model.ExistingBrigade.BrigadeCode</p>
                                </div>
                                
                                <div id="artilleryRegimentsList" class="units-list">
                                    @if (Model.ExistingArtillery != null && Model.ExistingArtillery.Any())
                                    {
                                        @foreach (var regiment in Model.ExistingArtillery)
                                        {
                                            var regimentData = (dynamic)regiment;
                                            <div class="unit-item">
                                                <div class="unit-info">
                                                    <div class="unit-name1">@regimentData.Name</div>
                                                    <div class="unit-details">Code: @regimentData.UnitCode | Strength: @regimentData.Strength | Guns: @regimentData.Guns</div>
                                                </div>
                                                <div class="unit-actions">
                                                    <button class="btn btn-sm btn-outline-secondary" onclick="editArtilleryRegiment('@regimentData.Id')">
                                                        <i class="fas fa-edit"></i> Edit
                                                    </button>
                                                    <button class="btn btn-sm btn-outline-danger" onclick="deleteArtilleryRegiment('@regimentData.Id')">
                                                        <i class="fas fa-trash"></i> Delete
                                                    </button>
                                                </div>
                                            </div>
                                        }
                                    }
                                    else
                                    {
                                        <div class="no-units-message">No artillery regiments found. Click "Add New" to create one.</div>
                                    }
                                </div>
                                
                                <div class="add-unit-section">
                                    <button type="button" class="btn btn-primary" onclick="openArtilleryRegimentForm('@Model.Token.Id', '@Model.ExistingBrigade.Id')">
                                        <i class="fas fa-plus"></i> Add New Artillery Regiment
                                    </button>
                                </div>
                            </div>
                            <div id="logistics-data" class="data-tab-content">
                                <div class="tab-content-header">
                                    <h6><i class="fas fa-truck"></i> Logistics Units</h6>
                                    <p class="text-muted">Manage logistics units for Brigade @Model.ExistingBrigade.BrigadeCode</p>
                                </div>
                                
                                <div id="logisticsUnitsList" class="units-list">
                                    @if (Model.ExistingLogistics != null)
                                    {
                                        <div class="unit-item">
                                            <div class="unit-info">
                                                <div class="unit-name1">@Model.ExistingLogistics.Name</div>
                                                <div class="unit-details">Code: @Model.ExistingLogistics.UnitCode | Strength: @Model.ExistingLogistics.Strength | Supply Trucks: @Model.ExistingLogistics.SupplyTrucks</div>
                                            </div>
                                            <div class="unit-actions">
                                                <button class="btn btn-sm btn-outline-secondary" onclick="editLogisticsUnit('@Model.ExistingLogistics.Id')">
                                                    <i class="fas fa-edit"></i> Edit
                                                </button>
                                                <button class="btn btn-sm btn-outline-danger" onclick="deleteLogisticsUnit('@Model.ExistingLogistics.Id')">
                                                    <i class="fas fa-trash"></i> Delete
                                                </button>
                                            </div>
                                        </div>
                                    }
                                    else
                                    {
                                        <div class="no-units-message">No logistics units found. Click "Add New" to create one.</div>
                                    }
                                </div>
                                
                                <div class="add-unit-section">
                                    <button type="button" class="btn btn-primary" onclick="openLogisticsUnitForm('@Model.Token.Id', '@Model.ExistingBrigade.Id')">
                                        <i class="fas fa-plus"></i> Add New Logistics Unit
                                    </button>
                                </div>
                            </div>
                            <div id="engineering-data" class="data-tab-content">
                                <div class="tab-content-header">
                                    <h6><i class="fas fa-hard-hat"></i> Combat Engineering Companies</h6>
                                    <p class="text-muted">Manage combat engineering companies for Brigade @Model.ExistingBrigade.BrigadeCode</p>
                                </div>
                                
                                <div id="engineeringCompaniesList" class="units-list">
                                    @if (Model.ExistingEngineering != null)
                                    {
                                        <div class="unit-item">
                                            <div class="unit-info">
                                                <div class="unit-name1">@Model.ExistingEngineering.Name</div>
                                                <div class="unit-details">Code: @Model.ExistingEngineering.UnitCode | Strength: @Model.ExistingEngineering.Strength | Vehicles: @Model.ExistingEngineering.BridgeLayingVehicles</div>
                                            </div>
                                            <div class="unit-actions">
                                                <button class="btn btn-sm btn-outline-secondary" onclick="editCombatEngineeringCompany('@Model.ExistingEngineering.Id')">
                                                    <i class="fas fa-edit"></i> Edit
                                                </button>
                                                <button class="btn btn-sm btn-outline-danger" onclick="deleteCombatEngineeringCompany('@Model.ExistingEngineering.Id')">
                                                    <i class="fas fa-trash"></i> Delete
                                                </button>
                                            </div>
                                        </div>
                                    }
                                    else
                                    {
                                        <div class="no-units-message">No combat engineering companies found. Click "Add New" to create one.</div>
                                    }
                                </div>
                                
                                <div class="add-unit-section">
                                    <button type="button" class="btn btn-primary" onclick="openCombatEngineeringCompanyForm('@Model.Token.Id', '@Model.ExistingBrigade.Id')">
                                        <i class="fas fa-plus"></i> Add New Combat Engineering Company
                                    </button>
                                </div>
                            </div>
                            <div id="recon-data" class="data-tab-content">
                                <div class="tab-content-header">
                                    <h6><i class="fas fa-binoculars"></i> Reconnaissance</h6>
                                    <p class="text-muted">Manage reconnaissance for Brigade @Model.ExistingBrigade.BrigadeCode</p>
                                </div>
                                
                                <div id="reconnaissanceList" class="units-list">
                                    @if (Model.ExistingRecon != null && Model.ExistingRecon.Any())
                                    {
                                        @foreach (var recon in Model.ExistingRecon)
                                        {
                                            var reconData = (dynamic)recon;
                                            <div class="unit-item">
                                                <div class="unit-info">
                                                    <div class="unit-name1">@reconData.ReconType</div>
                                                    <div class="unit-details">Location: @reconData.Location | Confidence: @reconData.Confidence</div>
                                                </div>
                                                <div class="unit-actions">
                                                    <button class="btn btn-sm btn-outline-secondary" onclick="editReconnaissance('@reconData.Id')">
                                                        <i class="fas fa-edit"></i> Edit
                                                    </button>
                                                    <button class="btn btn-sm btn-outline-danger" onclick="deleteReconnaissance('@reconData.Id')">
                                                        <i class="fas fa-trash"></i> Delete
                                                    </button>
                                                </div>
                                            </div>
                                        }
                                    }
                                    else
                                    {
                                        <div class="no-units-message">No reconnaissance found. Click "Add New" to create one.</div>
                                    }
                                </div>
                                
                                <div class="add-unit-section">
                                    <button type="button" class="btn btn-primary" onclick="openReconnaissanceForm('@Model.Token.Id', '@Model.ExistingBrigade.Id')">
                                        <i class="fas fa-plus"></i> Add New Reconnaissance
                                    </button>
                                </div>
                            </div>
                        </div>
                    }
                    else if (Model.AvailableBrigades.Any())
                    {
                        <!-- Link to Existing Brigade -->
                        <div class="alert alert-warning">
                            <i class="fas fa-link"></i> Link this token to an existing brigade or create new brigade data.
                        </div>
                        
                        <div class="form-group">
                            <label>Select Existing Brigade:</label>
                            <select class="form-control" id="brigadeSelector">
                                <option value="">-- Select a Brigade --</option>
                                @foreach (var brigade in Model.AvailableBrigades)
                                {
                                    <option value="@brigade.Id">Brigade @brigade.BrigadeCode</option>
                                }
                            </select>
                        </div>
                        
                        <div class="text-center mb-3">
                            <button type="button" class="btn btn-primary" onclick="linkSelectedBrigade('@Model.Token.Id')">
                                <i class="fas fa-link"></i> Link Brigade to Token
                            </button>
                        </div>
                        
                        <hr>
                        <p class="text-center text-muted">OR</p>
                        
                        <div class="text-center">
                            <button type="button" class="btn btn-success" onclick="createNewBrigadeData('@Model.Token.Id')">
                                <i class="fas fa-plus"></i> Create New Brigade Data
                            </button>
                        </div>
                    }
                    else
                    {
                        <!-- Create New Brigade -->
                        <div class="alert alert-success">
                            <i class="fas fa-plus"></i> Create new brigade data for this token.
                        </div>
                        
                        <div class="text-center">
                            <button type="button" class="btn btn-success" onclick="createNewBrigadeData('@Model.Token.Id')">
                                <i class="fas fa-plus"></i> Create New Brigade Data
                            </button>
                        </div>
                    }
                </div>
            </div>
        </div>
        <div class="gameplay-modal-footer">
            <button class="gameplay-btn" onclick="closeTokenDataEntryModal()">Close</button>
        </div>
    </div>
</div>

<style>
