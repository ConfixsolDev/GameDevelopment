    background: #1a1a1a;
    border-radius: 8px;
    padding: 20px;
}

.brigade-header-section {
    margin-bottom: 20px;
    padding: 15px;
    background: #2a2a2a;
    border-radius: 8px;
    border-left: 4px solid #00d4ff;
}

.brigade-name-display {
    display: flex;
    justify-content: space-between;
    align-items: center;
}

.brigade-name-display h5 {
    color: #00d4ff;
    margin: 0;
    font-weight: 600;
}

.data-entry-tabs {
    display: flex;
    gap: 3px;
    margin: 20px 0 10px 0;
    background: #1a1a1a;
    border-radius: 8px;
    padding: 5px;
}

.data-tab {
    flex: 1;
    padding: 12px 8px;
    border: 1px solid #333;
    background: #2a2a2a;
    color: #ccc;
    cursor: pointer;
    border-radius: 6px;
    text-align: center;
    font-size: 12px;
