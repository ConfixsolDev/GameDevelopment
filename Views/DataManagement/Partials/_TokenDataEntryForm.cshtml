// Load single unit form
function loadSingleUnitForm(unitType, tokenId, brigadeId) {
    $("#loading").show();
    
    $.ajax({
        url: '/DataManagement/SingleUnitForm',
        type: 'GET',
        data: { unitType: unitType, tokenId: tokenId, brigadeId: brigadeId },
        success: function(data) {
            console.log('✅ Single unit form loaded');
            
            // Remove any existing single unit modal
            $('#singleUnitModal').remove();
            
            // Add the new modal to the body
            $('body').append(data);
            
            // Show the modal
            document.getElementById('singleUnitModal').style.display = 'flex';
            
            console.log('✅ Single unit form displayed successfully');
        },
        error: function(xhr, status, error) {
            console.error('❌ Error loading single unit form:', error);
            alert('Failed to load unit form. Please try again.');
        },
        complete: function() {
            $("#loading").hide();
        }
    });
}

// Refresh units list after save
function refreshUnitsList(tokenId, brigadeId) {
    console.log('🔄 Refreshing units list...');
    // Reload the entire modal to get fresh data
    location.reload();
}

