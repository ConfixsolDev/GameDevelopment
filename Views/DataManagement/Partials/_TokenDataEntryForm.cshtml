@using static TechWebSol.Controllers.DataManagementController
@model TokenDataEntryViewModel

<!-- Token Data Entry Form Modal - Simple and Clean - Bootstrap Modal -->
<div class="modal fade" id="tokenDataEntryModal" tabindex="-1" role="dialog" aria-labelledby="tokenDataEntryModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-xl" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="tokenDataEntryModalLabel">
                    <i class="fas fa-database"></i> Data Entry - @Model.Token.Name
                </h5>
                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <div class="modal-body">
            <div class="data-entry-container">
                <!-- Token Base Information (Primary) -->
                <div class="token-base-section">
                    <h5><i class="fas fa-crosshairs"></i> Token Base Information</h5>
                    <div class="token-display">
                        @if (!string.IsNullOrEmpty(Model.Token.AssetImagePath))
                        {
                            <img src="@Model.Token.AssetImagePath" alt="@Model.Token.Name" class="token-preview-image">
                        }
                        else
                        {
                            <div class="token-preview-placeholder">
                                <i class="fas fa-crosshairs"></i>
                            </div>
                        }
                        <div class="token-details">
                            <h4>@Model.Token.Name</h4>
                            <p class="text-muted">@Model.Token.TokenGroup?.Name</p>
                            <div class="token-status">
                                <span class="badge badge-primary">Active Token</span>
                                <span class="badge badge-info">@Model.Token.ForceType</span>
                            </div>
                        </div>
                    </div>
                    <div class="alert alert-success">
                        <i class="fas fa-check-circle"></i> 
                        <strong>Token Selected:</strong> This token serves as the base for all brigade data management.
                    </div>
                </div>

                <!-- Data Entry Form -->
                <div class="data-entry-form-section">
                    @if (Model.ExistingBrigade != null)
                    {
                        <!-- Edit Existing Brigade Data -->
                        <div class="brigade-header-section">
                            <div class="brigade-name-display">
                                <h5>Brigade @Model.ExistingBrigade.BrigadeCode Information</h5>
                                <button type="button" class="btn btn-sm btn-outline-primary" onclick="editBrigadeCode()">
                                    <i class="fas fa-edit"></i> Edit Code
                                </button>
                            </div>
                        </div>
                        
                        <div class="brigade-data-form">
                            <!-- Comprehensive Data Entry Tabs -->
                            <div class="data-entry-tabs">
                                <button type="button" class="data-tab active" onclick="showDataTab('infantry')">
                                    <i class="fas fa-user-shield"></i> Infantry Battalion
                                </button>
                                <button type="button" class="data-tab" onclick="showDataTab('armoured')">
                                    <i class="fas fa-shield-alt"></i> Armoured Regiment
                                </button>
                                <button type="button" class="data-tab" onclick="showDataTab('artillery')">
                                    <i class="fas fa-crosshairs"></i> Artillery Regiment
                                </button>
                                <button type="button" class="data-tab" onclick="showDataTab('logistics')">
                                    <i class="fas fa-truck"></i> Logistics Unit
                                </button>
                                <button type="button" class="data-tab" onclick="showDataTab('engineering')">
                                    <i class="fas fa-hard-hat"></i> Combat Engineering
                                </button>
                                <button type="button" class="data-tab" onclick="showDataTab('recon')">
                                    <i class="fas fa-binoculars"></i> Reconnaissance
                                </button>
                            </div>
                            
                            <div id="infantry-data" class="data-tab-content active">
                                <div class="tab-content-header">
                                    <h6><i class="fas fa-user-shield"></i> Infantry Battalions</h6>
                                    <p class="text-muted">Manage infantry battalions for Brigade @Model.ExistingBrigade.BrigadeCode</p>
                                </div>
                                
                                <!-- Existing Infantry Battalions List -->
                                <div id="infantryBattalionsList" class="units-list">
                                    @if (Model.ExistingInfantry != null && Model.ExistingInfantry.Any())
                                    {
                                        @foreach (var battalion in Model.ExistingInfantry)
                                        {
                                            var battalionData = (dynamic)battalion;
                                            <div class="unit-item">
                                                <div class="unit-info">
                                                    <div class="unit-name1">@battalionData.Name</div>
                                                    <div class="unit-details">Code: @battalionData.UnitCode | Strength: @battalionData.Strength | Companies: @battalionData.Companies</div>
                                                </div>
                                                <div class="unit-actions">
                                                    <button class="btn btn-sm btn-outline-secondary" onclick="editBrigadeUnit('infantry', '@Model.Token.Id', '@Model.ExistingBrigade.Id', '@battalionData.Id')">
                                                        <i class="fas fa-edit"></i> Edit
                                                    </button>
                                                    <button class="btn btn-sm btn-outline-danger" onclick="deleteBrigadeUnit('infantry', '@battalionData.Id', '@Model.Token.Id', '@Model.ExistingBrigade.Id')">
                                                        <i class="fas fa-trash"></i> Delete
                                                    </button>
                                                </div>
                                            </div>
                                        }
                                    }
                                    else
                                    {
                                        <div class="no-units-message">No infantry battalions found. Click "Add New" to create one.</div>
                                    }
                                </div>
                                
                                <!-- Add New Button -->
                                <div class="add-unit-section">
                                    <button type="button" class="btn btn-primary" onclick="openInfantryBattalionForm('@Model.Token.Id', '@Model.ExistingBrigade.Id')">
                                        <i class="fas fa-plus"></i> Add New Infantry Battalion
                                    </button>
                                </div>
                            </div>
                            <div id="armoured-data" class="data-tab-content">
                                <div class="tab-content-header">
                                    <h6><i class="fas fa-shield-alt"></i> Armoured Regiments</h6>
                                    <p class="text-muted">Manage armoured regiments for Brigade @Model.ExistingBrigade.BrigadeCode</p>
                                </div>
                                
                                <div id="armouredRegimentsList" class="units-list">
                                    @if (Model.ExistingArmoured != null && Model.ExistingArmoured.Any())
                                    {
                                        @foreach (var regiment in Model.ExistingArmoured)
                                        {
                                            var regimentData = (dynamic)regiment;
                                            <div class="unit-item">
                                                <div class="unit-info">
                                                    <div class="unit-name1">@regimentData.Name</div>
                                                    <div class="unit-details">Code: @regimentData.UnitCode | Strength: @regimentData.Strength | Tanks: @regimentData.Tanks</div>
                                                </div>
                                                <div class="unit-actions">
                                                    <button class="btn btn-sm btn-outline-secondary" onclick="editBrigadeUnit('armoured', '@Model.Token.Id', '@Model.ExistingBrigade.Id', '@regimentData.Id')">
                                                        <i class="fas fa-edit"></i> Edit
                                                    </button>
                                                    <button class="btn btn-sm btn-outline-danger" onclick="deleteBrigadeUnit('armoured', '@regimentData.Id', '@Model.Token.Id', '@Model.ExistingBrigade.Id')">
                                                        <i class="fas fa-trash"></i> Delete
                                                    </button>
                                                </div>
                                            </div>
                                        }
                                    }
                                    else
                                    {
                                        <div class="no-units-message">No armoured regiments found. Click "Add New" to create one.</div>
                                    }
                                </div>
                                
                                <div class="add-unit-section">
                                    <button type="button" class="btn btn-primary" onclick="openArmouredRegimentForm('@Model.Token.Id', '@Model.ExistingBrigade.Id')">
                                        <i class="fas fa-plus"></i> Add New Armoured Regiment
                                    </button>
                                </div>
                            </div>
                            <div id="artillery-data" class="data-tab-content">
                                <div class="tab-content-header">
                                    <h6><i class="fas fa-crosshairs"></i> Artillery Regiments</h6>
                                    <p class="text-muted">Manage artillery regiments for Brigade @Model.ExistingBrigade.BrigadeCode</p>
                                </div>
                                
                                <div id="artilleryRegimentsList" class="units-list">
                                    @if (Model.ExistingArtillery != null && Model.ExistingArtillery.Any())
                                    {
                                        @foreach (var regiment in Model.ExistingArtillery)
                                        {
                                            var regimentData = (dynamic)regiment;
                                            <div class="unit-item">
                                                <div class="unit-info">
                                                    <div class="unit-name1">@regimentData.Name</div>
                                                    <div class="unit-details">Code: @regimentData.UnitCode | Strength: @regimentData.Strength | Guns: @regimentData.Guns</div>
                                                </div>
                                                <div class="unit-actions">
                                                    <button class="btn btn-sm btn-outline-secondary" onclick="editBrigadeUnit('artillery', '@Model.Token.Id', '@Model.ExistingBrigade.Id', '@regimentData.Id')">
                                                        <i class="fas fa-edit"></i> Edit
                                                    </button>
                                                    <button class="btn btn-sm btn-outline-danger" onclick="deleteBrigadeUnit('artillery', '@regimentData.Id', '@Model.Token.Id', '@Model.ExistingBrigade.Id')">
                                                        <i class="fas fa-trash"></i> Delete
                                                    </button>
                                                </div>
                                            </div>
                                        }
                                    }
                                    else
                                    {
                                        <div class="no-units-message">No artillery regiments found. Click "Add New" to create one.</div>
                                    }
                                </div>
                                
                                <div class="add-unit-section">
                                    <button type="button" class="btn btn-primary" onclick="openArtilleryRegimentForm('@Model.Token.Id', '@Model.ExistingBrigade.Id')">
                                        <i class="fas fa-plus"></i> Add New Artillery Regiment
                                    </button>
                                </div>
                            </div>
                            <div id="logistics-data" class="data-tab-content">
                                <div class="tab-content-header">
                                    <h6><i class="fas fa-truck"></i> Logistics Units</h6>
                                    <p class="text-muted">Manage logistics units for Brigade @Model.ExistingBrigade.BrigadeCode</p>
                                </div>
                                
                                <div id="logisticsUnitsList" class="units-list">
                                    @if (Model.ExistingLogistics != null)
                                    {
                                        <div class="unit-item">
                                            <div class="unit-info">
                                                <div class="unit-name1">@Model.ExistingLogistics.Name</div>
                                                <div class="unit-details">Code: @Model.ExistingLogistics.UnitCode | Strength: @Model.ExistingLogistics.Strength | Supply Trucks: @Model.ExistingLogistics.SupplyTrucks</div>
                                            </div>
                                            <div class="unit-actions">
                                                <button class="btn btn-sm btn-outline-secondary" onclick="editBrigadeUnit('logistics', '@Model.Token.Id', '@Model.ExistingBrigade.Id', '@Model.ExistingLogistics.Id')">
                                                    <i class="fas fa-edit"></i> Edit
                                                </button>
                                                <button class="btn btn-sm btn-outline-danger" onclick="deleteBrigadeUnit('logistics', '@Model.ExistingLogistics.Id', '@Model.Token.Id', '@Model.ExistingBrigade.Id')">
                                                    <i class="fas fa-trash"></i> Delete
                                                </button>
                                            </div>
                                        </div>
                                    }
                                    else
                                    {
                                        <div class="no-units-message">No logistics units found. Click "Add New" to create one.</div>
                                    }
                                </div>
                                
                                <div class="add-unit-section">
                                    <button type="button" class="btn btn-primary" onclick="openLogisticsUnitForm('@Model.Token.Id', '@Model.ExistingBrigade.Id')">
                                        <i class="fas fa-plus"></i> Add New Logistics Unit
                                    </button>
                                </div>
                            </div>
                            <div id="engineering-data" class="data-tab-content">
                                <div class="tab-content-header">
                                    <h6><i class="fas fa-hard-hat"></i> Combat Engineering Companies</h6>
                                    <p class="text-muted">Manage combat engineering companies for Brigade @Model.ExistingBrigade.BrigadeCode</p>
                                </div>
                                
                                <div id="engineeringCompaniesList" class="units-list">
                                    @if (Model.ExistingEngineering != null)
                                    {
                                        <div class="unit-item">
                                            <div class="unit-info">
                                                <div class="unit-name1">@Model.ExistingEngineering.Name</div>
                                                <div class="unit-details">Code: @Model.ExistingEngineering.UnitCode | Strength: @Model.ExistingEngineering.Strength | Vehicles: @Model.ExistingEngineering.BridgeLayingVehicles</div>
                                            </div>
                                            <div class="unit-actions">
                                                <button class="btn btn-sm btn-outline-secondary" onclick="editBrigadeUnit('engineering', '@Model.Token.Id', '@Model.ExistingBrigade.Id', '@Model.ExistingEngineering.Id')">
                                                    <i class="fas fa-edit"></i> Edit
                                                </button>
                                                <button class="btn btn-sm btn-outline-danger" onclick="deleteBrigadeUnit('engineering', '@Model.ExistingEngineering.Id', '@Model.Token.Id', '@Model.ExistingBrigade.Id')">
                                                    <i class="fas fa-trash"></i> Delete
                                                </button>
                                            </div>
                                        </div>
                                    }
                                    else
                                    {
                                        <div class="no-units-message">No combat engineering companies found. Click "Add New" to create one.</div>
                                    }
                                </div>
                                
                                <div class="add-unit-section">
                                    <button type="button" class="btn btn-primary" onclick="openCombatEngineeringCompanyForm('@Model.Token.Id', '@Model.ExistingBrigade.Id')">
                                        <i class="fas fa-plus"></i> Add New Combat Engineering Company
                                    </button>
                                </div>
                            </div>
                            <div id="recon-data" class="data-tab-content">
                                <div class="tab-content-header">
                                    <h6><i class="fas fa-binoculars"></i> Reconnaissance</h6>
                                    <p class="text-muted">Manage reconnaissance for Brigade @Model.ExistingBrigade.BrigadeCode</p>
                                </div>
                                
                                <div id="reconnaissanceList" class="units-list">
                                    @if (Model.ExistingRecon != null && Model.ExistingRecon.Any())
                                    {
                                        @foreach (var recon in Model.ExistingRecon)
                                        {
                                            var reconData = (dynamic)recon;
                                            <div class="unit-item">
                                                <div class="unit-info">
                                                    <div class="unit-name1">@reconData.ReconType</div>
                                                    <div class="unit-details">Location: @reconData.Location | Confidence: @reconData.Confidence</div>
                                                </div>
                                                <div class="unit-actions">
                                                    <button class="btn btn-sm btn-outline-secondary" onclick="editBrigadeUnit('recon', '@Model.Token.Id', '@Model.ExistingBrigade.Id', '@reconData.Id')">
                                                        <i class="fas fa-edit"></i> Edit
                                                    </button>
                                                    <button class="btn btn-sm btn-outline-danger" onclick="deleteBrigadeUnit('recon', '@reconData.Id', '@Model.Token.Id', '@Model.ExistingBrigade.Id')">
                                                        <i class="fas fa-trash"></i> Delete
                                                    </button>
                                                </div>
                                            </div>
                                        }
                                    }
                                    else
                                    {
                                        <div class="no-units-message">No reconnaissance found. Click "Add New" to create one.</div>
                                    }
                                </div>
                                
                                <div class="add-unit-section">
                                    <button type="button" class="btn btn-primary" onclick="openReconnaissanceForm('@Model.Token.Id', '@Model.ExistingBrigade.Id')">
                                        <i class="fas fa-plus"></i> Add New Reconnaissance
                                    </button>
                                </div>
                            </div>
                        </div>
                    }
                    else if (Model.AvailableBrigades.Any())
                    {
                        <!-- Link to Existing Brigade -->
                        <div class="alert alert-warning">
                            <i class="fas fa-link"></i> Link this token to an existing brigade or create new brigade data.
                        </div>
                        
                        <div class="form-group">
                            <label>Select Existing Brigade:</label>
                            <select class="form-control" id="brigadeSelector">
                                <option value="">-- Select a Brigade --</option>
                                @foreach (var brigade in Model.AvailableBrigades)
                                {
                                    <option value="@brigade.Id">Brigade @brigade.BrigadeCode</option>
                                }
                            </select>
                        </div>
                        
                        <div class="text-center mb-3">
                            <button type="button" class="btn btn-primary" onclick="linkSelectedBrigade('@Model.Token.Id')">
                                <i class="fas fa-link"></i> Link Brigade to Token
                            </button>
                        </div>
                        
                        <hr>
                        <p class="text-center text-muted">OR</p>
                        
                        <div class="text-center">
                            <button type="button" class="btn btn-success" onclick="createNewBrigadeData('@Model.Token.Id')">
                                <i class="fas fa-plus"></i> Create New Brigade Data
                            </button>
                        </div>
                    }
                    else
                    {
                        <!-- No Brigade - Direct Unit Entry Options -->
                        <div class="alert alert-info">
                            <i class="fas fa-info-circle"></i> 
                            <strong>Flexible Unit Entry:</strong> You can add units directly to this token or create a brigade first.
                        </div>
                        
                        <!-- Direct Unit Entry Options -->
                        <div class="direct-unit-entry-section">
                            <h6><i class="fas fa-users"></i> Add Units Directly to Token</h6>
                            <p class="text-muted">Add military units directly to this token without requiring a brigade.</p>
                            
                            <!-- Show existing units without brigade -->
                            @if (Model.ExistingInfantry.Any() || Model.ExistingArmoured.Any() || Model.ExistingArtillery.Any() || Model.ExistingLogistics != null || Model.ExistingEngineering != null)
                            {
                                <div class="existing-direct-units-summary">
                                    <h6><i class="fas fa-list"></i> Existing Units</h6>
                                    
                                    @if (Model.ExistingInfantry.Any())
                                    {
                                        <div class="unit-summary-item">
                                            <i class="fas fa-user-shield"></i>
                                            <strong>Infantry Battalions:</strong> @Model.ExistingInfantry.Count
                                            <button class="btn btn-sm btn-outline-primary" onclick="openDirectUnitForm('infantry', '@Model.Token.Id')">
                                                <i class="fas fa-eye"></i> View/Manage
                                            </button>
                                        </div>
                                    }
                                    
                                    @if (Model.ExistingArmoured.Any())
                                    {
                                        <div class="unit-summary-item">
                                            <i class="fas fa-shield-alt"></i>
                                            <strong>Armoured Regiments:</strong> @Model.ExistingArmoured.Count
                                            <button class="btn btn-sm btn-outline-primary" onclick="openDirectUnitForm('armoured', '@Model.Token.Id')">
                                                <i class="fas fa-eye"></i> View/Manage
                                            </button>
                                        </div>
                                    }
                                    
                                    @if (Model.ExistingArtillery.Any())
                                    {
                                        <div class="unit-summary-item">
                                            <i class="fas fa-crosshairs"></i>
                                            <strong>Artillery Regiments:</strong> @Model.ExistingArtillery.Count
                                            <button class="btn btn-sm btn-outline-primary" onclick="openDirectUnitForm('artillery', '@Model.Token.Id')">
                                                <i class="fas fa-eye"></i> View/Manage
                                            </button>
                                        </div>
                                    }
                                    
                                    @if (Model.ExistingLogistics != null)
                                    {
                                        <div class="unit-summary-item">
                                            <i class="fas fa-truck"></i>
                                            <strong>Logistics Unit:</strong> @Model.ExistingLogistics.Name
                                            <button class="btn btn-sm btn-outline-primary" onclick="openDirectUnitForm('logistics', '@Model.Token.Id')">
                                                <i class="fas fa-eye"></i> View/Manage
                                            </button>
                                        </div>
                                    }
                                    
                                    @if (Model.ExistingEngineering != null)
                                    {
                                        <div class="unit-summary-item">
                                            <i class="fas fa-hard-hat"></i>
                                            <strong>Engineering Company:</strong> @Model.ExistingEngineering.Name
                                            <button class="btn btn-sm btn-outline-primary" onclick="openDirectUnitForm('engineering', '@Model.Token.Id')">
                                                <i class="fas fa-eye"></i> View/Manage
                                            </button>
                                        </div>
                                    }
                                </div>
                                
                                <hr style="margin: 20px 0; border-top: 2px dashed #dee2e6;" />
                            }
                            
                            <h6><i class="fas fa-plus-circle"></i> Add More Units</h6>
                            <div class="direct-unit-buttons">
                                <button type="button" class="btn btn-outline-primary btn-sm" onclick="openDirectUnitForm('infantry', '@Model.Token.Id')">
                                    <i class="fas fa-user-shield"></i> Infantry Battalion
                                </button>
                                <button type="button" class="btn btn-outline-primary btn-sm" onclick="openDirectUnitForm('armoured', '@Model.Token.Id')">
                                    <i class="fas fa-shield-alt"></i> Armoured Regiment
                                </button>
                                <button type="button" class="btn btn-outline-primary btn-sm" onclick="openDirectUnitForm('artillery', '@Model.Token.Id')">
                                    <i class="fas fa-crosshairs"></i> Artillery Regiment
                                </button>
                                <button type="button" class="btn btn-outline-primary btn-sm" onclick="openDirectUnitForm('logistics', '@Model.Token.Id')">
                                    <i class="fas fa-truck"></i> Logistics Unit
                                </button>
                                <button type="button" class="btn btn-outline-primary btn-sm" onclick="openDirectUnitForm('engineering', '@Model.Token.Id')">
                                    <i class="fas fa-hard-hat"></i> Engineering
                                </button>
                            </div>
                        </div>
                        
                        <hr>
                        <p class="text-center text-muted">OR</p>
                        
                        <!-- Brigade Creation Option -->
                        <div class="brigade-creation-section">
                            <h6><i class="fas fa-flag"></i> Create Brigade First</h6>
                            <p class="text-muted">Create a brigade to organize units under a command structure.</p>
                            
                            <div class="text-center">
                                <button type="button" class="btn btn-success" onclick="createNewBrigadeData('@Model.Token.Id')">
                                    <i class="fas fa-plus"></i> Create New Brigade Data
                                </button>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
        <div class="modal-footer">
            <button type="button" class="btn btn-secondary" data-dismiss="modal">
                <i class="fas fa-times"></i> Close
            </button>
        </div>
    </div>
    </div>
</div>

<style>
/* Dark Theme Data Entry Form */
.data-entry-container {
    background: #1a1a1a;
    border-radius: 8px;
    padding: 20px;
}

.token-base-section {
    background: #e8f5e8;
    border: 2px solid #28a745;
    border-radius: 8px;
    padding: 20px;
    margin-bottom: 25px;
}

.token-base-section h5 {
    color: #28a745;
    margin-bottom: 15px;
    font-weight: 600;
}

.token-display {
    display: flex;
    align-items: center;
    gap: 15px;
}

.token-preview-image {
    width: 60px;
    height: 60px;
    border-radius: 8px;
    object-fit: cover;
    border: 2px solid #28a745;
}

.token-preview-placeholder {
    width: 60px;
    height: 60px;
    border-radius: 8px;
    background: linear-gradient(135deg, #28a745 0%, #20c997 100%);
    display: flex;
    align-items: center;
    justify-content: center;
    color: white;
    font-size: 24px;
    border: 2px solid #28a745;
}

.token-details h4 {
    margin: 0;
    color: #2c3e50;
}

.token-status {
    margin-top: 8px;
    display: flex;
    gap: 8px;
}

.badge {
    padding: 4px 8px;
    border-radius: 4px;
    font-size: 11px;
    font-weight: 600;
}

.badge-primary {
    background: #007bff;
    color: white;
}

.badge-info {
    background: #17a2b8;
    color: white;
}

.direct-unit-entry-section {
    background: #f8f9fa;
    border: 1px solid #dee2e6;
    border-radius: 8px;
    padding: 20px;
    margin-bottom: 20px;
}

.direct-unit-entry-section h6 {
    color: #495057;
    margin-bottom: 10px;
    font-weight: 600;
}

.direct-unit-buttons {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    margin-top: 15px;
}

.direct-unit-buttons .btn {
    flex: 1;
    min-width: 140px;
    text-align: center;
}

.existing-direct-units-summary {
    background: #f8f9fa;
    border: 1px solid #dee2e6;
    border-radius: 8px;
    padding: 15px;
    margin-bottom: 20px;
}

.existing-direct-units-summary h6 {
    color: #2c3e50;
    margin-bottom: 15px;
    font-weight: 600;
}

.unit-summary-item {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 12px;
    background: white;
    border: 1px solid #dee2e6;
