// Generic brigade unit form opener with loader
function openBrigadeUnitForm(unitType, tokenId, brigadeId, unitId = null) {
    console.log('🚀 Loading brigade unit form:', { unitType, tokenId, brigadeId, unitId });
    
    const params = {
        unitType: unitType,
        tokenId: tokenId,
        brigadeId: brigadeId
    };
    
    if (unitId) {
        params.unitId = unitId;
    }
    
    showLoader();
    
    $.get('/DataManagement/BrigadeUnitCreationForm', params, function(data) {
        // Remove any existing modal
        $('#brigadeUnitCreationModal').remove();
        
        // Append the new modal to body
        $('body').append(data);
        
        // Show the modal
        $('#brigadeUnitCreationModal').modal('show');
        
        hideLoader();
        console.log('✅ Brigade unit form loaded successfully');
