<script>
// Close token data entry modal
function closeTokenDataEntryModal() {
    console.log('🔒 Closing token data entry modal');
    document.getElementById('tokenDataEntryModal').style.display = 'none';
}

// Show different data tabs
function showDataTab(tabName) {
    // Hide all tab contents
    document.querySelectorAll('.data-tab-content').forEach(tab => {
        tab.classList.remove('active');
    });
    
    // Remove active class from all tabs
    document.querySelectorAll('.data-tab').forEach(tab => {
        tab.classList.remove('active');
    });
    
    // Show selected tab content
    document.getElementById(tabName + '-data').classList.add('active');
    
    // Activate clicked tab
    event.target.classList.add('active');
}

// Link selected brigade to token
function linkSelectedBrigade(tokenId) {
    const brigadeId = document.getElementById('brigadeSelector').value;
    if (!brigadeId) {
        alert('Please select a brigade first');
        return;
    }
    
    console.log('🔗 Linking brigade', brigadeId, 'to token', tokenId);
    // Implementation will be added later
    alert('Brigade linking functionality to be implemented');
}

// Create new brigade data
function createNewBrigadeData(tokenId) {
    console.log('🆕 Creating new brigade data for token', tokenId);
    
    // Close current modal
    closeTokenDataEntryModal();
    
    // Show loading
    $("#loading").show();
    
    // Load the new brigade creation form via AJAX
    $.ajax({
        url: '/DataManagement/NewBrigadeDataEntryForm',
        type: 'GET',
        data: { tokenId: tokenId },
        success: function(data) {
            console.log('✅ New brigade form loaded for token:', tokenId);
            
            // Remove any existing new brigade modal
            $('#newBrigadeDataEntryModal').remove();
            
            // Add the new modal to the body
            $('body').append(data);
            
            // Show the modal
            document.getElementById('newBrigadeDataEntryModal').style.display = 'flex';
            
            console.log('✅ New brigade form displayed successfully');
        },
        error: function(xhr, status, error) {
            console.error('❌ Error loading new brigade form:', error);
            console.error('   Status Code:', xhr.status);
            console.error('   Response Text:', xhr.responseText);
            
            let errorMessage = 'Failed to load new brigade form';
            if (xhr.status === 404) {
                errorMessage = 'New brigade form not found (404)';
            } else if (xhr.status === 500) {
                errorMessage = 'Server error loading new brigade form (500)';
            }
            
            alert(errorMessage);
        },
        complete: function() {
            $("#loading").hide();
        }
    });
}

// Edit brigade code
function editBrigadeCode() {
    const currentCode = document.querySelector('.brigade-name-display h5').textContent.replace('Brigade ', '').replace(' Information', '');
    const newCode = prompt('Enter new brigade code:', currentCode);
    
    if (newCode && newCode.trim() !== '' && newCode !== currentCode) {
        console.log('✏️ Updating brigade code from', currentCode, 'to', newCode);
        
        // Update the display
        document.querySelector('.brigade-name-display h5').textContent = 'Brigade ' + newCode + ' Information';
        
        // Update all references in tab content
        document.querySelectorAll('.tab-content-header .text-muted').forEach(element => {
            element.textContent = element.textContent.replace('Brigade ' + currentCode, 'Brigade ' + newCode);
        });
        
        // Here you would typically make an AJAX call to save the new code
        // For now, just show a success message
        alert('Brigade code updated successfully!');
    }
}

