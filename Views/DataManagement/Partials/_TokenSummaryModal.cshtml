@model TechWebSol.Controllers.DataManagementController.TokenSummaryViewModel

<!-- Token Summary Modal -->
<div id="tokenSummaryModal" class="gameplay-modal" style="display: none;">
    <div class="gameplay-modal-content">
        <div class="gameplay-modal-header">
            <h3><i class="fas fa-info-circle"></i> Token Summary</h3>
            <button class="gameplay-modal-close" onclick="closeTokenSummaryModal()">&times;</button>
        </div>
        
        <div class="gameplay-modal-body">
            <!-- Token Information -->
            <div class="token-summary-section">
                <h6><i class="fas fa-map-marker-alt"></i> Token Information</h6>
                <div class="summary-item">
                    <strong>Name:</strong> @(Model.Token?.Name ?? "Unknown Token")
                    <span class="badge-military">@(Model.Token?.TokenGroup?.Name ?? "Generic")</span>
                </div>
                @if (Model.Token?.MapMarkers?.Any() == true)
                {
                    var activeMarker = Model.Token.MapMarkers.FirstOrDefault();
                    if (activeMarker != null)
                    {
                        <div class="summary-item">
                            <strong>Position:</strong> @(activeMarker.latitude), @(activeMarker.longitude)
                        </div>
                    }
                }
                <div class="summary-item">
                    <strong>Status:</strong> <span class="badge-military">@(Model.Token?.IsActive == true ? "Active" : "Inactive")</span>
                </div>
            </div>

            @if (Model.Brigades.Any() || Model.InfantryBattalions.Any() || Model.ArmouredRegiments.Any() || Model.ArtilleryRegiments.Any() || Model.Recon.Any())
            {
                <!-- Military Hierarchy -->
                <div class="token-summary-section">
                    <h6><i class="fas fa-sitemap"></i> Military Hierarchy</h6>
                    
                    @if (Model.Brigades.Any())
                    {
                        @foreach (var brigade in Model.Brigades)
                        {
                            <div class="summary-item brigade">
                                <strong>Brigade:</strong> @(brigade.Name ?? "Unnamed Brigade")
                                <span class="badge-military">@(brigade.ForceType ?? "Unknown")</span>
                                <div class="text-muted">@(brigade.Description ?? "")</div>
                                
                                <!-- Infantry Units under this Brigade -->
                                @{
                                    var brigadeInfantry = Model.InfantryBattalions.Where(i => i.BrigadeId == brigade.Id).ToList();
                                }
                                @if (brigadeInfantry.Any())
                                {
                                    @foreach (var infantry in brigadeInfantry)
                                    {
                                        <div class="hierarchy-level">
                                            <div class="summary-item infantry">
                                                <strong>Infantry Battalion:</strong> @(infantry.Name ?? "Unnamed Infantry")
                                                <span class="badge-military">Strength: @(infantry.Strength)</span>
                                                <div class="text-muted">@(infantry.Description ?? "")</div>
                                            </div>
                                        </div>
                                    }
                                }
                                
                                <!-- Armoured Units under this Brigade -->
                                @{
                                    var brigadeArmoured = Model.ArmouredRegiments.Where(a => a.BrigadeId == brigade.Id).ToList();
                                }
                                @if (brigadeArmoured.Any())
                                {
                                    @foreach (var armoured in brigadeArmoured)
                                    {
                                        <div class="hierarchy-level">
                                            <div class="summary-item armoured">
                                                <strong>Armoured Regiment:</strong> @(armoured.Name ?? "Unnamed Armoured")
                                                <span class="badge-military">Tanks: @(armoured.Tanks)</span>
                                                <div class="text-muted">@(armoured.Description ?? "")</div>
                                            </div>
                                        </div>
                                    }
                                }
                                
                                <!-- Artillery Units under this Brigade -->
                                @{
                                    var brigadeArtillery = Model.ArtilleryRegiments.Where(a => a.BrigadeId == brigade.Id).ToList();
                                }
                                @if (brigadeArtillery.Any())
                                {
                                    @foreach (var artillery in brigadeArtillery)
                                    {
                                        <div class="hierarchy-level">
                                            <div class="summary-item artillery">
                                                <strong>Artillery Regiment:</strong> @(artillery.Name ?? "Unnamed Artillery")
                                                <span class="badge-military">Guns: @(artillery.Guns)</span>
                                                <div class="text-muted">@(artillery.Description ?? "")</div>
                                            </div>
                                        </div>
                                    }
                                }
                            </div>
                        }
                    }
                </div>
                
                
                @if (Model.Recon.Any())
                {
                    <!-- Reconnaissance Reports -->
                    <div class="token-summary-section">
                        <h6><i class="fas fa-search"></i> Reconnaissance Reports (@Model.Recon.Count)</h6>
                        @foreach (var reconItem in Model.Recon.Take(3))
                        {
                            <div class="summary-item recon">
                                <strong>@(reconItem.ReconType ?? "Untitled Recon")</strong>
                                <span class="badge-military">@(reconItem.Confidence ?? "Unknown Confidence")</span>
                                <div class="text-muted">Location: @(reconItem.Location ?? "Unknown")</div>
                                <div class="text-muted">@(reconItem.Description?.Length > 100 ? reconItem.Description.Substring(0, 100) + "..." : reconItem.Description ?? "")</div>
                            </div>
                        }
                        @if (Model.Recon.Count > 3)
                        {
                            <div class="text-muted text-center">... and @(Model.Recon.Count - 3) more reconnaissance reports</div>
                        }
                    </div>
                }
            }
            else
            {
                <!-- No Data Available -->
                <div class="no-data-message">
                    <i class="fas fa-exclamation-triangle fa-2x text-warning mb-3"></i>
                    <h6>No Military Data Available</h6>
                    <p>This token has not been linked to any military units, brigades, or reports yet.</p>
                    <button type="button" class="btn btn-primary btn-sm" onclick="addTokenData()">
                        <i class="fas fa-plus"></i> Add Military Data
                    </button>
                </div>
            }
        </div>
        
        <div class="gameplay-modal-footer">
            <button class="gameplay-btn" onclick="closeTokenSummaryModal()">Close</button>
            @if (Model.Brigades.Any() || Model.InfantryBattalions.Any() || Model.ArmouredRegiments.Any() || Model.ArtilleryRegiments.Any() || Model.Recon.Any())
            {
                <button class="gameplay-btn gameplay-btn-primary" onclick="editTokenData()">
                    <i class="fas fa-edit"></i> Edit Data
                </button>
            }
            else
            {
                <button class="gameplay-btn gameplay-btn-success" onclick="addTokenData()">
                    <i class="fas fa-plus"></i> Add Data
                </button>
            }
        </div>
    </div>
</div>

<script>
// Global token summary modal functions
if (typeof currentTokenId === 'undefined') {
    var currentTokenId = null;
}

function closeTokenSummaryModal() {
    console.log('🔒 Closing token summary modal');
    const modal = document.getElementById('tokenSummaryModal');
    if (modal) {
        modal.style.display = 'none';
        currentTokenId = null;
    }
}

function editTokenData() {
    if (currentTokenId) {
        console.log('✏️ Opening data entry for token:', currentTokenId);
        closeTokenSummaryModal();
        // Open data entry flow for this token
        openDataEntryForToken(currentTokenId);
    }
}

function addTokenData() {
    if (currentTokenId) {
        console.log('➕ Adding new data for token:', currentTokenId);
        closeTokenSummaryModal();
        // Open data entry flow for this token
        openDataEntryForToken(currentTokenId);
    }
}

function openDataEntryForToken(tokenId) {
    // Navigate directly to the token data entry form
    $("#loading").show();
    
    $.ajax({
        url: '/DataManagement/TokenDataEntryForm',
        type: 'GET',
        data: { tokenId: tokenId },
        success: function(data) {
            console.log('✅ Direct data entry form loaded for token:', tokenId);
            $('#tokenDataEntryModal').remove();
            $('body').append(data);
            document.getElementById('tokenDataEntryModal').style.display = 'flex';
        },
        error: function(xhr, status, error) {
            console.error('❌ Error loading direct data entry form:', error);
            alert('Failed to load data entry form');
        },
        complete: function() {
            $("#loading").hide();
        }
    });
}

// Set the current token ID when modal loads
@if (Model.Token != null)
{
    <text>
    currentTokenId = '@Model.Token.Id';
    </text>
}
</script>

<style>
/* Token Summary Modal - Dark Theme Matching Place Token Modal */
.token-summary-section {
    margin-bottom: 15px;
    padding: 12px;
    background-color: #1a1a1a;
    border-radius: 8px;
    border: 1px solid #333;
}

.token-summary-section h6 {
    color: #00d4ff;
    margin-bottom: 8px;
    font-weight: 600;
    font-size: 14px;
    text-transform: uppercase;
    letter-spacing: 0.5px;
}

.summary-item {
    margin-bottom: 6px;
    padding: 6px 8px;
    background-color: #2a2a2a;
    border-radius: 4px;
    border-left: 3px solid #555;
    font-size: 13px;
}

.summary-item.brigade {
    border-left-color: #ff4444;
    background-color: #2a1a1a;
}

.summary-item.infantry {
    border-left-color: #ffaa00;
    background-color: #2a2a1a;
}

.summary-item.armoured {
    border-left-color: #00aa44;
    background-color: #1a2a1a;
}

.summary-item.artillery {
    border-left-color: #aa44ff;
    background-color: #2a1a2a;
}

.summary-item.intelligence {
    border-left-color: #00aaaa;
    background-color: #1a2a2a;
}

.summary-item.recon {
    border-left-color: #aaaa00;
    background-color: #2a2a1a;
}

.summary-item strong {
    color: #ffffff;
    font-weight: 600;
}

.summary-item .text-muted {
    color: #888 !important;
    font-size: 12px;
    margin-top: 2px;
}

.badge-military {
    background-color: #00d4ff;
    color: #000;
    padding: 2px 6px;
    border-radius: 10px;
    font-size: 11px;
    margin-left: 5px;
    font-weight: 600;
}

.no-data-message {
    text-align: center;
    padding: 20px;
    color: #888;
    font-style: italic;
    background-color: #1a1a1a;
    border-radius: 8px;
    border: 1px solid #333;
}

.hierarchy-level {
    margin-left: 15px;
    position: relative;
}

.hierarchy-level::before {
    content: "└─";
    position: absolute;
    left: -12px;
    color: #666;
    font-size: 12px;
}

/* Compact layout for all information on one screen */
.gameplay-modal-body {
    max-height: 70vh;
    overflow-y: auto;
}

.token-summary-section:last-child {
    margin-bottom: 0;
}

/* Scrollbar styling for dark theme */
.gameplay-modal-body::-webkit-scrollbar {
    width: 6px;
}

.gameplay-modal-body::-webkit-scrollbar-track {
    background: #1a1a1a;
}

.gameplay-modal-body::-webkit-scrollbar-thumb {
    background: #444;
    border-radius: 3px;
}

.gameplay-modal-body::-webkit-scrollbar-thumb:hover {
    background: #666;
}
</style>
