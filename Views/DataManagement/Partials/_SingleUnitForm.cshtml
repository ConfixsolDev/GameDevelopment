/* Required field indicator */
label:after {
    content: '';
}

label[for$="Name"]:after,
label[for$="Code"]:after,
label[for$="Title"]:after,
label[for$="Type"]:after,
label[for$="Description"]:after {
    content: ' *';
    color: #ff4444;
}

/* Responsive adjustments */
@@media (max-width: 768px) {
    .form-row {
        flex-direction: column;
        gap: 0;
    }
    
    .large-modal {
        width: 95%;
        margin: 10px auto;
    }
