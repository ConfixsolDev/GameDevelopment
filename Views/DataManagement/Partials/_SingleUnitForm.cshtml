</style>

<script>
// Close single unit modal
function closeSingleUnitModal() {
    console.log('🔒 Closing single unit modal');
    document.getElementById('singleUnitModal').style.display = 'none';
}

// Save single unit
function saveSingleUnit() {
    const unitType = document.getElementById('unitType').value;
    console.log('💾 Saving single unit:', unitType);
    
    if (unitType === 'infantry') {
        saveInfantryBattalion();
    } else if (unitType === 'armoured') {
        saveArmouredRegiment();
    } else if (unitType === 'artillery') {
        saveArtilleryRegiment();
    } else if (unitType === 'intelligence') {
        saveIntelligence();
    } else if (unitType === 'recon') {
        saveReconnaissance();
    }
}

// Save Infantry Battalion
function saveInfantryBattalion() {
    console.log('💾 Saving Infantry Battalion...');
    
     const infantryData = {
         brigadeId: document.getElementById('brigadeId').value,
         tokenId: document.getElementById('tokenId').value,
         teamId: document.getElementById('teamId').value,
         forceType: document.getElementById('forceType').value,
         name: document.getElementById('infantryName').value,
         unitCode: document.getElementById('infantryCode').value,
         strength: parseInt(document.getElementById('infantryStrength').value) || 0,
         companies: parseInt(document.getElementById('infantryCompanies').value) || 0,
         description: document.getElementById('infantryDescription').value,
         atgms: parseInt(document.getElementById('infantryATGMS').value) || 0,
         rocketLauncher: parseInt(document.getElementById('infantryRocketLauncher').value) || 0,
         mortars81mm: parseInt(document.getElementById('infantryMortars81mm').value) || 0,
         mortars120mm: parseInt(document.getElementById('infantryMortars120mm').value) || 0,
         grenadeLaunchers: parseInt(document.getElementById('infantryGrenadeLaunchers').value) || 0,
         hmg_AGL: parseInt(document.getElementById('infantryHMG_AGL').value) || 0,
         mg_LMG: parseInt(document.getElementById('infantryMG_LMG').value) || 0,
         manpads: parseInt(document.getElementById('infantryMANPADS').value) || 0,
         grenades: parseInt(document.getElementById('infantryGrenades').value) || 0,
         drones: parseInt(document.getElementById('infantryDrones').value) || 0,
         droneTypes: document.getElementById('infantryDroneTypes').value,
         marchingSpeedTrucksRoads: parseFloat(document.getElementById('infantryMarchingSpeedTrucksRoads').value) || 30,
         marchingSpeedAPCs: parseFloat(document.getElementById('infantryMarchingSpeedAPCs').value) || 20,
         marchingSpeedCrossCountry: parseFloat(document.getElementById('infantryMarchingSpeedCrossCountry').value) || 5,
         marchingSpeedAPCsCrossCountry: parseFloat(document.getElementById('infantryMarchingSpeedAPCsCrossCountry').value) || 10,
         combatAdvanceSpeed: parseFloat(document.getElementById('infantryCombatAdvanceSpeed').value) || 1
     };
    
    // Validation
    if (!infantryData.name || !infantryData.unitCode) {
        alert('Please fill in Battalion Name and Unit Code');
        return;
    }
    
    // Save via AJAX
    saveUnit('infantry', infantryData, 'Infantry Battalion');
}

// Save Armoured Regiment
function saveArmouredRegiment() {
    console.log('💾 Saving Armoured Regiment...');
    
     const armouredData = {
         brigadeId: document.getElementById('brigadeId').value,
         tokenId: document.getElementById('tokenId').value,
         teamId: document.getElementById('teamId').value,
         forceType: document.getElementById('forceType').value,
         name: document.getElementById('armouredName').value,
         unitCode: document.getElementById('armouredCode').value,
         strength: parseInt(document.getElementById('armouredStrength').value) || 0,
         squadrons: parseInt(document.getElementById('armouredSquadrons').value) || 0,
         description: document.getElementById('armouredDescription').value,
         tanks: parseInt(document.getElementById('armouredTanks').value) || 0,
         atgms: parseInt(document.getElementById('armouredATGMS').value) || 0,
         mortars120mm: parseInt(document.getElementById('armouredMortars120mm').value) || 0,
         hmg: parseInt(document.getElementById('armouredHMG').value) || 0,
         drones: parseInt(document.getElementById('armouredDrones').value) || 0,
         droneTypes: document.getElementById('armouredDroneTypes').value,
         marchingSpeedRoads: parseFloat(document.getElementById('armouredMarchingSpeedRoads').value) || 15,
         marchingSpeedCrossCountry: parseFloat(document.getElementById('armouredMarchingSpeedCrossCountry').value) || 10,
         combatAdvanceSpeed: parseFloat(document.getElementById('armouredCombatAdvanceSpeed').value) || 1
     };
    
    // Validation
    if (!armouredData.name || !armouredData.unitCode) {
        alert('Please fill in Regiment Name and Unit Code');
        return;
    }
    
    // Save via AJAX
    saveUnit('armoured', armouredData, 'Armoured Regiment');
}

// Save Artillery Regiment
function saveArtilleryRegiment() {
    console.log('💾 Saving Artillery Regiment...');
    
     const artilleryData = {
         brigadeId: document.getElementById('brigadeId').value,
         tokenId: document.getElementById('tokenId').value,
         teamId: document.getElementById('teamId').value,
         forceType: document.getElementById('forceType').value,
         name: document.getElementById('artilleryName').value,
         unitCode: document.getElementById('artilleryCode').value,
         strength: parseInt(document.getElementById('artilleryStrength').value) || 0,
         batteries: parseInt(document.getElementById('artilleryBatteries').value) || 0,
         description: document.getElementById('artilleryDescription').value,
         guns: parseInt(document.getElementById('artilleryGuns').value) || 0,
         gunRange: parseFloat(document.getElementById('artilleryGunRange').value) || 0,
         gunCaliber: document.getElementById('artilleryGunCaliber').value,
         hmg: parseInt(document.getElementById('artilleryHMG').value) || 0,
         drones: parseInt(document.getElementById('artilleryDrones').value) || 0,
         droneTypes: document.getElementById('artilleryDroneTypes').value
     };
    
    // Validation
    if (!artilleryData.name || !artilleryData.unitCode) {
        alert('Please fill in Regiment Name and Unit Code');
        return;
    }
    
    // Save via AJAX
    saveUnit('artillery', artilleryData, 'Artillery Regiment');
}

// Save Intelligence Report
function saveIntelligence() {
    console.log('💾 Saving Intelligence Report...');
    
    const intelData = {
        tokenId: document.getElementById('tokenId').value,
        title: document.getElementById('intelTitle').value,
        source: document.getElementById('intelSource').value,
        priority: document.getElementById('intelPriority').value,
        description: document.getElementById('intelDescription').value
    };
    
    // Validation
    if (!intelData.title || !intelData.priority || !intelData.description) {
        alert('Please fill in Title, Priority, and Description');
        return;
    }
    
    $("#loading").show();
    
    $.ajax({
        url: '/DataManagement/CreateTokenIntelligence',
        type: 'POST',
        contentType: 'application/json',
        data: JSON.stringify(intelData),
        success: function(response) {
            console.log('✅ Intelligence Report saved successfully:', response);
            
            if (response.success) {
                alert('Intelligence Report saved successfully!');
                closeSingleUnitModal();
                
                // Refresh the parent units list
                if (window.refreshUnitsList) {
                    const tokenId = document.getElementById('tokenId').value;
                    const brigadeId = document.getElementById('brigadeId').value;
                    window.refreshUnitsList(tokenId, brigadeId);
                }
            } else {
                alert('Error saving Intelligence Report: ' + response.message);
            }
        },
        error: function(xhr, status, error) {
            console.error('❌ Error saving Intelligence Report:', error);
            alert('Error saving Intelligence Report. Please try again.');
        },
        complete: function() {
            $("#loading").hide();
        }
    });
}

// Save Reconnaissance
function saveReconnaissance() {
    console.log('💾 Saving Reconnaissance...');
    
    const reconData = {
        tokenId: document.getElementById('tokenId').value,
        reconType: document.getElementById('reconType').value,
        location: document.getElementById('reconLocation').value,
        confidence: document.getElementById('reconConfidence').value,
        description: document.getElementById('reconDescription').value
    };
    
    // Validation
    if (!reconData.reconType) {
        alert('Please fill in Reconnaissance Type');
        return;
    }
    
    $("#loading").show();
    
    $.ajax({
        url: '/DataManagement/CreateTokenRecon',
        type: 'POST',
        contentType: 'application/json',
        data: JSON.stringify(reconData),
        success: function(response) {
            console.log('✅ Reconnaissance saved successfully:', response);
            
            if (response.success) {
                alert('Reconnaissance saved successfully!');
                closeSingleUnitModal();
                
                // Refresh the parent units list
                if (window.refreshUnitsList) {
                    const tokenId = document.getElementById('tokenId').value;
                    const brigadeId = document.getElementById('brigadeId').value;
                    window.refreshUnitsList(tokenId, brigadeId);
                }
            } else {
                alert('Error saving Reconnaissance: ' + response.message);
            }
        },
        error: function(xhr, status, error) {
            console.error('❌ Error saving Reconnaissance:', error);
            alert('Error saving Reconnaissance. Please try again.');
        },
        complete: function() {
            $("#loading").hide();
        }
    });
}

// Generic save unit function (for infantry, armoured, artillery)
function saveUnit(unitType, unitData, unitDisplayName) {
    $("#loading").show();
    
    // Map unit types to correct endpoint names
    let endpoint;
    if (unitType === 'infantry') {
        endpoint = '/DataManagement/CreateTokenInfantryBattalion';
    } else if (unitType === 'armoured') {
        endpoint = '/DataManagement/CreateTokenArmouredRegiment';
    } else if (unitType === 'artillery') {
        endpoint = '/DataManagement/CreateTokenArtilleryRegiment';
    } else {
        console.error('Unknown unit type:', unitType);
        alert(`Unknown unit type: ${unitType}`);
        $("#loading").hide();
        return;
    }
    
    console.log(`📡 Saving ${unitDisplayName} to endpoint:`, endpoint);
    console.log('📦 Data being sent:', unitData);
    
    $.ajax({
        url: endpoint,
        type: 'POST',
        contentType: 'application/json',
        data: JSON.stringify(unitData),
        success: function(response) {
            console.log(`✅ ${unitDisplayName} saved successfully:`, response);
            
            if (response.success) {
                alert(`${unitDisplayName} saved successfully!`);
                closeSingleUnitModal();
                
                // Refresh the parent units list
                if (window.refreshUnitsList) {
                    const tokenId = document.getElementById('tokenId').value;
                    const brigadeId = document.getElementById('brigadeId').value;
                    window.refreshUnitsList(tokenId, brigadeId);
                }
            } else {
                alert(`Error saving ${unitDisplayName}: ` + (response.message || 'Unknown error'));
            }
        },
        error: function(xhr, status, error) {
            console.error(`❌ Error saving ${unitDisplayName}:`, error);
            console.error('   Status Code:', xhr.status);
            console.error('   Response Text:', xhr.responseText);
            
            let errorMessage = `Error saving ${unitDisplayName}. Please try again.`;
            if (xhr.status === 404) {
                errorMessage = `Endpoint not found (404): ${endpoint}`;
            } else if (xhr.status === 500) {
                errorMessage = `Server error (500): ${xhr.responseText}`;
            } else if (xhr.responseJSON && xhr.responseJSON.message) {
                errorMessage = `Error: ${xhr.responseJSON.message}`;
            }
            
            alert(errorMessage);
        },
        complete: function() {
            $("#loading").hide();
        }
    });
}
</script>
