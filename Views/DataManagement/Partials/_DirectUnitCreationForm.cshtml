                    <!-- LOGISTICS UNIT FORM -->
                    <form id="directLogisticsForm" onsubmit="return false;">
                        <div class="form-section">
                            <h6><i class="fas fa-truck"></i> Logistics Unit Details</h6>
                            
                            <div class="row">
                                <div class="col-md-6">
                                    <div class="form-group">
                                        <label for="directLogisticsName">Unit Name *</label>
                                        <input type="text" class="form-control" id="directLogisticsName" placeholder="e.g., 1st Logistics Company" required />
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="form-group">
                                        <label for="directLogisticsCode">Unit Code *</label>
