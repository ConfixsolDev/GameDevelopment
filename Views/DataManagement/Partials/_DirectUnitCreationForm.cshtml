                                </div>
                            </div>
                        </div>
                    </form>
                }
                else
                {
                    <div class="alert alert-warning">
                        <i class="fas fa-exclamation-triangle"></i> Unit type not yet supported
                    </div>
                }
            </div>

            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-dismiss="modal">
                    <i class="fas fa-times"></i> Cancel
                </button>
                <button type="button" class="btn btn-primary" onclick="saveDirectUnit()">
                    <i class="fas fa-save"></i> <span id="saveBtnText">@(Model.UnitId.HasValue ? "Update" : "Save") Unit</span>
                </button>
            </div>
        </div>
    </div>
</div>

