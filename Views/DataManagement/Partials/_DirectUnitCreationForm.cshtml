                                        <input type="text" class="form-control" id="directArtilleryGunCaliber" placeholder="e.g., 155mm" required />
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="form-group">
                                        <label for="directArtilleryGunRange">Gun Range (km) *</label>
                                        <input type="number" class="form-control" id="directArtilleryGunRange" placeholder="e.g., 30" min="0" required />
                                    </div>
                                </div>
                            </div>

                            <div class="form-group">
                                <label for="directArtilleryDescription">Description</label>
                                <textarea class="form-control" id="directArtilleryDescription" rows="3" placeholder="Enter regiment description..."></textarea>
                            </div>
                        </div>

                        <div class="form-section">
                            <h6><i class="fas fa-shield-alt"></i> Additional Equipment</h6>
                            
                            <div class="row">
                                <div class="col-md-6">
                                    <div class="form-group">
                                        <label for="directArtilleryHMG">Heavy Machine Guns</label>
                                        <input type="number" class="form-control" id="directArtilleryHMG" value="0" min="0" />
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="form-group">
                                        <label for="directArtilleryDrones">Drones</label>
                                        <input type="number" class="form-control" id="directArtilleryDrones" value="0" min="0" />
                                    </div>
                                </div>
                            </div>
                        </div>
