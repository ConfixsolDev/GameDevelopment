                                    </div>
                                </div>
                            </div>

                            <div class="form-group">
                                <label for="directArtilleryDescription">Description</label>
                                <textarea class="form-control" id="directArtilleryDescription" rows="3" placeholder="Enter regiment description..."></textarea>
                            </div>
                        </div>

                        <div class="form-section">
                            <h6><i class="fas fa-shield-alt"></i> Additional Equipment</h6>
                            
                            <div class="row">
                                <div class="col-md-6">
                                    <div class="form-group">
                                        <label for="directArtilleryHMG">Heavy Machine Guns</label>
                                        <input type="number" class="form-control" id="directArtilleryHMG" value="0" min="0" />
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="form-group">
                                        <label for="directArtilleryDrones">Drones</label>
                                        <input type="number" class="form-control" id="directArtilleryDrones" value="0" min="0" />
                                    </div>
                                </div>
                            </div>
                        </div>
                    </form>
                }
                else if (Model.UnitType == UnitType.Logistics)
                {
                    <!-- LOGISTICS UNIT FORM -->
                    <form id="directLogisticsForm">
                        <div class="form-section">
                            <h6><i class="fas fa-truck"></i> Logistics Unit Details</h6>
                            
                            <div class="row">
                                <div class="col-md-6">
                                    <div class="form-group">
                                        <label for="directLogisticsName">Unit Name *</label>
                                        <input type="text" class="form-control" id="directLogisticsName" placeholder="e.g., 1st Logistics Company" required />
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="form-group">
                                        <label for="directLogisticsCode">Unit Code *</label>
                                        <input type="text" class="form-control" id="directLogisticsCode" placeholder="e.g., LOG-01" required />
