@using static TechWebSol.Controllers.DataManagementController
@model DirectUnitCreationViewModel

<!-- Direct Unit Creation Form Modal - Bootstrap Modal -->
<div class="modal fade" id="directUnitCreationModal" tabindex="-1" role="dialog" aria-labelledby="directUnitCreationModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-xl" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="directUnitCreationModalLabel">
                    <i class="fas fa-@(Model.UnitType == UnitType.Infantry ? "user-shield" : Model.UnitType == UnitType.Armoured ? "shield-alt" : Model.UnitType == UnitType.Artillery ? "crosshairs" : Model.UnitType == UnitType.Logistics ? "truck" : "hard-hat")"></i>
                    @(Model.UnitId.HasValue ? "Edit" : "Create New") @(Model.UnitType == UnitType.Infantry ? "Infantry Battalion" : Model.UnitType == UnitType.Armoured ? "Armoured Regiment" : Model.UnitType == UnitType.Artillery ? "Artillery Regiment" : Model.UnitType == UnitType.Logistics ? "Logistics Unit" : "Combat Engineering Company")
                </h5>
                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            
            <div class="modal-body">
                <!-- Hidden fields -->
                <input type="hidden" id="directUnitType" value="@Model.UnitType.ToString().ToLower()" />
                <input type="hidden" id="directTokenId" value="@Model.Token.Id" />
                <input type="hidden" id="directTeamId" value="@Model.TeamId" />
                <input type="hidden" id="directForceType" value="@Model.ForceType" />
                <input type="hidden" id="directUnitId" value="@(Model.UnitId?.ToString() ?? "")" />
                <input type="hidden" id="directExistingUnitJson" value='@Html.Raw(Model.ExistingUnitJson ?? "")' />
                
                <!-- Token Information - Professional Dark Theme -->
                <div class="form-info-banner">
                    <div class="banner-left">
                        <i class="fas fa-crosshairs"></i>
                        <span class="banner-label">Token:</span>
                        <span class="banner-value">@Model.Token.Name</span>
                    </div>
                    <div class="banner-right">
                        <span class="badge badge-blue-solid">@Model.ForceType.ToUpper()</span>
                    </div>
                </div>

                @if (Model.UnitType == UnitType.Infantry)
                {
                    <!-- INFANTRY BATTALION FORM -->
                    <form id="directInfantryForm" onsubmit="return false;">
                        <div class="form-section">
                            <h6><i class="fas fa-user-shield"></i> Infantry Battalion Details</h6>
                            
                            <div class="row">
                                <div class="col-md-6">
                                    <div class="form-group">
                                        <label for="directInfantryName">Battalion Name *</label>
                                        <input type="text" class="form-control" id="directInfantryName" placeholder="e.g., 1st Infantry Battalion" required />
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="form-group">
                                        <label for="directInfantryCode">Unit Code *</label>
                                        <input type="text" class="form-control" id="directInfantryCode" placeholder="e.g., INF-01" required />
                                    </div>
                                </div>
                            </div>

                            <div class="row">
                                <div class="col-md-6">
                                    <div class="form-group">
                                        <label for="directInfantryStrength">Strength (Personnel) *</label>
                                        <input type="number" class="form-control" id="directInfantryStrength" placeholder="e.g., 600" min="0" required />
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="form-group">
                                        <label for="directInfantryCompanies">Number of Companies *</label>
                                        <input type="number" class="form-control" id="directInfantryCompanies" placeholder="e.g., 4" min="1" required />
                                    </div>
                                </div>
                            </div>

                            <div class="form-group">
                                <label for="directInfantryDescription">Description</label>
                                <textarea class="form-control" id="directInfantryDescription" rows="3" placeholder="Enter battalion description..."></textarea>
                            </div>
                        </div>

                        <div class="form-section">
                            <h6><i class="fas fa-shield-alt"></i> Equipment & Armaments</h6>
                            
                            <div class="row">
                                <div class="col-md-3">
                                    <div class="form-group">
                                        <label for="directInfantryATGMS">ATGMs</label>
                                        <input type="number" class="form-control" id="directInfantryATGMS" value="0" min="0" />
                                    </div>
                                </div>
                                <div class="col-md-3">
                                    <div class="form-group">
                                        <label for="directInfantryRocketLauncher">Rocket Launchers</label>
                                        <input type="number" class="form-control" id="directInfantryRocketLauncher" value="0" min="0" />
                                    </div>
                                </div>
                                <div class="col-md-3">
                                    <div class="form-group">
                                        <label for="directInfantryMortars81mm">81mm Mortars</label>
                                        <input type="number" class="form-control" id="directInfantryMortars81mm" value="0" min="0" />
                                    </div>
                                </div>
                                <div class="col-md-3">
                                    <div class="form-group">
                                        <label for="directInfantryMortars120mm">120mm Mortars</label>
                                        <input type="number" class="form-control" id="directInfantryMortars120mm" value="0" min="0" />
                                    </div>
                                </div>
                            </div>

                            <div class="row">
                                <div class="col-md-3">
                                    <div class="form-group">
                                        <label for="directInfantryGrenadeLaunchers">Grenade Launchers</label>
                                        <input type="number" class="form-control" id="directInfantryGrenadeLaunchers" value="0" min="0" />
                                    </div>
                                </div>
                                <div class="col-md-3">
                                    <div class="form-group">
                                        <label for="directInfantryHMG_AGL">HMG / AGL</label>
                                        <input type="number" class="form-control" id="directInfantryHMG_AGL" value="0" min="0" />
                                    </div>
                                </div>
                                <div class="col-md-3">
                                    <div class="form-group">
                                        <label for="directInfantryMG_LMG">MG / LMG</label>
                                        <input type="number" class="form-control" id="directInfantryMG_LMG" value="0" min="0" />
                                    </div>
                                </div>
                                <div class="col-md-3">
                                    <div class="form-group">
                                        <label for="directInfantryMANPADS">MANPADS</label>
                                        <input type="number" class="form-control" id="directInfantryMANPADS" value="0" min="0" />
                                    </div>
                                </div>
                            </div>

                            <div class="row">
                                <div class="col-md-4">
                                    <div class="form-group">
                                        <label for="directInfantrySniper">Snipers</label>
