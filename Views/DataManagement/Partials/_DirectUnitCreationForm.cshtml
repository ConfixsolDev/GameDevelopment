                                    </div>
                                </div>
                                <div class="col-md-4">
                                    <div class="form-group">
                                        <label for="directInfantryNVG">Night Vision Goggles</label>
                                        <input type="number" class="form-control" id="directInfantryNVG" value="0" min="0" />
                                    </div>
                                </div>
                            </div>
                        </div>
                    </form>
