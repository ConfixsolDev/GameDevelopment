                                    </div>
                                </div>
                            </div>
                        </div>
                    </form>
                }
                else if (Model.UnitType == UnitType.Engineering)
                {
                    <!-- COMBAT ENGINEERING COMPANY FORM -->
                    <form id="directEngineeringForm">
                        <div class="form-section">
                            <h6><i class="fas fa-hard-hat"></i> Combat Engineering Company Details</h6>
                            
