                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="form-group">
                                        <label for="directLogisticsCompanies">Number of Companies *</label>
                                        <input type="number" class="form-control" id="directLogisticsCompanies" placeholder="e.g., 2" min="1" required />
                                    </div>
                                </div>
                            </div>

                            <div class="form-group">
                                <label for="directLogisticsDescription">Description</label>
                                <textarea class="form-control" id="directLogisticsDescription" rows="3" placeholder="Enter unit description..."></textarea>
                            </div>
                        </div>

                        <div class="form-section">
                            <h6><i class="fas fa-truck-loading"></i> Vehicles & Equipment</h6>
                            
                            <div class="row">
                                <div class="col-md-3">
                                    <div class="form-group">
                                        <label for="directLogisticsSupplyTrucks">Supply Trucks</label>
                                        <input type="number" class="form-control" id="directLogisticsSupplyTrucks" value="0" min="0" />
