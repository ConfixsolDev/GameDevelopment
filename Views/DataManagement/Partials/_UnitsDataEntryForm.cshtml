@using static TechWebSol.Controllers.DataManagementController
@model UnitsDataEntryViewModel

<!-- Units Data Entry Form Modal - Bootstrap Modal -->
<div class="modal fade" id="unitsDataEntryModal" tabindex="-1" role="dialog" aria-labelledby="unitsDataEntryModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-xl" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="unitsDataEntryModalLabel">
                    <i class="fas fa-users"></i> Add Units to Brigade: @Model.Brigade.BrigadeCode (@Model.Token.Name)
                </h5>
                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <div class="modal-body" style="min-height: 500px;">
            <!-- Hidden fields -->
            <input type="hidden" id="tokenId" value="@Model.Token.Id" />
            <input type="hidden" id="brigadeId" value="@Model.Brigade.Id" />
            <input type="hidden" id="teamId" value="@Model.Brigade.TeamId" />
            <input type="hidden" id="forceType" value="@Model.Brigade.ForceType" />
            
            <!-- Brigade Information Display -->
            <div class="brigade-info-section">
                <div class="brigade-display">
                    @if (!string.IsNullOrEmpty(Model.Token.AssetImagePath))
                    {
                        <img src="@Model.Token.AssetImagePath" alt="@Model.Token.Name" class="token-preview-image">
                    }
                    else
                    {
                        <div class="token-preview-placeholder">
                            <i class="fas fa-crosshairs"></i>
                        </div>
                    }
                    <div class="brigade-details">
                        <h4>Brigade @Model.Brigade.BrigadeCode</h4>
                        <p class="text-muted">@Model.Token.Name • @Model.Brigade.ForceType Force</p>
                    </div>
                </div>
                <div class="alert alert-info">
                    <i class="fas fa-info-circle"></i> 
                    <strong>Manage Brigade Units:</strong> View existing units below and add new ones as needed. Each unit is saved separately.
                </div>
            </div>

            <!-- Unit Tabs -->
            <div class="unit-tabs">
                <button type="button" class="unit-tab active" onclick="showUnitTab('infantry')">
                    <i class="fas fa-user-shield"></i> Infantry Battalion
                    @if (Model.ExistingInfantryList != null && Model.ExistingInfantryList.Any())
                    {
                        <span class="unit-count-badge">@Model.ExistingInfantryList.Count</span>
                    }
                </button>
                <button type="button" class="unit-tab" onclick="showUnitTab('armoured')">
                    <i class="fas fa-shield-alt"></i> Armoured Regiment
                    @if (Model.ExistingArmouredList != null && Model.ExistingArmouredList.Any())
                    {
                        <span class="unit-count-badge">@Model.ExistingArmouredList.Count</span>
                    }
                </button>
                <button type="button" class="unit-tab" onclick="showUnitTab('artillery')">
                    <i class="fas fa-crosshairs"></i> Artillery Regiment
                    @if (Model.ExistingArtilleryList != null && Model.ExistingArtilleryList.Any())
                    {
                        <span class="unit-count-badge">@Model.ExistingArtilleryList.Count</span>
                    }
                </button>
                <button type="button" class="unit-tab" onclick="showUnitTab('recon')">
                    <i class="fas fa-binoculars"></i> Reconnaissance
                    @if (Model.ExistingReconList != null && Model.ExistingReconList.Any())
                    {
                        <span class="unit-count-badge">@Model.ExistingReconList.Count</span>
                    }
                </button>
                <button type="button" class="unit-tab" onclick="showUnitTab('logistics')">
                    <i class="fas fa-truck"></i> Logistics Unit
                    @if (Model.ExistingLogisticsList != null && Model.ExistingLogisticsList.Any())
                    {
                        <span class="unit-count-badge">@Model.ExistingLogisticsList.Count</span>
                    }
                </button>
                <button type="button" class="unit-tab" onclick="showUnitTab('engineering')">
                    <i class="fas fa-hard-hat"></i> Combat Engineering
                    @if (Model.ExistingEngineeringList != null && Model.ExistingEngineeringList.Any())
                    {
                        <span class="unit-count-badge">@Model.ExistingEngineeringList.Count</span>
                    }
                </button>
            </div>

            <!-- Infantry Battalion Tab -->
            <div id="infantry-tab" class="unit-tab-content active">
                <div class="unit-list-header">
                    <h5><i class="fas fa-user-shield"></i> Infantry Battalions</h5>
                    <button type="button" class="btn btn-primary btn-sm" onclick="openInfantryBattalionForm('@Model.Token.Id', '@Model.Brigade.Id')">
                        <i class="fas fa-plus"></i> Add New Infantry Battalion
                    </button>
                </div>
                
                @if (Model.ExistingInfantryList != null && Model.ExistingInfantryList.Any())
                {
                    <div class="existing-units-list">
                        @foreach (var unit in Model.ExistingInfantryList)
                        {
                            <div class="unit-card">
                                <div class="unit-card-header">
                                    <div class="unit-card-title">
                                        <h6>@unit.Name</h6>
                                        <span class="badge badge-info">@unit.UnitCode</span>
                    </div>
                                    <div class="unit-card-actions">
                                        <button type="button" class="btn btn-sm btn-outline-primary" onclick="editBrigadeInfantry('@unit.Id')">
                                            <i class="fas fa-edit"></i> Edit
                                        </button>
                                        <button type="button" class="btn btn-sm btn-outline-danger" onclick="deleteBrigadeInfantry('@unit.Id')">
                                            <i class="fas fa-trash"></i> Delete
                                        </button>
                                </div>
                            </div>
                                <div class="unit-card-body">
                                    <div class="unit-stat"><strong>Strength:</strong> @unit.Strength personnel</div>
                                    <div class="unit-stat"><strong>Companies:</strong> @unit.Companies</div>
                                    <div class="unit-stat"><strong>Combat Power:</strong> @unit.CombatPower</div>
                                    @if (!string.IsNullOrEmpty(unit.Description))
                                    {
                                        <div class="unit-stat"><strong>Description:</strong> @unit.Description</div>
                                    }
                                </div>
                            </div>
                        }
                                </div>
                        }
                        else
                        {
                    <div class="no-units-message">
                            <i class="fas fa-info-circle"></i>
                        No infantry battalions found. Click "Add New" to create one.
                        </div>
                }
                    </div>

            <!-- Armoured Regiment Tab -->
            <div id="armoured-tab" class="unit-tab-content">
                <div class="unit-list-header">
                    <h5><i class="fas fa-shield-alt"></i> Armoured Regiments</h5>
                    <button type="button" class="btn btn-primary btn-sm" onclick="openArmouredRegimentForm('@Model.Token.Id', '@Model.Brigade.Id')">
                        <i class="fas fa-plus"></i> Add New Armoured Regiment
                    </button>
                    </div>

                @if (Model.ExistingArmouredList != null && Model.ExistingArmouredList.Any())
                {
                    <div class="existing-units-list">
                        @foreach (var unit in Model.ExistingArmouredList)
                        {
                            <div class="unit-card">
                                <div class="unit-card-header">
                                    <div class="unit-card-title">
                                        <h6>@unit.Name</h6>
                                        <span class="badge badge-info">@unit.UnitCode</span>
                                </div>
                                    <div class="unit-card-actions">
                                        <button type="button" class="btn btn-sm btn-outline-primary" onclick="editBrigadeArmoured('@unit.Id')">
                                            <i class="fas fa-edit"></i> Edit
                                        </button>
                                        <button type="button" class="btn btn-sm btn-outline-danger" onclick="deleteBrigadeArmoured('@unit.Id')">
                                            <i class="fas fa-trash"></i> Delete
                                        </button>
                            </div>
                                </div>
                                <div class="unit-card-body">
                                    <div class="unit-stat"><strong>Strength:</strong> @unit.Strength personnel</div>
                                    <div class="unit-stat"><strong>Tanks:</strong> @unit.Tanks</div>
                                    <div class="unit-stat"><strong>Combat Power:</strong> @unit.CombatPower</div>
                                    @if (!string.IsNullOrEmpty(unit.Description))
                                    {
                                        <div class="unit-stat"><strong>Description:</strong> @unit.Description</div>
                                    }
                                </div>
                            </div>
                        }
                                </div>
                }
                else
                {
                    <div class="no-units-message">
                        <i class="fas fa-info-circle"></i>
                        No armoured regiments found. Click "Add New" to create one.
                    </div>
                }
            </div>

            <!-- Artillery Regiment Tab -->
            <div id="artillery-tab" class="unit-tab-content">
                <div class="unit-list-header">
                    <h5><i class="fas fa-crosshairs"></i> Artillery Regiments</h5>
                    <button type="button" class="btn btn-primary btn-sm" onclick="openArtilleryRegimentForm('@Model.Token.Id', '@Model.Brigade.Id')">
                        <i class="fas fa-plus"></i> Add New Artillery Regiment
                    </button>
                </div>
                
                @if (Model.ExistingArtilleryList != null && Model.ExistingArtilleryList.Any())
                {
                    <div class="existing-units-list">
                        @foreach (var unit in Model.ExistingArtilleryList)
                        {
                            <div class="unit-card">
                                <div class="unit-card-header">
                                    <div class="unit-card-title">
                                        <h6>@unit.Name</h6>
                                        <span class="badge badge-info">@unit.UnitCode</span>
                    </div>
                                    <div class="unit-card-actions">
                                        <button type="button" class="btn btn-sm btn-outline-primary" onclick="editBrigadeArtillery('@unit.Id')">
                                            <i class="fas fa-edit"></i> Edit
                                        </button>
                                        <button type="button" class="btn btn-sm btn-outline-danger" onclick="deleteBrigadeArtillery('@unit.Id')">
                                            <i class="fas fa-trash"></i> Delete
                                        </button>
                                </div>
                            </div>
                                <div class="unit-card-body">
                                    <div class="unit-stat"><strong>Strength:</strong> @unit.Strength personnel</div>
                                    <div class="unit-stat"><strong>Guns:</strong> @unit.Guns (@unit.GunCaliber)</div>
                                    <div class="unit-stat"><strong>Range:</strong> @unit.GunRange km</div>
                                    @if (!string.IsNullOrEmpty(unit.Description))
                                    {
                                        <div class="unit-stat"><strong>Description:</strong> @unit.Description</div>
                                    }
                                </div>
                            </div>
                        }
                                </div>
                }
                else
                {
                    <div class="no-units-message">
                        <i class="fas fa-info-circle"></i>
                        No artillery regiments found. Click "Add New" to create one.
                    </div>
                }
            </div>

            <!-- Reconnaissance Tab -->
            <div id="recon-tab" class="unit-tab-content">
                <div class="unit-list-header">
                    <h5><i class="fas fa-binoculars"></i> Reconnaissance Units</h5>
                    <button type="button" class="btn btn-primary btn-sm" onclick="openReconForm('@Model.Token.Id', '@Model.Brigade.Id')">
                        <i class="fas fa-plus"></i> Add New Recon Unit
                            </button>
                </div>

                @if (Model.ExistingReconList != null && Model.ExistingReconList.Any())
                {
                    <div class="existing-units-list">
                        @foreach (var unit in Model.ExistingReconList)
                        {
                            <div class="unit-card">
                                <div class="unit-card-header">
                                    <div class="unit-card-title">
                                        <h6>@unit.ReconType</h6>
                                        <span class="badge badge-info">@unit.Confidence</span>
                                    </div>
                                    <div class="unit-card-actions">
                                        <button type="button" class="btn btn-sm btn-outline-primary" onclick="editBrigadeRecon('@unit.Id')">
                                            <i class="fas fa-edit"></i> Edit
                                        </button>
                                        <button type="button" class="btn btn-sm btn-outline-danger" onclick="deleteBrigadeRecon('@unit.Id')">
                                            <i class="fas fa-trash"></i> Delete
                                        </button>
                                    </div>
                                </div>
                                <div class="unit-card-body">
                                    <div class="unit-stat"><strong>Location:</strong> @unit.Location</div>
                                    <div class="unit-stat"><strong>Timestamp:</strong> @unit.Timestamp.ToString("g")</div>
                                    @if (!string.IsNullOrEmpty(unit.Description))
                                    {
                                        <div class="unit-stat"><strong>Description:</strong> @unit.Description</div>
                                    }
                                </div>
                            </div>
                            }
                        </div>
                    }
                    else
                    {
                    <div class="no-units-message">
                        <i class="fas fa-info-circle"></i>
                        No reconnaissance units found. Click "Add New" to create one.
                    </div>
                    }
            </div>

            <!-- Logistics Unit Tab -->
            <div id="logistics-tab" class="unit-tab-content">
                <div class="unit-list-header">
                    <h5><i class="fas fa-truck"></i> Logistics Units</h5>
                    <button type="button" class="btn btn-primary btn-sm" onclick="openLogisticsForm('@Model.Token.Id', '@Model.Brigade.Id')">
                        <i class="fas fa-plus"></i> Add New Logistics Unit
                    </button>
                </div>
                
                @if (Model.ExistingLogisticsList != null && Model.ExistingLogisticsList.Any())
                {
                    <div class="existing-units-list">
                        @foreach (var unit in Model.ExistingLogisticsList)
                        {
                            <div class="unit-card">
                                <div class="unit-card-header">
                                    <div class="unit-card-title">
                                        <h6>@unit.Name</h6>
                                        <span class="badge badge-info">@unit.UnitCode</span>
                    </div>
                                    <div class="unit-card-actions">
                                        <button type="button" class="btn btn-sm btn-outline-primary" onclick="editBrigadeLogistics('@unit.Id')">
                                            <i class="fas fa-edit"></i> Edit
                                        </button>
                                        <button type="button" class="btn btn-sm btn-outline-danger" onclick="deleteBrigadeLogistics('@unit.Id')">
                                            <i class="fas fa-trash"></i> Delete
                                        </button>
                                </div>
                            </div>
                                <div class="unit-card-body">
                                    <div class="unit-stat"><strong>Name:</strong> @unit.Name</div>
                                    <div class="unit-stat"><strong>Supply Trucks:</strong> @unit.SupplyTrucks</div>
                                    <div class="unit-stat"><strong>Fuel Trucks:</strong> @unit.FuelTrucks</div>
                                    <div class="unit-stat"><strong>Maintenance Vehicles:</strong> @unit.MaintenanceVehicles</div>
                                    @if (!string.IsNullOrEmpty(unit.Description))
                                    {
                                        <div class="unit-stat"><strong>Description:</strong> @unit.Description</div>
                                    }
                                </div>
                            </div>
                        }
                        </div>
                }
                else
                {
                    <div class="no-units-message">
                        <i class="fas fa-info-circle"></i>
                        No logistics units found. Click "Add New" to create one.
                                </div>
                }
                    </div>

            <!-- Combat Engineering Tab -->
            <div id="engineering-tab" class="unit-tab-content">
                <div class="unit-list-header">
                    <h5><i class="fas fa-hard-hat"></i> Combat Engineering Companies</h5>
                    <button type="button" class="btn btn-primary btn-sm" onclick="openEngineeringForm('@Model.Token.Id', '@Model.Brigade.Id')">
                        <i class="fas fa-plus"></i> Add New Engineering Company
                    </button>
                    </div>

                @if (Model.ExistingEngineeringList != null && Model.ExistingEngineeringList.Any())
                {
                    <div class="existing-units-list">
                        @foreach (var unit in Model.ExistingEngineeringList)
                        {
                            <div class="unit-card">
                                <div class="unit-card-header">
                                    <div class="unit-card-title">
                                        <h6>@unit.Name</h6>
                                        <span class="badge badge-info">@unit.UnitCode</span>
                                </div>
                                    <div class="unit-card-actions">
                                        <button type="button" class="btn btn-sm btn-outline-primary" onclick="editBrigadeEngineering('@unit.Id')">
                                            <i class="fas fa-edit"></i> Edit
                        </button>
                                        <button type="button" class="btn btn-sm btn-outline-danger" onclick="deleteBrigadeEngineering('@unit.Id')">
                                            <i class="fas fa-trash"></i> Delete
                            </button>
                    </div>
            </div>
                                <div class="unit-card-body">
                                    <div class="unit-stat"><strong>Strength:</strong> @unit.Strength personnel</div>
                                    <div class="unit-stat"><strong>Bulldozers:</strong> @unit.Bulldozers</div>
                                    <div class="unit-stat"><strong>Excavators:</strong> @unit.Excavators</div>
                                    @if (!string.IsNullOrEmpty(unit.Description))
                                    {
                                        <div class="unit-stat"><strong>Description:</strong> @unit.Description</div>
                        }
                    </div>
                                </div>
                        }
                            </div>
                }
                else
                {
                    <div class="no-units-message">
                        <i class="fas fa-info-circle"></i>
                        No engineering companies found. Click "Add New" to create one.
                    </div>
                }
        </div>
        
            </div>
        <div class="modal-footer">
            <button type="button" class="btn btn-success" onclick="closeUnitsDataEntryModal()">
                <i class="fas fa-check"></i> Done Adding Units
            </button>
        </div>
    </div>
    </div>
</div>

<style>
.brigade-info-section {
    margin-bottom: 20px;
}

.brigade-display {
    display: flex;
    align-items: center;
    gap: 15px;
    padding: 15px;
    background: #f8f9fa;
    border-radius: 8px;
    margin-bottom: 15px;
}

.token-preview-image {
    width: 60px;
    height: 60px;
    border-radius: 8px;
    object-fit: cover;
}

.token-preview-placeholder {
    width: 60px;
    height: 60px;
    background: #6c757d;
    color: white;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 8px;
    font-size: 24px;
}

.brigade-details h4 {
    margin: 0;
    font-size: 1.2rem;
}

.brigade-details p {
    margin: 5px 0 0 0;
}

.unit-tabs {
    display: flex;
    gap: 5px;
    margin-bottom: 20px;
    flex-wrap: wrap;
    border-bottom: 2px solid #dee2e6;
}

.unit-tab {
    padding: 10px 15px;
    border: none;
    background: #f8f9fa;
    cursor: pointer;
    border-radius: 8px 8px 0 0;
    font-size: 0.9rem;
    display: flex;
    align-items: center;
    gap: 8px;
    transition: all 0.2s;
}

.unit-tab:hover {
    background: #e9ecef;
}

.unit-tab.active {
    background: #007bff;
    color: white;
}

.unit-count-badge {
    background: rgba(255, 255, 255, 0.3);
    padding: 2px 8px;
    border-radius: 12px;
    font-size: 0.8rem;
    font-weight: bold;
}

.unit-tab.active .unit-count-badge {
    background: rgba(255, 255, 255, 0.9);
    color: #007bff;
}

.unit-tab-content {
    display: none;
    padding: 20px;
    background: white;
    border-radius: 0 0 8px 8px;
}

.unit-tab-content.active {
    display: block;
}

.unit-list-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 20px;
    padding-bottom: 10px;
    border-bottom: 2px solid #dee2e6;
}

.unit-list-header h5 {
    margin: 0;
    display: flex;
    align-items: center;
    gap: 10px;
}

.existing-units-list {
    display: grid;
    gap: 15px;
}

.unit-card {
    border: 1px solid #dee2e6;
    border-radius: 8px;
    overflow: hidden;
    transition: box-shadow 0.2s;
}

.unit-card:hover {
    box-shadow: 0 4px 8px rgba(0,0,0,0.1);
}

.unit-card-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 15px;
    background: #f8f9fa;
    border-bottom: 1px solid #dee2e6;
}

.unit-card-title {
    display: flex;
    align-items: center;
    gap: 10px;
}

.unit-card-title h6 {
    margin: 0;
    font-size: 1rem;
    font-weight: 600;
}

.unit-card-actions {
    display: flex;
    gap: 8px;
}

.unit-card-body {
    padding: 15px;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 10px;
}

.unit-stat {
    font-size: 0.9rem;
    color: #495057;
}

.unit-stat strong {
    color: #212529;
}

.no-units-message {
    text-align: center;
    padding: 40px 20px;
    color: #6c757d;
    font-size: 1rem;
}

.no-units-message i {
    font-size: 2rem;
    display: block;
    margin-bottom: 10px;
    opacity: 0.5;
}

#unitsDataEntryModal .modal-body {
    min-height: 500px;
}
</style>

<script>
// Close units data entry modal
function closeUnitsDataEntryModal() {
    console.log('🔒 Closing units data entry modal');
    $('#unitsDataEntryModal').modal('hide');
}

// Show unit tab
function showUnitTab(tabName) {
    console.log('📑 Switching to tab:', tabName);
    
    // Hide all tab contents
    document.querySelectorAll('.unit-tab-content').forEach(tab => {
        tab.classList.remove('active');
    });
    
    // Remove active class from all tabs
    document.querySelectorAll('.unit-tab').forEach(tab => {
        tab.classList.remove('active');
    });
    
    // Show selected tab content
    const selectedTab = document.getElementById(tabName + '-tab');
    if (selectedTab) {
        selectedTab.classList.add('active');
    }
    
    // Add active class to selected tab button
    event.target.closest('.unit-tab').classList.add('active');
}

// Open Infantry Battalion Form (create or edit)
function openInfantryBattalionForm(tokenId, brigadeId, unitId = null) {
    console.log('📝 Opening Infantry Battalion form', { tokenId, brigadeId, unitId });
    openBrigadeUnitForm('infantry', tokenId, brigadeId, unitId);
}

// Open Armoured Regiment Form
function openArmouredRegimentForm(tokenId, brigadeId, unitId = null) {
    console.log('📝 Opening Armoured Regiment form', { tokenId, brigadeId, unitId });
    openBrigadeUnitForm('armoured', tokenId, brigadeId, unitId);
}

// Open Artillery Regiment Form
function openArtilleryRegimentForm(tokenId, brigadeId, unitId = null) {
    console.log('📝 Opening Artillery Regiment form', { tokenId, brigadeId, unitId });
    openBrigadeUnitForm('artillery', tokenId, brigadeId, unitId);
}

// Open Recon Form
function openReconForm(tokenId, brigadeId, unitId = null) {
    console.log('📝 Opening Recon form', { tokenId, brigadeId, unitId });
    alert('Recon units are managed differently. This feature is coming soon.');
}

// Open Logistics Form
function openLogisticsForm(tokenId, brigadeId, unitId = null) {
    console.log('📝 Opening Logistics form', { tokenId, brigadeId, unitId });
    openBrigadeUnitForm('logistics', tokenId, brigadeId, unitId);
}

// Open Engineering Form
function openEngineeringForm(tokenId, brigadeId, unitId = null) {
    console.log('📝 Opening Engineering form', { tokenId, brigadeId, unitId });
    openBrigadeUnitForm('engineering', tokenId, brigadeId, unitId);
}

// Generic function to open brigade unit form
function openBrigadeUnitForm(unitType, tokenId, brigadeId, unitId = null) {
    console.log('🚀 Loading brigade unit form:', { unitType, tokenId, brigadeId, unitId });
    
    const params = {
        unitType: unitType,
        tokenId: tokenId,
        brigadeId: brigadeId
    };
    
    if (unitId) {
        params.unitId = unitId;
    }
    
    $.get('/DataManagement/BrigadeUnitCreationForm', params, function(data) {
        // Remove any existing modal
        $('#brigadeUnitCreationModal').remove();
        
        // Append the new modal to body
        $('body').append(data);
        
        // Show the modal
        $('#brigadeUnitCreationModal').modal('show');
        
        console.log('✅ Brigade unit form loaded successfully');
    }).fail(function(xhr, status, error) {
        console.error('❌ Error loading brigade unit form:', error);
        alert('Failed to load unit form: ' + error);
    });
}

// Edit functions
function editBrigadeInfantry(unitId) {
    console.log('✏️ Editing Infantry:', unitId);
    const tokenId = $('#tokenId').val();
    const brigadeId = $('#brigadeId').val();
    openInfantryBattalionForm(tokenId, brigadeId, unitId);
}

