@using static TechWebSol.Controllers.DataManagementController
@model UnitsDataEntryViewModel

<!-- Units Data Entry Form Modal -->
<div id="unitsDataEntryModal" class="gameplay-modal" style="display: none;">
    <div class="gameplay-modal-content large-modal">
        <div class="gameplay-modal-header">
            <h3><i class="fas fa-users"></i> Add Units to Brigade: @Model.Brigade.Name (@Model.Token.Name)</h3>
            <button class="gameplay-modal-close" onclick="closeUnitsDataEntryModal()">&times;</button>
        </div>
        <div class="gameplay-modal-body">
            <!-- Hidden fields -->
            <input type="hidden" id="tokenId" value="@Model.Token.Id" />
            <input type="hidden" id="brigadeId" value="@Model.Brigade.Id" />
            <input type="hidden" id="teamId" value="@Model.Brigade.TeamId" />
            <input type="hidden" id="forceType" value="@Model.Brigade.ForceType" />
            
            <!-- Brigade Information Display -->
            <div class="brigade-info-section">
                <div class="brigade-display">
                    @if (!string.IsNullOrEmpty(Model.Token.AssetImagePath))
                    {
                        <img src="@Model.Token.AssetImagePath" alt="@Model.Token.Name" class="token-preview-image">
                    }
                    else
                    {
                        <div class="token-preview-placeholder">
                            <i class="fas fa-crosshairs"></i>
                        </div>
                    }
                    <div class="brigade-details">
                        <h4>@Model.Brigade.Name</h4>
                        <p class="text-muted">@Model.Token.Name • @Model.Brigade.ForceType Force</p>
                        <span class="badge badge-primary">@Model.Brigade.BrigadeCode</span>
                    </div>
                </div>
                <div class="alert alert-info">
                    <i class="fas fa-info-circle"></i> 
                    <strong>Add Military Units:</strong> Use the tabs below to add different types of units to this brigade. Each unit will be saved separately.
                </div>
            </div>

            <!-- Unit Tabs -->
            <div class="unit-tabs">
                <button type="button" class="unit-tab active" onclick="showUnitTab('infantry')">
                    <i class="fas fa-user-shield"></i> Infantry Battalion
                    @if (Model.ExistingInfantry != null)
                    {
                        <span class="unit-status saved">✓</span>
                    }
                </button>
                <button type="button" class="unit-tab" onclick="showUnitTab('armoured')">
                    <i class="fas fa-shield-alt"></i> Armoured Regiment
                    @if (Model.ExistingArmoured != null)
                    {
                        <span class="unit-status saved">✓</span>
                    }
                </button>
                <button type="button" class="unit-tab" onclick="showUnitTab('artillery')">
                    <i class="fas fa-crosshairs"></i> Artillery Regiment
                    @if (Model.ExistingArtillery != null)
                    {
                        <span class="unit-status saved">✓</span>
                    }
                </button>
                <button type="button" class="unit-tab" onclick="showUnitTab('intelligence')">
                    <i class="fas fa-eye"></i> Intelligence
                    @if (Model.ExistingIntelligence != null && Model.ExistingIntelligence.Any())
                    {
                        <span class="unit-status saved">@Model.ExistingIntelligence.Count</span>
                    }
                </button>
                <button type="button" class="unit-tab" onclick="showUnitTab('recon')">
                    <i class="fas fa-binoculars"></i> Reconnaissance
                    @if (Model.ExistingRecon != null && Model.ExistingRecon.Any())
                    {
                        <span class="unit-status saved">@Model.ExistingRecon.Count</span>
                    }
                </button>
            </div>

            <!-- Infantry Battalion Tab -->
            <div id="infantry-tab" class="unit-tab-content active">
                <form id="infantryForm">
                    <div class="unit-header">
                        <h5><i class="fas fa-user-shield"></i> Infantry Battalion Data</h5>
                        @if (Model.ExistingInfantry != null)
                        {
                            <span class="badge badge-success">Unit Exists - Editing</span>
                            <input type="hidden" id="infantryId" value="@Model.ExistingInfantry.Id" />
                        }
                        else
                        {
                            <span class="badge badge-warning">New Unit</span>
                            <input type="hidden" id="infantryId" value="" />
                        }
                    </div>

                    <!-- Basic Infantry Information -->
                    <div class="unit-section">
                        <h6>Basic Information</h6>
                        <div class="row">
                            <div class="col-md-6">
                                <div class="form-group">
                                    <label for="infantryName">Battalion Name *</label>
                                    <input type="text" class="form-control" id="infantryName" required 
                                           value="@(Model.ExistingInfantry?.Name ?? "")" 
                                           placeholder="e.g., 1st Infantry Battalion" />
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="form-group">
                                    <label for="infantryCode">Unit Code *</label>
                                    <input type="text" class="form-control" id="infantryCode" required 
                                           value="@(Model.ExistingInfantry?.UnitCode ?? "")" 
                                           placeholder="e.g., 1IB" />
                                </div>
                            </div>
                        </div>
                        <div class="row">
                            <div class="col-md-6">
                                <div class="form-group">
                                    <label for="infantryStrength">Strength (Personnel) *</label>
                                    <input type="number" class="form-control" id="infantryStrength" required 
                                           value="@(Model.ExistingInfantry?.Strength ?? 0)" min="0" />
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="form-group">
                                    <label for="infantryCompanies">Companies</label>
                                    <input type="number" class="form-control" id="infantryCompanies" 
                                           value="@(Model.ExistingInfantry?.Companies ?? 0)" min="0" />
                                </div>
                            </div>
                        </div>
                        <div class="row">
                            <div class="col-md-12">
                                <div class="form-group">
                                    <label for="infantryDescription">Description</label>
                                    <textarea class="form-control" id="infantryDescription" rows="2" 
                                              placeholder="Brief description of the infantry battalion">@(Model.ExistingInfantry?.Description ?? "")</textarea>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Weapons & Equipment -->
                    <div class="unit-section">
                        <h6>Weapons & Equipment</h6>
                        <div class="row">
                            <div class="col-md-4">
                                <div class="form-group">
                                    <label for="infantryATGMS">ATGMS (Anti-Tank Guided Missiles)</label>
                                    <input type="number" class="form-control" id="infantryATGMS" 
                                           value="@(Model.ExistingInfantry?.ATGMS ?? 0)" min="0" />
                                </div>
                            </div>
                            <div class="col-md-4">
                                <div class="form-group">
                                    <label for="infantryRocketLauncher">Rocket Launchers</label>
                                    <input type="number" class="form-control" id="infantryRocketLauncher" 
                                           value="@(Model.ExistingInfantry?.RocketLauncher ?? 0)" min="0" />
                                </div>
                            </div>
                            <div class="col-md-4">
                                <div class="form-group">
                                    <label for="infantryGrenadeLaunchers">Grenade Launchers</label>
                                    <input type="number" class="form-control" id="infantryGrenadeLaunchers" 
                                           value="@(Model.ExistingInfantry?.GrenadeLaunchers ?? 0)" min="0" />
                                </div>
                            </div>
                        </div>
                        <div class="row">
                            <div class="col-md-4">
                                <div class="form-group">
                                    <label for="infantryMortars81mm">Mortars 81mm</label>
                                    <input type="number" class="form-control" id="infantryMortars81mm" 
                                           value="@(Model.ExistingInfantry?.Mortars81mm ?? 0)" min="0" />
                                </div>
                            </div>
                            <div class="col-md-4">
                                <div class="form-group">
                                    <label for="infantryMortars120mm">Mortars 120mm</label>
                                    <input type="number" class="form-control" id="infantryMortars120mm" 
                                           value="@(Model.ExistingInfantry?.Mortars120mm ?? 0)" min="0" />
                                </div>
                            </div>
                            <div class="col-md-4">
                                <div class="form-group">
                                    <label for="infantryGrenades">Grenades</label>
                                    <input type="number" class="form-control" id="infantryGrenades" 
                                           value="@(Model.ExistingInfantry?.Grenades ?? 0)" min="0" />
                                </div>
                            </div>
                        </div>
                        <div class="row">
                            <div class="col-md-4">
                                <div class="form-group">
                                    <label for="infantryHMG_AGL">HMG/AGL (Heavy Machine Guns/Auto Grenade Launchers)</label>
                                    <input type="number" class="form-control" id="infantryHMG_AGL" 
                                           value="@(Model.ExistingInfantry?.HMG_AGL ?? 0)" min="0" />
                                </div>
                            </div>
                            <div class="col-md-4">
                                <div class="form-group">
                                    <label for="infantryMG_LMG">MG/LMG (Machine Guns/Light Machine Guns)</label>
                                    <input type="number" class="form-control" id="infantryMG_LMG" 
                                           value="@(Model.ExistingInfantry?.MG_LMG ?? 0)" min="0" />
                                </div>
                            </div>
                            <div class="col-md-4">
                                <div class="form-group">
                                    <label for="infantryMANPADS">MANPADS (Man-Portable Air Defense Systems)</label>
                                    <input type="number" class="form-control" id="infantryMANPADS" 
                                           value="@(Model.ExistingInfantry?.MANPADS ?? 0)" min="0" />
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Drone Systems -->
                    <div class="unit-section">
                        <h6>Drone Systems</h6>
                        <div class="row">
                            <div class="col-md-6">
                                <div class="form-group">
                                    <label for="infantryDrones">Number of Drones</label>
                                    <input type="number" class="form-control" id="infantryDrones" 
                                           value="@(Model.ExistingInfantry?.Drones ?? 0)" min="0" />
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="form-group">
                                    <label for="infantryDroneTypes">Drone Types</label>
                                    <input type="text" class="form-control" id="infantryDroneTypes" 
                                           value="@(Model.ExistingInfantry?.DroneTypes ?? "")" 
                                           placeholder="e.g., Recon, Combat, Surveillance" />
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Mobility Data -->
                    <div class="unit-section">
                        <h6>Mobility & Speed Data (km/h)</h6>
                        <div class="row">
                            <div class="col-md-6">
                                <div class="form-group">
                                    <label for="infantryMarchingSpeedTrucksRoads">Marching Speed - Trucks on Roads</label>
                                    <input type="number" step="0.1" class="form-control" id="infantryMarchingSpeedTrucksRoads" 
                                           value="@(Model.ExistingInfantry?.MarchingSpeedTrucksRoads ?? 30)" min="0" />
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="form-group">
                                    <label for="infantryMarchingSpeedAPCs">Marching Speed - APCs</label>
                                    <input type="number" step="0.1" class="form-control" id="infantryMarchingSpeedAPCs" 
                                           value="@(Model.ExistingInfantry?.MarchingSpeedAPCs ?? 20)" min="0" />
                                </div>
                            </div>
                        </div>
                        <div class="row">
                            <div class="col-md-6">
                                <div class="form-group">
                                    <label for="infantryMarchingSpeedCrossCountry">Marching Speed - Cross Country</label>
                                    <input type="number" step="0.1" class="form-control" id="infantryMarchingSpeedCrossCountry" 
                                           value="@(Model.ExistingInfantry?.MarchingSpeedCrossCountry ?? 5)" min="0" />
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="form-group">
                                    <label for="infantryMarchingSpeedAPCsCrossCountry">Marching Speed - APCs Cross Country</label>
                                    <input type="number" step="0.1" class="form-control" id="infantryMarchingSpeedAPCsCrossCountry" 
                                           value="@(Model.ExistingInfantry?.MarchingSpeedAPCsCrossCountry ?? 10)" min="0" />
                                </div>
                            </div>
                        </div>
                        <div class="row">
                            <div class="col-md-6">
                                <div class="form-group">
                                    <label for="infantryCombatAdvanceSpeed">Combat Advance Speed</label>
                                    <input type="number" step="0.1" class="form-control" id="infantryCombatAdvanceSpeed" 
                                           value="@(Model.ExistingInfantry?.CombatAdvanceSpeed ?? 1)" min="0" />
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="unit-footer">
                        <button type="button" class="btn btn-success" onclick="saveInfantryBattalion()">
                            <i class="fas fa-save"></i> Save Infantry Battalion
                        </button>
                        @if (Model.ExistingInfantry != null)
                        {
                            <button type="button" class="btn btn-danger" onclick="deleteInfantryBattalion()">
                                <i class="fas fa-trash"></i> Delete Unit
                            </button>
                        }
                    </div>
                </form>
            </div>

            <!-- Armoured Regiment Tab -->
            <div id="armoured-tab" class="unit-tab-content">
                <form id="armouredForm">
                    <div class="unit-header">
                        <h5><i class="fas fa-shield-alt"></i> Armoured Regiment Data</h5>
                        @if (Model.ExistingArmoured != null)
                        {
                            <span class="badge badge-success">Unit Exists - Editing</span>
                            <input type="hidden" id="armouredId" value="@Model.ExistingArmoured.Id" />
                        }
                        else
                        {
                            <span class="badge badge-warning">New Unit</span>
                            <input type="hidden" id="armouredId" value="" />
                        }
                    </div>

                    <!-- Basic Armoured Information -->
                    <div class="unit-section">
                        <h6>Basic Information</h6>
                        <div class="row">
                            <div class="col-md-6">
                                <div class="form-group">
                                    <label for="armouredName">Regiment Name *</label>
                                    <input type="text" class="form-control" id="armouredName" required 
                                           value="@(Model.ExistingArmoured?.Name ?? "")" 
                                           placeholder="e.g., 1st Armoured Regiment" />
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="form-group">
                                    <label for="armouredCode">Unit Code *</label>
                                    <input type="text" class="form-control" id="armouredCode" required 
                                           value="@(Model.ExistingArmoured?.UnitCode ?? "")" 
                                           placeholder="e.g., 1AR" />
                                </div>
                            </div>
                        </div>
                        <div class="row">
                            <div class="col-md-6">
                                <div class="form-group">
                                    <label for="armouredStrength">Strength (Personnel) *</label>
                                    <input type="number" class="form-control" id="armouredStrength" required 
                                           value="@(Model.ExistingArmoured?.Strength ?? 0)" min="0" />
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="form-group">
                                    <label for="armouredSquadrons">Squadrons</label>
                                    <input type="number" class="form-control" id="armouredSquadrons" 
                                           value="@(Model.ExistingArmoured?.Squadrons ?? 0)" min="0" />
                                </div>
                            </div>
                        </div>
                        <div class="row">
                            <div class="col-md-12">
                                <div class="form-group">
                                    <label for="armouredDescription">Description</label>
                                    <textarea class="form-control" id="armouredDescription" rows="2" 
                                              placeholder="Brief description of the armoured regiment">@(Model.ExistingArmoured?.Description ?? "")</textarea>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Vehicles & Weapons -->
                    <div class="unit-section">
                        <h6>Vehicles & Weapons</h6>
                        <div class="row">
                            <div class="col-md-4">
                                <div class="form-group">
                                    <label for="armouredTanks">Tanks</label>
                                    <input type="number" class="form-control" id="armouredTanks" 
                                           value="@(Model.ExistingArmoured?.Tanks ?? 0)" min="0" />
                                </div>
                            </div>
                            <div class="col-md-4">
                                <div class="form-group">
                                    <label for="armouredATGMS">ATGMS (Anti-Tank Guided Missiles)</label>
                                    <input type="number" class="form-control" id="armouredATGMS" 
                                           value="@(Model.ExistingArmoured?.ATGMS ?? 0)" min="0" />
                                </div>
                            </div>
                            <div class="col-md-4">
                                <div class="form-group">
                                    <label for="armouredMortars120mm">Mortars 120mm</label>
                                    <input type="number" class="form-control" id="armouredMortars120mm" 
                                           value="@(Model.ExistingArmoured?.Mortars120mm ?? 0)" min="0" />
                                </div>
                            </div>
                        </div>
                        <div class="row">
                            <div class="col-md-6">
                                <div class="form-group">
                                    <label for="armouredHMG">HMG (Heavy Machine Guns)</label>
                                    <input type="number" class="form-control" id="armouredHMG" 
                                           value="@(Model.ExistingArmoured?.HMG ?? 0)" min="0" />
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Drone Systems -->
                    <div class="unit-section">
                        <h6>Drone Systems</h6>
                        <div class="row">
                            <div class="col-md-6">
                                <div class="form-group">
                                    <label for="armouredDrones">Number of Drones</label>
                                    <input type="number" class="form-control" id="armouredDrones" 
                                           value="@(Model.ExistingArmoured?.Drones ?? 0)" min="0" />
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="form-group">
                                    <label for="armouredDroneTypes">Drone Types</label>
                                    <input type="text" class="form-control" id="armouredDroneTypes" 
                                           value="@(Model.ExistingArmoured?.DroneTypes ?? "")" 
                                           placeholder="e.g., Recon, Combat, Surveillance" />
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Mobility Data -->
                    <div class="unit-section">
                        <h6>Mobility & Speed Data (km/h)</h6>
                        <div class="row">
                            <div class="col-md-6">
                                <div class="form-group">
                                    <label for="armouredMarchingSpeedRoads">Marching Speed - Roads</label>
                                    <input type="number" step="0.1" class="form-control" id="armouredMarchingSpeedRoads" 
                                           value="@(Model.ExistingArmoured?.MarchingSpeedRoads ?? 15)" min="0" />
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="form-group">
                                    <label for="armouredMarchingSpeedCrossCountry">Marching Speed - Cross Country</label>
                                    <input type="number" step="0.1" class="form-control" id="armouredMarchingSpeedCrossCountry" 
                                           value="@(Model.ExistingArmoured?.MarchingSpeedCrossCountry ?? 10)" min="0" />
                                </div>
                            </div>
                        </div>
                        <div class="row">
                            <div class="col-md-6">
                                <div class="form-group">
                                    <label for="armouredCombatAdvanceSpeed">Combat Advance Speed</label>
                                    <input type="number" step="0.1" class="form-control" id="armouredCombatAdvanceSpeed" 
                                           value="@(Model.ExistingArmoured?.CombatAdvanceSpeed ?? 1)" min="0" />
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="unit-footer">
                        <button type="button" class="btn btn-success" onclick="saveArmouredRegiment()">
                            <i class="fas fa-save"></i> Save Armoured Regiment
                        </button>
                        @if (Model.ExistingArmoured != null)
                        {
                            <button type="button" class="btn btn-danger" onclick="deleteArmouredRegiment()">
                                <i class="fas fa-trash"></i> Delete Unit
                            </button>
                        }
                    </div>
                </form>
            </div>

            <!-- Artillery Regiment Tab -->
            <div id="artillery-tab" class="unit-tab-content">
                <form id="artilleryForm">
                    <div class="unit-header">
                        <h5><i class="fas fa-crosshairs"></i> Artillery Regiment Data</h5>
                        @if (Model.ExistingArtillery != null)
                        {
                            <span class="badge badge-success">Unit Exists - Editing</span>
                            <input type="hidden" id="artilleryId" value="@Model.ExistingArtillery.Id" />
                        }
                        else
                        {
                            <span class="badge badge-warning">New Unit</span>
                            <input type="hidden" id="artilleryId" value="" />
                        }
                    </div>

                    <!-- Basic Artillery Information -->
                    <div class="unit-section">
                        <h6>Basic Information</h6>
                        <div class="row">
                            <div class="col-md-6">
                                <div class="form-group">
                                    <label for="artilleryName">Regiment Name *</label>
                                    <input type="text" class="form-control" id="artilleryName" required 
                                           value="@(Model.ExistingArtillery?.Name ?? "")" 
                                           placeholder="e.g., 1st Artillery Regiment" />
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="form-group">
                                    <label for="artilleryCode">Unit Code *</label>
                                    <input type="text" class="form-control" id="artilleryCode" required 
                                           value="@(Model.ExistingArtillery?.UnitCode ?? "")" 
                                           placeholder="e.g., 1ArR" />
                                </div>
                            </div>
                        </div>
                        <div class="row">
                            <div class="col-md-6">
                                <div class="form-group">
                                    <label for="artilleryStrength">Strength (Personnel) *</label>
                                    <input type="number" class="form-control" id="artilleryStrength" required 
                                           value="@(Model.ExistingArtillery?.Strength ?? 0)" min="0" />
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="form-group">
                                    <label for="artilleryBatteries">Batteries</label>
                                    <input type="number" class="form-control" id="artilleryBatteries" 
                                           value="@(Model.ExistingArtillery?.Batteries ?? 0)" min="0" />
                                </div>
                            </div>
                        </div>
                        <div class="row">
                            <div class="col-md-12">
                                <div class="form-group">
                                    <label for="artilleryDescription">Description</label>
                                    <textarea class="form-control" id="artilleryDescription" rows="2" 
                                              placeholder="Brief description of the artillery regiment">@(Model.ExistingArtillery?.Description ?? "")</textarea>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Artillery Systems -->
                    <div class="unit-section">
                        <h6>Artillery Systems</h6>
                        <div class="row">
                            <div class="col-md-4">
                                <div class="form-group">
                                    <label for="artilleryGuns">Number of Guns</label>
                                    <input type="number" class="form-control" id="artilleryGuns" 
                                           value="@(Model.ExistingArtillery?.Guns ?? 0)" min="0" />
                                </div>
                            </div>
                            <div class="col-md-4">
                                <div class="form-group">
                                    <label for="artilleryGunRange">Gun Range (km)</label>
                                    <input type="number" step="0.1" class="form-control" id="artilleryGunRange" 
                                           value="@(Model.ExistingArtillery?.GunRange ?? 0)" min="0" />
                                </div>
                            </div>
                            <div class="col-md-4">
                                <div class="form-group">
                                    <label for="artilleryGunCaliber">Gun Caliber</label>
                                    <input type="text" class="form-control" id="artilleryGunCaliber" 
                                           value="@(Model.ExistingArtillery?.GunCaliber ?? "155mm SP")" 
                                           placeholder="e.g., 155mm SP, 105mm" />
                                </div>
                            </div>
                        </div>
                        <div class="row">
                            <div class="col-md-6">
                                <div class="form-group">
                                    <label for="artilleryHMG">HMG (Heavy Machine Guns)</label>
                                    <input type="number" class="form-control" id="artilleryHMG" 
                                           value="@(Model.ExistingArtillery?.HMG ?? 0)" min="0" />
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Drone Systems -->
                    <div class="unit-section">
                        <h6>Drone Systems</h6>
                        <div class="row">
                            <div class="col-md-6">
                                <div class="form-group">
                                    <label for="artilleryDrones">Number of Drones</label>
                                    <input type="number" class="form-control" id="artilleryDrones" 
                                           value="@(Model.ExistingArtillery?.Drones ?? 0)" min="0" />
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="form-group">
                                    <label for="artilleryDroneTypes">Drone Types</label>
                                    <input type="text" class="form-control" id="artilleryDroneTypes" 
                                           value="@(Model.ExistingArtillery?.DroneTypes ?? "")" 
                                           placeholder="e.g., Recon, Surveillance, Fire Control" />
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="unit-footer">
                        <button type="button" class="btn btn-success" onclick="saveArtilleryRegiment()">
                            <i class="fas fa-save"></i> Save Artillery Regiment
                        </button>
                        @if (Model.ExistingArtillery != null)
                        {
                            <button type="button" class="btn btn-danger" onclick="deleteArtilleryRegiment()">
                                <i class="fas fa-trash"></i> Delete Unit
                            </button>
                        }
                    </div>
                </form>
            </div>

            <!-- Intelligence Tab -->
            <div id="intelligence-tab" class="unit-tab-content">
                <div class="unit-header">
                    <h5><i class="fas fa-eye"></i> Intelligence Data</h5>
                    <span class="badge badge-info">Information & Intelligence Reports</span>
                </div>

                <!-- Add New Intelligence -->
                <div class="unit-section">
                    <h6>Add New Intelligence Report</h6>
                    <form id="intelligenceForm">
                        <div class="row">
                            <div class="col-md-6">
                                <div class="form-group">
                                    <label for="intelTitle">Title *</label>
                                    <input type="text" class="form-control" id="intelTitle" required 
                                           placeholder="e.g., Enemy Movement Spotted" />
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="form-group">
                                    <label for="intelSource">Source</label>
                                    <input type="text" class="form-control" id="intelSource" 
                                           placeholder="e.g., Drone Surveillance, Human Intelligence" />
                                </div>
                            </div>
                        </div>
                        <div class="row">
                            <div class="col-md-6">
                                <div class="form-group">
                                    <label for="intelPriority">Priority *</label>
                                    <select class="form-control" id="intelPriority" required>
                                        <option value="">Select Priority</option>
                                        <option value="High">High Priority</option>
                                        <option value="Medium">Medium Priority</option>
                                        <option value="Low">Low Priority</option>
                                    </select>
                                </div>
                            </div>
                        </div>
                        <div class="row">
                            <div class="col-md-12">
                                <div class="form-group">
                                    <label for="intelDescription">Description *</label>
                                    <textarea class="form-control" id="intelDescription" rows="3" required
                                              placeholder="Detailed intelligence information..."></textarea>
                                </div>
                            </div>
                        </div>
                        <div class="unit-footer">
                            <button type="button" class="btn btn-success" onclick="saveIntelligence()">
                                <i class="fas fa-save"></i> Save Intelligence Report
                            </button>
                        </div>
                    </form>
                </div>

                <!-- Existing Intelligence List -->
                <div class="unit-section">
                    <h6>Existing Intelligence Reports (@(Model.ExistingIntelligence?.Count ?? 0))</h6>
                    @if (Model.ExistingIntelligence != null && Model.ExistingIntelligence.Any())
                    {
                        <div class="intelligence-list">
                            @foreach (var intel in Model.ExistingIntelligence)
                            {
                                <div class="intelligence-item" data-intel-id="@intel.Id">
                                    <div class="intel-header">
                                        <h6>@intel.Title</h6>
                                        <span class="badge badge-@(intel.Priority.ToLower() == "high" ? "danger" : intel.Priority.ToLower() == "medium" ? "warning" : "secondary")">
                                            @intel.Priority Priority
                                        </span>
                                        <small class="text-muted">@intel.CreatedDate.Value.ToString("yyyy-MM-dd HH:mm")</small>
                                    </div>
                                    <p><strong>Source:</strong> @intel.Source</p>
                                    <p>@intel.Description</p>
                                    <div class="intel-actions">
                                        <button type="button" class="btn btn-sm btn-primary" onclick="editIntelligence('@intel.Id')">
                                            <i class="fas fa-edit"></i> Edit
                                        </button>
                                        <button type="button" class="btn btn-sm btn-danger" onclick="deleteIntelligence('@intel.Id')">
                                            <i class="fas fa-trash"></i> Delete
                                        </button>
                                    </div>
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                        <p class="text-muted">No intelligence reports yet. Add one above.</p>
                    }
                </div>
            </div>

            <!-- Reconnaissance Tab -->
            <div id="recon-tab" class="unit-tab-content">
                <div class="unit-header">
                    <h5><i class="fas fa-binoculars"></i> Reconnaissance Data</h5>
                    <span class="badge badge-info">Reconnaissance & Surveillance Reports</span>
                </div>

                <!-- Add New Recon -->
                <div class="unit-section">
                    <h6>Add New Reconnaissance Report</h6>
                    <form id="reconForm">
                        <div class="row">
                            <div class="col-md-6">
                                <div class="form-group">
                                    <label for="reconType">Reconnaissance Type *</label>
                                    <select class="form-control" id="reconType" required>
                                        <option value="">Select Type</option>
                                        <option value="Drone Surveillance">Drone Surveillance</option>
                                        <option value="Ground Patrol">Ground Patrol</option>
                                        <option value="Air Reconnaissance">Air Reconnaissance</option>
                                        <option value="Electronic Surveillance">Electronic Surveillance</option>
                                        <option value="Human Intelligence">Human Intelligence</option>
                                        <option value="Signal Intelligence">Signal Intelligence</option>
                                        <option value="Visual Observation">Visual Observation</option>
                                    </select>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="form-group">
                                    <label for="reconLocation">Location</label>
                                    <input type="text" class="form-control" id="reconLocation" 
                                           placeholder="e.g., Grid 12345, Sector Alpha" />
                                </div>
                            </div>
                        </div>
                        <div class="row">
                            <div class="col-md-6">
                                <div class="form-group">
                                    <label for="reconConfidence">Confidence Level *</label>
                                    <select class="form-control" id="reconConfidence" required>
                                        <option value="">Select Confidence</option>
                                        <option value="High">High Confidence</option>
                                        <option value="Medium">Medium Confidence</option>
                                        <option value="Low">Low Confidence</option>
                                    </select>
                                </div>
                            </div>
                        </div>
                        <div class="row">
                            <div class="col-md-12">
                                <div class="form-group">
                                    <label for="reconDescription">Reconnaissance Details *</label>
                                    <textarea class="form-control" id="reconDescription" rows="3" required
                                              placeholder="Detailed reconnaissance findings..."></textarea>
                                </div>
                            </div>
                        </div>
                        <div class="unit-footer">
                            <button type="button" class="btn btn-success" onclick="saveReconnaissance()">
                                <i class="fas fa-save"></i> Save Reconnaissance Report
                            </button>
                        </div>
                    </form>
                </div>

                <!-- Existing Recon List -->
                <div class="unit-section">
                    <h6>Existing Reconnaissance Reports (@(Model.ExistingRecon?.Count ?? 0))</h6>
                    @if (Model.ExistingRecon != null && Model.ExistingRecon.Any())
                    {
                        <div class="recon-list">
                            @foreach (var recon in Model.ExistingRecon)
                            {
                                <div class="recon-item" data-recon-id="@recon.Id">
                                    <div class="recon-header">
                                        <h6>@recon.ReconType</h6>
                                        <span class="badge badge-@(recon.Confidence.ToLower() == "high" ? "success" : recon.Confidence.ToLower() == "medium" ? "warning" : "secondary")">
                                            @recon.Confidence Confidence
                                        </span>
                                        <small class="text-muted">@recon.CreatedDate.Value.ToString("yyyy-MM-dd HH:mm")</small>
                                    </div>
                                    <p><strong>Location:</strong> @recon.Location</p>
                                    <p>@recon.Description</p>
                                    <div class="recon-actions">
                                        <button type="button" class="btn btn-sm btn-primary" onclick="editReconnaissance('@recon.Id')">
                                            <i class="fas fa-edit"></i> Edit
                                        </button>
                                        <button type="button" class="btn btn-sm btn-danger" onclick="deleteReconnaissance('@recon.Id')">
                                            <i class="fas fa-trash"></i> Delete
                                        </button>
                                    </div>
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                        <p class="text-muted">No reconnaissance reports yet. Add one above.</p>
                    }
                </div>
            </div>
        </div>
        
        <div class="gameplay-modal-footer">
            <button class="gameplay-btn gameplay-btn-success" onclick="closeUnitsDataEntryModal()">
                <i class="fas fa-check"></i> Done Adding Units
            </button>
        </div>
    </div>
</div>

<style>
