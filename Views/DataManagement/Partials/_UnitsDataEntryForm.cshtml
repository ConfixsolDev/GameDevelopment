// Delete functions
function deleteBrigadeInfantry(unitId) {
    if (!confirm('Are you sure you want to delete this Infantry Battalion?')) return;
    
    console.log('🗑️ Deleting Infantry:', unitId);
    
    $.ajax({
        url: '/DataManagement/DeleteTokenInfantryBattalion',
        type: 'DELETE',
        contentType: 'application/json',
        data: JSON.stringify({ Id: unitId }),
        success: function(response) {
            console.log('✅ Infantry deleted');
            alert('Infantry Battalion deleted successfully');
            
            // Reload the form to show updated list
            const tokenId = $('#tokenId').val();
            const brigadeId = $('#brigadeId').val();
            $.get('/DataManagement/UnitsDataEntryForm', { tokenId, brigadeId }, function(data) {
                $('#unitsDataEntryModal .modal-content').html($(data).find('.modal-content').html());
            });
        },
        error: function(xhr, status, error) {
            console.error('❌ Delete failed:', error);
            alert('Failed to delete Infantry Battalion: ' + error);
        }
    });
}

