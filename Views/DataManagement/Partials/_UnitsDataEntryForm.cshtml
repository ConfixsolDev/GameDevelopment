// Save Reconnaissance Report
function saveReconnaissance() {
    console.log('💾 Saving Reconnaissance Report...');
    
    const reconData = {
        tokenId: document.getElementById('tokenId').value,
        reconType: document.getElementById('reconType').value,
        location: document.getElementById('reconLocation').value,
        confidence: document.getElementById('reconConfidence').value,
        description: document.getElementById('reconDescription').value
    };
    
    // Validation
    if (!reconData.reconType || !reconData.confidence || !reconData.description) {
        alert('Please fill in Reconnaissance Type, Confidence Level, and Details');
        return;
    }
    
    $("#loading").show();
    
    $.ajax({
        url: '/DataManagement/CreateTokenRecon',
        type: 'POST',
        contentType: 'application/json',
        data: JSON.stringify(reconData),
        success: function(response) {
            console.log('✅ Reconnaissance saved successfully:', response);
            
            if (response.success) {
                alert('Reconnaissance report saved successfully!');
                
                // Clear the form
                document.getElementById('reconForm').reset();
                
                // Update the tab counter
                const tab = document.querySelector(`[onclick="showUnitTab('recon')"]`);
                if (tab) {
                    const statusSpan = tab.querySelector('.unit-status');
                    if (statusSpan) {
                        const currentCount = parseInt(statusSpan.textContent) || 0;
                        statusSpan.textContent = currentCount + 1;
                    } else {
                        tab.innerHTML += '<span class="unit-status saved">1</span>';
                    }
                }
                
                // Suggest refreshing to see the new data
                if (confirm('Reconnaissance saved! Would you like to refresh the form to see all reports?')) {
                    location.reload();
                }
            } else {
                alert('Error saving reconnaissance: ' + response.message);
            }
        },
        error: function(xhr, status, error) {
            console.error('❌ Error saving reconnaissance:', error);
            alert('Error saving reconnaissance. Please try again.');
        },
        complete: function() {
            $("#loading").hide();
        }
    });
}

// Generic save unit function
function saveUnit(unitType, unitData, unitDisplayName) {
    $("#loading").show();
    
    const isUpdate = unitData.id && unitData.id !== '';
    
    // Map unit types to correct endpoint names
    let endpoint;
    if (unitType === 'infantry') {
        endpoint = `/DataManagement/${isUpdate ? 'Update' : 'Create'}TokenInfantryBattalion`;
    } else if (unitType === 'armoured') {
        endpoint = `/DataManagement/${isUpdate ? 'Update' : 'Create'}TokenArmouredRegiment`;
    } else if (unitType === 'artillery') {
        endpoint = `/DataManagement/${isUpdate ? 'Update' : 'Create'}TokenArtilleryRegiment`;
    } else {
        console.error('Unknown unit type:', unitType);
        alert(`Unknown unit type: ${unitType}`);
        $("#loading").hide();
        return;
    }
    
    console.log(`📡 Saving ${unitDisplayName} to endpoint:`, endpoint);
    console.log('📦 Data being sent:', unitData);
    
    $.ajax({
        url: endpoint,
        type: isUpdate ? 'PUT' : 'POST',
        contentType: 'application/json',
        data: JSON.stringify(unitData),
        success: function(response) {
            console.log(`✅ ${unitDisplayName} saved successfully:`, response);
            
            if (response.success) {
                alert(`${unitDisplayName} saved successfully!`);
                
                // Update the tab to show saved status
                const tab = document.querySelector(`[onclick="showUnitTab('${unitType}')"]`);
                if (tab && !tab.querySelector('.unit-status')) {
                    tab.innerHTML += '<span class="unit-status saved">✓</span>';
                }
                
                // If it was a new unit, update the hidden ID field
                if (!isUpdate && response.data && response.data.id) {
                    document.getElementById(unitType + 'Id').value = response.data.id;
                }
            } else {
                alert(`Error saving ${unitDisplayName}: ` + (response.message || 'Unknown error'));
            }
        },
        error: function(xhr, status, error) {
            console.error(`❌ Error saving ${unitDisplayName}:`, error);
            console.error('   Status Code:', xhr.status);
            console.error('   Response Text:', xhr.responseText);
            
            let errorMessage = `Error saving ${unitDisplayName}. Please try again.`;
            if (xhr.status === 404) {
                errorMessage = `Endpoint not found (404): ${endpoint}`;
            } else if (xhr.status === 500) {
                errorMessage = `Server error (500): ${xhr.responseText}`;
            } else if (xhr.responseJSON && xhr.responseJSON.message) {
                errorMessage = `Error: ${xhr.responseJSON.message}`;
            }
            
            alert(errorMessage);
        },
        complete: function() {
            $("#loading").hide();
        }
    });
}

