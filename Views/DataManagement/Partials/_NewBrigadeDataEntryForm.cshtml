@using static TechWebSol.Controllers.DataManagementController
@model NewBrigadeDataEntryViewModel

<!-- New Brigade Data Entry Form Modal - Brigade Only -->
<div id="newBrigadeDataEntryModal" class="gameplay-modal" style="display: none;">
    <div class="gameplay-modal-content">
        <div class="gameplay-modal-header">
            <h3><i class="fas fa-flag"></i> Create New Brigade - @Model.Token.Name</h3>
            <button class="gameplay-modal-close" onclick="closeNewBrigadeDataEntryModal()">&times;</button>
        </div>
        <div class="gameplay-modal-body">
            <form id="brigadeOnlyForm">
                <!-- Hidden fields for token and team -->
                <input type="hidden" id="tokenId" value="@Model.Token.Id" />
                <input type="hidden" id="teamId" value="@Model.Brigade.TeamId" />
                
                <!-- Token Information Display -->
                <div class="token-info-section">
                    <div class="token-display">
                        @if (!string.IsNullOrEmpty(Model.Token.AssetImagePath))
                        {
                            <img src="@Model.Token.AssetImagePath" alt="@Model.Token.Name" class="token-preview-image">
                        }
                        else
                        {
                            <div class="token-preview-placeholder">
                                <i class="fas fa-crosshairs"></i>
                            </div>
                        }
                        <div class="token-details">
                            <h4>@Model.Token.Name</h4>
                            <p class="text-muted">@Model.Token.TokenGroup?.Name</p>
                        </div>
                    </div>
                </div>

                <!-- Brigade Information Only -->
                <div class="data-section">
                    <h5><i class="fas fa-flag"></i> Brigade Information</h5>
                    <div class="alert alert-info">
                        <i class="fas fa-info-circle"></i> 
                        <strong>Step 1 of 2:</strong> First create the Brigade, then you'll be able to add Infantry, Armoured, and Artillery units.
                    </div>
                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-group">
                                <label for="brigadeName">Brigade Name *</label>
                                <input type="text" class="form-control" id="brigadeName" required placeholder="e.g., 1st Armoured Brigade" />
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group">
                                <label for="brigadeCode">Brigade Code *</label>
                                <input type="text" class="form-control" id="brigadeCode" required placeholder="e.g., 1AB, 2IB" />
                            </div>
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-group">
                                <label for="forceType">Force Type *</label>
                                <select class="form-control" id="forceType" required>
                                    <option value="Blue" selected>Blue Force</option>
                                    <option value="Red">Red Force</option>
                                </select>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group">
                                <label for="brigadeDescription">Description</label>
                                <input type="text" class="form-control" id="brigadeDescription" placeholder="Brief description of the brigade" />
                            </div>
                        </div>
                    </div>
                    
                    <div class="alert alert-success mt-3">
                        <i class="fas fa-arrow-right"></i> 
                        After saving the Brigade, you'll be able to add specific units (Infantry Battalion, Armoured Regiment, Artillery Regiment) one by one.
                    </div>
                </div>
            </form>
        </div>
        <div class="gameplay-modal-footer">
            <button class="gameplay-btn gameplay-btn-primary" onclick="saveBrigadeOnly()">
                <i class="fas fa-save"></i> Save Brigade & Continue to Units
            </button>
            <button class="gameplay-btn" onclick="closeNewBrigadeDataEntryModal()">Cancel</button>
        </div>
    </div>
</div>

<style>
.token-info-section {
    background: #f8f9fa;
    border-radius: 8px;
    padding: 15px;
    margin-bottom: 20px;
}

.token-display {
    display: flex;
    align-items: center;
    gap: 15px;
}

.token-preview-image {
    width: 60px;
    height: 60px;
    border-radius: 8px;
    object-fit: cover;
    border: 2px solid #007bff;
}

.token-preview-placeholder {
    width: 60px;
    height: 60px;
    border-radius: 8px;
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    display: flex;
    align-items: center;
    justify-content: center;
    color: white;
    font-size: 24px;
    border: 2px solid #007bff;
}

.token-details h4 {
    margin: 0;
    color: #2c3e50;
}

.data-section {
    background: #fff;
    border: 1px solid #dee2e6;
    border-radius: 8px;
    padding: 20px;
    margin-bottom: 20px;
}

.data-section h5 {
    color: #495057;
    margin-bottom: 15px;
    padding-bottom: 10px;
    border-bottom: 2px solid #e9ecef;
}

.form-group {
    margin-bottom: 15px;
}

.form-group label {
    font-weight: 600;
    color: #495057;
    margin-bottom: 5px;
}

.gameplay-btn-primary {
    background: #28a745;
    color: white;
}

.gameplay-btn-primary:hover {
    background: #218838;
}
</style>

<script>
// Close new brigade data entry modal
function closeNewBrigadeDataEntryModal() {
    console.log('🔒 Closing new brigade data entry modal');
    document.getElementById('newBrigadeDataEntryModal').style.display = 'none';
}

// Save brigade only (first step)
function saveBrigadeOnly() {
    console.log('💾 Saving brigade only...');
    
    // Collect brigade form data
    const brigadeData = {
        tokenId: document.getElementById('tokenId').value,
        teamId: document.getElementById('teamId').value,
        brigadeName: document.getElementById('brigadeName').value,
        brigadeCode: document.getElementById('brigadeCode').value,
        forceType: document.getElementById('forceType').value,
        brigadeDescription: document.getElementById('brigadeDescription').value
    };
    
    // Basic validation
    if (!brigadeData.brigadeName || !brigadeData.brigadeCode) {
        alert('Please fill in Brigade Name and Brigade Code');
        return;
    }
    
    // Show loading
    $("#loading").show();
    
    // Save brigade via AJAX
    $.ajax({
        url: '/DataManagement/CreateTokenBrigade',
        type: 'POST',
        contentType: 'application/json',
        data: JSON.stringify(brigadeData),
        success: function(response) {
            console.log('✅ Brigade saved successfully:', response);
            
            if (response.success) {
                console.log('🎯 Brigade created, now loading units form...');
                closeNewBrigadeDataEntryModal();
                
                // Load the units form for this newly created brigade
                loadUnitsDataEntryForm(brigadeData.tokenId, response.brigadeId);
            } else {
                alert('Error saving brigade: ' + response.message);
            }
        },
        error: function(xhr, status, error) {
            console.error('❌ Error saving brigade:', error);
            alert('Error saving brigade. Please try again.');
        },
        complete: function() {
            $("#loading").hide();
        }
    });
}

// Load units data entry form after brigade is created
function loadUnitsDataEntryForm(tokenId, brigadeId) {
    console.log('🔧 Loading units form for brigade:', brigadeId);
    
    // Show loading
    $("#loading").show();
    
    // Load the units form via AJAX
    $.ajax({
        url: '/DataManagement/UnitsDataEntryForm',
        type: 'GET',
        data: { tokenId: tokenId, brigadeId: brigadeId },
        success: function(data) {
            console.log('✅ Units form loaded');
            
            // Remove any existing units modal
            $('#unitsDataEntryModal').remove();
            
            // Add the new modal to the body
            $('body').append(data);
            
            // Show the modal
            document.getElementById('unitsDataEntryModal').style.display = 'flex';
            
            console.log('✅ Units form displayed successfully');
        },
        error: function(xhr, status, error) {
            console.error('❌ Error loading units form:', error);
            alert('Brigade saved, but failed to load units form. Please refresh and try again.');
        },
        complete: function() {
            $("#loading").hide();
        }
    });
}
</script>