@using static TechWebSol.Controllers.DataManagementController
@model NewBrigadeDataEntryViewModel

<!-- New Brigade Data Entry Form Modal - Brigade Only - Bootstrap Modal -->
<div class="modal fade" id="newBrigadeDataEntryModal" tabindex="-1" role="dialog" aria-labelledby="newBrigadeDataEntryModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-xl" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="newBrigadeDataEntryModalLabel">
                    <i class="fas fa-flag"></i> Create New Brigade - @Model.Token.Name
                </h5>
                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <div class="modal-body">
            <form id="brigadeOnlyForm">
                <!-- Hidden fields for token and team -->
                <input type="hidden" id="tokenId" value="@Model.Token.Id" />
                <input type="hidden" id="teamId" value="@Model.Brigade.TeamId" />
                
                <!-- Token Information as Base Data (Primary) -->
                <div class="token-base-section">
                    <h5><i class="fas fa-crosshairs"></i> Token Base Information</h5>
                    <div class="token-display">
                        @if (!string.IsNullOrEmpty(Model.Token.AssetImagePath))
                        {
                            <img src="@Model.Token.AssetImagePath" alt="@Model.Token.Name" class="token-preview-image">
                        }
                        else
                        {
                            <div class="token-preview-placeholder">
                                <i class="fas fa-crosshairs"></i>
                            </div>
                        }
                        <div class="token-details">
                            <h4>@Model.Token.Name</h4>
                            <p class="text-muted">@Model.Token.TokenGroup?.Name</p>
                            <div class="token-status">
                                <span class="badge badge-primary">Active Token</span>
                                <span class="badge badge-info">@Model.Token.ForceType</span>
                            </div>
                        </div>
                    </div>
                    <div class="alert alert-success">
                        <i class="fas fa-check-circle"></i> 
                        <strong>Token Selected:</strong> This token will serve as the base for your brigade data entry.
                    </div>
                </div>

                <!-- Brigade Information (Secondary) -->
                <div class="data-section">
                    <h5><i class="fas fa-flag"></i> Brigade Information</h5>
                    <div class="alert alert-info">
                        <i class="fas fa-info-circle"></i> 
                        <strong>Step 1 of 2:</strong> Now create the Brigade for this token, then you'll be able to add Infantry, Armoured, and Artillery units.
                    </div>
                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-group">
                                <label for="brigadeName">Brigade Name *</label>
                                <input type="text" class="form-control" id="brigadeName" required placeholder="e.g., 1st Armoured Brigade" />
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group">
                                <label for="brigadeCode">Brigade Code *</label>
                                <input type="text" class="form-control" id="brigadeCode" required placeholder="e.g., 1AB, 2IB" />
                            </div>
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-group">
                                <label for="forceType">Force Type *</label>
                                <select class="form-control" id="forceType" required>
                                    <option value="Blue" selected>Blue Force</option>
                                    <option value="Red">Red Force</option>
                                </select>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group">
                                <label for="brigadeDescription">Description</label>
                                <input type="text" class="form-control" id="brigadeDescription" placeholder="Brief description of the brigade" />
                            </div>
                        </div>
                    </div>
                    
                    <div class="alert alert-success mt-3">
                        <i class="fas fa-arrow-right"></i> 
                        After saving the Brigade, you'll be able to add specific units (Infantry Battalion, Armoured Regiment, Artillery Regiment) one by one.
                    </div>
                </div>
            </form>
        </div>
        <div class="modal-footer">
            <button type="button" class="btn btn-secondary" data-dismiss="modal">
                <i class="fas fa-times"></i> Cancel
            </button>
            <button type="button" class="btn btn-primary" onclick="saveBrigadeOnly()">
                <i class="fas fa-save"></i> Save Brigade & Continue to Units
            </button>
        </div>
    </div>
    </div>
</div>

<style>
.token-base-section {
    background: #e8f5e8;
    border: 2px solid #28a745;
    border-radius: 8px;
    padding: 20px;
    margin-bottom: 25px;
}

.token-base-section h5 {
    color: #28a745;
    margin-bottom: 15px;
    font-weight: 600;
}

.token-display {
    display: flex;
    align-items: center;
    gap: 15px;
}

.token-preview-image {
    width: 60px;
    height: 60px;
    border-radius: 8px;
    object-fit: cover;
    border: 2px solid #007bff;
}

.token-preview-placeholder {
    width: 60px;
    height: 60px;
    border-radius: 8px;
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    display: flex;
    align-items: center;
    justify-content: center;
    color: white;
    font-size: 24px;
    border: 2px solid #007bff;
}

.token-details h4 {
    margin: 0;
    color: #2c3e50;
}

.token-status {
    margin-top: 8px;
    display: flex;
    gap: 8px;
}

.badge {
    padding: 4px 8px;
    border-radius: 4px;
    font-size: 11px;
    font-weight: 600;
}

.badge-primary {
    background: #007bff;
    color: white;
}

.badge-info {
    background: #17a2b8;
    color: white;
}

.data-section {
    background: #fff;
    border: 1px solid #dee2e6;
    border-radius: 8px;
    padding: 20px;
    margin-bottom: 20px;
}

.data-section h5 {
    color: #495057;
    margin-bottom: 15px;
    padding-bottom: 10px;
    border-bottom: 2px solid #e9ecef;
}

.form-group {
    margin-bottom: 15px;
}

.form-group label {
    font-weight: 600;
    color: #495057;
    margin-bottom: 5px;
}

.gameplay-btn-primary {
    background: #28a745;
    color: white;
}

.gameplay-btn-primary:hover {
    background: #218838;
}
</style>

<script>
// Close new brigade data entry modal - Bootstrap Modal API
function closeNewBrigadeDataEntryModal() {
    console.log('🔒 Closing new brigade data entry modal');
    $('#newBrigadeDataEntryModal').modal('hide');
}

// Save brigade only (first step)
function saveBrigadeOnly() {
    console.log('💾 Saving brigade only...');
    
    // Collect brigade form data - Use PascalCase to match controller
    const brigadeData = {
        TokenId: document.getElementById('tokenId').value,
        BrigadeCode: document.getElementById('brigadeCode').value
    };
    
    // Basic validation
    if (!brigadeData.BrigadeCode) {
        alert('Please fill in Brigade Code');
        return;
    }
    
    // Show loading
    $("#loading").show();
    
    // Save brigade via AJAX
    $.ajax({
        url: '/DataManagement/CreateTokenBrigade',
        type: 'POST',
        contentType: 'application/json',
        data: JSON.stringify(brigadeData),
        success: function(response) {
            console.log('✅ Brigade saved successfully:', response);
            
            if (response.success) {
                console.log('🎯 Brigade created, now loading units form...');
                closeNewBrigadeDataEntryModal();
                
                // Load the units form for this newly created brigade
                loadUnitsDataEntryForm(brigadeData.TokenId, response.data.id);
            } else {
                alert('Error saving brigade: ' + response.message);
            }
        },
        error: function(xhr, status, error) {
            console.error('❌ Error saving brigade:', error);
            alert('Error saving brigade. Please try again.');
        },
        complete: function() {
            $("#loading").hide();
        }
    });
}

// Load units data entry form after brigade is created
function loadUnitsDataEntryForm(tokenId, brigadeId) {
    console.log('🔧 Loading units form for brigade:', brigadeId);
    
    // Show loading
    $("#loading").show();
    
    // Load the units form via AJAX
    $.ajax({
        url: '/DataManagement/UnitsDataEntryForm',
        type: 'GET',
        data: { tokenId: tokenId, brigadeId: brigadeId },
        success: function(data) {
            console.log('✅ Units form loaded');
            
            // Remove any existing units modal
            $('#unitsDataEntryModal').remove();
            
            // Add the new modal to the body
            $('body').append(data);
            
            // Show the modal using Bootstrap modal API
            setTimeout(() => {
                $('#unitsDataEntryModal').modal('show');
            }, 100);
            
            console.log('✅ Units form displayed successfully');
        },
        error: function(xhr, status, error) {
            console.error('❌ Error loading units form:', error);
            alert('Brigade saved, but failed to load units form. Please refresh and try again.');
        },
        complete: function() {
            $("#loading").hide();
        }
    });
}
</script>