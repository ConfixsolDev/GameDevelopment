@using static TechWebSol.Controllers.DataManagementController
@model DirectUnitFormViewModel

<!-- Direct Unit Form Modal - Units without Brigade - Bootstrap Modal -->
<div class="modal fade" id="directUnitModal" tabindex="-1" role="dialog" aria-labelledby="directUnitModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-xl" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="directUnitModalLabel">
                    <i class="fas fa-users"></i> Direct Unit Entry - @Model.Token.Name
                </h5>
                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <div class="modal-body">
                <!-- Compact Token Information -->
                <div class="compact-token-info">
                    <div class="token-header-bar">
                        <div class="token-icon-wrapper">
                            <div class="token-mini-placeholder">
                                <i class="fas fa-crosshairs"></i>
                            </div>
                        </div>
                        <div class="token-title-section">
                            <h6 class="token-name">@Model.Token.Name</h6>
                            <span class="token-subtitle">@Model.Token.TokenGroup?.Name</span>
                        </div>
                        <div class="token-badges">
                            <span class="badge badge-success">ACTIVE TOKEN</span>
                            <span class="badge badge-primary">@Model.Token.ForceType.ToUpper()</span>
                    </div>
                </div>
                    <div class="compact-info-bar">
                        <i class="fas fa-check-circle text-success"></i>
                        <span><strong>Direct Unit Entry:</strong> Units added without requiring a brigade</span>
                    </div>
                </div>

                <!-- Existing Units List -->
                <div class="existing-units-section">
                    <h6><i class="fas fa-list"></i> Existing @Model.UnitType Units</h6>
                    <div id="existingUnitsList" class="units-list">
                        @if (Model.UnitType == UnitType.Infantry && Model.ExistingInfantry.Any())
                        {
                            @foreach (var unit in Model.ExistingInfantry)
                            {
                                <div class="unit-item">
                                    <div class="unit-info">
                                        <div class="unit-name">@unit.Name</div>
                                        <div class="unit-details">Code: @unit.UnitCode | Strength: @unit.Strength | Companies: @unit.Companies</div>
                                    </div>
                                    <div class="unit-actions">
                                        <button class="btn btn-sm btn-outline-secondary" onclick="editDirectUnit('@unit.Id', '@Model.UnitType')">
                                            <i class="fas fa-edit"></i> Edit
                                        </button>
                                        <button class="btn btn-sm btn-outline-danger" onclick="deleteDirectUnit('@unit.Id', '@Model.UnitType')">
                                            <i class="fas fa-trash"></i> Delete
                                        </button>
                                    </div>
                                </div>
                            }
                        }
                        else if (Model.UnitType == UnitType.Armoured && Model.ExistingArmoured.Any())
                        {
                            @foreach (var unit in Model.ExistingArmoured)
                            {
                                <div class="unit-item">
                                    <div class="unit-info">
                                        <div class="unit-name">@unit.Name</div>
                                        <div class="unit-details">Code: @unit.UnitCode | Strength: @unit.Strength | Tanks: @unit.Tanks</div>
                                    </div>
                                    <div class="unit-actions">
                                        <button class="btn btn-sm btn-outline-secondary" onclick="editDirectUnit('@unit.Id', '@Model.UnitType')">
                                            <i class="fas fa-edit"></i> Edit
                                        </button>
                                        <button class="btn btn-sm btn-outline-danger" onclick="deleteDirectUnit('@unit.Id', '@Model.UnitType')">
                                            <i class="fas fa-trash"></i> Delete
                                        </button>
                                    </div>
                                </div>
                            }
                        }
                        else if (Model.UnitType == UnitType.Artillery && Model.ExistingArtillery.Any())
                        {
                            @foreach (var unit in Model.ExistingArtillery)
                            {
                                <div class="unit-item">
                                    <div class="unit-info">
                                        <div class="unit-name">@unit.Name</div>
                                        <div class="unit-details">Code: @unit.UnitCode | Strength: @unit.Strength | Guns: @unit.Guns</div>
                                    </div>
                                    <div class="unit-actions">
                                        <button class="btn btn-sm btn-outline-secondary" onclick="editDirectUnit('@unit.Id', '@Model.UnitType')">
                                            <i class="fas fa-edit"></i> Edit
                                        </button>
                                        <button class="btn btn-sm btn-outline-danger" onclick="deleteDirectUnit('@unit.Id', '@Model.UnitType')">
                                            <i class="fas fa-trash"></i> Delete
                                        </button>
                                    </div>
                                </div>
                            }
                        }
                        else if (Model.UnitType == UnitType.Logistics && Model.ExistingLogistics != null)
                        {
                            var unit = Model.ExistingLogistics;
                            <div class="unit-item">
                                <div class="unit-info">
                                    <div class="unit-name">@unit.Name</div>
                                    <div class="unit-details">Code: @unit.UnitCode | Strength: @unit.Strength | Trucks: @(unit.SupplyTrucks + unit.FuelTrucks)</div>
                                </div>
                                <div class="unit-actions">
                                    <button class="btn btn-sm btn-outline-secondary" onclick="editDirectUnit('@unit.Id', '@Model.UnitType')">
                                        <i class="fas fa-edit"></i> Edit
                                    </button>
                                    <button class="btn btn-sm btn-outline-danger" onclick="deleteDirectUnit('@unit.Id', '@Model.UnitType')">
                                        <i class="fas fa-trash"></i> Delete
                                    </button>
                                </div>
                            </div>
                        }
                        else if (Model.UnitType == UnitType.Engineering && Model.ExistingEngineering != null)
                        {
                            var unit = Model.ExistingEngineering;
                            <div class="unit-item">
                                <div class="unit-info">
                                    <div class="unit-name">@unit.Name</div>
                                    <div class="unit-details">Code: @unit.UnitCode | Strength: @unit.Strength | Platoons: @unit.Platoons</div>
                                </div>
                                <div class="unit-actions">
                                    <button class="btn btn-sm btn-outline-secondary" onclick="editDirectUnit('@unit.Id', '@Model.UnitType')">
                                        <i class="fas fa-edit"></i> Edit
                                    </button>
                                    <button class="btn btn-sm btn-outline-danger" onclick="deleteDirectUnit('@unit.Id', '@Model.UnitType')">
                                        <i class="fas fa-trash"></i> Delete
                                    </button>
                                </div>
                            </div>
                        }
                        else
                        {
                            <div class="no-units-message">No @Model.UnitType units found. Click "Add New" to create one.</div>
                        }
                    </div>
                </div>

                <!-- Add New Unit Button -->
                <div class="add-unit-section">
                    <button type="button" class="btn btn-primary" onclick="openDirectUnitCreationForm('@Model.UnitType', '@Model.Token.Id')">
                        <i class="fas fa-plus"></i> Add New @Model.UnitType Unit
                    </button>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-dismiss="modal">
                    <i class="fas fa-times"></i> Close
                </button>
            </div>
        </div>
    </div>
</div>

<style>
/* Direct Unit Form Styling */
#directUnitModal .modal-body {
    min-height: 500px;
}

/* Compact Token Info - Professional & Colorful */
.compact-token-info {
    background: linear-gradient(135deg, #e8f5e9 0%, #f1f8e9 100%);
    border-left: 4px solid #4caf50;
    border-radius: 6px;
    margin-bottom: 20px;
    overflow: hidden;
}

.token-header-bar {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 12px 15px;
    background: rgba(255, 255, 255, 0.7);
    border-bottom: 1px solid #e0e0e0;
}

.token-icon-wrapper {
    flex-shrink: 0;
}

.token-mini-icon {
    width: 40px;
    height: 40px;
    border-radius: 6px;
    object-fit: cover;
    border: 2px solid #4caf50;
}

.token-mini-placeholder {
    width: 40px;
    height: 40px;
    border-radius: 6px;
    background: linear-gradient(135deg, #4caf50 0%, #388e3c 100%);
    display: flex;
    align-items: center;
    justify-content: center;
    color: white;
    font-size: 18px;
    font-weight: bold;
}

.token-title-section {
    flex: 1;
    min-width: 0;
}

.token-name {
    margin: 0;
    font-size: 16px;
    font-weight: 600;
    color: #1b5e20;
}

.token-subtitle {
    font-size: 12px;
    color: #666;
    display: block;
    margin-top: 2px;
}

.token-badges {
    display: flex;
    gap: 6px;
    flex-wrap: wrap;
}

.token-badges .badge {
    font-size: 11px;
    padding: 4px 8px;
    font-weight: 600;
    letter-spacing: 0.5px;
}

.compact-info-bar {
    padding: 10px 15px;
    font-size: 13px;
    color: #2e7d32;
    display: flex;
    align-items: center;
    gap: 8px;
}

.compact-info-bar i {
    font-size: 14px;
}

.token-base-section {
    background: #e8f5e8;
    border: 2px solid #28a745;
    border-radius: 8px;
    padding: 20px;
    margin-bottom: 25px;
}

.token-base-section h5 {
    color: #28a745;
    margin-bottom: 15px;
    font-weight: 600;
}

.token-display {
    display: flex;
    align-items: center;
    gap: 15px;
}

.token-preview-image {
    width: 50px;
    height: 50px;
    border-radius: 8px;
    object-fit: cover;
    border: 2px solid #007bff;
}

.token-preview-placeholder {
    width: 50px;
    height: 50px;
    border-radius: 8px;
    background: linear-gradient(135deg, #007bff 0%, #0056b3 100%);
    display: flex;
    align-items: center;
    justify-content: center;
    color: white;
    font-size: 20px;
    border: 2px solid #007bff;
}

.token-details h4 {
    margin: 0;
    color: #2c3e50;
    font-size: 20px;
    font-weight: 600;
}

.token-status {
    display: flex;
    gap: 8px;
    margin-top: 8px;
}

.unit-type-section {
    background: #e8f5e8;
    border: 1px solid #28a745;
    border-radius: 8px;
    padding: 15px;
    margin-bottom: 20px;
}

.unit-type-section h6 {
    color: #28a745;
    margin-bottom: 10px;
    font-weight: 600;
}

.existing-units-section {
    background: #fff;
    border: 1px solid #dee2e6;
    border-radius: 8px;
    padding: 20px;
    margin-bottom: 20px;
}

.existing-units-section h6 {
    color: #495057;
    margin-bottom: 15px;
    font-weight: 600;
}

.units-list {
    max-height: 300px;
    overflow-y: auto;
}

.unit-item {
    background: #f8f9fa;
    border: 1px solid #dee2e6;
    border-radius: 6px;
    padding: 12px;
    margin-bottom: 8px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    transition: all 0.3s ease;
}

.unit-item:hover {
    background: #e9ecef;
    border-color: #007bff;
}

.unit-info {
    flex: 1;
    margin-right: 12px;
}

.unit-name {
    color: #2c3e50;
    font-weight: 600;
    font-size: 14px;
    margin-bottom: 4px;
}

.unit-details {
    color: #6c757d;
    font-size: 12px;
}

.unit-actions {
    display: flex;
    gap: 8px;
    flex-shrink: 0;
}

.btn-sm {
    padding: 6px 12px;
    font-size: 12px;
    border-radius: 4px;
}

.add-unit-section {
    text-align: center;
    padding: 15px;
    border-top: 1px solid #dee2e6;
    margin-top: 10px;
}

.no-units-message {
    text-align: center;
    padding: 30px;
    color: #6c757d;
    font-style: italic;
    font-size: 14px;
    background: #f8f9fa;
    border-radius: 6px;
    border: 1px solid #dee2e6;
}

.badge {
    padding: 4px 8px;
    border-radius: 4px;
    font-size: 11px;
    font-weight: 600;
}

.badge-info {
    background: #17a2b8;
    color: white;
}
</style>

<script>
// Close direct unit modal
function closeDirectUnitModal() {
    console.log('🔒 Closing direct unit modal');
    $('#directUnitModal').modal('hide');
}

// Open direct unit creation form
function openDirectUnitCreationForm(unitType, tokenId) {
    console.log('🆕 Opening direct unit creation form for', unitType, 'token', tokenId);
    
    showLoader();
    
    // Load the direct unit creation form via AJAX
    $.ajax({
        url: '/DataManagement/DirectUnitCreationForm',
        type: 'GET',
        data: { unitType: unitType, tokenId: tokenId },
        success: function(data) {
            console.log('✅ Direct unit creation form loaded');
            
            // Remove any existing direct unit creation modal
            $('#directUnitCreationModal').remove();
            
            // Add the new modal to the body
            $('body').append(data);
            
            // Show the modal using Bootstrap modal API
            setTimeout(() => {
                $('#directUnitCreationModal').modal('show');
                hideLoader();
            }, 100);
            
            console.log('✅ Direct unit creation form displayed successfully');
        },
        error: function(xhr, status, error) {
            hideLoader();
            console.error('❌ Error loading direct unit creation form:', error);
            alert('Failed to load unit creation form. Please try again.');
        }
    });
}

// Edit direct unit
function editDirectUnit(unitId, unitType) {
    console.log('✏️ Editing direct unit', unitId, 'type', unitType);
    
    const tokenId = '@Model.Token.Id';
    
    showLoader();
    
    // Load the direct unit creation form in edit mode
    $.ajax({
        url: '/DataManagement/DirectUnitCreationForm',
        type: 'GET',
        data: { unitType: unitType.toLowerCase(), tokenId: tokenId, unitId: unitId },
        success: function(data) {
            console.log('✅ Direct unit edit form loaded');
            
            // Remove any existing direct unit creation modal
            $('#directUnitCreationModal').remove();
            
            // Add the new modal to the body
            $('body').append(data);
            
            // Show the modal using Bootstrap modal API
            setTimeout(() => {
                $('#directUnitCreationModal').modal('show');
                hideLoader();
            }, 100);
            
            console.log('✅ Direct unit edit form displayed successfully');
        },
        error: function(xhr, status, error) {
            hideLoader();
            console.error('❌ Error loading direct unit edit form:', error);
            alert('Failed to load unit edit form. Please try again.');
        }
    });
}

// Delete direct unit
function deleteDirectUnit(unitId, unitType) {
    console.log('🗑️ Deleting direct unit', unitId, 'type', unitType);
    
    if (!confirm('Are you sure you want to delete this unit? This action cannot be undone.')) {
        return;
    }
    
    // Determine the correct endpoint based on unit type
    let endpoint = '';
    switch(unitType.toString().toLowerCase()) {
        case 'infantry':
            endpoint = '/DataManagement/DeleteTokenInfantryBattalion';
            break;
        case 'armoured':
            endpoint = '/DataManagement/DeleteTokenArmouredRegiment';
            break;
        case 'artillery':
            endpoint = '/DataManagement/DeleteTokenArtilleryRegiment';
            break;
        case 'logistics':
            endpoint = '/DataManagement/DeleteTokenLogisticsUnit';
            break;
        case 'engineering':
            endpoint = '/DataManagement/DeleteTokenCombatEngineeringCompany';
            break;
        case 'recon':
            endpoint = '/DataManagement/DeleteTokenRecon';
            break;
        default:
            alert('Unknown unit type');
            return;
    }
    
    showLoader();
    
    // Delete via AJAX
    $.ajax({
        url: `${endpoint}?id=${unitId}`,
        type: 'DELETE',
        success: function(response) {
            console.log('✅ Unit deleted successfully, response:', response);
            console.log('✅ Unit deleted successfully - reloading modal');
            
            if (typeof toastr !== 'undefined') {
                toastr.success('Unit deleted successfully', 'Success');
            }
            
            // Reload just the unit list
            const tokenId = '@Model.Token.Id';
            loadDirectUnits(tokenId, unitType);
        },
        error: function(xhr, status, error) {
            hideLoader();
            console.error('❌ Error deleting unit:', error);
            
            let errorMsg = 'Failed to delete unit. Please try again.';
            if (xhr.responseJSON && xhr.responseJSON.message) {
                errorMsg = xhr.responseJSON.message;
            }
            
            if (typeof toastr !== 'undefined') {
                toastr.error(errorMsg, 'Error');
            } else {
                alert(errorMsg);
            }
        }
    });
}

// Load direct units list using GET endpoints (Index page pattern)
function loadDirectUnits(tokenId, unitType) {
    console.log('🔄 Loading direct units:', unitType, 'for token:', tokenId);
    showLoader();
    
    let endpoint = '';
    switch(unitType.toString().toLowerCase()) {
        case 'infantry':
            endpoint = '/DataManagement/GetInfantryBattalions';
            break;
        case 'armoured':
            endpoint = '/DataManagement/GetArmouredRegiments';
            break;
        case 'artillery':
            endpoint = '/DataManagement/GetArtilleryRegiments';
            break;
        case 'logistics':
            endpoint = '/DataManagement/GetLogisticsUnits';
            break;
        case 'engineering':
            endpoint = '/DataManagement/GetEngineeringCompanies';
            break;
        default:
            console.error('❌ Unknown unit type:', unitType);
            hideLoader();
            return;
    }
    
    $.get(endpoint, { tokenId: tokenId })
        .done(function(data) {
            console.log('✅ Received units data:', data.length, 'units');
            renderDirectUnitsList(data, unitType);
            hideLoader();
        })
        .fail(function(xhr, status, error) {
            console.error('❌ Error loading units:', error);
            $('#existingUnitsList').html('<div class="no-units-message text-danger">Failed to load units. Please try again.</div>');
            hideLoader();
        });
}

// Render the units list HTML
function renderDirectUnitsList(units, unitType) {
    const container = $('#existingUnitsList');
    container.empty();
    
    if (!units || units.length === 0) {
        container.html(`<div class="no-units-message">No ${unitType} units found. Click "Add New" to create one.</div>`);
        return;
    }
    
    units.forEach(function(unit) {
        let detailsHtml = '';
        
        switch(unitType.toString().toLowerCase()) {
            case 'infantry':
                detailsHtml = `Code: ${unit.unitCode || 'N/A'} | Strength: ${unit.strength || 0} | Companies: ${unit.companies || 0}`;
                break;
            case 'armoured':
                detailsHtml = `Code: ${unit.unitCode || 'N/A'} | Strength: ${unit.strength || 0} | Tanks: ${unit.tanks || 0}`;
                break;
            case 'artillery':
                detailsHtml = `Code: ${unit.unitCode || 'N/A'} | Strength: ${unit.strength || 0} | Guns: ${unit.guns || 0}`;
                break;
            case 'logistics':
                detailsHtml = `Code: ${unit.unitCode || 'N/A'} | Strength: ${unit.strength || 0} | Trucks: ${(unit.supplyTrucks || 0) + (unit.fuelTrucks || 0)}`;
                break;
            case 'engineering':
                detailsHtml = `Code: ${unit.unitCode || 'N/A'} | Strength: ${unit.strength || 0} | Platoons: ${unit.platoons || 0}`;
                break;
        }
        
        const unitHtml = `
            <div class="unit-item">
                <div class="unit-info">
                    <div class="unit-name">${unit.name || 'Unnamed Unit'}</div>
                    <div class="unit-details">${detailsHtml}</div>
                </div>
                <div class="unit-actions">
                    <button class="btn btn-sm btn-outline-secondary" onclick="editDirectUnit('${unit.id}', '${unitType}')">
                        <i class="fas fa-edit"></i> Edit
                    </button>
                    <button class="btn btn-sm btn-outline-danger" onclick="deleteDirectUnit('${unit.id}', '${unitType}')">
                        <i class="fas fa-trash"></i> Delete
                    </button>
                </div>
            </div>
        `;
        
        container.append(unitHtml);
    });
}

// Make function globally available
window.loadDirectUnits = loadDirectUnits;
</script>
