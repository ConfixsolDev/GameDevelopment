                url: '/DataManagement/DeleteTokenArtilleryRegiment/' + id,
                method: 'DELETE',
                contentType: 'application/json'
            })
            .done(function(response) {
                if (response.success) {
                    showNotification('Artillery regiment deleted successfully', 'success');
                    loadArtilleryRegiments();
                } else {
                    showNotification('Error: ' + response.message, 'error');
                }
            })
            .fail(function() {
                showNotification('Failed to delete artillery regiment', 'error');
                });
        }

        function openBrigadeModal() {
            $('#brigadeForm')[0].reset();
            $('#brigadeId').val('');
            $('.modal-title').text('Add Brigade');
            $('#brigadeModal').modal('show');
        }

        function saveBrigade() {
            const brigadeId = $('#brigadeId').val();
            const brigadeCode = $('#brigadeCode').val();
            const forceType = $('#forceType').val();

            // Validation
            if (!brigadeCode) {
                showNotification('Please enter Brigade Code', 'error');
                return;
            }
            if (!forceType) {
                showNotification('Please select Force Type', 'error');
                return;
            }

            const isEdit = brigadeId !== '';
            const url = isEdit ? '/DataManagement/UpdateTokenBrigade' : '/DataManagement/CreateTokenBrigade';
            const method = isEdit ? 'PUT' : 'POST';

            const brigadeData = {
                BrigadeCode: brigadeCode,
                ForceType: forceType,
                TokenId: null // Standalone brigade without token
            };

            // Add Id for update operations
            if (isEdit) {
                brigadeData.Id = brigadeId;
            }

            $.ajax({
                url: url,
                method: method,
                contentType: 'application/json',
                data: JSON.stringify(brigadeData)
            })
            .done(function(response) {
                if (response.success) {
                    showNotification(isEdit ? 'Brigade updated successfully' : 'Brigade created successfully', 'success');
                    $('#brigadeModal').modal('hide');
                    loadBrigades();
                } else {
                    showNotification('Error: ' + response.message, 'error');
                }
            })
            .fail(function(xhr, status, error) {
                console.error('Error saving brigade:', error);
                showNotification('Failed to save brigade', 'error');
            });
        }

        function editBrigade(brigadeId) {
            // Load brigade data
            $.get('/DataManagement/GetBrigades')
                .done(function(data) {
                    const brigade = data.find(b => b.id === brigadeId);
                    if (brigade) {
                        $('#brigadeId').val(brigade.id);
                        $('#brigadeCode').val(brigade.brigadeCode);
                        $('#forceType').val(brigade.forceType);
                        $('.modal-title').text('Edit Brigade');
                        $('#brigadeModal').modal('show');
                    } else {
                        showNotification('Brigade not found', 'error');
                    }
                })
                .fail(function() {
                    showNotification('Failed to load brigade data', 'error');
                });
        }

        function deleteBrigade(brigadeId) {
            if (!confirm('Are you sure you want to delete this brigade?')) {
                return;
            }

            $.ajax({
                url: '/DataManagement/DeleteTokenBrigade/' + brigadeId,
                method: 'DELETE',
                contentType: 'application/json'
            })
            .done(function(response) {
                if (response.success) {
                    showNotification('Brigade deleted successfully', 'success');
                    loadBrigades();
                } else {
                    showNotification('Error: ' + response.message, 'error');
                }
            })
            .fail(function() {
                showNotification('Failed to delete brigade', 'error');
            });
        }

        function showNotification(message, type) {
            // Simple notification implementation
            alert(message);
        }
    </script>
}
