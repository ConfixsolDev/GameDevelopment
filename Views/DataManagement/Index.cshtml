@{
    Layout = "_Layout";
    ViewData["Title"] = "Data Management";
}

<div class="container-fluid">
    <div class="row">
        <div class="col-12">
            <div class="card">
                <div class="card-header">
                    <h3 class="card-title">Military Unit Data Management</h3>
                </div>
                <div class="card-body">
                    <!-- Navigation Tabs -->
                    <ul class="nav nav-tabs" role="tablist" id="dataManagementTabs">
                        <li class="nav-item">
                            <a class="nav-link active" id="brigades-tab" href="#brigades" onclick="switchTab('brigades'); return false;">
                                <i class="fas fa-flag"></i> Brigades
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" id="infantry-tab" href="#infantry" onclick="switchTab('infantry'); return false;">
                                <i class="fas fa-user-shield"></i> Infantry Battalions
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" id="armoured-tab" href="#armoured" onclick="switchTab('armoured'); return false;">
                                <i class="fas fa-shield-alt"></i> Armoured Regiments
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" id="artillery-tab" href="#artillery" onclick="switchTab('artillery'); return false;">
                                <i class="fas fa-crosshairs"></i> Artillery Regiments
                            </a>
                        </li>
                    </ul>

                    <!-- Tab Content -->
                    <div class="tab-content mt-3">
                        <!-- Brigades Tab -->
                        <div class="tab-pane fade show active" id="brigades" role="tabpanel">
                            <div class="mb-3">
                        <button class="btn btn-primary" onclick="openBrigadeModal()">
                            <i class="fas fa-plus"></i> Add Brigade
                        </button>
                    </div>
                            <div class="table-responsive">
                                <table id="brigadesTable" class="table table-bordered ">
                                    <thead>
                                        <tr>
                                            <th>Brigade Code</th>
                                            <th>Force Type</th>
                                            <th>Token</th>
                                            <th>Actions</th>
                                        </tr>
                                    </thead>
                                    <tbody></tbody>
                                </table>
                            </div>
                        </div>

                        <!-- Infantry Battalions Tab -->
                        <div class="tab-pane fade" id="infantry" role="tabpanel">
                            <div class="mb-3">
                                <button class="btn btn-primary" onclick="openInfantryModal()">
                                    <i class="fas fa-plus"></i> Add Infantry Battalion
                                </button>
                            </div>
                            <div id="infantryLoading" class="text-center py-5" style="display:none;">
                                <div class="spinner-border text-primary" role="status">
                                    <span class="sr-only">Loading...</span>
                                </div>
                                <p class="mt-2">Loading Infantry Battalions...</p>
                            </div>
                            <div class="table-responsive">
                                <table id="infantryTable" class="table table-bordered ">
                                    <thead>
                                        <tr>
                                            <th>Name</th>
                                            <th>Unit Code</th>
                                            <th>Strength</th>
                                            <th>Companies</th>
                                            <th>Brigade</th>
                                            <th>Actions</th>
                                        </tr>
                                    </thead>
                                    <tbody></tbody>
                                </table>
                            </div>
                        </div>

                        <!-- Armoured Regiments Tab -->
                        <div class="tab-pane fade" id="armoured" role="tabpanel">
                            <div class="mb-3">
                                <button class="btn btn-primary" onclick="openArmouredModal()">
                                    <i class="fas fa-plus"></i> Add Armoured Regiment
                                </button>
                            </div>
                            <div id="armouredLoading" class="text-center py-5" style="display:none;">
                                <div class="spinner-border text-primary" role="status">
                                    <span class="sr-only">Loading...</span>
                                </div>
                                <p class="mt-2">Loading Armoured Regiments...</p>
                            </div>
                            <div class="table-responsive">
                                <table id="armouredTable" class="table table-bordered ">
                                    <thead>
                                        <tr>
                                            <th>Name</th>
                                            <th>Unit Code</th>
                                            <th>Strength</th>
                                            <th>Tanks</th>
                                            <th>Brigade</th>
                                            <th>Actions</th>
                                        </tr>
                                    </thead>
                                    <tbody></tbody>
                                </table>
                            </div>
                        </div>

                        <!-- Artillery Regiments Tab -->
                        <div class="tab-pane fade" id="artillery" role="tabpanel">
                            <div class="mb-3">
                                <button class="btn btn-primary" onclick="openArtilleryModal()">
                                    <i class="fas fa-plus"></i> Add Artillery Regiment
                                </button>
                            </div>
                            <div id="artilleryLoading" class="text-center py-5" style="display:none;">
                                <div class="spinner-border text-primary" role="status">
                                    <span class="sr-only">Loading...</span>
                                </div>
                                <p class="mt-2">Loading Artillery Regiments...</p>
                            </div>
                            <div class="table-responsive">
                                <table id="artilleryTable" class="table table-bordered ">
                                    <thead>
                                        <tr>
                                            <th>Name</th>
                                            <th>Unit Code</th>
                                            <th>Strength</th>
                                            <th>Guns</th>
                                            <th>Brigade</th>
                                            <th>Actions</th>
                                        </tr>
                                    </thead>
                                    <tbody></tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Brigade Modal -->
<div class="modal fade" id="brigadeModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Brigade Details</h5>
                <button type="button" class="close" data-dismiss="modal">&times;</button>
            </div>
            <div class="modal-body">
                <form id="brigadeForm">
                    <input type="hidden" id="brigadeId" value="">
                    <div class="row">
                        <div class="col-md-12">
                            <div class="form-group">
                                <label>Brigade Code *</label>
                                <input type="text" class="form-control" id="brigadeCode" required>
                            </div>
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-md-12">
                            <div class="form-group">
                                <label>Force Type *</label>
                                <select class="form-control" id="forceType" required>
                                    <option value="">Select Force Type</option>
                                    <option value="Blue">Blue Force</option>
                                    <option value="Red">Red Force</option>
                                </select>
                            </div>
                        </div>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-primary" onclick="saveBrigade()">Save Brigade</button>
            </div>
        </div>
    </div>
</div>

<!-- Infantry Battalion Modal -->
<div class="modal fade" id="infantryModal" tabindex="-1">
    <div class="modal-dialog modal-xl">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="infantryModalTitle">Infantry Battalion Details</h5>
                <button type="button" class="close" data-dismiss="modal">&times;</button>
            </div>
            <div class="modal-body">
                <form id="infantryForm">
                    <input type="hidden" id="infantryId" value="">
                    
                    <!-- Basic Information -->
                    <h6 class="border-bottom pb-2 mb-3">Basic Information</h6>
                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-group">
                                <label>Name *</label>
                                <input type="text" class="form-control" id="infantryName" required>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group">
                                <label>Unit Code *</label>
                                <input type="text" class="form-control" id="infantryUnitCode" required>
                            </div>
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-md-4">
                            <div class="form-group">
                                <label>Strength</label>
                                <input type="number" class="form-control" id="infantryStrength" value="0" min="0">
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="form-group">
                                <label>Companies</label>
                                <input type="number" class="form-control" id="infantryCompanies" value="0" min="0">
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="form-group">
                                <label>Force Type *</label>
                                <select class="form-control" id="infantryForceType" required>
                                    <option value="Blue">Blue Force</option>
                                    <option value="Red">Red Force</option>
                                </select>
                            </div>
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-md-12">
                            <div class="form-group">
                                <label>Description</label>
                                <textarea class="form-control" id="infantryDescription" rows="2"></textarea>
                            </div>
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-md-12">
                            <div class="form-group">
                                <label>Assign to Brigade (Optional)</label>
                                <select class="form-control" id="infantryBrigadeId">
                                    <option value="">-- No Brigade --</option>
                                </select>
                                <small class="form-text text-muted">Select a brigade to assign this battalion to</small>
                            </div>
                        </div>
                    </div>

                    <!-- Equipment & Weapons -->
                    <h6 class="border-bottom pb-2 mb-3 mt-3">Equipment & Weapons</h6>
                    <div class="row">
                        <div class="col-md-3">
                            <div class="form-group">
                                <label>ATGMS</label>
                                <input type="number" class="form-control" id="infantryATGMS" value="0" min="0">
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="form-group">
                                <label>Rocket Launchers</label>
                                <input type="number" class="form-control" id="infantryRocketLauncher" value="0" min="0">
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="form-group">
                                <label>81mm Mortars</label>
                                <input type="number" class="form-control" id="infantryMortars81mm" value="0" min="0">
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="form-group">
                                <label>120mm Mortars</label>
                                <input type="number" class="form-control" id="infantryMortars120mm" value="0" min="0">
                            </div>
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-md-3">
                            <div class="form-group">
                                <label>Grenade Launchers</label>
                                <input type="number" class="form-control" id="infantryGrenadeLaunchers" value="0" min="0">
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="form-group">
                                <label>HMG/AGL</label>
                                <input type="number" class="form-control" id="infantryHMG_AGL" value="0" min="0">
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="form-group">
                                <label>MG/LMG</label>
                                <input type="number" class="form-control" id="infantryMG_LMG" value="0" min="0">
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="form-group">
                                <label>MANPADS</label>
                                <input type="number" class="form-control" id="infantryMANPADS" value="0" min="0">
                            </div>
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-md-4">
                            <div class="form-group">
                                <label>Grenades</label>
                                <input type="number" class="form-control" id="infantryGrenades" value="0" min="0">
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="form-group">
                                <label>Drones</label>
                                <input type="number" class="form-control" id="infantryDrones" value="0" min="0">
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="form-group">
                                <label>Drone Types</label>
                                <input type="text" class="form-control" id="infantryDroneTypes">
                            </div>
                        </div>
                    </div>

                    <!-- Mobility Data -->
                    <h6 class="border-bottom pb-2 mb-3 mt-3">Mobility Data (km/h)</h6>
                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-group">
                                <label>Marching Speed - Trucks on Roads</label>
                                <input type="number" class="form-control" id="infantryMarchingSpeedTrucksRoads" value="30" step="0.1">
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group">
                                <label>Marching Speed - APCs</label>
                                <input type="number" class="form-control" id="infantryMarchingSpeedAPCs" value="20" step="0.1">
                            </div>
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-md-4">
                            <div class="form-group">
                                <label>Marching Speed - Cross Country</label>
                                <input type="number" class="form-control" id="infantryMarchingSpeedCrossCountry" value="5" step="0.1">
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="form-group">
                                <label>Marching Speed - APCs Cross Country</label>
                                <input type="number" class="form-control" id="infantryMarchingSpeedAPCsCrossCountry" value="10" step="0.1">
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="form-group">
                                <label>Combat Advance Speed</label>
                                <input type="number" class="form-control" id="infantryCombatAdvanceSpeed" value="1" step="0.1">
                            </div>
                        </div>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-primary" onclick="saveInfantry()">Save Infantry Battalion</button>
            </div>
        </div>
    </div>
</div>

