@{
    Layout = "_Layout";
    ViewData["Title"] = "Data Management";
}

<div class="container-fluid">
    <div class="row">
        <div class="col-12">
            <div class="card">
                <div class="card-header">
                    <h3 class="card-title">Military Unit Data Management</h3>
                    <div class="card-tools">
                        <button class="btn btn-primary" onclick="openBrigadeModal()">
                            <i class="fas fa-plus"></i> Add Brigade
                        </button>
                    </div>
                </div>
                <div class="card-body">
                    <!-- Brigade Management Tab -->
                    <div class="tab-content">
                        <div class="tab-pane active" id="brigades">
                            <div class="table-responsive">
                                <table id="brigadesTable" class="table table-bordered">
                                    <thead>
                                        <tr>
                                            <th>Brigade Code</th>
                                            <th>Force Type</th>
                                            <th>Actions</th>
                                        </tr>
                                    </thead>
                                    <tbody></tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Brigade Modal -->
<div class="modal fade" id="brigadeModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Brigade Details</h5>
                <button type="button" class="close" data-dismiss="modal">&times;</button>
            </div>
            <div class="modal-body">
                <form id="brigadeForm">
                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-group">
                                <label>Brigade Name</label>
                                <input type="text" class="form-control" id="brigadeName" required>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group">
                                <label>Brigade Code</label>
                                <input type="text" class="form-control" id="brigadeCode" required>
                            </div>
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-group">
                                <label>Force Type</label>
                                <select class="form-control" id="forceType" required>
                                    <option value="">Select Force Type</option>
                                    <option value="Blue">Blue Force</option>
                                    <option value="Red">Red Force</option>
                                </select>
                            </div>
                        </div>
                    </div>
                    <div class="form-group">
                        <label>Description</label>
                        <textarea class="form-control" id="brigadeDescription" rows="3"></textarea>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-primary" onclick="saveBrigade()">Save Brigade</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function() {
            loadBrigades();
        });

        function loadBrigades() {
            $.get('/DataManagement/GetBrigades')
                .done(function(data) {
                    $('#brigadesTable tbody').empty();
                    data.forEach(function(brigade) {
                        $('#brigadesTable tbody').append(`
                            <tr>
                                <td>${brigade.brigadeCode}</td>
                                <td>${brigade.forceType}</td>
                                <td>
                                    <button class="btn btn-sm btn-primary" onclick="editBrigade('${brigade.id}')">Edit</button>
                                    <button class="btn btn-sm btn-danger" onclick="deleteBrigade('${brigade.id}')">Delete</button>
                                </td>
                            </tr>
                        `);
                    });
                })
                .fail(function() {
                    showNotification('Failed to load brigades', 'error');
                });
        }

        function openBrigadeModal() {
            $('#brigadeForm')[0].reset();
            $('#brigadeModal').modal('show');
        }

        function saveBrigade() {
            const brigadeData = {
                Name: $('#brigadeName').val(),
                BrigadeCode: $('#brigadeCode').val(),
                ForceType: $('#forceType').val(),
                Description: $('#brigadeDescription').val()
            };

            $.ajax({
                url: '/DataManagement/CreateBrigade',
                method: 'POST',
                contentType: 'application/json',
                data: JSON.stringify(brigadeData)
            })
            .done(function(response) {
                if (response.success) {
                    showNotification('Brigade created successfully', 'success');
                    $('#brigadeModal').modal('hide');
                    loadBrigades();
                } else {
                    showNotification('Error: ' + response.message, 'error');
                }
            })
            .fail(function() {
                showNotification('Failed to create brigade', 'error');
            });
        }

        function showNotification(message, type) {
            // Simple notification implementation
            alert(message);
        }
    </script>
}
