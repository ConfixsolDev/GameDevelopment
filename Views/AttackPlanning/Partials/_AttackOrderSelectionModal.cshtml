@model List<TechWebSol.ViewModels.AttackOrderSelectionViewModel>

<div class="modal fade gameplay-modal" id="attackOrderSelectionModal" tabindex="-1" role="dialog" aria-labelledby="attackOrderSelectionModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-xl" role="document" style="max-width: 900px; margin: 1.75rem auto;">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="attackOrderSelectionModalLabel">
                    <i class="fas fa-crosshairs"></i> Select Attack Order to Simulate
                </h5>
                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <div class="modal-body">
            <div class="military-instruction mb-3">SELECT ATTACK ORDER FOR COMBAT SIMULATION</div>
            <div class="military-orders-list">
                @foreach (var order in Model)
                {
                    <div class="military-order-item">
                        <div class="military-order-line">
                            ATTACKER: <span class="military-value">@order.AttackerTokenName</span> → 
                            TARGET: <span class="military-value">@order.TargetTokenName</span>
                            @if (order.IsSuspectedToken)
                            {
                                <span class="military-tag">[SUSPECTED]</span>
                            }
                            | STATUS: <span class="military-status">@order.Status.ToUpper()</span> 
                            | COMPLETION: <span class="military-value">@order.CompletionPercentage</span>
                        </div>
                        <button type="button" class="military-simulate-btn btn"
                                data-order-id="@order.Id"
                                data-attacker-name="@order.AttackerTokenName"
                                data-target-name="@order.TargetTokenName"
                                onclick="window.runSimulationForOrder('@order.Id', '@order.AttackerTokenName', '@order.TargetTokenName'); return false;">
                            ► RUN SIMULATION
                        </button>
                    </div>
                }
            </div>
        </div>
        <div class="modal-footer">
            <button type="button" class="btn btn-secondary" data-dismiss="modal">
                <i class="fas fa-times"></i> Close
            </button>
        </div>
    </div>
    </div>
</div>

@functions {
    string GetStatusBadgeColor(string status)
    {
        return status switch
        {
            "Draft" => "secondary",
            "Planned" => "info",
            "Approved" => "success",
            "Executing" => "warning",
            "Completed" => "dark",
            "Failed" => "danger",
            "Cancelled" => "secondary",
            _ => "secondary"
        };
    }
}

<style>
    /* Military Dark Theme for Attack Order Selection */
    #attackOrderSelectionModal .modal-content {
        background-color: #0a0e14;
        border: 2px solid #1a4d2e;
    }

    #attackOrderSelectionModal .modal-header {
        background-color: #0f1419;
        border-bottom: 2px solid #1a4d2e;
        color: #00ff00;
        font-family: 'Courier New', monospace;
        text-transform: uppercase;
        letter-spacing: 2px;
    }

    #attackOrderSelectionModal .modal-body {
        background-color: #0a0e14;
        color: #00ff00;
        font-family: 'Courier New', monospace;
        padding: 20px;
    }

    #attackOrderSelectionModal .modal-footer {
        background-color: #0f1419;
        border-top: 2px solid #1a4d2e;
    }

    #attackOrderSelectionModal .military-instruction {
        background-color: #0f1419;
        border: 1px solid #1a4d2e;
        border-left: 4px solid #00ff00;
        padding: 10px 15px;
        font-weight: bold;
        font-size: 13px;
        letter-spacing: 2px;
        color: #00ff00;
    }

    #attackOrderSelectionModal .military-orders-list {
        display: flex;
        flex-direction: column;
        gap: 15px;
    }

    #attackOrderSelectionModal .military-order-item {
        background-color: #0f1419;
        border: 1px solid #1a4d2e;
        padding: 15px;
        border-radius: 4px;
        display: flex;
        justify-content: space-between;
        align-items: center;
        transition: all 0.2s;
    }

        #attackOrderSelectionModal .military-order-item:hover {
            border-color: #00ff00;
            box-shadow: 0 0 10px rgba(0, 255, 0, 0.2);
        }

    #attackOrderSelectionModal .military-order-line {
        flex: 1;
        color: #00ff00;
        font-size: 12px;
        letter-spacing: 1px;
    }

    #attackOrderSelectionModal .military-value {
        color: #00ffff;
        font-weight: bold;
    }

    #attackOrderSelectionModal .military-tag {
        background: #ff8800;
        color: #000;
        padding: 2px 8px;
        border-radius: 3px;
        font-size: 10px;
        font-weight: bold;
        margin-left: 5px;
    }

    #attackOrderSelectionModal .military-status {
        color: #ffff00;
        font-weight: bold;
    }

    #attackOrderSelectionModal .military-simulate-btn {
        background-color: #1a4d2e;
        color: #00ff00;
        border: 2px solid #00ff00;
        padding: 8px 20px;
        font-family: 'Courier New', monospace;
        font-weight: bold;
        letter-spacing: 2px;
        cursor: pointer;
        transition: all 0.2s;
        border-radius: 4px;
        font-size: 12px;
    }

        #attackOrderSelectionModal .military-simulate-btn:hover {
            background-color: #00ff00;
            color: #000;
            box-shadow: 0 0 15px rgba(0, 255, 0, 0.5);
        }

        #attackOrderSelectionModal .military-simulate-btn:active {
            transform: scale(0.95);
        }

    #attackOrderSelectionModal .btn-secondary {
        background-color: #0f1419;
        border-color: #1a4d2e;
        color: #00ff00;
    }

        #attackOrderSelectionModal .btn-secondary:hover {
            background-color: #1a4d2e;
            border-color: #00ff00;
        }
</style>
