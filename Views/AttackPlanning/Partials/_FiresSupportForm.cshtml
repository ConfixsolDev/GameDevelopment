@model TechWebSol.Models.AttackPlanning.FiresSupport

<div class="attack-form-section">
    <div class="section-header">
        <h4><i class="fas fa-bomb"></i> Fires Support</h4>
        <p class="text-muted">Configure artillery and engineer support for the attack.</p>
    </div>

    <form id="firesForm" class="attack-planning-form">
        <div class="form-row">
            <div class="form-group">
                <label for="ArtilleryTask" class="form-label">Artillery Task *</label>
                <select asp-for="ArtilleryTask" class="form-control" id="ArtilleryTask" required>
                    <option value="">Select Artillery Task</option>
                    <option value="PrepFires">Prep Fires</option>
                    <option value="OnCall">On Call</option>
                    <option value="Counterbattery">Counterbattery</option>
                </select>
                <small class="form-text text-muted">Type of artillery support for this attack.</small>
            </div>

            <div class="form-group">
                <label class="form-label">Artillery Units Available</label>
                <div class="unit-counter">
                    <span id="artilleryCount">0</span> units selected
                </div>
                <small class="form-text text-muted">Select artillery units to attach to this attack.</small>
            </div>
        </div>

        <div class="artillery-selection">
            <h5><i class="fas fa-rocket"></i> Artillery Units</h5>
            <div class="unit-selection-container">
                <div class="unit-search">
                    <input type="text" id="artillerySearch" class="form-control" placeholder="Search artillery units...">
                </div>
                
                <div class="unit-list" id="artilleryUnitList">
                    <!-- Artillery units will be loaded here -->
                    <div class="unit-item">
                        <div class="unit-info">
                            <span class="unit-icon">🚀</span>
                            <span class="unit-name">Artillery Battery Alpha</span>
                            <span class="unit-type">155mm Howitzer</span>
                        </div>
                        <div class="unit-actions">
                            <button type="button" class="btn btn-sm btn-outline-primary" onclick="toggleArtilleryUnit('artillery_1')">
                                <i class="fas fa-plus"></i> Attach
                            </button>
                        </div>
                    </div>
                    
                    <div class="unit-item">
                        <div class="unit-info">
                            <span class="unit-icon">🚀</span>
                            <span class="unit-name">Artillery Battery Bravo</span>
                            <span class="unit-type">120mm Mortar</span>
                        </div>
                        <div class="unit-actions">
                            <button type="button" class="btn btn-sm btn-outline-primary" onclick="toggleArtilleryUnit('artillery_2')">
                                <i class="fas fa-plus"></i> Attach
                            </button>
                        </div>
                    </div>
                    
                    <div class="unit-item">
                        <div class="unit-info">
                            <span class="unit-icon">🚀</span>
                            <span class="unit-name">Artillery Battery Charlie</span>
                            <span class="unit-type">105mm Howitzer</span>
                        </div>
                        <div class="unit-actions">
                            <button type="button" class="btn btn-sm btn-outline-primary" onclick="toggleArtilleryUnit('artillery_3')">
                                <i class="fas fa-plus"></i> Attach
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="engineer-section">
            <div class="form-row">
                <div class="form-group">
                    <label class="form-label">Engineers Present</label>
                    <div class="checkbox-container">
                        <input type="checkbox" asp-for="EngineersPresent" id="EngineersPresent" class="form-check-input">
                        <label for="EngineersPresent" class="form-check-label">Engineers are available for this attack</label>
                    </div>
                    <small class="form-text text-muted">Check if engineer units are available for support.</small>
                </div>

                <div class="form-group">
                    <label class="form-label">Engineer Units</label>
                    <div class="unit-counter">
                        <span id="engineerCount">0</span> units selected
                    </div>
                    <small class="form-text text-muted">Select engineer units if available.</small>
                </div>
            </div>

            <div class="engineer-selection" id="engineerSelection" style="display: none;">
                <h5><i class="fas fa-tools"></i> Engineer Units</h5>
                <div class="unit-selection-container">
                    <div class="unit-list" id="engineerUnitList">
                        <!-- Engineer units will be loaded here -->
                        <div class="unit-item">
                            <div class="unit-info">
                                <span class="unit-icon">🔧</span>
                                <span class="unit-name">Engineer Company Alpha</span>
                                <span class="unit-type">Combat Engineers</span>
                            </div>
                            <div class="unit-actions">
                                <button type="button" class="btn btn-sm btn-outline-primary" onclick="toggleEngineerUnit('engineer_1')">
                                    <i class="fas fa-plus"></i> Attach
                                </button>
                            </div>
                        </div>
                        
                        <div class="unit-item">
                            <div class="unit-info">
                                <span class="unit-icon">🔧</span>
                                <span class="unit-name">Engineer Company Bravo</span>
                                <span class="unit-type">Construction Engineers</span>
                            </div>
                            <div class="unit-actions">
                                <button type="button" class="btn btn-sm btn-outline-primary" onclick="toggleEngineerUnit('engineer_2')">
                                    <i class="fas fa-plus"></i> Attach
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="support-summary">
            <div class="summary-row">
                <div class="summary-item">
                    <label>Artillery Units:</label>
                    <span id="summaryArtilleryUnits">0</span>
                </div>
                <div class="summary-item">
                    <label>Artillery Task:</label>
                    <span id="summaryArtilleryTask">-</span>
                </div>
                <div class="summary-item">
                    <label>Engineers:</label>
                    <span id="summaryEngineers">No</span>
                </div>
            </div>
        </div>

        <div class="form-group">
            <label for="Notes" class="form-label">Fires Support Notes</label>
            <textarea asp-for="Notes" class="form-control" id="Notes" rows="3" 
                      placeholder="Coordination notes, fire support requirements, or special instructions..."></textarea>
            <small class="form-text text-muted">Optional notes about fires support coordination.</small>
        </div>

        <div class="form-actions">
            <button type="button" class="btn btn-outline-secondary" onclick="resetFiresForm()">
                <i class="fas fa-undo"></i> Reset
            </button>
            <button type="button" class="btn btn-primary" onclick="validateFiresForm()">
                <i class="fas fa-check"></i> Validate
            </button>
        </div>
    </form>

    <div class="fires-summary-detail" id="firesSummary" style="display: none;">
        <h5>Fires Support Summary</h5>
        <div class="summary-content">
            <p><strong>Artillery Task:</strong> <span id="summaryDetailArtilleryTask">-</span></p>
            <p><strong>Artillery Units:</strong> <span id="summaryDetailArtilleryUnits">-</span></p>
            <p><strong>Engineers Present:</strong> <span id="summaryDetailEngineers">-</span></p>
            <p><strong>Engineer Units:</strong> <span id="summaryDetailEngineerUnits">-</span></p>
            <p><strong>Notes:</strong> <span id="summaryDetailNotes">-</span></p>
        </div>
    </div>
</div>

<style>
.unit-counter {
    background: #1a1a1a;
    border: 1px solid #444;
    color: #00d4ff;
    padding: 10px 12px;
    border-radius: 6px;
    font-weight: 600;
    min-height: 38px;
    display: flex;
    align-items: center;
    justify-content: center;
}

.artillery-selection, .engineer-selection {
    margin-top: 20px;
    background: #1a1a1a;
    border-radius: 6px;
    padding: 15px;
    border: 1px solid #333;
}

.artillery-selection h5, .engineer-selection h5 {
    color: #00d4ff;
    margin: 0 0 15px 0;
    font-size: 14px;
}

.unit-selection-container {
    max-height: 300px;
    overflow-y: auto;
}

.unit-search {
    margin-bottom: 15px;
}

.unit-list {
    display: flex;
    flex-direction: column;
    gap: 8px;
}

.unit-item {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 12px;
    background: #2a2a2a;
    border-radius: 6px;
    border: 1px solid #444;
    transition: all 0.3s ease;
}

.unit-item:hover {
    background: #3a3a3a;
    border-color: #00d4ff;
}

.unit-item.attached {
    background: #1a3a1a;
    border-color: #00ff88;
}

.unit-info {
    display: flex;
    align-items: center;
    gap: 12px;
    flex: 1;
}

.unit-icon {
    font-size: 20px;
    width: 30px;
    text-align: center;
}

.unit-name {
    color: #fff;
    font-weight: 600;
    font-size: 13px;
}

.unit-type {
    color: #888;
    font-size: 11px;
}

.unit-actions {
    display: flex;
    gap: 8px;
}

.checkbox-container {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 10px 0;
}

.form-check-input {
    width: 18px;
    height: 18px;
    accent-color: #00d4ff;
}

.form-check-label {
    color: #ccc;
    font-size: 13px;
    margin: 0;
}

.support-summary {
    background: #1a1a1a;
    border-radius: 6px;
    padding: 15px;
    margin: 20px 0;
    border: 1px solid #333;
}

.summary-row {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    gap: 20px;
}

.summary-item {
    text-align: center;
}

.summary-item label {
    display: block;
    color: #888;
    font-size: 11px;
    margin-bottom: 5px;
}

.summary-item span {
    color: #00d4ff;
    font-weight: 600;
    font-size: 14px;
}

.fires-summary-detail {
    background: #1a1a1a;
    border-radius: 6px;
    padding: 15px;
    margin-top: 20px;
    border: 1px solid #333;
}

.fires-summary-detail h5 {
    color: #00d4ff;
    margin: 0 0 10px 0;
    font-size: 14px;
}

.summary-content p {
    margin: 5px 0;
    font-size: 12px;
    color: #ccc;
}

.summary-content strong {
    color: #fff;
}

@@media (max-width: 768px) {
    .summary-row {
        grid-template-columns: 1fr;
        gap: 10px;
    }
    
    .unit-item {
        flex-direction: column;
        gap: 10px;
        align-items: stretch;
    }
    
    .unit-info {
        justify-content: center;
    }
    
    .unit-actions {
        justify-content: center;
    }
}
</style>

<script>
// Fires Support Form JavaScript
let selectedArtilleryUnits = [];
let selectedEngineerUnits = [];

document.addEventListener('DOMContentLoaded', function() {
    initializeFiresForm();
});

function initializeFiresForm() {
    console.log('Initializing fires support form');
    
    // Add change listeners
    document.getElementById('ArtilleryTask').addEventListener('change', updateFiresSummary);
    document.getElementById('EngineersPresent').addEventListener('change', toggleEngineerSelection);
    document.getElementById('Notes').addEventListener('input', updateFiresSummary);
    
    // Add search functionality
    document.getElementById('artillerySearch').addEventListener('input', filterArtilleryUnits);
    
    // Mark form as dirty when changed
    document.querySelectorAll('#firesForm input, #firesForm select, #firesForm textarea').forEach(element => {
        element.addEventListener('change', () => {
            if (window.currentAttackOrder) {
                window.currentAttackOrder.isDirty = true;
            }
        });
    });
    
    updateFiresSummary();
}

function toggleArtilleryUnit(unitId) {
    const button = event.target.closest('button');
    const unitItem = button.closest('.unit-item');
    
    if (selectedArtilleryUnits.includes(unitId)) {
        // Remove unit
        selectedArtilleryUnits = selectedArtilleryUnits.filter(id => id !== unitId);
        unitItem.classList.remove('attached');
        button.innerHTML = '<i class="fas fa-plus"></i> Attach';
        button.classList.remove('btn-primary');
        button.classList.add('btn-outline-primary');
    } else {
        // Add unit
        selectedArtilleryUnits.push(unitId);
        unitItem.classList.add('attached');
        button.innerHTML = '<i class="fas fa-check"></i> Attached';
        button.classList.remove('btn-outline-primary');
        button.classList.add('btn-primary');
    }
    
    updateFiresSummary();
    
    if (window.currentAttackOrder) {
        window.currentAttackOrder.isDirty = true;
    }
}

function toggleEngineerUnit(unitId) {
    const button = event.target.closest('button');
    const unitItem = button.closest('.unit-item');
    
    if (selectedEngineerUnits.includes(unitId)) {
        // Remove unit
        selectedEngineerUnits = selectedEngineerUnits.filter(id => id !== unitId);
        unitItem.classList.remove('attached');
        button.innerHTML = '<i class="fas fa-plus"></i> Attach';
        button.classList.remove('btn-primary');
        button.classList.add('btn-outline-primary');
    } else {
        // Add unit
        selectedEngineerUnits.push(unitId);
        unitItem.classList.add('attached');
        button.innerHTML = '<i class="fas fa-check"></i> Attached';
        button.classList.remove('btn-outline-primary');
        button.classList.add('btn-primary');
    }
    
    updateFiresSummary();
    
    if (window.currentAttackOrder) {
        window.currentAttackOrder.isDirty = true;
    }
}

function toggleEngineerSelection() {
    const engineersPresent = document.getElementById('EngineersPresent').checked;
    const engineerSelection = document.getElementById('engineerSelection');
    
    if (engineersPresent) {
        engineerSelection.style.display = 'block';
    } else {
        engineerSelection.style.display = 'none';
        // Clear selected engineer units
        selectedEngineerUnits = [];
        updateEngineerUnitButtons();
    }
    
    updateFiresSummary();
}

function updateEngineerUnitButtons() {
    document.querySelectorAll('#engineerUnitList .unit-item').forEach(item => {
        const button = item.querySelector('button');
        const unitId = button.getAttribute('onclick').match(/'([^']+)'/)[1];
        
        if (selectedEngineerUnits.includes(unitId)) {
            item.classList.add('attached');
            button.innerHTML = '<i class="fas fa-check"></i> Attached';
            button.classList.remove('btn-outline-primary');
            button.classList.add('btn-primary');
        } else {
            item.classList.remove('attached');
            button.innerHTML = '<i class="fas fa-plus"></i> Attach';
            button.classList.remove('btn-primary');
            button.classList.add('btn-outline-primary');
        }
    });
}

function filterArtilleryUnits() {
    const searchTerm = document.getElementById('artillerySearch').value.toLowerCase();
    const unitItems = document.querySelectorAll('#artilleryUnitList .unit-item');
    
    unitItems.forEach(item => {
        const unitName = item.querySelector('.unit-name').textContent.toLowerCase();
        const unitType = item.querySelector('.unit-type').textContent.toLowerCase();
        
        if (unitName.includes(searchTerm) || unitType.includes(searchTerm)) {
            item.style.display = 'flex';
        } else {
            item.style.display = 'none';
        }
    });
}

function updateFiresSummary() {
    const artilleryTask = document.getElementById('ArtilleryTask').value;
    const engineersPresent = document.getElementById('EngineersPresent').checked;
    const notes = document.getElementById('Notes').value;
    
    // Update counters
    document.getElementById('artilleryCount').textContent = selectedArtilleryUnits.length;
    document.getElementById('engineerCount').textContent = selectedEngineerUnits.length;
    
    // Update summary row
    document.getElementById('summaryArtilleryUnits').textContent = selectedArtilleryUnits.length;
    document.getElementById('summaryArtilleryTask').textContent = artilleryTask || '-';
    document.getElementById('summaryEngineers').textContent = engineersPresent ? 'Yes' : 'No';
    
    // Update detailed summary
    if (artilleryTask || selectedArtilleryUnits.length > 0 || engineersPresent || notes) {
        document.getElementById('summaryDetailArtilleryTask').textContent = artilleryTask || 'Not selected';
        document.getElementById('summaryDetailArtilleryUnits').textContent = selectedArtilleryUnits.length > 0 ? 
            selectedArtilleryUnits.join(', ') : 'None selected';
        document.getElementById('summaryDetailEngineers').textContent = engineersPresent ? 'Yes' : 'No';
        document.getElementById('summaryDetailEngineerUnits').textContent = selectedEngineerUnits.length > 0 ? 
            selectedEngineerUnits.join(', ') : 'None selected';
        document.getElementById('summaryDetailNotes').textContent = notes || 'None';
        
        document.getElementById('firesSummary').style.display = 'block';
    } else {
        document.getElementById('firesSummary').style.display = 'none';
    }
}

function validateFiresForm() {
    const artilleryTask = document.getElementById('ArtilleryTask').value;
    
    if (!artilleryTask) {
        showNotification('Please select an artillery task', 'warning');
        return false;
    }
    
    if (selectedArtilleryUnits.length === 0) {
        showNotification('Please select at least one artillery unit', 'warning');
        return false;
    }
    
    const engineersPresent = document.getElementById('EngineersPresent').checked;
    if (engineersPresent && selectedEngineerUnits.length === 0) {
        showNotification('Please select engineer units if engineers are present', 'warning');
        return false;
    }
    
    console.log('Fires support form validated successfully');
    showNotification('Fires support form validated successfully', 'success');
    return true;
}

function resetFiresForm() {
    document.getElementById('firesForm').reset();
    selectedArtilleryUnits = [];
    selectedEngineerUnits = [];
    
    // Reset unit buttons
    document.querySelectorAll('.unit-item').forEach(item => {
        item.classList.remove('attached');
        const button = item.querySelector('button');
        button.innerHTML = '<i class="fas fa-plus"></i> Attach';
        button.classList.remove('btn-primary');
        button.classList.add('btn-outline-primary');
    });
    
    document.getElementById('engineerSelection').style.display = 'none';
    document.getElementById('firesSummary').style.display = 'none';
    console.log('Fires support form reset');
}
</script>
