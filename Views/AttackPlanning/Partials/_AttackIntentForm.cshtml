@model TechWebSol.Models.AttackPlanning.AttackIntent

<div class="attack-form-section">
    <div class="section-header">
        <h4><i class="fas fa-bullseye"></i> Attack Intent</h4>
        <p class="text-muted">Define the tactical approach and desired outcome of the attack.</p>
    </div>

    <form id="intentForm" class="attack-planning-form">
        <!-- Attack Preparation -->
        <div class="form-row">
            <div class="form-group">
                <label for="AttackPreparation" class="form-label">Attack Preparation *</label>
                <select asp-for="AttackPreparation" class="form-control" id="AttackPreparation" required>
                    <option value="">Select Preparation Type</option>
                    <option value="Hasty">Hasty</option>
                    <option value="Deliberate">Deliberate</option>
                </select>
                <small class="form-text text-muted">Choose between hasty (quick) or deliberate (planned) attack.</small>
            </div>

            <div class="form-group">
                <label for="DesiredEffect" class="form-label">Desired Effect *</label>
                <select asp-for="DesiredEffect" class="form-control" id="DesiredEffect" required>
                    <option value="">Select Desired Effect</option>
                    <option value="Destroy">Destroy</option>
                    <option value="Disrupt">Disrupt</option>
                    <option value="Fix">Fix</option>
                    <option value="Delay">Delay</option>
                    <option value="Deny">Deny</option>
                </select>
                <small class="form-text text-muted">What you want to achieve with this attack.</small>
            </div>
        </div>

        <!-- NATO Attack Type Selection -->
        <div class="form-row">
            <div class="form-group">
                <label for="NatoAttackType" class="form-label">NATO Attack Type *</label>
                <div class="nato-attack-type-selector">
                    <div class="attack-type-grid">
                        <div class="attack-type-option" data-type="frontal">
                            <div class="attack-symbol">⇨</div>
                            <div class="attack-name">Frontal Attack</div>
                            <div class="attack-description">Direct assault on enemy position</div>
                            <div class="attack-risk">Risk: High</div>
                        </div>
                        <div class="attack-type-option" data-type="flanking">
                            <div class="attack-symbol">↗</div>
                            <div class="attack-name">Flanking Attack</div>
                            <div class="attack-description">Attack from the side/rear</div>
                            <div class="attack-risk">Risk: Medium</div>
                        </div>
                        <div class="attack-type-option" data-type="envelopment">
                            <div class="attack-symbol">↻</div>
                            <div class="attack-name">Envelopment</div>
                            <div class="attack-description">Surround and isolate enemy</div>
                            <div class="attack-risk">Risk: Medium</div>
                        </div>
                        <div class="attack-type-option" data-type="penetration">
                            <div class="attack-symbol">⇉</div>
                            <div class="attack-name">Penetration</div>
                            <div class="attack-description">Break through enemy lines</div>
                            <div class="attack-risk">Risk: High</div>
                        </div>
                        <div class="attack-type-option" data-type="raid">
                            <div class="attack-symbol">⚔</div>
                            <div class="attack-name">Raid</div>
                            <div class="attack-description">Quick strike and withdrawal</div>
                            <div class="attack-risk">Risk: Low</div>
                        </div>
                        <div class="attack-type-option" data-type="ambush">
                            <div class="attack-symbol">⚡</div>
                            <div class="attack-name">Ambush</div>
                            <div class="attack-description">Surprise attack from concealment</div>
                            <div class="attack-risk">Risk: Low</div>
                        </div>
                    </div>
                </div>
                <input type="hidden" asp-for="NatoAttackType" id="NatoAttackType" required />
                <small class="form-text text-muted">Select the NATO-standard attack type. Click on an option to select.</small>
            </div>
        </div>

        <!-- Attack Intensity and Coordination -->
        <div class="form-row">
            <div class="form-group">
                <label for="AttackIntensity" class="form-label">Attack Intensity *</label>
                <div class="intensity-selector">
                    <div class="intensity-option" data-intensity="light">
                        <div class="intensity-color" style="background: #ffaa44;"></div>
                        <div class="intensity-name">Light Attack</div>
                        <div class="intensity-description">Minimal resources, low risk</div>
                    </div>
                    <div class="intensity-option active" data-intensity="standard">
                        <div class="intensity-color" style="background: #ff4444;"></div>
                        <div class="intensity-name">Standard Attack</div>
                        <div class="intensity-description">Balanced approach</div>
                    </div>
                    <div class="intensity-option" data-intensity="heavy">
                        <div class="intensity-color" style="background: #cc0000;"></div>
                        <div class="intensity-name">Heavy Attack</div>
                        <div class="intensity-description">Maximum force, high risk</div>
                    </div>
                    <div class="intensity-option" data-intensity="overwhelming">
                        <div class="intensity-color" style="background: #990000;"></div>
                        <div class="intensity-name">Overwhelming</div>
                        <div class="intensity-description">All available resources</div>
                    </div>
                </div>
                <input type="hidden" asp-for="AttackIntensity" id="AttackIntensity" value="standard" required />
                <small class="form-text text-muted">Select the intensity level for this attack.</small>
            </div>

            <div class="form-group">
                <label for="CoordinationType" class="form-label">Coordination Type *</label>
                <select asp-for="CoordinationType" class="form-control" id="CoordinationType" required>
                    <option value="">Select Coordination Type</option>
                    <option value="independent">Independent Action</option>
                    <option value="supporting">Supporting Attack</option>
                    <option value="main">Main Effort</option>
                    <option value="feint">Feint/Diversion</option>
                    <option value="exploitation">Exploitation</option>
                </select>
                <small class="form-text text-muted">How this attack coordinates with other operations.</small>
            </div>
        </div>

        <div class="form-group">
            <label for="Notes" class="form-label">Intent Notes</label>
            <textarea asp-for="Notes" class="form-control" id="Notes" rows="3" 
                      placeholder="Additional notes about the attack intent, tactical considerations, or special instructions..."></textarea>
            <small class="form-text text-muted">Optional notes to clarify the attack intent.</small>
        </div>

        <div class="form-actions">
            <button type="button" class="btn btn-outline-secondary" onclick="resetIntentForm()">
                <i class="fas fa-undo"></i> Reset
            </button>
            <button type="button" class="btn btn-primary" onclick="validateIntentForm()">
                <i class="fas fa-check"></i> Validate
            </button>
        </div>
    </form>

    <div class="intent-summary" id="intentSummary" style="display: none;">
        <h5>Intent Summary</h5>
        <div class="summary-content">
            <p><strong>Attack Preparation:</strong> <span id="summaryAttackPreparation">-</span></p>
            <p><strong>NATO Attack Type:</strong> <span id="summaryNatoAttackType">-</span></p>
            <p><strong>Attack Intensity:</strong> <span id="summaryAttackIntensity">-</span></p>
            <p><strong>Coordination Type:</strong> <span id="summaryCoordinationType">-</span></p>
            <p><strong>Desired Effect:</strong> <span id="summaryDesiredEffect">-</span></p>
            <p><strong>Notes:</strong> <span id="summaryNotes">-</span></p>
        </div>
    </div>
</div>

<style>
.attack-form-section {
    background: #ffffff;
    border-radius: 8px;
    padding: 20px;
    border: 1px solid #e1e5ea;
}

.section-header {
    margin-bottom: 20px;
    padding-bottom: 15px;
    border-bottom: 1px solid #e1e5ea;
}

.section-header h4 {
    color: #00d4ff;
    margin: 0 0 5px 0;
    font-weight: 600;
}

.form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20px;
    margin-bottom: 20px;
}

@@media (max-width: 768px) {
    .form-row {
        grid-template-columns: 1fr;
        gap: 15px;
    }
}

.form-group {
    margin-bottom: 15px;
}

.form-label {
    color: #344767;
    font-weight: 600;
    margin-bottom: 5px;
    font-size: 13px;
}

.form-control {
    background: #f8f9fa;
    border: 1px solid #e1e5ea;
    color: #344767;
    border-radius: 6px;
    padding: 10px 12px;
}

.form-control:focus {
    background: #ffffff;
    border-color: #00bcd4;
    color: #344767;
    box-shadow: 0 0 0 0.2rem rgba(0, 188, 212, 0.15);
}

.form-text {
    color: #6c757d;
    font-size: 11px;
    margin-top: 5px;
}

.form-actions {
    display: flex;
    gap: 10px;
    justify-content: flex-end;
    margin-top: 20px;
    padding-top: 15px;
    border-top: 1px solid #e1e5ea;
}

.btn {
    padding: 8px 16px;
    border-radius: 6px;
    font-weight: 600;
    transition: all 0.3s ease;
}

.btn-primary {
    background: #00bcd4;
    border-color: #00bcd4;
    color: #ffffff;
}

.btn-primary:hover {
    background: #008fa1;
    border-color: #008fa1;
}

.btn-outline-secondary {
    background: transparent;
    border-color: #6c757d;
    color: #344767;
}

.btn-outline-secondary:hover {
    background: #6c757d;
    border-color: #6c757d;
    color: #ffffff;
}

.intent-summary {
    background: #f8f9fa;
    border-radius: 6px;
    padding: 15px;
    margin-top: 20px;
    border: 1px solid #e1e5ea;
}

.intent-summary h5 {
    color: #008fa1;
    margin: 0 0 10px 0;
    font-size: 14px;
}

.summary-content p {
    margin: 5px 0;
    font-size: 12px;
    color: #6c757d;
}

.summary-content strong {
    color: #344767;
}

/* NATO Attack Type Selector Styles */
.nato-attack-type-selector {
    margin-top: 10px;
}

.attack-type-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
    gap: 10px;
    margin-bottom: 15px;
}

.attack-type-option {
    background: #ffffff;
    border: 2px solid #e1e5ea;
    border-radius: 8px;
    padding: 15px;
    text-align: center;
    cursor: pointer;
    transition: all 0.3s ease;
    position: relative;
}

.attack-type-option:hover {
    border-color: #00bcd4;
    background: #e3f2fd;
    transform: translateY(-2px);
}

.attack-type-option.selected {
    border-color: #00bcd4;
    background: #b3e5fc;
    box-shadow: 0 0 10px rgba(0, 188, 212, 0.3);
}

.attack-symbol {
    font-size: 24px;
    color: #008fa1;
    margin-bottom: 8px;
    font-weight: bold;
}

.attack-name {
    color: #344767;
    font-weight: 600;
    font-size: 12px;
    margin-bottom: 5px;
}

.attack-description {
    color: #6c757d;
    font-size: 10px;
    margin-bottom: 5px;
    line-height: 1.3;
}

.attack-risk {
    color: #ffaa44;
    font-size: 10px;
    font-weight: 600;
}

/* Intensity Selector Styles */
.intensity-selector {
    display: flex;
    gap: 10px;
    margin-top: 10px;
}

.intensity-option {
    flex: 1;
    background: #ffffff;
    border: 2px solid #e1e5ea;
    border-radius: 6px;
    padding: 10px;
    text-align: center;
    cursor: pointer;
    transition: all 0.3s ease;
}

.intensity-option:hover {
    border-color: #00bcd4;
    background: #e3f2fd;
}

.intensity-option.active {
    border-color: #00bcd4;
    background: #b3e5fc;
    box-shadow: 0 0 8px rgba(0, 188, 212, 0.3);
}

.intensity-color {
    width: 20px;
    height: 20px;
    border-radius: 50%;
    margin: 0 auto 8px;
    border: 2px solid #344767;
}

.intensity-name {
    color: #344767;
    font-weight: 600;
    font-size: 11px;
    margin-bottom: 3px;
}

.intensity-description {
    color: #6c757d;
    font-size: 9px;
    line-height: 1.2;
}

@@media (max-width: 768px) {
    .attack-type-grid {
        grid-template-columns: repeat(2, 1fr);
        gap: 8px;
    }
    
    .attack-type-option {
        padding: 10px;
    }
    
    .attack-symbol {
        font-size: 20px;
    }
    
    .intensity-selector {
        flex-direction: column;
        gap: 8px;
    }
}
</style>

<script>
// Intent Form JavaScript
document.addEventListener('DOMContentLoaded', function() {
    initializeIntentForm();
});

function initializeIntentForm() {
    console.log('Initializing intent form');
    
    // Initialize NATO attack type selector
    initializeNatoAttackTypeSelector();
    
    // Initialize intensity selector
    initializeIntensitySelector();
    
    // Add change listeners for real-time validation
    document.getElementById('AttackPreparation').addEventListener('change', updateIntentSummary);
    document.getElementById('DesiredEffect').addEventListener('change', updateIntentSummary);
    document.getElementById('CoordinationType').addEventListener('change', updateIntentSummary);
    document.getElementById('Notes').addEventListener('input', updateIntentSummary);
    
    // Mark form as dirty when changed
    document.querySelectorAll('#intentForm input, #intentForm select, #intentForm textarea').forEach(element => {
        element.addEventListener('change', () => {
            if (window.currentAttackOrder) {
                window.currentAttackOrder.isDirty = true;
            }
        });
    });
}

function initializeNatoAttackTypeSelector() {
    const attackTypeOptions = document.querySelectorAll('.attack-type-option');
    const hiddenInput = document.getElementById('NatoAttackType');
    
    attackTypeOptions.forEach(option => {
        option.addEventListener('click', function() {
            // Remove selected class from all options
            attackTypeOptions.forEach(opt => opt.classList.remove('selected'));
            
            // Add selected class to clicked option
            this.classList.add('selected');
            
            // Update hidden input
            const attackType = this.getAttribute('data-type');
            hiddenInput.value = attackType;
            
            // Update summary
            updateIntentSummary();
            
            // Mark form as dirty
            if (window.currentAttackOrder) {
                window.currentAttackOrder.isDirty = true;
            }
            
            console.log('Selected NATO attack type:', attackType);
        });
    });
}

function initializeIntensitySelector() {
    const intensityOptions = document.querySelectorAll('.intensity-option');
    const hiddenInput = document.getElementById('AttackIntensity');
    
    intensityOptions.forEach(option => {
        option.addEventListener('click', function() {
            // Remove active class from all options
            intensityOptions.forEach(opt => opt.classList.remove('active'));
            
            // Add active class to clicked option
            this.classList.add('active');
            
            // Update hidden input
            const intensity = this.getAttribute('data-intensity');
            hiddenInput.value = intensity;
            
            // Update summary
            updateIntentSummary();
            
            // Mark form as dirty
            if (window.currentAttackOrder) {
                window.currentAttackOrder.isDirty = true;
            }
            
            console.log('Selected attack intensity:', intensity);
        });
    });
}

function updateIntentSummary() {
    const attackPreparation = document.getElementById('AttackPreparation').value;
    const natoAttackType = document.getElementById('NatoAttackType').value;
    const attackIntensity = document.getElementById('AttackIntensity').value;
    const coordinationType = document.getElementById('CoordinationType').value;
    const desiredEffect = document.getElementById('DesiredEffect').value;
    const notes = document.getElementById('Notes').value;
    
    // Get display names
    const natoAttackTypeName = getNatoAttackTypeName(natoAttackType);
    const attackIntensityName = getAttackIntensityName(attackIntensity);
    const coordinationTypeName = getCoordinationTypeName(coordinationType);
    
    if (attackPreparation && natoAttackType && attackIntensity && coordinationType && desiredEffect) {
        document.getElementById('summaryAttackPreparation').textContent = attackPreparation;
        document.getElementById('summaryNatoAttackType').textContent = natoAttackTypeName;
        document.getElementById('summaryAttackIntensity').textContent = attackIntensityName;
        document.getElementById('summaryCoordinationType').textContent = coordinationTypeName;
        document.getElementById('summaryDesiredEffect').textContent = desiredEffect;
        document.getElementById('summaryNotes').textContent = notes || 'None';
        
        document.getElementById('intentSummary').style.display = 'block';
    } else {
        document.getElementById('intentSummary').style.display = 'none';
    }
}

function getNatoAttackTypeName(type) {
    const names = {
        'frontal': 'Frontal Attack',
        'flanking': 'Flanking Attack',
        'envelopment': 'Envelopment',
        'penetration': 'Penetration',
        'raid': 'Raid',
        'ambush': 'Ambush'
    };
    return names[type] || 'Unknown Attack Type';
}

function getAttackIntensityName(intensity) {
    const names = {
        'light': 'Light Attack',
        'standard': 'Standard Attack',
        'heavy': 'Heavy Attack',
        'overwhelming': 'Overwhelming Attack'
    };
    return names[intensity] || 'Unknown Intensity';
}

function getCoordinationTypeName(coordination) {
    const names = {
        'independent': 'Independent Action',
        'supporting': 'Supporting Attack',
        'main': 'Main Effort',
        'feint': 'Feint/Diversion',
        'exploitation': 'Exploitation'
    };
    return names[coordination] || 'Unknown Coordination';
}

function validateIntentForm() {
    const form = document.getElementById('intentForm');
    const formData = new FormData(form);
    
    const attackPreparation = formData.get('AttackPreparation');
    const natoAttackType = formData.get('NatoAttackType');
    const attackIntensity = formData.get('AttackIntensity');
    const coordinationType = formData.get('CoordinationType');
    const desiredEffect = formData.get('DesiredEffect');
    
    if (!attackPreparation || !natoAttackType || !attackIntensity || !coordinationType || !desiredEffect) {
        showNotification('Please fill in all required fields', 'warning');
        return false;
    }
    
    console.log('Intent form validated successfully');
    showNotification('Intent form validated successfully', 'success');
    return true;
}

function resetIntentForm() {
    document.getElementById('intentForm').reset();
    document.getElementById('intentSummary').style.display = 'none';
    console.log('Intent form reset');
}
</script>
