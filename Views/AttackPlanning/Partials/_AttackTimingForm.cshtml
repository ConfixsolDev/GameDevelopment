@model TechWebSol.Models.AttackPlanning.AttackTiming

<div class="attack-form-section">
    <div class="section-header">
        <h4><i class="fas fa-clock"></i> Attack Timing</h4>
        <p class="text-muted">Set the timing and coordination parameters for the attack execution.</p>
    </div>

    <form id="timingForm" class="attack-planning-form">
        <div class="form-row">
            <div class="form-group">
                <label for="StartTurn" class="form-label">Start Turn *</label>
                <select asp-for="StartTurn" class="form-control" id="StartTurn" required>
                    <option value="">Select Start Turn</option>
                    @foreach (var turn in AttackTiming.AvailableStartTurns)
                    {
                        <option value="@turn">Turn @turn</option>
                    }
                </select>
                <small class="form-text text-muted">When the attack should begin.</small>
            </div>

            <div class="form-group">
                <label for="DurationTurns" class="form-label">Duration (Turns) *</label>
                <select asp-for="DurationTurns" class="form-control" id="DurationTurns" required>
                    <option value="">Select Duration</option>
                    @foreach (var duration in AttackTiming.AvailableDurations)
                    {
                        <option value="@duration">@duration Turn@(duration > 1 ? "s" : "")</option>
                    }
                </select>
                <small class="form-text text-muted">How long the attack will last.</small>
            </div>
        </div>

        <div class="form-row">
            <div class="form-group">
                <label for="Posture" class="form-label">Posture *</label>
                <select asp-for="Posture" class="form-control" id="Posture" required>
                    <option value="">Select Posture</option>
                    @foreach (var posture in AttackTiming.Postures)
                    {
                        <option value="@posture">@posture</option>
                    }
                </select>
                <small class="form-text text-muted">Tactical posture during the attack.</small>
            </div>

            <div class="form-group">
                <label class="form-label">Expected End Turn</label>
                <div class="calculated-field">
                    <span id="expectedEndTurn">-</span>
                </div>
                <small class="form-text text-muted">Automatically calculated based on start turn and duration.</small>
            </div>
        </div>

        <div class="form-group">
            <label for="Notes" class="form-label">Timing Notes</label>
            <textarea asp-for="Notes" class="form-control" id="Notes" rows="3" 
                      placeholder="Coordination notes, timing constraints, or synchronization requirements..."></textarea>
            <small class="form-text text-muted">Optional notes about timing and coordination.</small>
        </div>

        <div class="timing-visualization">
            <h5>Timeline Visualization</h5>
            <div class="timeline-container">
                <div class="timeline" id="timeline">
                    <!-- Timeline will be generated by JavaScript -->
                </div>
            </div>
        </div>

        <div class="form-actions">
            <button type="button" class="btn btn-outline-secondary" onclick="resetTimingForm()">
                <i class="fas fa-undo"></i> Reset
            </button>
            <button type="button" class="btn btn-primary" onclick="validateTimingForm()">
                <i class="fas fa-check"></i> Validate
            </button>
        </div>
    </form>

    <div class="timing-summary" id="timingSummary" style="display: none;">
        <h5>Timing Summary</h5>
        <div class="summary-content">
            <p><strong>Start Turn:</strong> <span id="summaryStartTurn">-</span></p>
            <p><strong>Duration:</strong> <span id="summaryDuration">-</span></p>
            <p><strong>End Turn:</strong> <span id="summaryEndTurn">-</span></p>
            <p><strong>Posture:</strong> <span id="summaryPosture">-</span></p>
            <p><strong>Notes:</strong> <span id="summaryNotes">-</span></p>
        </div>
    </div>
</div>

<style>
.calculated-field {
    background: #1a1a1a;
    border: 1px solid #444;
    color: #00d4ff;
    padding: 10px 12px;
    border-radius: 6px;
    font-weight: 600;
    min-height: 38px;
    display: flex;
    align-items: center;
}

.timing-visualization {
    margin-top: 20px;
    padding: 15px;
    background: #1a1a1a;
    border-radius: 6px;
    border: 1px solid #333;
}

.timing-visualization h5 {
    color: #00d4ff;
    margin: 0 0 15px 0;
    font-size: 14px;
}

.timeline-container {
    overflow-x: auto;
    padding: 10px 0;
}

.timeline {
    display: flex;
    gap: 10px;
    min-width: 500px;
}

.timeline-turn {
    background: #2a2a2a;
    border: 2px solid #444;
    border-radius: 8px;
    padding: 10px;
    text-align: center;
    min-width: 80px;
    transition: all 0.3s ease;
}

.timeline-turn.active {
    border-color: #00d4ff;
    background: #00d4ff;
    color: #000;
}

.timeline-turn.turn-number {
    font-weight: 600;
    font-size: 12px;
}

.timeline-turn.turn-status {
    font-size: 10px;
    margin-top: 5px;
    opacity: 0.8;
}

.timing-summary {
    background: #1a1a1a;
    border-radius: 6px;
    padding: 15px;
    margin-top: 20px;
    border: 1px solid #333;
}

.timing-summary h5 {
    color: #00d4ff;
    margin: 0 0 10px 0;
    font-size: 14px;
}

.summary-content p {
    margin: 5px 0;
    font-size: 12px;
    color: #ccc;
}

.summary-content strong {
    color: #fff;
}
</style>

<script>
// Timing Form JavaScript
document.addEventListener('DOMContentLoaded', function() {
    initializeTimingForm();
});

function initializeTimingForm() {
    console.log('Initializing timing form');
    
    // Add change listeners
    document.getElementById('StartTurn').addEventListener('change', updateTimingCalculations);
    document.getElementById('DurationTurns').addEventListener('change', updateTimingCalculations);
    document.getElementById('Posture').addEventListener('change', updateTimingSummary);
    document.getElementById('Notes').addEventListener('input', updateTimingSummary);
    
    // Mark form as dirty when changed
    document.querySelectorAll('#timingForm input, #timingForm select, #timingForm textarea').forEach(element => {
        element.addEventListener('change', () => {
            if (window.currentAttackOrder) {
                window.currentAttackOrder.isDirty = true;
            }
        });
    });
}

function updateTimingCalculations() {
    const startTurn = parseInt(document.getElementById('StartTurn').value) || 0;
    const duration = parseInt(document.getElementById('DurationTurns').value) || 0;
    
    if (startTurn && duration) {
        const endTurn = startTurn + duration - 1;
        document.getElementById('expectedEndTurn').textContent = `Turn ${endTurn}`;
        
        // Update timeline
        generateTimeline(startTurn, duration);
        
        // Update summary
        updateTimingSummary();
    } else {
        document.getElementById('expectedEndTurn').textContent = '-';
        document.getElementById('timeline').innerHTML = '<p class="text-muted">Select start turn and duration to see timeline</p>';
    }
}

function generateTimeline(startTurn, duration) {
    const timeline = document.getElementById('timeline');
    timeline.innerHTML = '';
    
    const endTurn = startTurn + duration - 1;
    
    for (let turn = Math.max(1, startTurn - 2); turn <= endTurn + 2; turn++) {
        const turnElement = document.createElement('div');
        turnElement.className = 'timeline-turn';
        
        if (turn >= startTurn && turn <= endTurn) {
            turnElement.classList.add('active');
        }
        
        turnElement.innerHTML = `
            <div class="turn-number">Turn ${turn}</div>
            <div class="turn-status">
                ${turn === startTurn ? 'START' : 
                  turn === endTurn ? 'END' : 
                  turn > startTurn && turn < endTurn ? 'ACTIVE' : 'PRE/POST'}
            </div>
        `;
        
        timeline.appendChild(turnElement);
    }
}

function updateTimingSummary() {
    const startTurn = document.getElementById('StartTurn').value;
    const duration = document.getElementById('DurationTurns').value;
    const posture = document.getElementById('Posture').value;
    const notes = document.getElementById('Notes').value;
    
    if (startTurn && duration && posture) {
        const endTurn = parseInt(startTurn) + parseInt(duration) - 1;
        
        document.getElementById('summaryStartTurn').textContent = `Turn ${startTurn}`;
        document.getElementById('summaryDuration').textContent = `${duration} Turn${duration > 1 ? 's' : ''}`;
        document.getElementById('summaryEndTurn').textContent = `Turn ${endTurn}`;
        document.getElementById('summaryPosture').textContent = posture;
        document.getElementById('summaryNotes').textContent = notes || 'None';
        
        document.getElementById('timingSummary').style.display = 'block';
    } else {
        document.getElementById('timingSummary').style.display = 'none';
    }
}

function validateTimingForm() {
    const form = document.getElementById('timingForm');
    const formData = new FormData(form);
    
    const startTurn = formData.get('StartTurn');
    const duration = formData.get('DurationTurns');
    const posture = formData.get('Posture');
    
    if (!startTurn || !duration || !posture) {
        showNotification('Please fill in all required fields', 'warning');
        return false;
    }
    
    // Validate timing logic
    const start = parseInt(startTurn);
    const dur = parseInt(duration);
    
    if (start < 1 || start > 10) {
        showNotification('Start turn must be between 1 and 10', 'warning');
        return false;
    }
    
    if (dur < 1 || dur > 5) {
        showNotification('Duration must be between 1 and 5 turns', 'warning');
        return false;
    }
    
    console.log('Timing form validated successfully');
    showNotification('Timing form validated successfully', 'success');
    return true;
}

function resetTimingForm() {
    document.getElementById('timingForm').reset();
    document.getElementById('timingSummary').style.display = 'none';
    document.getElementById('expectedEndTurn').textContent = '-';
    document.getElementById('timeline').innerHTML = '<p class="text-muted">Select start turn and duration to see timeline</p>';
    console.log('Timing form reset');
}
</script>
