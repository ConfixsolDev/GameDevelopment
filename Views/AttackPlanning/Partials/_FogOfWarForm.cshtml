@model TechWebSol.Models.AttackPlanning.FogOfWar

<div class="attack-form-section">
    <div class="section-header">
        <h4><i class="fas fa-eye-slash"></i> Fog of War</h4>
        <p class="text-muted">Manage uncertainty and risk factors for the attack.</p>
    </div>

    <form id="fogOfWarForm" class="attack-planning-form">
        <div class="form-row">
            <div class="form-group">
                <label for="DetectionConfidence" class="form-label">Detection Confidence *</label>
                <div class="confidence-container">
                    <input type="range" asp-for="DetectionConfidence" class="form-range" id="DetectionConfidence" 
                           min="0" max="100" step="1" value="72" required>
                    <div class="confidence-display">
                        <span id="confidenceValue">72%</span>
                        <span id="confidenceLevel" class="confidence-level">Medium</span>
                    </div>
                </div>
                <small class="form-text text-muted">How confident are you about enemy positions and capabilities?</small>
            </div>

            <div class="form-group">
                <label class="form-label">Risk Assessment</label>
                <div class="risk-indicator" id="riskIndicator">
                    <div class="risk-bar">
                        <div class="risk-fill" id="riskFill"></div>
                    </div>
                    <div class="risk-label" id="riskLabel">Medium Risk</div>
                </div>
                <small class="form-text text-muted">Automatically calculated based on detection confidence.</small>
            </div>
        </div>

        <div class="form-group">
            <label class="form-label">Commit with Uncertainty</label>
            <div class="checkbox-container">
                <input type="checkbox" asp-for="CommitWithUncertainty" id="CommitWithUncertainty" class="form-check-input" checked>
                <label for="CommitWithUncertainty" class="form-check-label">Proceed with attack despite uncertainty</label>
            </div>
            <small class="form-text text-muted">Check to proceed even with low detection confidence.</small>
        </div>

        <div class="abort-criteria-section">
            <div class="criteria-header">
                <h5><i class="fas fa-exclamation-triangle"></i> Abort Criteria</h5>
                <div class="criteria-actions">
                    <button type="button" class="btn btn-sm btn-outline-primary" onclick="addAbortCriteria()">
                        <i class="fas fa-plus"></i> Add Criteria
                    </button>
                </div>
            </div>

            <div class="criteria-list" id="criteriaList">
                <!-- Abort criteria will be added here -->
            </div>

            <div class="criteria-input" id="criteriaInput" style="display: none;">
                <div class="form-row">
                    <div class="form-group">
                        <label class="form-label">Criteria Type</label>
                        <select class="form-control" id="newCriteriaType">
                            <option value="">Select Criteria Type</option>
                            <option value="DetectionBelow">Detection Below</option>
                            <option value="SupplyBelow">Supply Below</option>
                            <option value="CasualtyAbove">Casualty Above</option>
                            <option value="TimeExceeded">Time Exceeded</option>
                        </select>
                    </div>
                    <div class="form-group">
                        <label class="form-label">Threshold Value</label>
                        <input type="text" class="form-control" id="newCriteriaValue" placeholder="e.g., 0.4, Amber, 30%">
                    </div>
                </div>
                <div class="form-group">
                    <label class="form-label">Criteria Notes (Optional)</label>
                    <input type="text" class="form-control" id="newCriteriaNotes" placeholder="Additional details about this criteria...">
                </div>
                <div class="criteria-input-actions">
                    <button type="button" class="btn btn-sm btn-primary" onclick="saveAbortCriteria()">
                        <i class="fas fa-save"></i> Add Criteria
                    </button>
                    <button type="button" class="btn btn-sm btn-secondary" onclick="cancelAbortCriteria()">
                        <i class="fas fa-times"></i> Cancel
                    </button>
                </div>
            </div>
        </div>

        <div class="uncertainty-summary">
            <div class="summary-row">
                <div class="summary-item">
                    <label>Detection Confidence:</label>
                    <span id="summaryConfidence">72%</span>
                </div>
                <div class="summary-item">
                    <label>Risk Level:</label>
                    <span id="summaryRiskLevel">Medium</span>
                </div>
                <div class="summary-item">
                    <label>Abort Criteria:</label>
                    <span id="summaryAbortCriteria">0</span>
                </div>
            </div>
        </div>

        <div class="form-group">
            <label for="Notes" class="form-label">Fog of War Notes</label>
            <textarea asp-for="Notes" class="form-control" id="Notes" rows="3" 
                      placeholder="Intelligence notes, uncertainty factors, or risk considerations..."></textarea>
            <small class="form-text text-muted">Optional notes about fog of war considerations.</small>
        </div>

        <div class="form-actions">
            <button type="button" class="btn btn-outline-secondary" onclick="resetFogOfWarForm()">
                <i class="fas fa-undo"></i> Reset
            </button>
            <button type="button" class="btn btn-primary" onclick="validateFogOfWarForm()">
                <i class="fas fa-check"></i> Validate
            </button>
        </div>
    </form>

    <div class="fogofwar-summary-detail" id="fogOfWarSummary" style="display: none;">
        <h5>Fog of War Summary</h5>
        <div class="summary-content">
            <p><strong>Detection Confidence:</strong> <span id="summaryDetailConfidence">-</span></p>
            <p><strong>Risk Level:</strong> <span id="summaryDetailRiskLevel">-</span></p>
            <p><strong>Commit with Uncertainty:</strong> <span id="summaryDetailCommit">-</span></p>
            <p><strong>Abort Criteria:</strong> <span id="summaryDetailAbortCriteria">-</span></p>
            <p><strong>Notes:</strong> <span id="summaryDetailNotes">-</span></p>
        </div>
    </div>
</div>

<style>
.confidence-container {
    position: relative;
}

.form-range {
    width: 100%;
    height: 8px;
    background: #444;
    border-radius: 4px;
    outline: none;
    -webkit-appearance: none;
}

.form-range::-webkit-slider-thumb {
    -webkit-appearance: none;
    width: 24px;
    height: 24px;
    background: #00d4ff;
    border-radius: 50%;
    cursor: pointer;
}

.form-range::-moz-range-thumb {
    width: 24px;
    height: 24px;
    background: #00d4ff;
    border-radius: 50%;
    cursor: pointer;
    border: none;
}

.confidence-display {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-top: 10px;
}

.confidence-level {
    padding: 4px 8px;
    border-radius: 4px;
    font-size: 11px;
    font-weight: 600;
}

.confidence-level.high {
    background: #00ff88;
    color: #000;
}

.confidence-level.medium {
    background: #ffaa00;
    color: #000;
}

.confidence-level.low {
    background: #ff4444;
    color: #fff;
}

.confidence-level.very-low {
    background: #880000;
    color: #fff;
}

.risk-indicator {
    background: #1a1a1a;
    border-radius: 6px;
    padding: 15px;
    border: 1px solid #333;
}

.risk-bar {
    width: 100%;
    height: 20px;
    background: #333;
    border-radius: 10px;
    overflow: hidden;
    margin-bottom: 8px;
}

.risk-fill {
    height: 100%;
    transition: all 0.3s ease;
    border-radius: 10px;
}

.risk-fill.low {
    background: linear-gradient(90deg, #00ff88, #00cc66);
    width: 25%;
}

.risk-fill.medium {
    background: linear-gradient(90deg, #ffaa00, #ff8800);
    width: 50%;
}

.risk-fill.high {
    background: linear-gradient(90deg, #ff4444, #cc0000);
    width: 75%;
}

.risk-fill.critical {
    background: linear-gradient(90deg, #880000, #440000);
    width: 100%;
}

.risk-label {
    text-align: center;
    font-weight: 600;
    font-size: 12px;
}

.abort-criteria-section {
    margin-top: 20px;
    background: #1a1a1a;
    border-radius: 6px;
    padding: 15px;
    border: 1px solid #333;
}

.criteria-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 15px;
}

.criteria-header h5 {
    color: #00d4ff;
    margin: 0;
    font-size: 14px;
}

.criteria-list {
    margin-bottom: 15px;
}

.criteria-item {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 10px;
    background: #2a2a2a;
    border-radius: 6px;
    margin-bottom: 8px;
    border: 1px solid #444;
}

.criteria-info {
    display: flex;
    align-items: center;
    gap: 10px;
    flex: 1;
}

.criteria-type {
    background: #ff4444;
    color: #fff;
    padding: 2px 6px;
    border-radius: 4px;
    font-size: 10px;
    font-weight: 600;
}

.criteria-details {
    color: #ccc;
    font-size: 12px;
}

.criteria-actions {
    display: flex;
    gap: 8px;
}

.criteria-input {
    background: #2a2a2a;
    border-radius: 6px;
    padding: 15px;
    border: 1px solid #444;
    margin-bottom: 15px;
}

.criteria-input-actions {
    display: flex;
    gap: 8px;
    justify-content: flex-end;
    margin-top: 10px;
}

.uncertainty-summary {
    background: #1a1a1a;
    border-radius: 6px;
    padding: 15px;
    margin: 20px 0;
    border: 1px solid #333;
}

.summary-row {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    gap: 20px;
}

.summary-item {
    text-align: center;
}

.summary-item label {
    display: block;
    color: #888;
    font-size: 11px;
    margin-bottom: 5px;
}

.summary-item span {
    color: #00d4ff;
    font-weight: 600;
    font-size: 14px;
}

.fogofwar-summary-detail {
    background: #1a1a1a;
    border-radius: 6px;
    padding: 15px;
    margin-top: 20px;
    border: 1px solid #333;
}

.fogofwar-summary-detail h5 {
    color: #00d4ff;
    margin: 0 0 10px 0;
    font-size: 14px;
}

.summary-content p {
    margin: 5px 0;
    font-size: 12px;
    color: #ccc;
}

.summary-content strong {
    color: #fff;
}

@@media (max-width: 768px) {
    .summary-row {
        grid-template-columns: 1fr;
        gap: 10px;
    }
    
    .criteria-header {
        flex-direction: column;
        gap: 10px;
        align-items: stretch;
    }
    
    .criteria-actions {
        justify-content: center;
    }
}
</style>

<script>
// Fog of War Form JavaScript
let abortCriteria = [];

document.addEventListener('DOMContentLoaded', function() {
    initializeFogOfWarForm();
});

function initializeFogOfWarForm() {
    console.log('Initializing fog of war form');
    
    // Add change listeners
    document.getElementById('DetectionConfidence').addEventListener('input', updateConfidenceDisplay);
    document.getElementById('CommitWithUncertainty').addEventListener('change', updateFogOfWarSummary);
    document.getElementById('Notes').addEventListener('input', updateFogOfWarSummary);
    
    // Mark form as dirty when changed
    document.querySelectorAll('#fogOfWarForm input, #fogOfWarForm select, #fogOfWarForm textarea').forEach(element => {
        element.addEventListener('change', () => {
            if (window.currentAttackOrder) {
                window.currentAttackOrder.isDirty = true;
            }
        });
    });
    
    updateConfidenceDisplay();
}

function updateConfidenceDisplay() {
    const confidence = parseInt(document.getElementById('DetectionConfidence').value);
    const confidenceValue = document.getElementById('confidenceValue');
    const confidenceLevel = document.getElementById('confidenceLevel');
    const riskFill = document.getElementById('riskFill');
    const riskLabel = document.getElementById('riskLabel');
    
    confidenceValue.textContent = confidence + '%';
    
    // Update confidence level
    let level, levelClass;
    if (confidence >= 80) {
        level = 'High';
        levelClass = 'high';
    } else if (confidence >= 60) {
        level = 'Medium';
        levelClass = 'medium';
    } else if (confidence >= 40) {
        level = 'Low';
        levelClass = 'low';
    } else {
        level = 'Very Low';
        levelClass = 'very-low';
    }
    
    confidenceLevel.textContent = level;
    confidenceLevel.className = 'confidence-level ' + levelClass;
    
    // Update risk indicator
    let riskLevel, riskClass;
    if (confidence >= 80) {
        riskLevel = 'Low Risk';
        riskClass = 'low';
    } else if (confidence >= 60) {
        riskLevel = 'Medium Risk';
        riskClass = 'medium';
    } else if (confidence >= 40) {
        riskLevel = 'High Risk';
        riskClass = 'high';
    } else {
        riskLevel = 'Critical Risk';
        riskClass = 'critical';
    }
    
    riskFill.className = 'risk-fill ' + riskClass;
    riskLabel.textContent = riskLevel;
    
    updateFogOfWarSummary();
}

function addAbortCriteria() {
    document.getElementById('criteriaInput').style.display = 'block';
    document.getElementById('newCriteriaType').focus();
}

function cancelAbortCriteria() {
    document.getElementById('criteriaInput').style.display = 'none';
    document.getElementById('newCriteriaType').value = '';
    document.getElementById('newCriteriaValue').value = '';
    document.getElementById('newCriteriaNotes').value = '';
}

function saveAbortCriteria() {
    const type = document.getElementById('newCriteriaType').value;
    const value = document.getElementById('newCriteriaValue').value;
    const notes = document.getElementById('newCriteriaNotes').value;
    
    if (!type || !value) {
        showNotification('Please fill in criteria type and value', 'warning');
        return;
    }
    
    const criteria = {
        id: Date.now(),
        type: type,
        value: value,
        notes: notes || ''
    };
    
    abortCriteria.push(criteria);
    updateCriteriaList();
    cancelAbortCriteria();
    
    if (window.currentAttackOrder) {
        window.currentAttackOrder.isDirty = true;
    }
}

function updateCriteriaList() {
    const list = document.getElementById('criteriaList');
    list.innerHTML = '';
    
    abortCriteria.forEach(criteria => {
        const criteriaElement = document.createElement('div');
        criteriaElement.className = 'criteria-item';
        criteriaElement.innerHTML = `
            <div class="criteria-info">
                <span class="criteria-type">${criteria.type}</span>
                <span class="criteria-details">${criteria.value}${criteria.notes ? ' - ' + criteria.notes : ''}</span>
            </div>
            <div class="criteria-actions">
                <button type="button" class="btn btn-sm btn-outline-danger" onclick="removeAbortCriteria(${criteria.id})">
                    <i class="fas fa-trash"></i>
                </button>
            </div>
        `;
        list.appendChild(criteriaElement);
    });
    
    updateFogOfWarSummary();
}

function removeAbortCriteria(criteriaId) {
    abortCriteria = abortCriteria.filter(c => c.id !== criteriaId);
    updateCriteriaList();
    
    if (window.currentAttackOrder) {
        window.currentAttackOrder.isDirty = true;
    }
}

function updateFogOfWarSummary() {
    const confidence = parseInt(document.getElementById('DetectionConfidence').value);
    const commitWithUncertainty = document.getElementById('CommitWithUncertainty').checked;
    const notes = document.getElementById('Notes').value;
    
    // Update summary row
    document.getElementById('summaryConfidence').textContent = confidence + '%';
    
    let riskLevel;
    if (confidence >= 80) riskLevel = 'Low';
    else if (confidence >= 60) riskLevel = 'Medium';
    else if (confidence >= 40) riskLevel = 'High';
    else riskLevel = 'Critical';
    
    document.getElementById('summaryRiskLevel').textContent = riskLevel;
    document.getElementById('summaryAbortCriteria').textContent = abortCriteria.length;
    
    // Update detailed summary
    if (confidence !== 72 || commitWithUncertainty || abortCriteria.length > 0 || notes) {
        document.getElementById('summaryDetailConfidence').textContent = confidence + '%';
        document.getElementById('summaryDetailRiskLevel').textContent = riskLevel;
        document.getElementById('summaryDetailCommit').textContent = commitWithUncertainty ? 'Yes' : 'No';
        document.getElementById('summaryDetailAbortCriteria').textContent = abortCriteria.length > 0 ? 
            abortCriteria.map(c => `${c.type}: ${c.value}`).join(', ') : 'None';
        document.getElementById('summaryDetailNotes').textContent = notes || 'None';
        
        document.getElementById('fogOfWarSummary').style.display = 'block';
    } else {
        document.getElementById('fogOfWarSummary').style.display = 'none';
    }
}

function validateFogOfWarForm() {
    const confidence = parseInt(document.getElementById('DetectionConfidence').value);
    const commitWithUncertainty = document.getElementById('CommitWithUncertainty').checked;
    
    if (confidence < 0 || confidence > 100) {
        showNotification('Detection confidence must be between 0% and 100%', 'warning');
        return false;
    }
    
    if (confidence < 30 && !commitWithUncertainty) {
        showNotification('Consider committing with uncertainty for low confidence attacks', 'warning');
    }
    
    console.log('Fog of war form validated successfully');
    showNotification('Fog of war form validated successfully', 'success');
    return true;
}

function resetFogOfWarForm() {
    document.getElementById('fogOfWarForm').reset();
    abortCriteria = [];
    updateCriteriaList();
    document.getElementById('criteriaInput').style.display = 'none';
    document.getElementById('fogOfWarSummary').style.display = 'none';
    updateConfidenceDisplay();
    console.log('Fog of war form reset');
}
</script>
