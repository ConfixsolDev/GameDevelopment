@{
    ViewData["Title"] = "Game Session Management";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container-fluid">
    <div class="row">
        <div class="col-12">
            <div class="card">
                <div class="card-header">
                    <h3 class="card-title">
                        <i class="fas fa-gamepad"></i> Game Session Management
                    </h3>
                    <div class="card-tools">
                        <button type="button" class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#startSessionModal">
                            <i class="fas fa-play"></i> Start New Session
                        </button>
                    </div>
                </div>
                <div class="card-body">
                    <div class="table-responsive">
                        <table id="gameSessionsTable" class="table table-bordered table-striped">
                            <thead>
                                <tr>
                                    <th>Session Name</th>
                                    <th>Session Code</th>
                                    <th>Status</th>
                                    <th>Start Time</th>
                                    <th>End Time</th>
                                    <th>Created By</th>
                                    <th>Token Bindings</th>
                                    <th>Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                <!-- Data will be loaded via JavaScript -->
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Start Session Modal -->
<div class="modal fade" id="startSessionModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Start New Game Session</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <form id="startSessionForm">
                    <div class="mb-3">
                        <label for="sessionName" class="form-label">Session Name *</label>
                        <input type="text" class="form-control" id="sessionName" required>
                    </div>
                    <div class="mb-3">
                        <label for="sessionCode" class="form-label">Session Code *</label>
                        <input type="text" class="form-control" id="sessionCode" required>
                        <div class="form-text">Unique identifier for this session</div>
                    </div>
                    <div class="mb-3">
                        <label for="sessionDescription" class="form-label">Description</label>
                        <textarea class="form-control" id="sessionDescription" rows="3"></textarea>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-primary" id="startSessionBtn">Start Session</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function() {
            loadGameSessions();

            $('#startSessionBtn').click(function() {
                startGameSession();
            });
        });

        function loadGameSessions() {
            $.get('/api/game/GameManagement/active-sessions')
                .done(function(sessions) {
                    const tbody = $('#gameSessionsTable tbody');
                    tbody.empty();
                    
                    sessions.forEach(function(session) {
                        const row = `
                            <tr>
                                <td>${session.name}</td>
                                <td><span class="badge bg-info">${session.sessionCode}</span></td>
                                <td>${session.status === 'Active' ? '<span class="badge bg-success">Active</span>' : '<span class="badge bg-secondary">Inactive</span>'}</td>
                                <td>${new Date(session.startTime).toLocaleString()}</td>
                                <td>${session.endTime ? new Date(session.endTime).toLocaleString() : 'N/A'}</td>
                                <td>${session.createdByUserName || 'N/A'}</td>
                                <td><span class="badge bg-primary">${session.tokenBindingCount}</span></td>
                                <td>
                                    ${session.status === 'Active' ? 
                                        `<button class="btn btn-sm btn-danger" onclick="endSession(${session.id})">
                                            <i class="fas fa-stop"></i> End Session
                                        </button>` : 
                                        '<span class="text-muted">Completed</span>'
                                    }
                                </td>
                            </tr>
                        `;
                        tbody.append(row);
                    });
                })
                .fail(function() {
                    showAlert('Error loading game sessions', 'danger');
                });
        }

        function startGameSession() {
            const data = {
                name: $('#sessionName').val(),
                sessionCode: $('#sessionCode').val(),
                description: $('#sessionDescription').val()
            };

            $.post('/api/game/GameManagement/start-session', data)
                .done(function(response) {
                    if (response.success) {
                        showAlert('Game session started successfully', 'success');
                        $('#startSessionModal').modal('hide');
                        $('#startSessionForm')[0].reset();
                        loadGameSessions();
                    } else {
                        showAlert(response.message, 'danger');
                    }
                })
                .fail(function(xhr) {
                    const message = xhr.responseJSON?.message || 'Error starting game session';
                    showAlert(message, 'danger');
                });
        }

        function endSession(sessionId) {
            if (confirm('Are you sure you want to end this game session? All bound tokens will be freed.')) {
                $.post(`/api/game/GameManagement/end-session/${sessionId}`)
                    .done(function(response) {
                        if (response.success) {
                            showAlert('Game session ended successfully', 'success');
                            loadGameSessions();
                        } else {
                            showAlert(response.message, 'danger');
                        }
                    })
                    .fail(function() {
                        showAlert('Error ending game session', 'danger');
                    });
            }
        }

        function showAlert(message, type) {
            const alertDiv = `
                <div class="alert alert-${type} alert-dismissible fade show" role="alert">
                    ${message}
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            `;
            $('.container-fluid').prepend(alertDiv);
            
            setTimeout(function() {
                $('.alert').fadeOut();
            }, 5000);
        }
    </script>
}
