@{
    ViewData["Title"] = "Active Game Sessions";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container-fluid">
    <div class="row">
        <div class="col-12">
            <div class="card">
                <div class="card-header">
                    <h3 class="card-title">
                        <i class="fas fa-gamepad"></i> Active Game Sessions
                    </h3>
                    <div class="card-tools">
                        <button type="button" class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#startSessionModal">
                            <i class="fas fa-play"></i> Start New Session
                        </button>
                    </div>
                </div>
                <div class="card-body">
                    <div class="table-responsive">
                        <table id="activeSessionsTable" class="table table-bordered table-striped">
                            <thead>
                                <tr>
                                    <th>Session Name</th>
                                    <th>Session Code</th>
                                    <th>Status</th>
                                    <th>Start Time</th>
                                    <th>Duration</th>
                                    <th>Created By</th>
                                    <th>Token Bindings</th>
                                    <th>Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                <!-- Data will be loaded via JavaScript -->
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Start Session Modal -->
<div class="modal fade" id="startSessionModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Start New Game Session</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <form id="startSessionForm">
                    <div class="mb-3">
                        <label for="sessionName" class="form-label">Session Name *</label>
                        <input type="text" class="form-control" id="sessionName" required>
                    </div>
                    <div class="mb-3">
                        <label for="sessionCode" class="form-label">Session Code *</label>
                        <input type="text" class="form-control" id="sessionCode" required>
                        <div class="form-text">Unique identifier for this session</div>
                    </div>
                    <div class="mb-3">
                        <label for="sessionDescription" class="form-label">Description</label>
                        <textarea class="form-control" id="sessionDescription" rows="3"></textarea>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-primary" id="startSessionBtn">Start Session</button>
            </div>
        </div>
    </div>
</div>

<!-- Session Details Modal -->
<div class="modal fade" id="sessionDetailsModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Session Details</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div id="sessionDetailsContent">
                    <!-- Content will be loaded via JavaScript -->
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                <button type="button" class="btn btn-danger" id="endSessionBtn">End Session</button>
            </div>
        </div>
    </div>
</div>

<!-- Token Binding Modal -->
<div class="modal fade" id="tokenBindingModal" tabindex="-1">
    <div class="modal-dialog modal-xl">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Bind Tokens to Entities</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div class="row">
                    <div class="col-md-6">
                        <h6>Available Token Groups</h6>
                        <div id="availableTokenGroups">
                            <!-- Token groups will be loaded here -->
                        </div>
                    </div>
                    <div class="col-md-6">
                        <h6>Entity Assignments</h6>
                        <div id="entityAssignments">
                            <!-- Entity assignments will be shown here -->
                        </div>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-primary" id="saveBindingsBtn">Save Bindings</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        let currentSessionId = null;

        $(document).ready(function() {
            loadActiveSessions();

            $('#startSessionBtn').click(function() {
                startGameSession();
            });

            $('#endSessionBtn').click(function() {
                endGameSession();
            });

            $('#saveBindingsBtn').click(function() {
                saveTokenBindings();
            });
        });

        function loadActiveSessions() {
            $.get('/api/game/GameManagement/active-sessions')
                .done(function(sessions) {
                    const tbody = $('#activeSessionsTable tbody');
                    tbody.empty();
                    
                    sessions.forEach(function(session) {
                        const duration = calculateDuration(session.startTime);
                        const row = `
                            <tr>
                                <td>${session.name}</td>
                                <td><span class="badge bg-info">${session.sessionCode}</span></td>
                                <td>${session.status === 'Active' ? '<span class="badge bg-success">Active</span>' : '<span class="badge bg-secondary">Inactive</span>'}</td>
                                <td>${new Date(session.startTime).toLocaleString()}</td>
                                <td>${duration}</td>
                                <td>${session.createdByUserName || 'N/A'}</td>
                                <td><span class="badge bg-primary">${session.tokenBindingCount}</span></td>
                                <td>
                                    <button class="btn btn-sm btn-info" onclick="viewSessionDetails('${session.id}')">
                                        <i class="fas fa-eye"></i> Details
                                    </button>
                                    <button class="btn btn-sm btn-warning" onclick="manageTokenBindings('${session.id}')">
                                        <i class="fas fa-link"></i> Bind Tokens
                                    </button>
                                    <button class="btn btn-sm btn-danger" onclick="endSession('${session.id}')">
                                        <i class="fas fa-stop"></i> End
                                    </button>
                                </td>
                            </tr>
                        `;
                        tbody.append(row);
                    });
                })
                .fail(function() {
                    showAlert('Error loading active sessions', 'danger');
                });
        }

        function calculateDuration(startTime) {
            const start = new Date(startTime);
            const now = new Date();
            const diffMs = now - start;
            const diffHours = Math.floor(diffMs / (1000 * 60 * 60));
            const diffMinutes = Math.floor((diffMs % (1000 * 60 * 60)) / (1000 * 60));
            return `${diffHours}h ${diffMinutes}m`;
        }

        function startGameSession() {
            const data = {
                name: $('#sessionName').val(),
                sessionCode: $('#sessionCode').val(),
                description: $('#sessionDescription').val()
            };

            if (!data.name || !data.sessionCode) {
                showAlert('Session name and code are required', 'warning');
                return;
            }

            $.post('/api/game/GameManagement/start-session', data)
                .done(function(response) {
                    if (response.success) {
                        showAlert('Game session started successfully', 'success');
                        $('#startSessionModal').modal('hide');
                        $('#startSessionForm')[0].reset();
                        loadActiveSessions();
                    } else {
                        showAlert(response.message, 'danger');
                    }
                })
                .fail(function(xhr) {
                    const message = xhr.responseJSON?.message || 'Error starting game session';
                    showAlert(message, 'danger');
                });
        }

        function viewSessionDetails(sessionId) {
            currentSessionId = sessionId;
            $.get(`/api/game/GameManagement/session-details/${sessionId}`)
                .done(function(session) {
                    const content = `
                        <div class="row">
                            <div class="col-md-6">
                                <h6>Session Information</h6>
                                <table class="table table-sm">
                                    <tr><td><strong>Name:</strong></td><td>${session.name}</td></tr>
                                    <tr><td><strong>Code:</strong></td><td>${session.sessionCode}</td></tr>
                                    <tr><td><strong>Status:</strong></td><td><span class="badge bg-success">${session.status}</span></td></tr>
                                    <tr><td><strong>Start Time:</strong></td><td>${new Date(session.startTime).toLocaleString()}</td></tr>
                                    <tr><td><strong>Created By:</strong></td><td>${session.createdByUserName}</td></tr>
                                </table>
                            </div>
                            <div class="col-md-6">
                                <h6>Description</h6>
                                <p>${session.description || 'No description provided'}</p>
                            </div>
                        </div>
                        <div class="row mt-3">
                            <div class="col-12">
                                <h6>Token Bindings (${session.tokenBindingCount})</h6>
                                <div id="sessionTokenBindings">
                                    <!-- Token bindings will be loaded here -->
                                </div>
                            </div>
                        </div>
                    `;
                    $('#sessionDetailsContent').html(content);
                    loadSessionTokenBindings(sessionId);
                    $('#sessionDetailsModal').modal('show');
                })
                .fail(function() {
                    showAlert('Error loading session details', 'danger');
                });
        }

        function loadSessionTokenBindings(sessionId) {
            $.get(`/api/game/GameManagement/session-bindings/${sessionId}`)
                .done(function(bindings) {
                    const container = $('#sessionTokenBindings');
                    container.empty();
                    
                    if (bindings.length === 0) {
                        container.html('<p class="text-muted">No token bindings found for this session.</p>');
                        return;
                    }

                    bindings.forEach(function(binding) {
                        const bindingDiv = `
                            <div class="card mb-2">
                                <div class="card-body py-2">
                                    <div class="row">
                                        <div class="col-md-4">
                                            <strong>Entity:</strong> ${binding.entityName}
                                        </div>
                                        <div class="col-md-4">
                                            <strong>Token Group:</strong> ${binding.tokenGroupName}
                                        </div>
                                        <div class="col-md-4">
                                            <strong>Bound:</strong> ${new Date(binding.boundAt).toLocaleString()}
                                        </div>
                                    </div>
                                </div>
                            </div>
                        `;
                        container.append(bindingDiv);
                    });
                })
                .fail(function() {
                    $('#sessionTokenBindings').html('<p class="text-danger">Error loading token bindings</p>');
                });
        }

        function manageTokenBindings(sessionId) {
            currentSessionId = sessionId;
            loadAvailableTokenGroups();
            loadCurrentBindings(sessionId);
            $('#tokenBindingModal').modal('show');
        }

        function loadAvailableTokenGroups() {
            $.get('/api/admin/AdminToken/groups')
                .done(function(groups) {
                    const container = $('#availableTokenGroups');
                    container.empty();
                    
                    groups.forEach(function(group) {
                        const groupDiv = `
                            <div class="card mb-2">
                                <div class="card-body py-2">
                                    <div class="form-check">
                                        <input class="form-check-input" type="checkbox" value="${group.id}" id="group_${group.id}">
                                        <label class="form-check-label" for="group_${group.id}">
                                            <strong>${group.name}</strong> (${group.groupCode})
                                            <br><small class="text-muted">${group.description || 'No description'}</small>
                                        </label>
                                    </div>
                                    <div class="mt-2">
                                        <input type="text" class="form-control form-control-sm" placeholder="Entity name" id="entity_${group.id}">
                                        <input type="text" class="form-control form-control-sm mt-1" placeholder="Entity code (optional)" id="entityCode_${group.id}">
                                    </div>
                                </div>
                            </div>
                        `;
                        container.append(groupDiv);
                    });
                })
                .fail(function() {
                    showAlert('Error loading token groups', 'danger');
                });
        }

        function loadCurrentBindings(sessionId) {
            $.get(`/api/game/GameManagement/session-bindings/${sessionId}`)
                .done(function(bindings) {
                    const container = $('#entityAssignments');
                    container.empty();
                    
                    if (bindings.length === 0) {
                        container.html('<p class="text-muted">No current bindings</p>');
                        return;
                    }

                    bindings.forEach(function(binding) {
                        const bindingDiv = `
                            <div class="card mb-2">
                                <div class="card-body py-2">
                                    <div class="row">
                                        <div class="col-md-6">
                                            <strong>${binding.entityName}</strong>
                                        </div>
                                        <div class="col-md-4">
                                            <small>${binding.tokenGroupName}</small>
                                        </div>
                                        <div class="col-md-2">
                                            <button class="btn btn-sm btn-danger" onclick="removeBinding('${binding.id}')">
                                                <i class="fas fa-trash"></i>
                                            </button>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        `;
                        container.append(bindingDiv);
                    });
                })
                .fail(function() {
                    showAlert('Error loading current bindings', 'danger');
                });
        }

        function saveTokenBindings() {
            const bindings = [];
            $('.form-check-input:checked').each(function() {
                const groupId = $(this).val();
                const entityName = $(`#entity_${groupId}`).val();
                const entityCode = $(`#entityCode_${groupId}`).val();
                
                if (entityName) {
                    bindings.push({
                        tokenGroupId: groupId,
                        entityName: entityName,
                        entityCode: entityCode
                    });
                }
            });

            if (bindings.length === 0) {
                showAlert('Please select at least one token group and provide entity names', 'warning');
                return;
            }

            const data = {
                sessionId: currentSessionId,
                entities: bindings
            };

            $.post('/api/game/GameManagement/bind-tokens', data)
                .done(function(response) {
                    if (response.success) {
                        showAlert('Token bindings saved successfully', 'success');
                        $('#tokenBindingModal').modal('hide');
                        loadActiveSessions();
                    } else {
                        showAlert(response.message, 'danger');
                    }
                })
                .fail(function(xhr) {
                    const message = xhr.responseJSON?.message || 'Error saving token bindings';
                    showAlert(message, 'danger');
                });
        }

        function endSession(sessionId) {
            if (confirm('Are you sure you want to end this game session? All bound tokens will be freed.')) {
                $.post(`/api/game/GameManagement/end-session/${sessionId}`)
                    .done(function(response) {
                        if (response.success) {
                            showAlert('Game session ended successfully', 'success');
                            loadActiveSessions();
                        } else {
                            showAlert(response.message, 'danger');
                        }
                    })
                    .fail(function() {
                        showAlert('Error ending game session', 'danger');
                    });
            }
        }

        function endGameSession() {
            if (currentSessionId) {
                endSession(currentSessionId);
                $('#sessionDetailsModal').modal('hide');
            }
        }

        function removeBinding(bindingId) {
            if (confirm('Are you sure you want to remove this binding?')) {
                $.ajax({
                    url: `/api/game/GameManagement/remove-binding/${bindingId}`,
                    type: 'DELETE'
                })
                .done(function(response) {
                    if (response.success) {
                        showAlert('Binding removed successfully', 'success');
                        loadCurrentBindings(currentSessionId);
                    } else {
                        showAlert(response.message, 'danger');
                    }
                })
                .fail(function() {
                    showAlert('Error removing binding', 'danger');
                });
            }
        }

        function showAlert(message, type) {
            const alertDiv = `
                <div class="alert alert-${type} alert-dismissible fade show" role="alert">
                    ${message}
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            `;
            $('.container-fluid').prepend(alertDiv);
            
            setTimeout(function() {
                $('.alert').fadeOut();
            }, 5000);
        }
    </script>
}
