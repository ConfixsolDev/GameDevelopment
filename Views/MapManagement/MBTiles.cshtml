@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>MBTiles Browser</title>
  <link rel="stylesheet" href="~/lib/jquery.dataTables/css/dataTables.bootstrap5.min.css" />
  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    body {
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
      background: #f3f6fb;
      padding: 24px;
    }

    .table-wrap { background:#fff; border-radius:12px; box-shadow: 0 6px 20px rgba(20, 40, 80, 0.08); padding:16px; }
    .table { width: 100%; border-collapse: separate; border-spacing: 0; }
    .table thead th { background:#f0f4fa; color:#2c3e50; font-weight:600; padding:12px 14px; border-bottom:1px solid #e6eef8; position:sticky; top:0; z-index:1; }
    .table tbody td { padding:12px 14px; border-bottom:1px solid #eef3fb; color:#364152; }
    .table tbody tr:hover { background:#f9fbff; }
    .table tbody tr:last-child td { border-bottom:none; }
    .page-title { font-size:22px; font-weight:700; color:#22314d; margin:0 0 12px 0; }
    .page-sub { color:#6b7a90; margin-bottom:18px; }

    .badge { display:inline-flex; align-items:center; gap:6px; font-size:12px; padding:4px 10px; border-radius:999px; font-weight:600; }
    .badge-default { background:#e9f7ef; color:#1e7e34; border:1px solid #d4f0e0; }
    .status-dot { width: 8px; height: 8px; display: inline-block; border-radius: 50%; }
    .dot-green { background: #22c55e; }
    .dot-gray { background: #9aa6b2; }
    .btn { display:inline-flex; align-items:center; gap:8px; padding:8px 12px; border-radius:8px; border:1px solid transparent; cursor:pointer; text-decoration:none; font-size:13px; transition:all .15s ease; }
    .btn:hover { filter:brightness(0.95); }
    .btn-primary { background:#2563eb; color:#fff; box-shadow:0 4px 10px rgba(37,99,235,.25); }
    .btn-secondary { background:#eef3fb; color:#274060; border-color:#d8e3f5; }
    .toolbar { display:flex; align-items:center; justify-content:space-between; margin-bottom:12px; }
  </style>
</head>
<body>
  <div class="container" style="padding: 12px;">
    <div class="toolbar">
        <div>
            <div class="page-title">Offline Maps</div>
            <div class="page-sub">Manage and preview your downloaded maps</div>
        </div>
        <div>
            <a href="/GamePlay/Index" class="btn btn-secondary" style="margin-right:8px;">← Back to Arena</a>
            <a href="/MapManagement/Index" class="btn btn-primary">← Download More</a>
        </div>
    </div>
    <div class="table-wrap">
    <table id="mbtilesTable" class="table table-striped" style="width:100%">
        <thead>
            <tr>
                <th>Map</th>
                <th>Street</th>
                <th>Satellite</th>
                <th>Terrain</th>
                <th>Created (UTC)</th>
                <th>Modified (UTC)</th>
                <th>Default</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody></tbody>
    </table>
    </div>
</div>

<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="~/lib/jquery.dataTables/js/dataTables.dataTables.js"></script>
<script src="~/lib/jquery.dataTables/js/dataTables.bootstrap5.min.js"></script>
<script>
(function() {
    let currentDefault = '';
    let currentDefaultSat = '';

    async function loadDefault() {
        try {
            const res = await fetch('/Map/GetConfiguration?key=DefaultMapPath');
            const json = await res.json();
            if (json && json.success && json.data && json.data.value) {
                currentDefault = json.data.value;
            } else {
                currentDefault = '';
            }
        } catch { currentDefault = ''; }
        try {
            const res2 = await fetch('/Map/GetConfiguration?key=DefaultSatelliteMapPath');
            const json2 = await res2.json();
            if (json2 && json2.success && json2.data && json2.data.value) {
                currentDefaultSat = json2.data.value;
            } else {
                currentDefaultSat = '';
            }
        } catch { currentDefaultSat = ''; }
    }

    function formatSize(bytes) {
        if (!bytes || bytes <= 0) return '-';
        return (bytes / (1024*1024)).toFixed(2) + ' MB';
    }

    function isDefaultForFolder(folderName) {
        // default path like: maps/{folder}/street.mbtiles or satellite.mbtiles
        const isStreet = typeof currentDefault === 'string' && currentDefault.indexOf(`maps/${folderName}/`) === 0;
        const isSat = typeof currentDefaultSat === 'string' && currentDefaultSat.indexOf(`maps/${folderName}/`) === 0;
        return isStreet || isSat;
    }

    async function setDefaultMap(pathStreet, pathSat) {
        const payload = {
            ConfigurationType: 'Map',
            Key: 'DefaultMapPath',
            Value: pathStreet ?? pathSat ?? '',
            Properties: null,
            Description: 'Default offline map path'
        };
        const res = await fetch('/Map/SaveConfiguration', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(payload)
        });
        const json = await res.json();
        if (!(json && json.success)) {
            alert('Failed to set default map');
            return;
        }
        // Also set satellite default if provided
        if (pathSat) {
            const payloadSat = {
                ConfigurationType: 'Map',
                Key: 'DefaultSatelliteMapPath',
                Value: pathSat,
                Properties: null,
                Description: 'Default offline satellite map path'
            };
            const resSat = await fetch('/Map/SaveConfiguration', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(payloadSat)
            });
            const jsonSat = await resSat.json();
            if (!(jsonSat && jsonSat.success)) {
                alert('Failed to set default satellite map');
            }
        }
        // Persist TileServer-GL dataset IDs derived from filenames (without extension)
        try {
            const getId = (p) => {
                if (!p) return null;
                const f = p.split('/').pop() || '';
                return f.toLowerCase().endsWith('.mbtiles') ? f.slice(0, -8) : f;
            };
            const streetId = getId(pathStreet);
            const satId = getId(pathSat);
            if (streetId) {
                await fetch('/Map/SaveConfiguration', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        ConfigurationType: 'Map',
                        Key: 'TileServerMapIdStreet',
                        Value: streetId,
                        Properties: null,
                        Description: 'TileServer-GL dataset ID for default street map'
                    })
                });
            }
            if (satId) {
                await fetch('/Map/SaveConfiguration', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        ConfigurationType: 'Map',
                        Key: 'TileServerMapIdSatellite',
                        Value: satId,
                        Properties: null,
                        Description: 'TileServer-GL dataset ID for default satellite map'
                    })
                });
            }
        } catch {}
        currentDefault = pathStreet ?? '';
        currentDefaultSat = pathSat ?? '';
        renderTable(lastFiles);
    }

    let lastFiles = [];

    function renderTable(files) {
        const tbody = document.querySelector('#mbtilesTable tbody');
        tbody.innerHTML = '';
        files.forEach(f => {
            const tr = document.createElement('tr');
            const folder = f.name;
            const streetSize = formatSize(f.street_size);
            const satelliteSize = formatSize(f.satellite_size);
            const terrainBadge = f.has_terrain
                ? `<span class="status-dot dot-green"></span>${(f.terrain_size/1024/1024).toFixed(2)} MB`
                : `<span class="status-dot dot-gray"></span>-`;
            const created = new Date(f.created).toISOString();
            const modified = new Date(f.modified).toISOString();

            const isDef = isDefaultForFolder(folder);
            const defaultCell = isDef ? `<span class="badge badge-default"><span class="status-dot dot-green"></span>Default</span>` : '';

            const streetView = f.street_path ? `<a class="btn btn-secondary" href="/MapManagement/TacticalViewer?file=${encodeURIComponent(f.street_path)}" target="_blank">View Street</a>` : '';
            const satelliteView = f.satellite_path ? `<a class="btn btn-secondary" href="/MapManagement/TacticalViewer?file=${encodeURIComponent(f.satellite_path)}" target="_blank">View Satellite</a>` : '';
            const setDefaultBtn = `<button class="btn btn-primary" data-default-street="${f.street_path ? encodeURIComponent(f.street_path) : ''}" data-default-sat="${f.satellite_path ? encodeURIComponent(f.satellite_path) : ''}" data-terrain="${f.has_terrain ? encodeURIComponent('maps/' + folder + '/terrain.db') : ''}">Set Default</button>`;

            tr.innerHTML = `
                <td>${folder}</td>
                <td>${streetSize}</td>
                <td>${satelliteSize}</td>
                <td>${terrainBadge}</td>
                <td>${created}</td>
                <td>${modified}</td>
                <td>${defaultCell}</td>
                <td>${streetView} ${satelliteView} ${setDefaultBtn}</td>
            `;
            tbody.appendChild(tr);
        });

        // bind default buttons
        tbody.querySelectorAll('button[data-default-street],button[data-default-sat]').forEach(btn => {
            btn.addEventListener('click', async (e) => {
                const street = e.currentTarget.getAttribute('data-default-street');
                const sat = e.currentTarget.getAttribute('data-default-sat');
                const terrain = e.currentTarget.getAttribute('data-terrain');
                const streetPath = street ? decodeURIComponent(street) : null;
                const satPath = sat ? decodeURIComponent(sat) : null;
                await setDefaultMap(streetPath, satPath);
                // Persist terrain default if available
                if (terrain) {
                    const terrainPath = decodeURIComponent(terrain);
                    const payloadTerrain = {
                        ConfigurationType: 'Map',
                        Key: 'DefaultTerrainDbPath',
                        Value: terrainPath,
                        Properties: null,
                        Description: 'Default offline terrain database path'
                    };
                    try {
                        await fetch('/Map/SaveConfiguration', {
                            method: 'POST',
                            headers: { 'Content-Type': 'application/json' },
                            body: JSON.stringify(payloadTerrain)
                        });
                    } catch {}
                }
            });
        });
    }

    async function init() {
        await loadDefault();
        const res = await fetch('/mbtiles/list');
        lastFiles = await res.json();
        renderTable(lastFiles);
        // Initialize DataTable offline styling
        if (window.jQuery && $('#mbtilesTable').length) {
            $('#mbtilesTable').DataTable({
                paging: true,
                pageLength: 15,
                lengthChange: false,
                order: [[0, 'asc']],
                language: { search: "Filter:", zeroRecords: "No maps found" }
            });
        }
    }

    document.addEventListener('DOMContentLoaded', init);
})();
</script>
</body>
</html>

