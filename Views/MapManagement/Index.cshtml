@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Offline Map Downloader</title>
  <link rel="shortcut icon" href="/favicon.ico">
  <link rel="stylesheet" href="https://unpkg.com/leaflet/dist/leaflet.css" />
  <link rel="stylesheet" href="https://unpkg.com/leaflet-draw/dist/leaflet.draw.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/nouislider@15.6.1/dist/nouislider.min.css" />
    <link href="~/css/pop.css" rel="stylesheet" />
</head>

<body>
  <div id="app-container">
    <div id="map"></div>
    <div id="overlay">
      <h3>Offline Map Downloader</h3>
      <div style="margin-bottom: 12px;">
        <a href="/Home/MBTiles" style="color: #66c0ff; margin-right: 12px;">📦 Browse MBTiles</a>
        <a href="/Home/LeafletBounded" style="color: #66c0ff; margin-right: 12px;">🗺️ Leaflet Viewer</a>
        <a href="/Home/Downloads" style="color: #66c0ff;">📥 Downloads</a>
      </div>
      <label for="address">Search Address or ZIP:</label>
      <input type="text" id="address" placeholder="Enter address or ZIP" />
      <button id="search-btn">Go to Location</button>

      <div><strong>Center:</strong> <span id="coords">-</span></div>
      <div><strong>Zoom:</strong> <span id="zoom">-</span></div>
      <label>Zoom Range: <span id="zoom-range-value">14 - 16</span></label>
      <div id="zoom-slider" style="margin-bottom: 10px;"></div>

      <label>Format:</label>
      <label><input type="radio" name="format" value="zip" checked> ZIP</label>
      <label><input type="radio" name="format" value="mbtiles"> MBTiles</label>
      <label>Map Style:</label>
      <select id="map-style">
        <option value="map">Map</option>
        <option value="satellite">Satellite</option>
      </select>
      <div id="prediction" style="font-size: 13px; color: #555; min-height: 20px;"></div>
      <div id="area-info" style="font-size: 13px; color: #2b7de9; font-weight: bold; min-height: 20px; margin-top: 4px;"></div>
      <canvas id="tile-preview" width="280" height="180"
        style="border-radius: 8px; margin-top: 10px; background: #f0f0f0;"></canvas>
       <div id="progress-wrap" style="display:none; margin-top:8px;">
         <div id="progress-bar" style="height:10px; background:#2b2b2b; border:1px solid #555; border-radius:6px; overflow:hidden;">
           <div id="progress-fill" style="width:0%; height:100%; background:#007acc;"></div>
         </div>
         <div id="progress-text" style="margin-top:6px; font-size:12px; color:#bbb;">0% — ETA --:--</div>
       </div>
      <button id="download">Download Tiles</button>
      <button id="validate-mbtiles" style="display:none; margin-top:8px; background:#28a745; font-weight:bold;">✓ Validate MBTiles File</button>
      <a id="download-link" href="#" style="display:none; margin-top:8px; color:#66c0ff; text-decoration:underline;" target="_blank">Download file</a>
      <div id="status"></div>
      <div id="validation-hint" style="display:none; margin-top:8px; padding:8px; background:#1a4d2e; border-radius:6px; color:#90ee90; font-size:12px;">
        💡 Click "Validate MBTiles File" to check if your file is ready for MapTiler upload
      </div>
      <div id="validation-result" style="display:none; margin-top:12px; padding:10px; background:#2b2b2b; border-radius:8px; border:1px solid #555;">
        <h4 style="margin-top:0;">MBTiles Validation Result</h4>
        <div id="validation-details"></div>
      </div>
    </div>
  </div>
  <div id="loading-modal">
    <div id="loading-content">
      <div class="spinner"></div>
      <p id="loading-status">Preparing download...</p>
    </div>
  </div>

  <script src="https://unpkg.com/leaflet/dist/leaflet.js"></script>
  <script src="https://unpkg.com/leaflet-draw/dist/leaflet.draw.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/nouislider@15.6.1/dist/nouislider.min.js"></script>
  <script>
    let currentMapStyle = "map";
    let isDownloading = false;
    let previewVersion = 0; // increments to cancel stale renders
    const MAX_PREVIEW_TILES = 400; // guard to avoid freezing the page

    function debounce(fn, delay) {
      let t;
      return (...args) => {
        clearTimeout(t);
        t = setTimeout(() => fn.apply(null, args), delay);
      };
    }

    const osmLayer = L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
      maxZoom: 19,
      attribution: '&copy; OpenStreetMap contributors'
    });

    const satelliteLayer = L.tileLayer('https://server.arcgisonline.com/ArcGIS/rest/services/World_Imagery/MapServer/tile/{z}/{y}/{x}', {
      maxZoom: 19,
      attribution: 'Tiles © Esri'
    });

    const baseMaps = {
      "Map": osmLayer,
      "Satellite": satelliteLayer
    };

    const map = L.map('map', {
      center: [37.7749, -122.4194],
      zoom: 13,
      layers: [osmLayer]
    });

    L.control.layers(baseMaps).addTo(map);
    
    const drawnItems = new L.FeatureGroup();
    map.addLayer(drawnItems);

    const drawControl = new L.Control.Draw({
      draw: {
        polygon: false,
        polyline: false,
        circle: false,
        marker: false,
        circlemarker: false,
        rectangle: true
      },
      edit: { featureGroup: drawnItems }
    });
    map.addControl(drawControl);

    let selectedBounds = null;
    map.on('draw:created', function (e) {
      drawnItems.clearLayers();
      drawnItems.addLayer(e.layer);
      selectedBounds = e.layer.getBounds();
    });

    const coordsEl = document.getElementById("coords");
    const zoomEl = document.getElementById("zoom");
    function updateInfo() {
      const center = map.getCenter();
      coordsEl.textContent = `${center.lat.toFixed(5)}, ${center.lng.toFixed(5)}`;
      zoomEl.textContent = map.getZoom();
    }
    map.on("move zoom", updateInfo);
    updateInfo();

    const zoomSlider = document.getElementById("zoom-slider");
    const zoomRangeValue = document.getElementById("zoom-range-value");
    noUiSlider.create(zoomSlider, {
      start: [14, 16],
      connect: true,
      range: { min: 10, max: 19 },
      step: 1,
      tooltips: true,
      format: {
        to: value => Math.round(value),
        from: value => Math.round(value)
      }
    });
    zoomSlider.noUiSlider.on('update', function (values) {
      zoomRangeValue.textContent = `${values[0]} - ${values[1]}`;
    });

    const updateTilePrediction = debounce(async function () {
      const predictionEl = document.getElementById("prediction");
      const areaInfoEl = document.getElementById("area-info");
      if (!selectedBounds) {
        predictionEl.textContent = "";
        areaInfoEl.textContent = "";
        return;
      }

      const [zmin, zmax] = zoomSlider.noUiSlider.get().map(v => parseInt(v));
      const zoomLevels = [];
      for (let z = zmin; z <= zmax; z++) zoomLevels.push(z);

      const data = {
        bounds: {
          north: selectedBounds.getNorth(),
          south: selectedBounds.getSouth(),
          east: selectedBounds.getEast(),
          west: selectedBounds.getWest()
        },
        zoom_levels: zoomLevels
      };

      try {
        const res = await fetch("/preview_tile_count", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify(data)
        });
        const result = await res.json();
        if (result.error) {
          predictionEl.textContent = result.error;
          predictionEl.style.color = "red";
          areaInfoEl.textContent = "";
        } else {
          predictionEl.textContent = `Estimated tile count: ${result.tile_count}`;
          predictionEl.style.color = "#555";
          
          // Display area information
          if (result.area_km2 !== undefined && result.area_mi2 !== undefined) {
            areaInfoEl.textContent = `Selected area: ${result.area_km2.toLocaleString()} km² (${result.area_mi2.toLocaleString()} mi²)`;
            areaInfoEl.style.color = "#2b7de9";
          }
        }
      } catch (err) {
        predictionEl.textContent = "Prediction failed.";
        predictionEl.style.color = "red";
        areaInfoEl.textContent = "";
      }
    }, 250);


    let lastJobId = null;
    let lastFormat = null;

    const updateTilePreview = debounce(async function () {
      const canvas = document.getElementById("tile-preview");
      const ctx = canvas.getContext("2d");
      ctx.clearRect(0, 0, canvas.width, canvas.height);

      if (!selectedBounds) return;

      const TILE_SIZE = 256;
      const TILE_MARGIN = 0;
      const zoomSlider = document.getElementById("zoom-slider");
      const zoom = parseInt(zoomSlider.noUiSlider.get()[1]);

      const [x1, y1] = deg2num(selectedBounds.getNorth(), selectedBounds.getWest(), zoom);
      const [x2, y2] = deg2num(selectedBounds.getSouth(), selectedBounds.getEast(), zoom);
      const x_min = Math.min(x1, x2) - TILE_MARGIN;
      const x_max = Math.max(x1, x2) + TILE_MARGIN;
      const y_min = Math.min(y1, y2) - TILE_MARGIN;
      const y_max = Math.max(y1, y2) + TILE_MARGIN;

      const tileCols = x_max - x_min + 1;
      const tileRows = y_max - y_min + 1;

      // Guard: disable preview for very large selections to keep the page responsive
      if (tileCols * tileRows > MAX_PREVIEW_TILES) {
        ctx.fillStyle = '#666';
        ctx.font = '12px sans-serif';
        ctx.fillText('Preview disabled for large selections', 10, 20);
        return;
      }

      const previewTileWidth = tileCols * TILE_SIZE;
      const previewTileHeight = tileRows * TILE_SIZE;

      const scale = Math.min(canvas.width / previewTileWidth, canvas.height / previewTileHeight);
      const totalWidth = previewTileWidth * scale;
      const totalHeight = previewTileHeight * scale;
      const offsetX = (canvas.width - totalWidth) / 2;
      const offsetY = (canvas.height - totalHeight) / 2;

      const thisVersion = ++previewVersion;
      for (let x = x_min; x <= x_max; x++) {
        for (let y = y_min; y <= y_max; y++) {
          const img = new Image();
          img.crossOrigin = "anonymous";
          img.onload = () => {
            if (thisVersion !== previewVersion) return; // cancelled by newer render
            const dx = offsetX + (x - x_min) * TILE_SIZE * scale;
            const dy = offsetY + (y - y_min) * TILE_SIZE * scale;
            ctx.drawImage(img, dx, dy, TILE_SIZE * scale, TILE_SIZE * scale);
          };
          img.src = currentMapStyle === "map"
            ? `https://tile.openstreetmap.org/${zoom}/${x}/${y}.png`
            : `https://server.arcgisonline.com/ArcGIS/rest/services/World_Imagery/MapServer/tile/${zoom}/${y}/${x}`;
        }
      }
    }, 150);

    function deg2num(lat, lon, zoom) {
      const latRad = lat * Math.PI / 180;
      const n = 2 ** zoom;
      const x = Math.floor((lon + 180) / 360 * n);
      const y = Math.floor((1 - Math.log(Math.tan(latRad) + 1 / Math.cos(latRad)) / Math.PI) / 2 * n);
      return [x, y];
    }

    map.on('draw:created', () => {
      updateTilePrediction();
      updateTilePreview();
    });

    map.on('baselayerchange', function (e) {
      if (e.name === "Map") {
        currentMapStyle = "map";
        styleSelector.value = "map";
      } else if (e.name === "Satellite") {
        currentMapStyle = "satellite";
        styleSelector.value = "satellite";
      }

      updateTilePreview(); 
    });

    zoomSlider.noUiSlider.on('update', () => {
      updateTilePrediction();
      updateTilePreview();
    });

    const styleSelector = document.getElementById("map-style");

    styleSelector.addEventListener("change", () => {
      const style = styleSelector.value;
      currentMapStyle = style;

      if (style === "map") {
        map.removeLayer(satelliteLayer);
        map.addLayer(osmLayer);
      } else {
        map.removeLayer(osmLayer);
        map.addLayer(satelliteLayer);
      }

      updateTilePreview();
    });

    document.getElementById("search-btn").addEventListener("click", async () => {
      const query = document.getElementById("address").value.trim();
      if (!query) return;
      try {
        const res = await fetch(`https://nominatim.openstreetmap.org/search?format=json&q=${encodeURIComponent(query)}`);
        const results = await res.json();
        if (results.length > 0) {
          const lat = parseFloat(results[0].lat);
          const lon = parseFloat(results[0].lon);
          map.setView([lat, lon], 15);
        } else {
          alert("Location not found.");
        }
      } catch (err) {
        console.error("Geocoding failed:", err);
        alert("Failed to fetch location.");
      }
    });

    window.addEventListener('beforeunload', function (e) {
      if (!isDownloading) return;
      e.preventDefault();
      e.returnValue = '';
    });

    function setLoading(active, msg) {
      const modal = document.getElementById("loading-modal");
      const loadingStatus = document.getElementById("loading-status");
      modal.style.display = active ? "flex" : "none";
      if (msg) loadingStatus.textContent = msg;
    }

    document.getElementById("download").addEventListener("click", async (evt) => {
      const statusEl = document.getElementById("status");
      const [zmin, zmax] = zoomSlider.noUiSlider.get().map(v => parseInt(v));
      const format = document.querySelector('input[name="format"]:checked').value;
      const downloadBtn = document.getElementById("download");
      if (isDownloading) return; // prevent double-clicks
      if (!selectedBounds) {
        statusEl.textContent = "Please draw a rectangle to select an area.";
        statusEl.style.color = "red";
        return;
      }
      const zoomLevels = [];

      for (let z = zmin; z <= zmax; z++) zoomLevels.push(z);
      const data = {
        bounds: {
          north: selectedBounds.getNorth(),
          south: selectedBounds.getSouth(),
          east: selectedBounds.getEast(),
          west: selectedBounds.getWest()
        },
        zoom_levels: zoomLevels,
        format: format,
        map_style: currentMapStyle
      };

      try {
        isDownloading = true;
        downloadBtn.disabled = true;
        statusEl.style.color = "#ccc";
        statusEl.textContent = "Calculating tile count...";

        const preview = await fetch("/preview_tile_count", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify(data)
        });
        const { tile_count, error } = await preview.json();
        if (error) {
          statusEl.textContent = error;
          statusEl.style.color = "red";
          isDownloading = false;
          downloadBtn.disabled = false;
          return;
        }
        setLoading(true, "Preparing download...");

        statusEl.textContent = `Starting download of ${tile_count} tiles...`;
        const job = await fetch("/download_tiles", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify(data)
        });

        const { job_id } = await job.json();
        const evtSource = new EventSource(`/progress/${job_id}`);
        const progressWrap = document.getElementById('progress-wrap');
        const progressFill = document.getElementById('progress-fill');
        const progressText = document.getElementById('progress-text');
        progressWrap.style.display = 'block';
        const startTime = Date.now();
        evtSource.onmessage = function (e) {
          const msg = e.data;

          if (msg === "error") {
            statusEl.textContent = "An error occurred.";
            statusEl.style.color = "red";
            evtSource.close();
            setLoading(false);
            isDownloading = false;
            downloadBtn.disabled = false;
            return;
          }

          if (msg === "ready") {
            evtSource.close();
            (async () => {
              try {
                statusEl.textContent = "Starting download...";
                const fileUrl = `/get_file/${job_id}`;
                // Store job ID and format for validation
                lastJobId = job_id;
                lastFormat = format;
                
                // Trigger a real browser download via a temporary anchor to avoid gesture restrictions
                const a = document.createElement('a');
                a.href = fileUrl;
                a.download = '';
                document.body.appendChild(a);
                a.click();
                a.remove();
                statusEl.textContent = "Download started.";
                // Provide a manual link as backup; prefer static path for MBTiles
                const link = document.getElementById('download-link');
                if ((typeof format !== 'undefined') && format === 'mbtiles') {
                  link.href = `/downloads/mbtiles/${job_id}.mbtiles`;
                } else {
                  link.href = fileUrl;
                }
                link.style.display = 'inline-block';
                
                // Show validate button for MBTiles
                const validateBtn = document.getElementById('validate-mbtiles');
                const validationHint = document.getElementById('validation-hint');
                console.log('Download complete. Format:', format, 'JobId:', job_id);
                if (format === 'mbtiles') {
                  validateBtn.style.display = 'inline-block';
                  validationHint.style.display = 'block';
                  console.log('Validate button shown for MBTiles');
                } else {
                  validateBtn.style.display = 'none';
                  validationHint.style.display = 'none';
                }
              } catch (e) {
                statusEl.textContent = "Failed to open download. Please click the link.";
                statusEl.style.color = 'red';
                const link = document.getElementById('download-link');
                link.href = (typeof format !== 'undefined' && format === 'mbtiles') ? `/downloads/mbtiles/${job_id}.mbtiles` : `/get_file/${job_id}`;
                link.style.display = 'inline-block';
              } finally {
                setLoading(false);
                isDownloading = false;
                downloadBtn.disabled = false;
              }
            })();
            return;
          }

          const [done, total] = msg.split(" / ").map(Number);
          const pct = total > 0 ? Math.floor((done / total) * 100) : 0;
          statusEl.textContent = `Progress: ${done} / ${total}`;
          progressFill.style.width = pct + '%';
          const elapsedSec = (Date.now() - startTime) / 1000;
          const rate = done > 0 ? done / elapsedSec : 0; // tiles/sec
          const remaining = Math.max(total - done, 0);
          const etaSec = rate > 0 ? Math.ceil(remaining / rate) : 0;
          const mm = String(Math.floor(etaSec / 60)).padStart(2, '0');
          const ss = String(etaSec % 60).padStart(2, '0');
          progressText.textContent = `${pct}% — ETA ${mm}:${ss}`;
          document.getElementById("loading-status").textContent = `Downloading: ${done} / ${total}`;

          // Do not close here; wait for explicit 'ready' signal from server

        };

        evtSource.onerror = function () {
          statusEl.textContent = "Connection lost. Please try again.";
          statusEl.style.color = "red";
          evtSource.close();
          setLoading(false);
          isDownloading = false;
          downloadBtn.disabled = false;
        };
      } catch (err) {
        console.error(err);
        statusEl.textContent = "Download failed.";
        statusEl.style.color = "red";
        setLoading(false);
        isDownloading = false;
        const downloadBtn = document.getElementById("download");
        downloadBtn.disabled = false;
      }
    });

    // Validate MBTiles button handler
    document.getElementById("validate-mbtiles").addEventListener("click", async () => {
      const validateBtn = document.getElementById("validate-mbtiles");
      const validationResult = document.getElementById("validation-result");
      const validationDetails = document.getElementById("validation-details");
      
      console.log('Validate button clicked. LastJobId:', lastJobId, 'LastFormat:', lastFormat);
      
      if (!lastJobId || lastFormat !== 'mbtiles') {
        alert("No MBTiles file available to validate");
        return;
      }

      validateBtn.disabled = true;
      validateBtn.textContent = "Validating...";
      validationResult.style.display = "none";

      try {
        console.log('Calling validation API:', `/validate_mbtiles/${lastJobId}`);
        const response = await fetch(`/validate_mbtiles/${lastJobId}`);
        console.log('Response status:', response.status, response.statusText);
        
        if (!response.ok) {
          throw new Error(`HTTP ${response.status}: ${response.statusText}`);
        }
        
        const result = await response.json();
        console.log('Validation result:', result);
        
        let html = `<div style="font-size:13px;">`;
        html += `<div style="margin-bottom:8px;"><strong>File Size:</strong> ${(result.file_size / 1024 / 1024).toFixed(2)} MB</div>`;
        html += `<div style="margin-bottom:8px;"><strong>Tile Count:</strong> ${result.tile_count?.toLocaleString() || 'N/A'}</div>`;
        html += `<div style="margin-bottom:8px;"><strong>MapTiler Ready:</strong> <span style="color:${result.maptiler_ready ? '#28a745' : '#dc3545'}; font-weight:bold;">${result.maptiler_ready ? 'YES ✓' : 'NO ✗'}</span></div>`;
        
        if (result.issues && result.issues.length > 0) {
          html += `<div style="margin-top:12px;"><strong style="color:#dc3545;">Issues Found:</strong></div>`;
          html += `<ul style="margin:4px 0; padding-left:20px; color:#dc3545;">`;
          result.issues.forEach(issue => {
            html += `<li>${issue}</li>`;
          });
          html += `</ul>`;
        }
        
        if (result.metadata && Object.keys(result.metadata).length > 0) {
          html += `<div style="margin-top:12px;"><strong>Metadata:</strong></div>`;
          html += `<div style="font-size:11px; margin-top:4px; max-height:150px; overflow-y:auto; background:#1a1a1a; padding:8px; border-radius:4px;">`;
          Object.entries(result.metadata).forEach(([key, value]) => {
            if (key !== 'json') { // Skip the JSON field as it's verbose
              html += `<div style="margin:2px 0;"><span style="color:#66c0ff;">${key}:</span> ${value.length > 100 ? value.substring(0, 100) + '...' : value}</div>`;
            }
          });
          html += `</div>`;
        }
        
        html += `<div style="margin-top:12px; padding:8px; background:${result.maptiler_ready ? '#1a4d2e' : '#4d1a1a'}; border-radius:4px; color:${result.maptiler_ready ? '#90ee90' : '#ffcccb'};">${result.message}</div>`;
        html += `</div>`;
        
        validationDetails.innerHTML = html;
        validationResult.style.display = "block";
      } catch (error) {
        console.error('Validation error:', error);
        validationDetails.innerHTML = `<div style="color:#dc3545; font-size:13px;">
          <strong>Validation failed:</strong><br>
          ${error.message}<br><br>
          <small>Check the browser console (F12) for more details.</small>
        </div>`;
        validationResult.style.display = "block";
      } finally {
        validateBtn.disabled = false;
        validateBtn.textContent = "Validate MBTiles";
      }
    });
  </script>
</body>

</html>