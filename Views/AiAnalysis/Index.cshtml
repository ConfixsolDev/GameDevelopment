@{
    ViewData["Title"] = "AI Analysis Dashboard";
}

<div class="ai-analysis-container">
    <div class="ai-header">
        <h1>NATO AI Analysis Dashboard</h1>
        <p>Intelligent analysis and decision support for military operations</p>
    </div>

    <div class="ai-controls">
        <div class="analysis-panel">
            <h3>Analysis Configuration</h3>
            
            <div class="control-group">
                <label for="analysisType">Analysis Type:</label>
                <select id="analysisType" class="form-control">
                    <option value="tactical">Tactical Analysis</option>
                    <option value="operational">Operational Analysis</option>
                    <option value="strategic">Strategic Analysis</option>
                    <option value="comprehensive">Comprehensive Analysis</option>
                </select>
            </div>
            
            <div class="control-group">
                <label for="analysisScope">Analysis Scope:</label>
                <select id="analysisScope" class="form-control">
                    <option value="tactical">Tactical</option>
                    <option value="operational">Operational</option>
                    <option value="strategic">Strategic</option>
                </select>
            </div>
            
            <div class="control-group">
                <label for="timeframe">Timeframe:</label>
                <select id="timeframe" class="form-control">
                    <option value="immediate">Immediate (0-24 hours)</option>
                    <option value="shortTerm">Short Term (1-7 days)</option>
                    <option value="mediumTerm">Medium Term (1-4 weeks)</option>
                    <option value="longTerm">Long Term (1-12 months)</option>
                </select>
            </div>
            
            <div class="control-group">
                <label for="priority">Priority Level:</label>
                <select id="priority" class="form-control">
                    <option value="low">Low</option>
                    <option value="medium" selected>Medium</option>
                    <option value="high">High</option>
                    <option value="critical">Critical</option>
                </select>
            </div>
            
            <div class="control-group">
                <label for="objectives">Objectives:</label>
                <textarea id="objectives" class="form-control" rows="3" placeholder="Enter analysis objectives..."></textarea>
            </div>
            
            <div class="control-group">
                <label for="constraints">Constraints:</label>
                <textarea id="constraints" class="form-control" rows="3" placeholder="Enter operational constraints..."></textarea>
            </div>
            
            <div class="control-buttons">
                <button id="btnStartAnalysis" class="btn btn-primary">
                    <i class="fas fa-brain"></i> Start AI Analysis
                </button>
                <button id="btnClearAnalysis" class="btn btn-secondary">
                    <i class="fas fa-trash"></i> Clear Analysis
                </button>
            </div>
        </div>
        
        <div class="data-panel">
            <h3>Input Data</h3>
            
            <div class="data-section">
                <h4>Forces</h4>
                <div class="data-input">
                    <button id="btnAddForce" class="btn btn-sm btn-info">
                        <i class="fas fa-plus"></i> Add Force
                    </button>
                </div>
                <div class="forces-list" id="forcesList">
                    <!-- Forces will be loaded here -->
                </div>
            </div>
            
            <div class="data-section">
                <h4>Threats</h4>
                <div class="data-input">
                    <button id="btnAddThreat" class="btn btn-sm btn-warning">
                        <i class="fas fa-plus"></i> Add Threat
                    </button>
                </div>
                <div class="threats-list" id="threatsList">
                    <!-- Threats will be loaded here -->
                </div>
            </div>
            
            <div class="data-section">
                <h4>Opportunities</h4>
                <div class="data-input">
                    <button id="btnAddOpportunity" class="btn btn-sm btn-success">
                        <i class="fas fa-plus"></i> Add Opportunity
                    </button>
                </div>
                <div class="opportunities-list" id="opportunitiesList">
                    <!-- Opportunities will be loaded here -->
                </div>
            </div>
            
            <div class="data-section">
                <h4>Terrain</h4>
                <div class="terrain-input">
                    <label for="terrainType">Terrain Type:</label>
                    <select id="terrainType" class="form-control">
                        <option value="open">Open</option>
                        <option value="urban">Urban</option>
                        <option value="forest">Forest</option>
                        <option value="hills">Hills</option>
                        <option value="swamp">Swamp</option>
                        <option value="desert">Desert</option>
                        <option value="mountain">Mountain</option>
                        <option value="water">Water</option>
                    </select>
                </div>
            </div>
        </div>
    </div>

    <div class="ai-results" id="aiResults" style="display: none;">
        <div class="results-header">
            <h3>AI Analysis Results</h3>
            <div class="results-controls">
                <button id="btnExportAnalysis" class="btn btn-success">
                    <i class="fas fa-download"></i> Export Analysis
                </button>
                <button id="btnGenerateReport" class="btn btn-info">
                    <i class="fas fa-file-alt"></i> Generate Report
                </button>
            </div>
        </div>
        
        <div class="results-content">
            <div class="analysis-summary" id="analysisSummary">
                <!-- Analysis summary will be loaded here -->
            </div>
            
            <div class="recommendations" id="recommendations">
                <!-- Recommendations will be loaded here -->
            </div>
            
            <div class="risk-assessment" id="riskAssessment">
                <!-- Risk assessment will be loaded here -->
            </div>
            
            <div class="decision-support" id="decisionSupport">
                <!-- Decision support will be loaded here -->
            </div>
        </div>
    </div>

    <div class="ai-history">
        <h3>Analysis History</h3>
        <div class="history-list" id="historyList">
            <!-- Analysis history will be loaded here -->
        </div>
    </div>
</div>

<!-- Add Force Modal -->
<div class="modal fade" id="addForceModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Add Force</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <form id="forceForm">
                    <div class="form-group">
                        <label for="forceName">Force Name:</label>
                        <input type="text" id="forceName" class="form-control" required />
                    </div>
                    
                    <div class="form-group">
                        <label for="forceType">Force Type:</label>
                        <select id="forceType" class="form-control" required>
                            <option value="Infantry">Infantry</option>
                            <option value="Armoured">Armoured</option>
                            <option value="Artillery">Artillery</option>
                            <option value="Engineers">Engineers</option>
                            <option value="Signals">Signals</option>
                            <option value="Medical">Medical</option>
                        </select>
                    </div>
                    
                    <div class="form-group">
                        <label for="forceStrength">Strength:</label>
                        <input type="number" id="forceStrength" class="form-control" value="100" min="1" max="1000" />
                    </div>
                    
                    <div class="form-group">
                        <label for="forceMorale">Morale:</label>
                        <select id="forceMorale" class="form-control">
                            <option value="high">High</option>
                            <option value="average" selected>Average</option>
                            <option value="low">Low</option>
                            <option value="broken">Broken</option>
                        </select>
                    </div>
                    
                    <div class="form-group">
                        <label for="forceTraining">Training:</label>
                        <select id="forceTraining" class="form-control">
                            <option value="elite">Elite</option>
                            <option value="regular" selected>Regular</option>
                            <option value="reserve">Reserve</option>
                            <option value="militia">Militia</option>
                        </select>
                    </div>
                    
                    <div class="form-group">
                        <label for="forceSupply">Supply:</label>
                        <select id="forceSupply" class="form-control">
                            <option value="abundant">Abundant</option>
                            <option value="adequate" selected>Adequate</option>
                            <option value="limited">Limited</option>
                            <option value="critical">Critical</option>
                        </select>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-primary" id="btnSaveForce">Add Force</button>
            </div>
        </div>
    </div>
</div>

<!-- Add Threat Modal -->
<div class="modal fade" id="addThreatModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Add Threat</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <form id="threatForm">
                    <div class="form-group">
                        <label for="threatName">Threat Name:</label>
                        <input type="text" id="threatName" class="form-control" required />
                    </div>
                    
                    <div class="form-group">
                        <label for="threatType">Threat Type:</label>
                        <select id="threatType" class="form-control" required>
                            <option value="military">Military</option>
                            <option value="insurgent">Insurgent</option>
                            <option value="terrorist">Terrorist</option>
                            <option value="criminal">Criminal</option>
                            <option value="natural">Natural</option>
                        </select>
                    </div>
                    
                    <div class="form-group">
                        <label for="threatLevel">Threat Level:</label>
                        <select id="threatLevel" class="form-control">
                            <option value="low">Low</option>
                            <option value="moderate" selected>Moderate</option>
                            <option value="high">High</option>
                            <option value="critical">Critical</option>
                        </select>
                    </div>
                    
                    <div class="form-group">
                        <label for="threatCapability">Capability:</label>
                        <select id="threatCapability" class="form-control">
                            <option value="low">Low</option>
                            <option value="moderate" selected>Moderate</option>
                            <option value="high">High</option>
                            <option value="very_high">Very High</option>
                        </select>
                    </div>
                    
                    <div class="form-group">
                        <label for="threatIntention">Intention:</label>
                        <select id="threatIntention" class="form-control">
                            <option value="aggressive">Aggressive</option>
                            <option value="defensive" selected>Defensive</option>
                            <option value="neutral">Neutral</option>
                            <option value="unknown">Unknown</option>
                        </select>
                    </div>
                    
                    <div class="form-group">
                        <label for="threatDescription">Description:</label>
                        <textarea id="threatDescription" class="form-control" rows="3" placeholder="Enter threat description..."></textarea>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-primary" id="btnSaveThreat">Add Threat</button>
            </div>
        </div>
    </div>
</div>

<!-- Add Opportunity Modal -->
<div class="modal fade" id="addOpportunityModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Add Opportunity</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <form id="opportunityForm">
                    <div class="form-group">
                        <label for="opportunityName">Opportunity Name:</label>
                        <input type="text" id="opportunityName" class="form-control" required />
                    </div>
                    
                    <div class="form-group">
                        <label for="opportunityType">Opportunity Type:</label>
                        <select id="opportunityType" class="form-control" required>
                            <option value="tactical">Tactical</option>
                            <option value="operational">Operational</option>
                            <option value="strategic">Strategic</option>
                            <option value="logistical">Logistical</option>
                            <option value="intelligence">Intelligence</option>
                        </select>
                    </div>
                    
                    <div class="form-group">
                        <label for="opportunityValue">Value:</label>
                        <select id="opportunityValue" class="form-control">
                            <option value="low">Low</option>
                            <option value="moderate" selected>Moderate</option>
                            <option value="high">High</option>
                            <option value="critical">Critical</option>
                        </select>
                    </div>
                    
                    <div class="form-group">
                        <label for="opportunityRisk">Risk:</label>
                        <select id="opportunityRisk" class="form-control">
                            <option value="low">Low</option>
                            <option value="moderate" selected>Moderate</option>
                            <option value="high">High</option>
                            <option value="critical">Critical</option>
                        </select>
                    </div>
                    
                    <div class="form-group">
                        <label for="opportunityTiming">Timing:</label>
                        <select id="opportunityTiming" class="form-control">
                            <option value="immediate">Immediate</option>
                            <option value="shortTerm" selected>Short Term</option>
                            <option value="mediumTerm">Medium Term</option>
                            <option value="longTerm">Long Term</option>
                        </select>
                    </div>
                    
                    <div class="form-group">
                        <label for="opportunityDescription">Description:</label>
                        <textarea id="opportunityDescription" class="form-control" rows="3" placeholder="Enter opportunity description..."></textarea>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-primary" id="btnSaveOpportunity">Add Opportunity</button>
            </div>
        </div>
    </div>
</div>

<!-- AI Report Modal -->
<div class="modal fade" id="aiReportModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">NATO AI Analysis Report</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div id="aiReportContent">
                    <!-- AI report content will be loaded here -->
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                <button type="button" class="btn btn-primary" id="btnExportReport">Export Report</button>
            </div>
        </div>
    </div>
</div>

<style>
.ai-analysis-container {
    padding: 20px;
    max-width: 1400px;
    margin: 0 auto;
}

.ai-header {
    text-align: center;
    margin-bottom: 30px;
}

.ai-header h1 {
    color: #2c3e50;
    margin-bottom: 10px;
}

.ai-header p {
    color: #7f8c8d;
    font-size: 1.1em;
}

.ai-controls {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20px;
    margin-bottom: 30px;
}

.analysis-panel, .data-panel {
    background: #f8f9fa;
    padding: 20px;
    border-radius: 8px;
    border: 1px solid #dee2e6;
}

.analysis-panel h3, .data-panel h3 {
    color: #2c3e50;
    margin-bottom: 20px;
    border-bottom: 2px solid #3498db;
    padding-bottom: 10px;
}

.control-group {
    margin-bottom: 15px;
}

.control-group label {
    display: block;
    margin-bottom: 5px;
    font-weight: 600;
    color: #2c3e50;
}

.control-buttons {
    display: flex;
    gap: 10px;
    margin-top: 20px;
}

.control-buttons .btn {
    flex: 1;
}

.data-section {
    margin-bottom: 20px;
    padding: 15px;
    background: white;
    border-radius: 5px;
    border: 1px solid #dee2e6;
}

.data-section h4 {
    color: #2c3e50;
    margin-bottom: 15px;
}

.data-input {
    margin-bottom: 15px;
}

.forces-list, .threats-list, .opportunities-list {
    max-height: 200px;
    overflow-y: auto;
}

.data-item {
    background: #f8f9fa;
    padding: 10px;
    margin-bottom: 10px;
    border-radius: 5px;
    border: 1px solid #dee2e6;
    display: flex;
    justify-content: space-between;
    align-items: center;
}

.data-item-info {
    flex: 1;
}

.data-item-name {
    font-weight: 600;
    color: #2c3e50;
}

.data-item-details {
    font-size: 0.9em;
    color: #7f8c8d;
}

.data-item-actions {
    display: flex;
    gap: 5px;
}

.terrain-input {
    margin-top: 15px;
}

.ai-results {
    background: #f8f9fa;
    padding: 20px;
    border-radius: 8px;
    border: 1px solid #dee2e6;
    margin-bottom: 30px;
}

.results-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 20px;
}

.results-controls {
    display: flex;
    gap: 10px;
}

.results-content {
    background: white;
    padding: 20px;
    border-radius: 5px;
    border: 1px solid #dee2e6;
}

.analysis-summary, .recommendations, .risk-assessment, .decision-support {
    margin-bottom: 30px;
    padding: 20px;
    background: #f8f9fa;
    border-radius: 5px;
    border: 1px solid #dee2e6;
}

.analysis-summary h4, .recommendations h4, .risk-assessment h4, .decision-support h4 {
    color: #2c3e50;
    margin-bottom: 15px;
    border-bottom: 1px solid #dee2e6;
    padding-bottom: 10px;
}

.summary-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 15px;
}

.summary-item {
    background: white;
    padding: 15px;
    border-radius: 5px;
    border: 1px solid #dee2e6;
}

.summary-item h5 {
    color: #2c3e50;
    margin-bottom: 10px;
}

.summary-value {
    font-size: 1.2em;
    font-weight: 600;
    color: #3498db;
}

.recommendations-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 15px;
}

.recommendation-item {
    background: white;
    padding: 15px;
    border-radius: 5px;
    border: 1px solid #dee2e6;
}

.recommendation-item h5 {
    color: #2c3e50;
    margin-bottom: 10px;
}

.recommendation-priority {
    display: inline-block;
    padding: 4px 8px;
    border-radius: 4px;
    font-size: 0.8em;
    font-weight: 600;
    margin-bottom: 10px;
}

.recommendation-priority.high {
    background: #e74c3c;
    color: white;
}

.recommendation-priority.medium {
    background: #f39c12;
    color: white;
}

.recommendation-priority.low {
    background: #27ae60;
    color: white;
}

.risk-matrix {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 15px;
}

.risk-item {
    background: white;
    padding: 15px;
    border-radius: 5px;
    border: 1px solid #dee2e6;
    text-align: center;
}

.risk-item h5 {
    color: #2c3e50;
    margin-bottom: 10px;
}

.risk-level {
    font-size: 1.2em;
    font-weight: 600;
    padding: 5px 10px;
    border-radius: 4px;
}

.risk-level.low {
    background: #27ae60;
    color: white;
}

.risk-level.moderate {
    background: #f39c12;
    color: white;
}

.risk-level.high {
    background: #e74c3c;
    color: white;
}

.decision-options {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 15px;
}

.decision-item {
    background: white;
    padding: 15px;
    border-radius: 5px;
    border: 1px solid #dee2e6;
}

.decision-item h5 {
    color: #2c3e50;
    margin-bottom: 10px;
}

.decision-score {
    font-size: 1.5em;
    font-weight: 600;
    color: #3498db;
    text-align: center;
    margin: 10px 0;
}

.ai-history {
    background: #f8f9fa;
    padding: 20px;
    border-radius: 8px;
    border: 1px solid #dee2e6;
}

.history-list {
    max-height: 400px;
    overflow-y: auto;
}

.history-item {
    background: white;
    padding: 15px;
    margin-bottom: 10px;
    border-radius: 5px;
    border: 1px solid #dee2e6;
    display: flex;
    justify-content: space-between;
    align-items: center;
}

.history-info {
    flex: 1;
}

.history-name {
    font-weight: 600;
    color: #2c3e50;
}

.history-details {
    font-size: 0.9em;
    color: #7f8c8d;
}

.history-actions {
    display: flex;
    gap: 10px;
}

.btn {
    padding: 8px 16px;
    border: none;
    border-radius: 4px;
    cursor: pointer;
    font-size: 0.9em;
    transition: all 0.3s ease;
}

.btn-primary {
    background: #007bff;
    color: white;
}

.btn-primary:hover {
    background: #0056b3;
}

.btn-secondary {
    background: #6c757d;
    color: white;
}

.btn-secondary:hover {
    background: #545b62;
}

.btn-info {
    background: #17a2b8;
    color: white;
}

.btn-info:hover {
    background: #138496;
}

.btn-success {
    background: #28a745;
    color: white;
}

.btn-success:hover {
    background: #218838;
}

.btn-warning {
    background: #ffc107;
    color: #212529;
}

.btn-warning:hover {
    background: #e0a800;
}

.btn-sm {
    padding: 4px 8px;
    font-size: 0.8em;
}

.form-control {
    width: 100%;
    padding: 8px 12px;
    border: 1px solid #ced4da;
    border-radius: 4px;
    font-size: 0.9em;
}

.form-control:focus {
    outline: none;
    border-color: #007bff;
    box-shadow: 0 0 0 2px rgba(0, 123, 255, 0.25);
}

.form-group {
    margin-bottom: 15px;
}

.form-group label {
    display: block;
    margin-bottom: 5px;
    font-weight: 600;
    color: #2c3e50;
}

.modal {
    display: none;
    position: fixed;
    z-index: 1000;
    left: 0;
    top: 0;
    width: 100%;
    height: 100%;
    background-color: rgba(0, 0, 0, 0.5);
}

.modal.show {
    display: flex;
    align-items: center;
    justify-content: center;
}

.modal-dialog {
    background: white;
    border-radius: 8px;
    max-width: 500px;
    width: 90%;
    max-height: 90vh;
    overflow-y: auto;
}

.modal-lg {
    max-width: 800px;
}

.modal-header {
    padding: 20px;
    border-bottom: 1px solid #dee2e6;
    display: flex;
    justify-content: space-between;
    align-items: center;
}

.modal-title {
    margin: 0;
    color: #2c3e50;
}

.btn-close {
    background: none;
    border: none;
    font-size: 1.5em;
    cursor: pointer;
    color: #7f8c8d;
}

.btn-close:hover {
    color: #2c3e50;
}

.modal-body {
    padding: 20px;
}

.modal-footer {
    padding: 20px;
    border-top: 1px solid #dee2e6;
    display: flex;
    justify-content: flex-end;
    gap: 10px;
}

.report-section {
    margin-bottom: 20px;
    padding: 15px;
    background: #f8f9fa;
    border-radius: 5px;
    border: 1px solid #dee2e6;
}

.report-section h4 {
    color: #2c3e50;
    margin-bottom: 10px;
}

.report-content {
    color: #495057;
    line-height: 1.6;
}

.report-list {
    list-style: none;
    padding: 0;
}

.report-list li {
    padding: 5px 0;
    border-bottom: 1px solid #dee2e6;
}

.report-list li:last-child {
    border-bottom: none;
}

@@media (max-width: 768px) {
    .ai-controls {
        grid-template-columns: 1fr;
    }
    
    .summary-grid {
        grid-template-columns: 1fr;
    }
    
    .recommendations-grid {
        grid-template-columns: 1fr;
    }
    
    .risk-matrix {
        grid-template-columns: 1fr;
    }
    
    .decision-options {
        grid-template-columns: 1fr;
    }
    
    .control-buttons {
        flex-direction: column;
    }
}
</style>

<script>
// AI Analysis Manager
class AiAnalysisManager {
    constructor() {
        this.currentAnalysis = null;
        this.analysisHistory = [];
        this.forces = [];
        this.threats = [];
        this.opportunities = [];
        
        this.initializeEventListeners();
        this.loadAnalysisHistory();
    }

    initializeEventListeners() {
        // Analysis buttons
        document.getElementById('btnStartAnalysis').addEventListener('click', () => this.startAnalysis());
        document.getElementById('btnClearAnalysis').addEventListener('click', () => this.clearAnalysis());
        
        // Data management buttons
        document.getElementById('btnAddForce').addEventListener('click', () => this.showAddForceModal());
        document.getElementById('btnAddThreat').addEventListener('click', () => this.showAddThreatModal());
        document.getElementById('btnAddOpportunity').addEventListener('click', () => this.showAddOpportunityModal());
        
        // Save buttons
        document.getElementById('btnSaveForce').addEventListener('click', () => this.saveForce());
        document.getElementById('btnSaveThreat').addEventListener('click', () => this.saveThreat());
        document.getElementById('btnSaveOpportunity').addEventListener('click', () => this.saveOpportunity());
        
        // Results buttons
        document.getElementById('btnExportAnalysis').addEventListener('click', () => this.exportAnalysis());
        document.getElementById('btnGenerateReport').addEventListener('click', () => this.generateReport());
        document.getElementById('btnExportReport').addEventListener('click', () => this.exportReport());
    }

    async startAnalysis() {
        try {
            const analysisRequest = this.getAnalysisRequest();
            
            if (!window.natoAiAnalysisEngine) {
                alert('AI Analysis Engine not available. Please ensure the system is properly loaded.');
                return;
            }
            
            console.log('🤖 Starting AI analysis:', analysisRequest);
            
            // Show loading state
            this.showLoadingState();
            
            // Perform AI analysis
            const analysis = await window.natoAiAnalysisEngine.performAnalysis(analysisRequest);
            
            this.currentAnalysis = analysis;
            this.displayAnalysisResults(analysis);
            this.addToHistory(analysis);
            
            console.log('✅ AI analysis complete:', analysis);
        } catch (error) {
            console.error('❌ Error performing AI analysis:', error);
            alert('Failed to perform AI analysis: ' + error.message);
        }
    }

    getAnalysisRequest() {
        return {
            type: document.getElementById('analysisType').value,
            scope: document.getElementById('analysisScope').value,
            timeframe: document.getElementById('timeframe').value,
            priority: document.getElementById('priority').value,
            objectives: document.getElementById('objectives').value,
            constraints: document.getElementById('constraints').value,
            resources: {
                forces: this.forces
            },
            threats: this.threats,
            opportunities: this.opportunities,
            terrain: {
                type: document.getElementById('terrainType').value
            }
        };
    }

    showLoadingState() {
        const resultsElement = document.getElementById('aiResults');
        resultsElement.style.display = 'block';
        
        const summaryElement = document.getElementById('analysisSummary');
        summaryElement.innerHTML = `
            <h4>AI Analysis in Progress</h4>
            <div style="text-align: center; padding: 40px;">
                <div class="spinner" style="border: 4px solid #f3f3f3; border-top: 4px solid #3498db; border-radius: 50%; width: 40px; height: 40px; animation: spin 2s linear infinite; margin: 0 auto;"></div>
                <p style="margin-top: 20px; color: #7f8c8d;">Performing NATO-compliant AI analysis...</p>
            </div>
        `;
        
        // Hide other sections
        document.getElementById('recommendations').style.display = 'none';
        document.getElementById('riskAssessment').style.display = 'none';
        document.getElementById('decisionSupport').style.display = 'none';
    }

    displayAnalysisResults(analysis) {
        // Display analysis summary
        this.displayAnalysisSummary(analysis);
        
        // Display recommendations
        this.displayRecommendations(analysis.recommendations);
        
        // Display risk assessment
        this.displayRiskAssessment(analysis.riskAssessment);
        
        // Display decision support
        this.displayDecisionSupport(analysis.decisionSupport);
    }

    displayAnalysisSummary(analysis) {
        const element = document.getElementById('analysisSummary');
        
        element.innerHTML = `
            <h4>Analysis Summary</h4>
            <div class="summary-grid">
                <div class="summary-item">
                    <h5>Analysis ID</h5>
                    <div class="summary-value">${analysis.analysisId}</div>
                </div>
                <div class="summary-item">
                    <h5>Analysis Type</h5>
                    <div class="summary-value">${analysis.context.type}</div>
                </div>
                <div class="summary-item">
                    <h5>Analysis Scope</h5>
                    <div class="summary-value">${analysis.context.scope}</div>
                </div>
                <div class="summary-item">
                    <h5>Timeframe</h5>
                    <div class="summary-value">${analysis.context.timeframe}</div>
                </div>
                <div class="summary-item">
                    <h5>Confidence</h5>
                    <div class="summary-value">${(analysis.confidence * 100).toFixed(1)}%</div>
                </div>
                <div class="summary-item">
                    <h5>Duration</h5>
                    <div class="summary-value">${analysis.duration}ms</div>
                </div>
            </div>
        `;
    }

    displayRecommendations(recommendations) {
        const element = document.getElementById('recommendations');
        element.style.display = 'block';
        
        element.innerHTML = `
            <h4>AI Recommendations</h4>
            <div class="recommendations-grid">
                ${recommendations.immediate.map(rec => `
                    <div class="recommendation-item">
                        <div class="recommendation-priority high">Immediate</div>
                        <h5>${rec.recommendation}</h5>
                        <p>${rec.rationale}</p>
                    </div>
                `).join('')}
                ${recommendations.shortTerm.map(rec => `
                    <div class="recommendation-item">
                        <div class="recommendation-priority medium">Short Term</div>
                        <h5>${rec.recommendation}</h5>
                        <p>${rec.rationale}</p>
                    </div>
                `).join('')}
                ${recommendations.longTerm.map(rec => `
                    <div class="recommendation-item">
                        <div class="recommendation-priority low">Long Term</div>
                        <h5>${rec.recommendation}</h5>
                        <p>${rec.rationale}</p>
                    </div>
                `).join('')}
            </div>
        `;
    }

    displayRiskAssessment(riskAssessment) {
        const element = document.getElementById('riskAssessment');
        element.style.display = 'block';
        
        element.innerHTML = `
            <h4>Risk Assessment</h4>
            <div class="risk-matrix">
                <div class="risk-item">
                    <h5>Overall Risk Level</h5>
                    <div class="risk-level ${riskAssessment.overallRiskLevel}">${riskAssessment.overallRiskLevel}</div>
                </div>
                <div class="risk-item">
                    <h5>Threat Assessment</h5>
                    <div class="summary-value">${riskAssessment.threatAssessment ? 'Completed' : 'Pending'}</div>
                </div>
                <div class="risk-item">
                    <h5>Vulnerability Assessment</h5>
                    <div class="summary-value">${riskAssessment.vulnerabilityAssessment ? 'Completed' : 'Pending'}</div>
                </div>
                <div class="risk-item">
                    <h5>Impact Assessment</h5>
                    <div class="summary-value">${riskAssessment.impactAssessment ? 'Completed' : 'Pending'}</div>
                </div>
            </div>
        `;
    }

    displayDecisionSupport(decisionSupport) {
        const element = document.getElementById('decisionSupport');
        element.style.display = 'block';
        
        element.innerHTML = `
            <h4>Decision Support</h4>
            <div class="decision-options">
                <div class="decision-item">
                    <h5>Recommended Action</h5>
                    <div class="decision-score">${decisionSupport.recommendedAction}</div>
                    <p>Based on AI analysis of available options and constraints</p>
                </div>
                <div class="decision-item">
                    <h5>Decision Options</h5>
                    <div class="summary-value">${decisionSupport.decisionOptions ? decisionSupport.decisionOptions.length : 0}</div>
                    <p>Options generated and analyzed</p>
                </div>
                <div class="decision-item">
                    <h5>Decision Criteria</h5>
                    <div class="summary-value">${decisionSupport.decisionCriteria ? 'Established' : 'Pending'}</div>
                    <p>Criteria for decision validation</p>
                </div>
            </div>
        `;
    }

    clearAnalysis() {
        document.getElementById('aiResults').style.display = 'none';
        this.currentAnalysis = null;
        console.log('🤖 AI analysis cleared');
    }

    showAddForceModal() {
        const modal = document.getElementById('addForceModal');
        modal.style.display = 'flex';
    }

    hideAddForceModal() {
        const modal = document.getElementById('addForceModal');
        modal.style.display = 'none';
        document.getElementById('forceForm').reset();
    }

    saveForce() {
        const force = {
            id: Date.now(),
            name: document.getElementById('forceName').value,
            unitType: document.getElementById('forceType').value,
            strength: parseInt(document.getElementById('forceStrength').value),
            morale: document.getElementById('forceMorale').value,
            training: document.getElementById('forceTraining').value,
            supply: document.getElementById('forceSupply').value
        };
        
        this.forces.push(force);
        this.updateForcesList();
        this.hideAddForceModal();
        
        console.log('✅ Force added:', force);
    }

    updateForcesList() {
        const list = document.getElementById('forcesList');
        list.innerHTML = '';
        
        this.forces.forEach((force, index) => {
            const item = document.createElement('div');
            item.className = 'data-item';
            item.innerHTML = `
                <div class="data-item-info">
                    <div class="data-item-name">${force.name}</div>
                    <div class="data-item-details">
                        ${force.unitType} • Strength: ${force.strength} • Morale: ${force.morale}
                    </div>
                </div>
                <div class="data-item-actions">
                    <button class="btn btn-sm btn-warning" onclick="aiAnalysisManager.editForce(${index})">
                        <i class="fas fa-edit"></i>
                    </button>
                    <button class="btn btn-sm btn-danger" onclick="aiAnalysisManager.removeForce(${index})">
                        <i class="fas fa-trash"></i>
                    </button>
                </div>
            `;
            list.appendChild(item);
        });
    }

    removeForce(index) {
        if (confirm('Are you sure you want to remove this force?')) {
            this.forces.splice(index, 1);
            this.updateForcesList();
            console.log('✅ Force removed at index:', index);
        }
    }

    editForce(index) {
        console.log('✏️ Editing force at index:', index);
    }

    showAddThreatModal() {
        const modal = document.getElementById('addThreatModal');
        modal.style.display = 'flex';
    }

    hideAddThreatModal() {
        const modal = document.getElementById('addThreatModal');
        modal.style.display = 'none';
        document.getElementById('threatForm').reset();
    }

    saveThreat() {
        const threat = {
            id: Date.now(),
            name: document.getElementById('threatName').value,
            type: document.getElementById('threatType').value,
            level: document.getElementById('threatLevel').value,
            capability: document.getElementById('threatCapability').value,
            intention: document.getElementById('threatIntention').value,
            description: document.getElementById('threatDescription').value
        };
        
        this.threats.push(threat);
        this.updateThreatsList();
        this.hideAddThreatModal();
        
        console.log('✅ Threat added:', threat);
    }

    updateThreatsList() {
        const list = document.getElementById('threatsList');
        list.innerHTML = '';
        
        this.threats.forEach((threat, index) => {
            const item = document.createElement('div');
            item.className = 'data-item';
            item.innerHTML = `
                <div class="data-item-info">
                    <div class="data-item-name">${threat.name}</div>
                    <div class="data-item-details">
                        ${threat.type} • Level: ${threat.level} • Capability: ${threat.capability}
                    </div>
                </div>
                <div class="data-item-actions">
                    <button class="btn btn-sm btn-warning" onclick="aiAnalysisManager.editThreat(${index})">
                        <i class="fas fa-edit"></i>
                    </button>
                    <button class="btn btn-sm btn-danger" onclick="aiAnalysisManager.removeThreat(${index})">
                        <i class="fas fa-trash"></i>
                    </button>
                </div>
            `;
            list.appendChild(item);
        });
    }

    removeThreat(index) {
        if (confirm('Are you sure you want to remove this threat?')) {
            this.threats.splice(index, 1);
            this.updateThreatsList();
            console.log('✅ Threat removed at index:', index);
        }
    }

    editThreat(index) {
        console.log('✏️ Editing threat at index:', index);
    }

    showAddOpportunityModal() {
        const modal = document.getElementById('addOpportunityModal');
        modal.style.display = 'flex';
    }

    hideAddOpportunityModal() {
        const modal = document.getElementById('addOpportunityModal');
        modal.style.display = 'none';
        document.getElementById('opportunityForm').reset();
    }

    saveOpportunity() {
        const opportunity = {
            id: Date.now(),
            name: document.getElementById('opportunityName').value,
            type: document.getElementById('opportunityType').value,
            value: document.getElementById('opportunityValue').value,
            risk: document.getElementById('opportunityRisk').value,
            timing: document.getElementById('opportunityTiming').value,
            description: document.getElementById('opportunityDescription').value
        };
        
        this.opportunities.push(opportunity);
        this.updateOpportunitiesList();
        this.hideAddOpportunityModal();
        
        console.log('✅ Opportunity added:', opportunity);
    }

    updateOpportunitiesList() {
        const list = document.getElementById('opportunitiesList');
        list.innerHTML = '';
        
        this.opportunities.forEach((opportunity, index) => {
            const item = document.createElement('div');
            item.className = 'data-item';
            item.innerHTML = `
                <div class="data-item-info">
                    <div class="data-item-name">${opportunity.name}</div>
                    <div class="data-item-details">
                        ${opportunity.type} • Value: ${opportunity.value} • Risk: ${opportunity.risk}
                    </div>
                </div>
                <div class="data-item-actions">
                    <button class="btn btn-sm btn-warning" onclick="aiAnalysisManager.editOpportunity(${index})">
                        <i class="fas fa-edit"></i>
                    </button>
                    <button class="btn btn-sm btn-danger" onclick="aiAnalysisManager.removeOpportunity(${index})">
                        <i class="fas fa-trash"></i>
                    </button>
                </div>
            `;
            list.appendChild(item);
        });
    }

    removeOpportunity(index) {
        if (confirm('Are you sure you want to remove this opportunity?')) {
            this.opportunities.splice(index, 1);
            this.updateOpportunitiesList();
            console.log('✅ Opportunity removed at index:', index);
        }
    }

    editOpportunity(index) {
        console.log('✏️ Editing opportunity at index:', index);
    }

    addToHistory(analysis) {
        const historyItem = {
            id: analysis.analysisId,
            name: `${analysis.context.type} Analysis`,
            description: `Scope: ${analysis.context.scope} • Timeframe: ${analysis.context.timeframe} • Confidence: ${(analysis.confidence * 100).toFixed(1)}%`,
            analysis: analysis,
            timestamp: new Date().toISOString()
        };
        
        this.analysisHistory.unshift(historyItem);
        this.displayAnalysisHistory();
        
        // Keep only last 50 analyses
        if (this.analysisHistory.length > 50) {
            this.analysisHistory = this.analysisHistory.slice(0, 50);
        }
    }

    displayAnalysisHistory() {
        const list = document.getElementById('historyList');
        list.innerHTML = '';
        
        this.analysisHistory.forEach(item => {
            const element = document.createElement('div');
            element.className = 'history-item';
            element.innerHTML = `
                <div class="history-info">
                    <div class="history-name">${item.name}</div>
                    <div class="history-details">${item.description}</div>
                </div>
                <div class="history-actions">
                    <button class="btn btn-sm btn-info" onclick="aiAnalysisManager.viewAnalysis('${item.id}')">
                        <i class="fas fa-eye"></i> View
                    </button>
                    <button class="btn btn-sm btn-success" onclick="aiAnalysisManager.exportAnalysis('${item.id}')">
                        <i class="fas fa-download"></i> Export
                    </button>
                </div>
            `;
            list.appendChild(element);
        });
    }

    viewAnalysis(analysisId) {
        const analysis = this.analysisHistory.find(item => item.id === analysisId);
        if (analysis) {
            this.currentAnalysis = analysis.analysis;
            this.displayAnalysisResults(analysis.analysis);
            console.log('👁️ Viewing analysis:', analysis);
        }
    }

    exportAnalysis(analysisId) {
        const analysis = this.analysisHistory.find(item => item.id === analysisId);
        if (analysis) {
            const data = JSON.stringify(analysis.analysis, null, 2);
            const blob = new Blob([data], { type: 'application/json' });
            const url = URL.createObjectURL(blob);
            const a = document.createElement('a');
            a.href = url;
            a.download = `ai_analysis_${analysisId}.json`;
            a.click();
            URL.revokeObjectURL(url);
            console.log('📤 Analysis exported:', analysis);
        }
    }

    exportAnalysis() {
        if (!this.currentAnalysis) {
            alert('No analysis to export.');
            return;
        }
        
        const data = JSON.stringify(this.currentAnalysis, null, 2);
        const blob = new Blob([data], { type: 'application/json' });
        const url = URL.createObjectURL(blob);
        const a = document.createElement('a');
        a.href = url;
        a.download = `ai_analysis_${this.currentAnalysis.analysisId}.json`;
        a.click();
        URL.revokeObjectURL(url);
        console.log('📤 AI analysis exported');
    }

    generateReport() {
        if (!this.currentAnalysis) {
            alert('No analysis to report.');
            return;
        }
        
        const modal = document.getElementById('aiReportModal');
        const content = document.getElementById('aiReportContent');
        
        content.innerHTML = `
            <div class="report-section">
                <h4>Executive Summary</h4>
                <div class="report-content">
                    <p><strong>Analysis ID:</strong> ${this.currentAnalysis.analysisId}</p>
                    <p><strong>Analysis Type:</strong> ${this.currentAnalysis.context.type}</p>
                    <p><strong>Analysis Scope:</strong> ${this.currentAnalysis.context.scope}</p>
                    <p><strong>Timeframe:</strong> ${this.currentAnalysis.context.timeframe}</p>
                    <p><strong>Confidence:</strong> ${(this.currentAnalysis.confidence * 100).toFixed(1)}%</p>
                    <p><strong>Duration:</strong> ${this.currentAnalysis.duration}ms</p>
                </div>
            </div>
            
            <div class="report-section">
                <h4>AI Recommendations</h4>
                <div class="report-content">
                    <h5>Immediate Actions</h5>
                    <ul class="report-list">
                        ${this.currentAnalysis.recommendations.immediate.map(rec => `<li>${rec.recommendation}</li>`).join('')}
                    </ul>
                    
                    <h5>Short Term Actions</h5>
                    <ul class="report-list">
                        ${this.currentAnalysis.recommendations.shortTerm.map(rec => `<li>${rec.recommendation}</li>`).join('')}
                    </ul>
                    
                    <h5>Long Term Actions</h5>
                    <ul class="report-list">
                        ${this.currentAnalysis.recommendations.longTerm.map(rec => `<li>${rec.recommendation}</li>`).join('')}
                    </ul>
                </div>
            </div>
            
            <div class="report-section">
                <h4>Risk Assessment</h4>
                <div class="report-content">
                    <p><strong>Overall Risk Level:</strong> ${this.currentAnalysis.riskAssessment.overallRiskLevel}</p>
                    <p><strong>Risk Mitigation:</strong> ${this.currentAnalysis.riskAssessment.riskMitigation ? 'Identified' : 'Pending'}</p>
                    <p><strong>Risk Monitoring:</strong> ${this.currentAnalysis.riskAssessment.riskMonitoring ? 'Established' : 'Pending'}</p>
                </div>
            </div>
            
            <div class="report-section">
                <h4>Decision Support</h4>
                <div class="report-content">
                    <p><strong>Recommended Action:</strong> ${this.currentAnalysis.decisionSupport.recommendedAction}</p>
                    <p><strong>Decision Options:</strong> ${this.currentAnalysis.decisionSupport.decisionOptions ? this.currentAnalysis.decisionSupport.decisionOptions.length : 0}</p>
                    <p><strong>Decision Criteria:</strong> ${this.currentAnalysis.decisionSupport.decisionCriteria ? 'Established' : 'Pending'}</p>
                </div>
            </div>
            
            <div class="report-section">
                <h4>NATO Compliance</h4>
                <div class="report-content">
                    <p><strong>Standards:</strong> NATO ATP-3-90.1/90.2/90.3</p>
                    <p><strong>Compliance:</strong> ${this.currentAnalysis.natoCompliance ? 'Compliant' : 'Non-compliant'}</p>
                    <p><strong>Generated:</strong> ${new Date(this.currentAnalysis.timestamp).toLocaleString()}</p>
                </div>
            </div>
        `;
        
        modal.style.display = 'flex';
    }

    exportReport() {
        if (!this.currentAnalysis) {
            alert('No analysis to export.');
            return;
        }
        
        const reportData = {
            reportType: 'NATO AI Analysis Report',
            classification: 'UNCLASSIFIED',
            timestamp: new Date().toISOString(),
            analysis: this.currentAnalysis,
            natoStandards: {
                reference: 'NATO ATP-3-90.1/90.2/90.3',
                compliance: this.currentAnalysis.natoCompliance
            }
        };
        
        const data = JSON.stringify(reportData, null, 2);
        const blob = new Blob([data], { type: 'application/json' });
        const url = URL.createObjectURL(blob);
        const a = document.createElement('a');
        a.href = url;
        a.download = `nato_ai_analysis_report_${Date.now()}.json`;
        a.click();
        URL.revokeObjectURL(url);
        console.log('📤 AI analysis report exported');
    }

    loadAnalysisHistory() {
        try {
            const stored = localStorage.getItem('ai_analysis_history');
            if (stored) {
                this.analysisHistory = JSON.parse(stored);
                this.displayAnalysisHistory();
                console.log(`🤖 Loaded ${this.analysisHistory.length} AI analyses from history`);
            }
        } catch (error) {
            console.warn('Failed to load analysis history:', error);
        }
    }

    saveAnalysisHistory() {
        try {
            localStorage.setItem('ai_analysis_history', JSON.stringify(this.analysisHistory));
            console.log('🤖 Analysis history saved');
        } catch (error) {
            console.warn('Failed to save analysis history:', error);
        }
    }
}

// Initialize AI analysis manager
const aiAnalysisManager = new AiAnalysisManager();
console.log('🤖 AI Analysis Manager initialized');

// Save history when page unloads
window.addEventListener('beforeunload', () => {
    aiAnalysisManager.saveAnalysisHistory();
});

// Add CSS for spinner animation
const style = document.createElement('style');
style.textContent = `
@@keyframes spin {
    0% { transform: rotate(0deg); }
    100% { transform: rotate(360deg); }
}
`;
document.head.appendChild(style);
</script>
