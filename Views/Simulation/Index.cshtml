@{
    ViewData["Title"] = "Combat Simulation";
}

<div class="simulation-container">
    <div class="simulation-header">
        <h1>Combat Simulation Arena</h1>
        <p>NATO-compliant turn-based combat simulation with AI analysis</p>
    </div>

    <div class="simulation-controls">
        <div class="control-panel">
            <h3>Simulation Controls</h3>
            
            <div class="control-group">
                <label for="simulationName">Simulation Name:</label>
                <input type="text" id="simulationName" class="form-control" value="Combat Simulation" />
            </div>
            
            <div class="control-group">
                <label for="simulationDescription">Description:</label>
                <textarea id="simulationDescription" class="form-control" rows="3" placeholder="Enter simulation description..."></textarea>
            </div>
            
            <div class="control-group">
                <label for="maxTurns">Maximum Turns:</label>
                <input type="number" id="maxTurns" class="form-control" value="20" min="1" max="100" />
            </div>
            
            <div class="control-group">
                <label for="turnDuration">Turn Duration (seconds):</label>
                <input type="number" id="turnDuration" class="form-control" value="30" min="5" max="300" />
            </div>
            
            <div class="control-group">
                <label for="terrainType">Terrain Type:</label>
                <select id="terrainType" class="form-control">
                    <option value="open">Open Terrain</option>
                    <option value="urban">Urban</option>
                    <option value="forest">Forest</option>
                    <option value="hills">Hills</option>
                    <option value="swamp">Swamp</option>
                    <option value="desert">Desert</option>
                </select>
            </div>
            
            <!-- HLA/Interoperability Settings -->
            <div class="control-group hla-settings">
                <h4>Interoperability (HLA/NETN)</h4>
                <div class="hla-toggle">
                    <label class="switch">
                        <input type="checkbox" id="enableHla" />
                        <span class="slider round"></span>
                    </label>
                    <label for="enableHla">Enable HLA Federation</label>
                </div>
                
                <div id="hlaConfiguration" style="display: none;">
                    <div class="control-group">
                        <label for="federationName">Federation Name:</label>
                        <input type="text" id="federationName" class="form-control" value="KSA_WARGAME_FEDERATION" />
                    </div>
                    
                    <div class="control-group">
                        <label for="federateType">Federate Type:</label>
                        <select id="federateType" class="form-control">
                            <option value="WARGAME_CLIENT">Wargame Client</option>
                            <option value="TRAINING_SYSTEM">Training System</option>
                            <option value="ANALYSIS_TOOL">Analysis Tool</option>
                            <option value="OBSERVER">Observer</option>
                        </select>
                    </div>
                    
                    <div id="hlaStatusPanel" class="hla-status-panel">
                        <div class="hla-status disconnected">
                            <span class="status-icon">🔴</span>
                            <span class="status-text">DISCONNECTED</span>
                        </div>
                    </div>
                    
                    <div class="control-buttons">
                        <button id="btnConnectHla" class="btn btn-success btn-sm">
                            <i class="fas fa-plug"></i> Connect to Federation
                        </button>
                        <button id="btnDisconnectHla" class="btn btn-danger btn-sm" disabled>
                            <i class="fas fa-unlink"></i> Disconnect
                        </button>
                    </div>
                </div>
            </div>
            
            <div class="control-buttons">
                <button id="btnStartSimulation" class="btn btn-primary">
                    <i class="fas fa-play"></i> Start Simulation
                </button>
                <button id="btnStopSimulation" class="btn btn-danger" disabled>
                    <i class="fas fa-stop"></i> Stop Simulation
                </button>
                <button id="btnPauseSimulation" class="btn btn-warning" disabled>
                    <i class="fas fa-pause"></i> Pause Simulation
                </button>
            </div>
        </div>
        
        <div class="participants-panel">
            <h3>Participants</h3>
            
            <div class="participants-list" id="participantsList">
                <!-- Participants will be loaded here -->
            </div>
            
            <div class="add-participant">
                <button id="btnAddParticipant" class="btn btn-secondary">
                    <i class="fas fa-plus"></i> Add Participant
                </button>
            </div>
        </div>
    </div>

    <div class="simulation-status" id="simulationStatus" style="display: none;">
        <div class="status-header">
            <h3>Simulation Status</h3>
            <div class="status-indicator">
                <span class="status-dot" id="statusDot"></span>
                <span id="statusText">Ready</span>
            </div>
        </div>
        
        <div class="status-details">
            <div class="status-item">
                <label>Current Turn:</label>
                <span id="currentTurn">0</span>
            </div>
            <div class="status-item">
                <label>Max Turns:</label>
                <span id="maxTurnsDisplay">20</span>
            </div>
            <div class="status-item">
                <label>Duration:</label>
                <span id="simulationDuration">00:00:00</span>
            </div>
            <div class="status-item">
                <label>Status:</label>
                <span id="simulationStatusText">Ready</span>
            </div>
        </div>
    </div>

    <div class="simulation-results" id="simulationResults" style="display: none;">
        <div class="results-header">
            <h3>Simulation Results</h3>
            <div class="results-controls">
                <button id="btnGenerateAnalysis" class="btn btn-info">
                    <i class="fas fa-chart-line"></i> Generate Analysis
                </button>
                <button id="btnExportResults" class="btn btn-success">
                    <i class="fas fa-download"></i> Export Results
                </button>
            </div>
        </div>
        
        <div class="results-content">
            <div class="results-summary" id="resultsSummary">
                <!-- Results summary will be loaded here -->
            </div>
            
            <div class="results-analysis" id="resultsAnalysis" style="display: none;">
                <!-- Analysis results will be loaded here -->
            </div>
        </div>
    </div>

    <div class="simulation-history">
        <h3>Simulation History</h3>
        <div class="history-list" id="historyList">
            <!-- Simulation history will be loaded here -->
        </div>
    </div>
</div>

<!-- Add Participant Modal -->
<div class="modal fade" id="addParticipantModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Add Participant</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <form id="participantForm">
                    <div class="form-group">
                        <label for="participantName">Name:</label>
                        <input type="text" id="participantName" class="form-control" required />
                    </div>
                    
                    <div class="form-group">
                        <label for="participantType">Type:</label>
                        <select id="participantType" class="form-control" required>
                            <option value="attacker">Attacker</option>
                            <option value="defender">Defender</option>
                        </select>
                    </div>
                    
                    <div class="form-group">
                        <label for="unitType">Unit Type:</label>
                        <select id="unitType" class="form-control" required>
                            <option value="Infantry">Infantry</option>
                            <option value="Armoured">Armoured</option>
                            <option value="Artillery">Artillery</option>
                            <option value="Engineers">Engineers</option>
                            <option value="Signals">Signals</option>
                            <option value="Medical">Medical</option>
                        </select>
                    </div>
                    
                    <div class="form-group">
                        <label for="organizationLevel">Organization Level:</label>
                        <select id="organizationLevel" class="form-control" required>
                            <option value="Squad">Squad</option>
                            <option value="Platoon">Platoon</option>
                            <option value="Company">Company</option>
                            <option value="Battalion">Battalion</option>
                            <option value="Brigade">Brigade</option>
                            <option value="Division">Division</option>
                        </select>
                    </div>
                    
                    <div class="form-group">
                        <label for="unitDesignation">Unit Designation:</label>
                        <input type="text" id="unitDesignation" class="form-control" value="1" />
                    </div>
                    
                    <div class="form-group">
                        <label for="forceType">Force Type:</label>
                        <select id="forceType" class="form-control" required>
                            <option value="Friendly">Friendly</option>
                            <option value="Hostile">Hostile</option>
                            <option value="Neutral">Neutral</option>
                            <option value="Unknown">Unknown</option>
                        </select>
                    </div>
                    
                    <div class="form-group">
                        <label for="strength">Strength:</label>
                        <input type="number" id="strength" class="form-control" value="100" min="1" max="1000" />
                    </div>
                    
                    <div class="form-group">
                        <label for="morale">Morale:</label>
                        <select id="morale" class="form-control">
                            <option value="high">High</option>
                            <option value="average" selected>Average</option>
                            <option value="low">Low</option>
                            <option value="broken">Broken</option>
                        </select>
                    </div>
                    
                    <div class="form-group">
                        <label for="training">Training:</label>
                        <select id="training" class="form-control">
                            <option value="elite">Elite</option>
                            <option value="regular" selected>Regular</option>
                            <option value="reserve">Reserve</option>
                            <option value="militia">Militia</option>
                        </select>
                    </div>
                    
                    <div class="form-group">
                        <label for="equipment">Equipment:</label>
                        <select id="equipment" class="form-control">
                            <option value="modern">Modern</option>
                            <option value="standard" selected>Standard</option>
                            <option value="obsolete">Obsolete</option>
                            <option value="inadequate">Inadequate</option>
                        </select>
                    </div>
                    
                    <div class="form-group">
                        <label for="supply">Supply:</label>
                        <select id="supply" class="form-control">
                            <option value="abundant">Abundant</option>
                            <option value="adequate" selected>Adequate</option>
                            <option value="limited">Limited</option>
                            <option value="critical">Critical</option>
                        </select>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-primary" id="btnSaveParticipant">Add Participant</button>
            </div>
        </div>
    </div>
</div>

<!-- Analysis Results Modal -->
<div class="modal fade" id="analysisModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Simulation Analysis</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div id="analysisContent">
                    <!-- Analysis content will be loaded here -->
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                <button type="button" class="btn btn-primary" id="btnExportAnalysis">Export Analysis</button>
            </div>
        </div>
    </div>
</div>

<style>
