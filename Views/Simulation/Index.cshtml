}

.btn-close:hover {
    color: #2c3e50;
}

.modal-body {
    padding: 20px;
}

.modal-footer {
    padding: 20px;
    border-top: 1px solid #dee2e6;
    display: flex;
    justify-content: flex-end;
    gap: 10px;
}

.analysis-section {
    margin-bottom: 20px;
    padding: 15px;
    background: #f8f9fa;
    border-radius: 5px;
    border: 1px solid #dee2e6;
}

.analysis-section h4 {
    color: #2c3e50;
    margin-bottom: 10px;
}

.analysis-content {
    color: #495057;
    line-height: 1.6;
}

.analysis-list {
    list-style: none;
    padding: 0;
}

.analysis-list li {
    padding: 5px 0;
    border-bottom: 1px solid #dee2e6;
}

.analysis-list li:last-child {
    border-bottom: none;
}

@@media (max-width: 768px) {
    .simulation-controls {
        grid-template-columns: 1fr;
    }
    
    .status-details {
        grid-template-columns: 1fr;
    }
    
    .results-summary {
        grid-template-columns: 1fr;
    }
    
    .control-buttons {
        flex-direction: column;
    }
}
</style>

<script>
// Simulation Manager
class SimulationManager {
    constructor() {
        this.currentSimulation = null;
        this.participants = [];
        this.simulationInterval = null;
        this.startTime = null;
        
        this.initializeEventListeners();
        this.loadSimulationHistory();
    }

    initializeEventListeners() {
        // Control buttons
        document.getElementById('btnStartSimulation').addEventListener('click', () => this.startSimulation());
        document.getElementById('btnStopSimulation').addEventListener('click', () => this.stopSimulation());
        document.getElementById('btnPauseSimulation').addEventListener('click', () => this.pauseSimulation());
        
        // Participant management
        document.getElementById('btnAddParticipant').addEventListener('click', () => this.showAddParticipantModal());
        document.getElementById('btnSaveParticipant').addEventListener('click', () => this.saveParticipant());
        
        // Results management
        document.getElementById('btnGenerateAnalysis').addEventListener('click', () => this.generateAnalysis());
        document.getElementById('btnExportResults').addEventListener('click', () => this.exportResults());
        document.getElementById('btnExportAnalysis').addEventListener('click', () => this.exportAnalysis());
        
        // HLA/Interoperability controls
        document.getElementById('enableHla').addEventListener('change', (e) => this.toggleHlaConfiguration(e.target.checked));
        document.getElementById('btnConnectHla').addEventListener('click', () => this.connectToHlaFederation());
        document.getElementById('btnDisconnectHla').addEventListener('click', () => this.disconnectFromHlaFederation());
    }
    
    toggleHlaConfiguration(enabled) {
        const config = document.getElementById('hlaConfiguration');
        config.style.display = enabled ? 'block' : 'none';
        console.log(`🔗 HLA configuration ${enabled ? 'shown' : 'hidden'}`);
    }
    
    async connectToHlaFederation() {
        try {
            if (!window.interoperabilityService) {
                alert('Interoperability service not available');
                return;
            }
            
            const federationName = document.getElementById('federationName').value;
            const federateType = document.getElementById('federateType').value;
            
            console.log(`🔗 Connecting to HLA federation: ${federationName}`);
            
            const result = await window.interoperabilityService.enableInteroperability(federationName, federateType);
            
            if (result.success) {
                document.getElementById('btnConnectHla').disabled = true;
                document.getElementById('btnDisconnectHla').disabled = false;
                console.log('✅ Connected to HLA federation');
            }
        } catch (error) {
            console.error('❌ Error connecting to HLA federation:', error);
            alert('Failed to connect to HLA federation: ' + error.message);
        }
    }
    
    async disconnectFromHlaFederation() {
        try {
            if (!window.interoperabilityService) {
                return;
            }
            
            console.log('🔗 Disconnecting from HLA federation');
            
            const result = await window.interoperabilityService.disableInteroperability();
            
            if (result.success) {
                document.getElementById('btnConnectHla').disabled = false;
                document.getElementById('btnDisconnectHla').disabled = true;
                console.log('✅ Disconnected from HLA federation');
            }
        } catch (error) {
            console.error('❌ Error disconnecting from HLA federation:', error);
            alert('Failed to disconnect from HLA federation: ' + error.message);
        }
    }

    async startSimulation() {
        try {
            const config = this.getSimulationConfig();
            
            if (this.participants.length < 2) {
                alert('Please add at least 2 participants before starting the simulation.');
                return;
            }
            
            console.log('🚀 Starting simulation with config:', config);
            
            // Call simulation API
            const response = await fetch('/api/simulation/start', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json'
                },
                body: JSON.stringify(config)
            });
            
            const result = await response.json();
            
            if (result.success) {
                this.currentSimulation = result;
                this.startTime = new Date();
                this.updateSimulationStatus('running');
                this.startStatusUpdates();
                
                console.log('✅ Simulation started:', result);
            } else {
                throw new Error(result.message || 'Failed to start simulation');
            }
        } catch (error) {
            console.error('❌ Error starting simulation:', error);
            alert('Failed to start simulation: ' + error.message);
        }
    }

    async stopSimulation() {
        try {
            if (!this.currentSimulation) {
                return;
            }
            
            console.log('🛑 Stopping simulation:', this.currentSimulation.simulationId);
            
            const response = await fetch(`/api/simulation/stop/${this.currentSimulation.simulationId}`, {
                method: 'POST'
            });
            
            const result = await response.json();
            
            if (result.success) {
                this.currentSimulation = null;
                this.updateSimulationStatus('stopped');
                this.stopStatusUpdates();
                
                console.log('✅ Simulation stopped:', result);
            } else {
                throw new Error(result.message || 'Failed to stop simulation');
            }
        } catch (error) {
            console.error('❌ Error stopping simulation:', error);
            alert('Failed to stop simulation: ' + error.message);
        }
    }

    pauseSimulation() {
        // Implementation for pausing simulation
        console.log('⏸️ Pausing simulation');
        this.updateSimulationStatus('paused');
    }

    getSimulationConfig() {
        return {
            name: document.getElementById('simulationName').value,
            description: document.getElementById('simulationDescription').value,
            maxTurns: parseInt(document.getElementById('maxTurns').value),
            turnDuration: parseInt(document.getElementById('turnDuration').value),
            participants: this.participants,
            terrain: {
                type: document.getElementById('terrainType').value,
                elevation: 0,
                cover: 'none',
                concealment: 'none',
                obstacles: []
            },
            defenseElements: []
        };
    }

    updateSimulationStatus(status) {
        const statusElement = document.getElementById('simulationStatus');
        const statusDot = document.getElementById('statusDot');
        const statusText = document.getElementById('statusText');
        const simulationStatusText = document.getElementById('simulationStatusText');
        
        statusElement.style.display = 'block';
        statusDot.className = `status-dot ${status}`;
        statusText.textContent = status.charAt(0).toUpperCase() + status.slice(1);
        simulationStatusText.textContent = status.charAt(0).toUpperCase() + status.slice(1);
        
        // Update control buttons
        const startBtn = document.getElementById('btnStartSimulation');
        const stopBtn = document.getElementById('btnStopSimulation');
        const pauseBtn = document.getElementById('btnPauseSimulation');
        
        startBtn.disabled = status === 'running';
        stopBtn.disabled = status !== 'running';
        pauseBtn.disabled = status !== 'running';
    }

    startStatusUpdates() {
        this.simulationInterval = setInterval(() => {
            this.updateStatusDisplay();
        }, 1000);
    }

    stopStatusUpdates() {
        if (this.simulationInterval) {
            clearInterval(this.simulationInterval);
            this.simulationInterval = null;
        }
    }

    updateStatusDisplay() {
        if (this.startTime) {
            const elapsed = new Date() - this.startTime;
            const hours = Math.floor(elapsed / 3600000);
            const minutes = Math.floor((elapsed % 3600000) / 60000);
            const seconds = Math.floor((elapsed % 60000) / 1000);
            
            document.getElementById('simulationDuration').textContent = 
                `${hours.toString().padStart(2, '0')}:${minutes.toString().padStart(2, '0')}:${seconds.toString().padStart(2, '0')}`;
        }
    }

    showAddParticipantModal() {
        const modal = document.getElementById('addParticipantModal');
        modal.style.display = 'flex';
    }

    hideAddParticipantModal() {
        const modal = document.getElementById('addParticipantModal');
        modal.style.display = 'none';
        document.getElementById('participantForm').reset();
    }

    saveParticipant() {
        const form = document.getElementById('participantForm');
        const formData = new FormData(form);
        
        const participant = {
            name: document.getElementById('participantName').value,
            type: document.getElementById('participantType').value,
            unit: {
                unitType: document.getElementById('unitType').value,
                organizationLevel: document.getElementById('organizationLevel').value,
                unitDesignation: document.getElementById('unitDesignation').value,
                forceType: document.getElementById('forceType').value
            },
            position: [0, 0], // Default position
            strength: parseInt(document.getElementById('strength').value),
            morale: document.getElementById('morale').value,
            training: document.getElementById('training').value,
            equipment: document.getElementById('equipment').value,
            supply: document.getElementById('supply').value
        };
        
        this.participants.push(participant);
        this.updateParticipantsList();
        this.hideAddParticipantModal();
        
        console.log('✅ Participant added:', participant);
    }

    updateParticipantsList() {
        const list = document.getElementById('participantsList');
        list.innerHTML = '';
        
        this.participants.forEach((participant, index) => {
            const item = document.createElement('div');
            item.className = 'participant-item';
            item.innerHTML = `
                <div class="participant-info">
                    <div class="participant-name">${participant.name}</div>
                    <div class="participant-details">
                        ${participant.type} • ${participant.unit.unitType} • ${participant.unit.organizationLevel} • Strength: ${participant.strength}
                    </div>
                </div>
                <div class="participant-actions">
                    <button class="btn btn-sm btn-warning" onclick="simulationManager.editParticipant(${index})">
                        <i class="fas fa-edit"></i>
                    </button>
                    <button class="btn btn-sm btn-danger" onclick="simulationManager.removeParticipant(${index})">
                        <i class="fas fa-trash"></i>
                    </button>
                </div>
            `;
            list.appendChild(item);
        });
    }

    removeParticipant(index) {
        if (confirm('Are you sure you want to remove this participant?')) {
            this.participants.splice(index, 1);
            this.updateParticipantsList();
            console.log('✅ Participant removed at index:', index);
        }
    }

    editParticipant(index) {
        // Implementation for editing participant
        console.log('✏️ Editing participant at index:', index);
    }

    async generateAnalysis() {
        try {
            if (!this.currentSimulation) {
                alert('No simulation running. Please start a simulation first.');
                return;
            }
            
            console.log('📊 Generating analysis for simulation:', this.currentSimulation.simulationId);
            
            const response = await fetch(`/api/simulation/analyze/${this.currentSimulation.simulationId}?analysisType=nato_combat_report`, {
                method: 'POST'
            });
            
            const analysis = await response.json();
            
            this.displayAnalysis(analysis);
            
            console.log('✅ Analysis generated:', analysis);
        } catch (error) {
            console.error('❌ Error generating analysis:', error);
            alert('Failed to generate analysis: ' + error.message);
        }
    }

    displayAnalysis(analysis) {
        const modal = document.getElementById('analysisModal');
        const content = document.getElementById('analysisContent');
        
        content.innerHTML = '';
        
        // Display each section
        Object.entries(analysis.sections).forEach(([sectionName, section]) => {
            const sectionDiv = document.createElement('div');
            sectionDiv.className = 'analysis-section';
            
            sectionDiv.innerHTML = `
                <h4>${section.title}</h4>
                <div class="analysis-content">
                    ${this.formatAnalysisContent(section.content)}
                </div>
            `;
            
            content.appendChild(sectionDiv);
        });
        
        modal.style.display = 'flex';
    }

    formatAnalysisContent(content) {
        if (typeof content === 'object') {
            let html = '';
            Object.entries(content).forEach(([key, value]) => {
                if (Array.isArray(value)) {
                    html += `<h5>${key.replace(/([A-Z])/g, ' $1').trim()}:</h5>`;
                    html += '<ul class="analysis-list">';
                    value.forEach(item => {
                        html += `<li>${item}</li>`;
                    });
                    html += '</ul>';
                } else if (typeof value === 'object') {
                    html += `<h5>${key.replace(/([A-Z])/g, ' $1').trim()}:</h5>`;
                    html += `<div>${this.formatAnalysisContent(value)}</div>`;
                } else {
                    html += `<p><strong>${key.replace(/([A-Z])/g, ' $1').trim()}:</strong> ${value}</p>`;
                }
            });
            return html;
        }
        return content;
    }

    async exportResults() {
        try {
            if (!this.currentSimulation) {
                alert('No simulation running. Please start a simulation first.');
                return;
            }
            
            console.log('📤 Exporting results for simulation:', this.currentSimulation.simulationId);
            
            const response = await fetch(`/api/simulation/export/${this.currentSimulation.simulationId}?format=json`);
            const data = await response.json();
            
            // Download as JSON file
            const blob = new Blob([JSON.stringify(data, null, 2)], { type: 'application/json' });
            const url = URL.createObjectURL(blob);
            const a = document.createElement('a');
            a.href = url;
            a.download = `simulation_results_${this.currentSimulation.simulationId}.json`;
            a.click();
            URL.revokeObjectURL(url);
            
            console.log('✅ Results exported');
        } catch (error) {
            console.error('❌ Error exporting results:', error);
            alert('Failed to export results: ' + error.message);
        }
    }

    exportAnalysis() {
        // Implementation for exporting analysis
        console.log('📤 Exporting analysis');
    }

    async loadSimulationHistory() {
        try {
            console.log('📋 Loading simulation history...');
            
            const response = await fetch('/api/simulation/list');
            const data = await response.json();
            
            if (data.success) {
                this.displaySimulationHistory(data.simulations);
                console.log('✅ Simulation history loaded:', data.simulations);
            } else {
                throw new Error(data.message || 'Failed to load simulation history');
            }
        } catch (error) {
            console.error('❌ Error loading simulation history:', error);
        }
    }

    displaySimulationHistory(simulations) {
        const list = document.getElementById('historyList');
        list.innerHTML = '';
        
        simulations.forEach(simulation => {
            const item = document.createElement('div');
            item.className = 'history-item';
            item.innerHTML = `
                <div class="history-info">
                    <div class="history-name">${simulation.name}</div>
                    <div class="history-details">
                        ${simulation.description} • ${simulation.status} • ${simulation.totalTurns} turns • ${simulation.totalCasualties} casualties
                    </div>
                </div>
                <div class="history-actions">
                    <button class="btn btn-sm btn-info" onclick="simulationManager.viewSimulation('${simulation.simulationId}')">
                        <i class="fas fa-eye"></i> View
                    </button>
                    <button class="btn btn-sm btn-success" onclick="simulationManager.exportSimulation('${simulation.simulationId}')">
                        <i class="fas fa-download"></i> Export
                    </button>
                </div>
            `;
            list.appendChild(item);
        });
    }

    viewSimulation(simulationId) {
        // Implementation for viewing simulation details
        console.log('👁️ Viewing simulation:', simulationId);
    }

    exportSimulation(simulationId) {
        // Implementation for exporting simulation
        console.log('📤 Exporting simulation:', simulationId);
    }
}

// Initialize simulation manager
const simulationManager = new SimulationManager();
console.log('🎮 Simulation Manager initialized');
</script>
