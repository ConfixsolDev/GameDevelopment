    color: #2c3e50;
    margin-bottom: 10px;
}

.simulation-header p {
    color: #7f8c8d;
    font-size: 1.1em;
}

.simulation-controls {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20px;
    margin-bottom: 30px;
}

.control-panel, .participants-panel {
    background: #f8f9fa;
    padding: 20px;
    border-radius: 8px;
    border: 1px solid #dee2e6;
}

.control-panel h3, .participants-panel h3 {
    color: #2c3e50;
    margin-bottom: 20px;
    border-bottom: 2px solid #3498db;
    padding-bottom: 10px;
}

.control-group {
    margin-bottom: 15px;
}

.control-group label {
    display: block;
    margin-bottom: 5px;
    font-weight: 600;
    color: #2c3e50;
}

.control-buttons {
    display: flex;
    gap: 10px;
    margin-top: 20px;
}

.control-buttons .btn {
    flex: 1;
}

.participants-list {
    max-height: 300px;
    overflow-y: auto;
    margin-bottom: 15px;
}

.participant-item {
    background: white;
    padding: 10px;
    margin-bottom: 10px;
    border-radius: 5px;
    border: 1px solid #dee2e6;
    display: flex;
    justify-content: space-between;
    align-items: center;
}

.participant-info {
    flex: 1;
}

.participant-name {
    font-weight: 600;
    color: #2c3e50;
}

.participant-details {
    font-size: 0.9em;
    color: #7f8c8d;
}

.participant-actions {
    display: flex;
    gap: 5px;
}

.simulation-status {
    background: #f8f9fa;
    padding: 20px;
    border-radius: 8px;
    border: 1px solid #dee2e6;
    margin-bottom: 30px;
}

.status-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 20px;
}

.status-indicator {
    display: flex;
    align-items: center;
    gap: 10px;
}

.status-dot {
