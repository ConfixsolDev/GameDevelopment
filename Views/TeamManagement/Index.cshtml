@{
    ViewData["Title"] = "Team Management";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container-fluid">
    <div class="row">
        <div class="col-12">
            <div class="card">
                <div class="card-header">
                    <h3 class="card-title">
                        <i class="fas fa-users"></i> Team Management
                    </h3>
                    <div class="card-tools">
                        <button type="button" class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#createTeamModal">
                            <i class="fas fa-plus"></i> Create New Team
                        </button>
                    </div>
                </div>
                <div class="card-body">
                    <div class="table-responsive">
                        <table id="teamsTable" class="table table-bordered table-striped">
                            <thead>
                                <tr>
                                    <th>Team Name</th>
                                    <th>Team Code</th>
                                    <th>Sub Team Code</th>
                                    <th>Category</th>
                                    <th>Description</th>
                                    <th>Members</th>
                                    <th>Created By</th>
                                    <th>Created At</th>
                                    <th>Status</th>
                                    <th>Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                <!-- Data will be loaded via JavaScript -->
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Create Team Modal -->
<div class="modal fade" id="createTeamModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Create New Team</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <form id="createTeamForm">
                    <div class="mb-3">
                        <label for="teamName" class="form-label">Team Name *</label>
                        <input type="text" class="form-control" id="teamName" required>
                    </div>
                    <div class="mb-3">
                        <label for="teamCode" class="form-label">Team Code *</label>
                        <input type="text" class="form-control" id="teamCode" required>
                        <div class="form-text">Unique identifier (e.g., TEAM_A, BRIG_1)</div>
                    </div>
                    <div class="mb-3">
                        <label for="subTeamCode" class="form-label">Sub Team Code</label>
                        <input type="text" class="form-control" id="subTeamCode">
                        <div class="form-text">Optional sub-team identifier</div>
                    </div>
                    <div class="mb-3">
                        <label for="teamCategory" class="form-label">Category</label>
                        <select class="form-control" id="teamCategory">
                            <option value="">-- Select Category --</option>
                            <option value="Company">Company</option>
                            <option value="Brigade">Brigade</option>
                            <option value="Department">Department</option>
                            <option value="Unit">Unit</option>
                            <option value="Squad">Squad</option>
                        </select>
                    </div>
                    <div class="mb-3">
                        <label for="teamDescription" class="form-label">Description</label>
                        <textarea class="form-control" id="teamDescription" rows="3"></textarea>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-primary" id="saveTeamBtn">Create Team</button>
            </div>
        </div>
    </div>
</div>

<!-- Edit Team Modal -->
<div class="modal fade" id="editTeamModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Edit Team</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <form id="editTeamForm">
                    <input type="hidden" id="editTeamId">
                    <div class="mb-3">
                        <label for="editTeamName" class="form-label">Team Name *</label>
                        <input type="text" class="form-control" id="editTeamName" required>
                    </div>
                    <div class="mb-3">
                        <label for="editTeamCode" class="form-label">Team Code *</label>
                        <input type="text" class="form-control" id="editTeamCode" required>
                    </div>
                    <div class="mb-3">
                        <label for="editSubTeamCode" class="form-label">Sub Team Code</label>
                        <input type="text" class="form-control" id="editSubTeamCode">
                    </div>
                    <div class="mb-3">
                        <label for="editTeamCategory" class="form-label">Category</label>
                        <select class="form-control" id="editTeamCategory">
                            <option value="">-- Select Category --</option>
                            <option value="Company">Company</option>
                            <option value="Brigade">Brigade</option>
                            <option value="Department">Department</option>
                            <option value="Unit">Unit</option>
                            <option value="Squad">Squad</option>
                        </select>
                    </div>
                    <div class="mb-3">
                        <label for="editTeamDescription" class="form-label">Description</label>
                        <textarea class="form-control" id="editTeamDescription" rows="3"></textarea>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-primary" id="updateTeamBtn">Update Team</button>
            </div>
        </div>
    </div>
</div>

<!-- Team Members Modal -->
<div class="modal fade" id="teamMembersModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Team Members</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div class="row mb-3">
                    <div class="col-md-6">
                        <label for="userSelect">Select User:</label>
                        <select id="userSelect" class="form-control">
                            <option value="">-- Select User --</option>
                        </select>
                    </div>
                    <div class="col-md-6">
                        <button type="button" class="btn btn-success" id="assignUserBtn">
                            <i class="fas fa-plus"></i> Assign User
                        </button>
                    </div>
                </div>
                <div class="table-responsive">
                    <table id="teamMembersTable" class="table table-bordered">
                        <thead>
                            <tr>
                                <th>User Name</th>
                                <th>Email</th>
                                <th>Role</th>
                                <th>Assigned Date</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            <!-- Data will be loaded via JavaScript -->
                        </tbody>
                    </table>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function() {
            loadTeams();
            loadUsers();

            // Create Team functionality
            $('#saveTeamBtn').click(function() {
                createTeam();
            });

            // Edit Team functionality
            $('#updateTeamBtn').click(function() {
                updateTeam();
            });

            // Assign User functionality
            $('#assignUserBtn').click(function() {
                assignUserToTeam();
            });
        });

        function loadTeams() {
            $.get(getApiUrl('TeamManagement', 'teams'))
                .done(function(teams) {
                    const tbody = $('#teamsTable tbody');
                    tbody.empty();
                    
                    teams.forEach(function(team) {
                        const row = `
                            <tr>
                                <td>${team.name}</td>
                                <td><span class="badge bg-info">${team.teamCode}</span></td>
                                <td>${team.subTeamCode || 'N/A'}</td>
                                <td>${team.category || 'N/A'}</td>
                                <td>${team.description || 'N/A'}</td>
                                <td><span class="badge bg-success">${team.memberCount}</span></td>
                                <td>${team.createdByUserName || 'N/A'}</td>
                                <td>${new Date(team.createdAt).toLocaleDateString()}</td>
                                <td>${team.isActive ? '<span class="badge bg-success">Active</span>' : '<span class="badge bg-danger">Inactive</span>'}</td>
                                <td>
                                    <button class="btn btn-sm btn-info" onclick="viewTeamMembers('${team.id}')">
                                        <i class="fas fa-users"></i> Members
                                    </button>
                                    <button class="btn btn-sm btn-warning" onclick="editTeam('${team.id}')">
                                        <i class="fas fa-edit"></i> Edit
                                    </button>
                                    <button class="btn btn-sm btn-danger" onclick="deleteTeam('${team.id}')">
                                        <i class="fas fa-trash"></i> Delete
                                    </button>
                                </td>
                            </tr>
                        `;
                        tbody.append(row);
                    });
                })
                .fail(function() {
                    showAlert('Error loading teams', 'danger');
                });
        }

        function loadUsers() {
            $.get('/api/admin/TeamManagementApi/users')
                .done(function(users) {
                    const select = $('#userSelect');
                    select.empty().append('<option value="">-- Select User --</option>');
                    
                    users.forEach(function(user) {
                        select.append(`<option value="${user.id}">${user.firstName} ${user.lastName} (${user.email})</option>`);
                    });
                })
                .fail(function() {
                    showAlert('Error loading users', 'danger');
                });
        }

        function createTeam() {
            const data = {
                name: $('#teamName').val(),
                teamCode: $('#teamCode').val(),
                subTeamCode: $('#subTeamCode').val(),
                category: $('#teamCategory').val(),
                description: $('#teamDescription').val()
            };

            if (!data.name || !data.teamCode) {
                showAlert('Team name and code are required', 'warning');
                return;
            }

            $.post(getApiUrl('TeamManagement', 'createTeam'), data)
                .done(function(response) {
                    if (response.success) {
                        showAlert('Team created successfully', 'success');
                        $('#createTeamModal').modal('hide');
                        $('#createTeamForm')[0].reset();
                        loadTeams();
                    } else {
                        showAlert(response.message, 'danger');
                    }
                })
                .fail(function(xhr) {
                    const message = xhr.responseJSON?.message || 'Error creating team';
                    showAlert(message, 'danger');
                });
        }

        function editTeam(teamId) {
            // Load team data and populate edit form
            $.get(`/api/admin/TeamManagementApi/teams`)
                .done(function(teams) {
                    const team = teams.find(t => t.id === teamId);
                    if (team) {
                        $('#editTeamId').val(team.id);
                        $('#editTeamName').val(team.name);
                        $('#editTeamCode').val(team.teamCode);
                        $('#editSubTeamCode').val(team.subTeamCode || '');
                        $('#editTeamCategory').val(team.category || '');
                        $('#editTeamDescription').val(team.description || '');
                        $('#editTeamModal').modal('show');
                    }
                })
                .fail(function() {
                    showAlert('Error loading team data', 'danger');
                });
        }

        function updateTeam() {
            const teamId = $('#editTeamId').val();
            const data = {
                name: $('#editTeamName').val(),
                teamCode: $('#editTeamCode').val(),
                subTeamCode: $('#editSubTeamCode').val(),
                category: $('#editTeamCategory').val(),
                description: $('#editTeamDescription').val()
            };

            if (!data.name || !data.teamCode) {
                showAlert('Team name and code are required', 'warning');
                return;
            }

            $.ajax({
                url: `/api/admin/TeamManagementApi/update-team/${teamId}`,
                type: 'PUT',
                data: JSON.stringify(data),
                contentType: 'application/json'
            })
            .done(function(response) {
                if (response.success) {
                    showAlert('Team updated successfully', 'success');
                    $('#editTeamModal').modal('hide');
                    loadTeams();
                } else {
                    showAlert(response.message, 'danger');
                }
            })
            .fail(function(xhr) {
                const message = xhr.responseJSON?.message || 'Error updating team';
                showAlert(message, 'danger');
            });
        }

        function viewTeamMembers(teamId) {
            $('#teamMembersModal').data('team-id', teamId);
            loadTeamMembers(teamId);
            $('#teamMembersModal').modal('show');
        }

        function loadTeamMembers(teamId) {
            $.get(`/api/admin/TeamManagementApi/team-members/${teamId}`)
                .done(function(members) {
                    const tbody = $('#teamMembersTable tbody');
                    tbody.empty();
                    
                    members.forEach(function(member) {
                        const row = `
                            <tr>
                                <td>${member.firstName} ${member.lastName}</td>
                                <td>${member.email}</td>
                                <td><span class="badge bg-info">${member.role || 'Member'}</span></td>
                                <td>${new Date(member.assignedDate).toLocaleDateString()}</td>
                                <td>
                                    <button class="btn btn-sm btn-danger" onclick="removeUserFromTeam('${member.id}', '${teamId}')">
                                        <i class="fas fa-trash"></i> Remove
                                    </button>
                                </td>
                            </tr>
                        `;
                        tbody.append(row);
                    });
                })
                .fail(function() {
                    showAlert('Error loading team members', 'danger');
                });
        }

        function assignUserToTeam() {
            const teamId = $('#teamMembersModal').data('team-id');
            const userId = $('#userSelect').val();

            if (!userId) {
                showAlert('Please select a user', 'warning');
                return;
            }

            const data = {
                userId: userId,
                teamId: teamId
            };

            $.post('/api/admin/TeamManagementApi/assign-user-to-team', data)
                .done(function(response) {
                    if (response.success) {
                        showAlert('User assigned to team successfully', 'success');
                        $('#userSelect').val('');
                        loadTeamMembers(teamId);
                    } else {
                        showAlert(response.message, 'danger');
                    }
                })
                .fail(function(xhr) {
                    const message = xhr.responseJSON?.message || 'Error assigning user to team';
                    showAlert(message, 'danger');
                });
        }

        function removeUserFromTeam(userId, teamId) {
            if (confirm('Are you sure you want to remove this user from the team?')) {
                $.ajax({
                    url: `/api/admin/TeamManagementApi/remove-user-from-team/${userId}`,
                    type: 'DELETE'
                })
                .done(function(response) {
                    if (response.success) {
                        showAlert('User removed from team successfully', 'success');
                        loadTeamMembers(teamId);
                    } else {
                        showAlert(response.message, 'danger');
                    }
                })
                .fail(function() {
                    showAlert('Error removing user from team', 'danger');
                });
            }
        }

        function deleteTeam(teamId) {
            if (confirm('Are you sure you want to delete this team? This action cannot be undone.')) {
                $.ajax({
                    url: `/api/admin/TeamManagementApi/delete-team/${teamId}`,
                    type: 'DELETE'
                })
                .done(function(response) {
                    if (response.success) {
                        showAlert('Team deleted successfully', 'success');
                        loadTeams();
                    } else {
                        showAlert(response.message, 'danger');
                    }
                })
                .fail(function() {
                    showAlert('Error deleting team', 'danger');
                });
            }
        }

        // showAlert function is now provided by the centralized AlertSystem
    </script>
}
