@model WargameBoard.Core.Entities.Side

@{
    ViewData["Title"] = "Delete Side";
}

<div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-3 pb-2 mb-3 border-bottom">
    <h1 class="h2 text-danger">Delete Side</h1>
    <div class="btn-toolbar mb-2 mb-md-0">
        <a asp-action="Index" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left"></i> Back to List
        </a>
    </div>
</div>

<div class="alert alert-warning" role="alert">
    <h4 class="alert-heading">
        <i class="bi bi-exclamation-triangle"></i> Warning!
    </h4>
    <p>Are you sure you want to delete this side? This action cannot be undone.</p>
    <hr>
    <p class="mb-0">This may affect units and other entities that reference this side.</p>
</div>

<div class="row">
    <div class="col-md-8">
        <div class="card">
            <div class="card-header">
                <h5 class="card-title mb-0">Side Information</h5>
            </div>
            <div class="card-body">
                <dl class="row">
                    <dt class="col-sm-3">Name:</dt>
                    <dd class="col-sm-9">@Model.Name</dd>

                    <dt class="col-sm-3">Color:</dt>
                    <dd class="col-sm-9">
                        @if (!string.IsNullOrEmpty(Model.Color))
                        {
                            <span class="badge" style="background-color: @Model.Color; color: white;">
                                @Model.Color
                            </span>
                        }
                        else
                        {
                            <span class="text-muted">Not specified</span>
                        }
                    </dd>

                    <dt class="col-sm-3">Description:</dt>
                    <dd class="col-sm-9">
                        @if (!string.IsNullOrEmpty(Model.Description))
                        {
                            @Model.Description
                        }
                        else
                        {
                            <span class="text-muted">No description provided</span>
                        }
                    </dd>

                    <dt class="col-sm-3">Status:</dt>
                    <dd class="col-sm-9">
                        @if (Model.IsActive)
                        {
                            <span class="badge bg-success">Active</span>
                        }
                        else
                        {
                            <span class="badge bg-secondary">Inactive</span>
                        }
                    </dd>
                </dl>

                <form asp-action="Delete" method="post" class="mt-4">
                    <input type="hidden" asp-for="Id" />
                    <div class="d-flex justify-content-between">
                        <a asp-action="Index" class="btn btn-secondary">
                            <i class="bi bi-arrow-left"></i> Cancel
                        </a>
                        <button type="submit" class="btn btn-danger">
                            <i class="bi bi-trash"></i> Delete Side
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
