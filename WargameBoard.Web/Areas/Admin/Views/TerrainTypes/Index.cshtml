@model IEnumerable<WargameBoard.Core.Entities.TerrainType>

@{
    ViewData["Title"] = "Terrain Types";
    var pagingInfo = ViewBag.PagingInfo as WargameBoard.Web.Models.PagingInfo;
    var searchString = ViewBag.SearchString as string;
}

<div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-3 pb-2 mb-3 border-bottom">
    <h1 class="h2">Terrain Types</h1>
    <div class="btn-toolbar mb-2 mb-md-0">
        <a asp-action="Create" class="btn btn-primary">
            <i class="bi bi-plus"></i> Create New
        </a>
    </div>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<!-- Search Form -->
<form asp-action="Index" method="get" class="mb-3">
    <div class="row">
        <div class="col-md-6">
            <div class="input-group">
                <input type="text" name="searchString" value="@searchString" class="form-control" placeholder="Search terrain types..." />
                <button type="submit" class="btn btn-outline-secondary">
                    <i class="bi bi-search"></i> Search
                </button>
                @if (!string.IsNullOrEmpty(searchString))
                {
                    <a asp-action="Index" class="btn btn-outline-secondary">
                        <i class="bi bi-x"></i> Clear
                    </a>
                }
            </div>
        </div>
    </div>
</form>

<div class="card">
    <div class="card-body">
        @if (Model.Any())
        {
            <div class="table-responsive">
                <table class="table table-striped table-hover">
                    <thead class="table-dark">
                        <tr>
                            <th>Name</th>
                            <th>Color</th>
                            <th>Movement Cost</th>
                            <th>Defense Modifier</th>
                            <th>Status</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td>
                                    <strong>@item.Name</strong>
                                </td>
                                <td>
                                    @if (!string.IsNullOrEmpty(item.Color))
                                    {
                                        <span class="badge" style="background-color: @item.Color; color: white;">
                                            @item.Color
                                        </span>
                                    }
                                </td>
                                <td>
                                    <span class="badge bg-primary">@item.MovementCost</span>
                                </td>
                                <td>
                                    @if (item.DefenseModifier > 0)
                                    {
                                        <span class="badge bg-success">+@item.DefenseModifier</span>
                                    }
                                    else if (item.DefenseModifier < 0)
                                    {
                                        <span class="badge bg-danger">@item.DefenseModifier</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">0</span>
                                    }
                                </td>
                                <td>
                                    @if (item.IsActive)
                                    {
                                        <span class="badge bg-success">Active</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">Inactive</span>
                                    }
                                </td>
                                <td>
                                    <div class="btn-group btn-group-sm" role="group">
                                        <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-outline-info">
                                            <i class="bi bi-eye"></i>
                                        </a>
                                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-outline-primary">
                                            <i class="bi bi-pencil"></i>
                                        </a>
                                        <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-outline-danger">
                                            <i class="bi bi-trash"></i>
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            @if (pagingInfo != null)
            {
                @await Html.PartialAsync("_PagingPartial", pagingInfo)
            }
        }
        else
        {
            <div class="text-center py-5">
                <i class="bi bi-inbox display-1 text-muted"></i>
                <h4 class="text-muted mt-3">No terrain types found</h4>
                <p class="text-muted">
                    @if (!string.IsNullOrEmpty(searchString))
                    {
                        <span>No terrain types match your search criteria.</span>
                    }
                    else
                    {
                        <span>Get started by creating your first terrain type.</span>
                    }
                </p>
                <a asp-action="Create" class="btn btn-primary">
                    <i class="bi bi-plus"></i> Create First Terrain Type
                </a>
            </div>
        }
    </div>
</div>
