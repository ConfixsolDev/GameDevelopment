@model WargameBoard.Core.Entities.TerrainType

<div class="row">
    <div class="col-md-6">
        <div class="mb-3">
            <label asp-for="Name" class="form-label"></label>
            <input asp-for="Name" class="form-control" placeholder="Enter terrain type name" />
            <span asp-validation-for="Name" class="text-danger"></span>
        </div>
    </div>
    <div class="col-md-6">
        <div class="mb-3">
            <label asp-for="Color" class="form-label"></label>
            <input asp-for="Color" type="color" class="form-control form-control-color" />
            <span asp-validation-for="Color" class="text-danger"></span>
            <div class="form-text">Choose a color to represent this terrain type</div>
        </div>
    </div>
</div>

<div class="row">
    <div class="col-md-6">
        <div class="mb-3">
            <label asp-for="MovementCost" class="form-label"></label>
            <input asp-for="MovementCost" class="form-control" min="0" max="10" />
            <span asp-validation-for="MovementCost" class="text-danger"></span>
            <div class="form-text">Movement cost multiplier (1 = normal, 2 = double cost, etc.)</div>
        </div>
    </div>
    <div class="col-md-6">
        <div class="mb-3">
            <label asp-for="DefenseModifier" class="form-label"></label>
            <input asp-for="DefenseModifier" class="form-control" min="-10" max="10" />
            <span asp-validation-for="DefenseModifier" class="text-danger"></span>
            <div class="form-text">Defense modifier (-10 to +10)</div>
        </div>
    </div>
</div>

<div class="mb-3">
    <label asp-for="Description" class="form-label"></label>
    <textarea asp-for="Description" class="form-control" rows="3" placeholder="Enter description (optional)"></textarea>
    <span asp-validation-for="Description" class="text-danger"></span>
</div>

<div class="mb-3">
    <div class="form-check">
        <input asp-for="IsActive" class="form-check-input" />
        <label asp-for="IsActive" class="form-check-label">
            Active
        </label>
    </div>
    <div class="form-text">Inactive terrain types will not appear in selection lists</div>
</div>
