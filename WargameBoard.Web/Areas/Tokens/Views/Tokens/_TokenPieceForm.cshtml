@model WargameBoard.Web.Models.ViewModels.TokenPieceEditVm
@{
    Layout = "/Views/Shared/_Layout.cshtml";
}
<form id="pieceForm" asp-action="@(Model.Id == 0 ? "CreatePiece" : "EditPiece")" method="post">
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
    
    @if (Model.Id != 0)
    {
        <input asp-for="Id" type="hidden" />
    }

    <input asp-for="TokenDesignId" type="hidden" />

    <div class="row">
        <div class="col-md-6">
            <div class="mb-3">
                <label asp-for="SideId" class="form-label"></label>
                <select asp-for="SideId" asp-items="Model.Sides" class="form-select">
                    <option value="">-- No Side --</option>
                </select>
                <span asp-validation-for="SideId" class="text-danger"></span>
            </div>
        </div>
        <div class="col-md-6">
            <div class="mb-3">
                <label asp-for="Serial" class="form-label"></label>
                <input asp-for="Serial" class="form-control" />
                <span asp-validation-for="Serial" class="text-danger"></span>
            </div>
        </div>
    </div>

    <div class="mb-3">
        <label asp-for="HardwareIdentity" class="form-label"></label>
        <input asp-for="HardwareIdentity" class="form-control" />
        <div class="form-text">Hardware Identity must be unique across all token pieces.</div>
        <span asp-validation-for="HardwareIdentity" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <div class="form-check">
            <input asp-for="IsUnique" class="form-check-input" />
            <label asp-for="IsUnique" class="form-check-label"></label>
        </div>
    </div>

    <div class="d-flex justify-content-end">
        <button type="button" class="btn btn-secondary me-2" data-bs-dismiss="modal">Cancel</button>
        <button type="submit" class="btn btn-primary">
            <i class="fas fa-save"></i> @(Model.Id == 0 ? "Create" : "Update") Piece
        </button>
    </div>
</form>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
