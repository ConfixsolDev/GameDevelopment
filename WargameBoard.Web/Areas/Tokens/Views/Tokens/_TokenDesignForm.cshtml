@model WargameBoard.Web.Models.ViewModels.TokenDesignEditVm
@{
    Layout = "/Views/Shared/_Layout.cshtml";
}
<form id="designForm" asp-action="@(Model.Id == 0 ? "CreateDesign" : "EditDesign")" method="post">
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
    
    @if (Model.Id != 0)
    {
        <input asp-for="Id" type="hidden" />
    }

    <div class="row">
        <div class="col-md-6">
            <div class="mb-3">
                <label asp-for="TokenGroupId" class="form-label"></label>
                <select asp-for="TokenGroupId" asp-items="Model.TokenGroups" class="form-select">
                    <option value="">-- Select Token Type --</option>
                </select>
                <span asp-validation-for="TokenGroupId" class="text-danger"></span>
            </div>
        </div>
        <div class="col-md-6">
            <div class="mb-3">
                <label asp-for="DefaultSideId" class="form-label"></label>
                <select asp-for="DefaultSideId" asp-items="Model.Sides" class="form-select">
                    <option value="">-- No Default Side --</option>
                </select>
                <span asp-validation-for="DefaultSideId" class="text-danger"></span>
            </div>
        </div>
    </div>

    <div class="mb-3">
        <label asp-for="Name" class="form-label"></label>
        <input asp-for="Name" class="form-control" />
        <span asp-validation-for="Name" class="text-danger"></span>
    </div>

    <div class="row">
        <div class="col-md-6">
            <div class="mb-3">
                <label asp-for="WidthMm" class="form-label"></label>
                <input asp-for="WidthMm" class="form-control" min="1" max="100" step="0.1" />
                <span asp-validation-for="WidthMm" class="text-danger"></span>
            </div>
        </div>
        <div class="col-md-6">
            <div class="mb-3">
                <label asp-for="HeightMm" class="form-label"></label>
                <input asp-for="HeightMm" class="form-control" min="1" max="100" step="0.1" />
                <span asp-validation-for="HeightMm" class="text-danger"></span>
            </div>
        </div>
    </div>

    <div class="mb-3">
        <label asp-for="Notes" class="form-label"></label>
        <textarea asp-for="Notes" class="form-control" rows="3"></textarea>
        <span asp-validation-for="Notes" class="text-danger"></span>
    </div>

    <div class="d-flex justify-content-end">
        <button type="button" class="btn btn-secondary me-2" data-bs-dismiss="modal">Cancel</button>
        <button type="submit" class="btn btn-primary">
            <i class="fas fa-save"></i> @(Model.Id == 0 ? "Create" : "Update") Design
        </button>
    </div>
</form>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
