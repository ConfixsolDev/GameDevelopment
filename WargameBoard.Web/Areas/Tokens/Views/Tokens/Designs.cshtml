@model IEnumerable<WargameBoard.Core.Entities.TokenDesign>

@{
    ViewData["Title"] = "Token Designs";
    Layout = "/Views/Shared/_Layout.cshtml";
}

<div class="row">
    <div class="col-md-12">
        <div class="card">
            <div class="card-header d-flex justify-content-between align-items-center">
                <h3 class="card-title">
                    <i class="fas fa-puzzle-piece"></i> Token Designs
                </h3>
                <button type="button" class="btn btn-primary" id="createDesignBtn">
                    <i class="fas fa-plus"></i> Create Design
                </button>
            </div>
            <div class="card-body">
                @if (TempData["SuccessMessage"] != null)
                {
                    <div class="alert alert-success alert-dismissible fade show" role="alert">
                        @TempData["SuccessMessage"]
                        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                    </div>
                }

                <div class="row">
                    <!-- Left Panel - Designs Grid -->
                    <div class="col-md-6">
                        <h5>Designs</h5>
                        <div id="designsContainer">
                            @if (Model.Any())
                            {
                                <div class="table-responsive">
                                    <table class="table table-striped table-hover" id="designsTable">
                                        <thead>
                                            <tr>
                                                <th>Name</th>
                                                <th>Type</th>
                                                <th>Size</th>
                                                <th>Actions</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            @foreach (var design in Model)
                                            {
                                                <tr data-design-id="@design.Id" class="design-row">
                                                    <td>@design.Name</td>
                                                    <td>@design.TokenGroupId</td>
                                                    <td>@design.WidthMm x @design.HeightMm mm</td>
                                                    <td>
                                                        <div class="btn-group" role="group">
                                                            <button type="button" class="btn btn-sm btn-outline-primary editDesignBtn" data-design-id="@design.Id">
                                                                <i class="fas fa-edit"></i>
                                                            </button>
                                                            <button type="button" class="btn btn-sm btn-outline-danger deleteDesignBtn" data-design-id="@design.Id">
                                                                <i class="fas fa-trash"></i>
                                                            </button>
                                                        </div>
                                                    </td>
                                                </tr>
                                            }
                                        </tbody>
                                    </table>
                                </div>
                            }
                            else
                            {
                                <div class="text-center py-4">
                                    <i class="fas fa-puzzle-piece fa-3x text-muted mb-3"></i>
                                    <h5 class="text-muted">No designs found</h5>
                                    <p class="text-muted">Create your first token design to get started.</p>
                                </div>
                            }
                        </div>
                    </div>

                    <!-- Right Panel - Pieces List -->
                    <div class="col-md-6">
                        <div class="d-flex justify-content-between align-items-center mb-3">
                            <h5 id="piecesTitle">Pieces</h5>
                            <button type="button" class="btn btn-success btn-sm" id="createPieceBtn" style="display: none;">
                                <i class="fas fa-plus"></i> Add Piece
                            </button>
                        </div>
                        <div id="piecesContainer">
                            <div class="text-center py-4">
                                <i class="fas fa-cubes fa-3x text-muted mb-3"></i>
                                <h5 class="text-muted">Select a design</h5>
                                <p class="text-muted">Choose a design from the left panel to view its pieces.</p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Design Form Modal -->
<div class="modal fade" id="designModal" tabindex="-1" aria-labelledby="designModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="designModalLabel">Token Design</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body" id="designModalBody">
                <!-- Design form will be loaded here -->
            </div>
        </div>
    </div>
</div>

<!-- Piece Form Modal -->
<div class="modal fade" id="pieceModal" tabindex="-1" aria-labelledby="pieceModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="pieceModalLabel">Token Piece</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body" id="pieceModalBody">
                <!-- Piece form will be loaded here -->
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        let selectedDesignId = null;

        $(document).ready(function() {
            // Create Design button click handler
            $('#createDesignBtn').click(function() {
                $.get('@Url.Action("CreateDesign", "Tokens")')
                    .done(function(data) {
                        $('#designModalLabel').text('Create Token Design');
                        $('#designModalBody').html(data);
                        $('#designModal').modal('show');
                    })
                    .fail(function() {
                        alert('Failed to load design form');
                    });
            });

            // Edit Design button click handler
            $(document).on('click', '.editDesignBtn', function() {
                var designId = $(this).data('design-id');
                $.get('@Url.Action("EditDesign", "Tokens")', { id: designId })
                    .done(function(data) {
                        $('#designModalLabel').text('Edit Token Design');
                        $('#designModalBody').html(data);
                        $('#designModal').modal('show');
                    })
                    .fail(function() {
                        alert('Failed to load design form');
                    });
            });

            // Delete Design button click handler
            $(document).on('click', '.deleteDesignBtn', function() {
                var designId = $(this).data('design-id');
                if (confirm('Are you sure you want to delete this design? This will also delete all associated pieces.')) {
                    $.post('@Url.Action("DeleteDesign", "Tokens")', { id: designId })
                        .done(function(response) {
                            if (response.success) {
                                location.reload();
                            } else {
                                alert('Failed to delete design: ' + response.message);
                            }
                        })
                        .fail(function() {
                            alert('Failed to delete design');
                        });
                }
            });

            // Design row click handler
            $(document).on('click', '.design-row', function() {
                $('.design-row').removeClass('table-active');
                $(this).addClass('table-active');
                
                var designId = $(this).data('design-id');
                var designName = $(this).find('td:first').text();
                selectedDesignId = designId;
                
                // Load pieces for selected design
                $.get('@Url.Action("Pieces", "Tokens")', { designId: designId })
                    .done(function(data) {
                        $('#piecesTitle').text('Pieces - ' + designName);
                        $('#piecesContainer').html(data);
                        $('#createPieceBtn').show();
                    })
                    .fail(function() {
                        alert('Failed to load pieces');
                    });
            });

            // Create Piece button click handler
            $(document).on('click', '#createPieceBtn', function() {
                if (!selectedDesignId) {
                    alert('Please select a design first');
                    return;
                }
                
                $.get('@Url.Action("CreatePiece", "Tokens")', { designId: selectedDesignId })
                    .done(function(data) {
                        $('#pieceModalLabel').text('Create Token Piece');
                        $('#pieceModalBody').html(data);
                        $('#pieceModal').modal('show');
                    })
                    .fail(function() {
                        alert('Failed to load piece form');
                    });
            });

            // Edit Piece button click handler
            $(document).on('click', '.editPieceBtn', function() {
                var pieceId = $(this).data('piece-id');
                $.get('@Url.Action("EditPiece", "Tokens")', { id: pieceId })
                    .done(function(data) {
                        $('#pieceModalLabel').text('Edit Token Piece');
                        $('#pieceModalBody').html(data);
                        $('#pieceModal').modal('show');
                    })
                    .fail(function() {
                        alert('Failed to load piece form');
                    });
            });

            // Delete Piece button click handler
            $(document).on('click', '.deletePieceBtn', function() {
                var pieceId = $(this).data('piece-id');
                if (confirm('Are you sure you want to delete this piece?')) {
                    $.post('@Url.Action("DeletePiece", "Tokens")', { id: pieceId })
                        .done(function(response) {
                            if (response.success) {
                                // Reload pieces for current design
                                if (selectedDesignId) {
                                    $.get('@Url.Action("Pieces", "Tokens")', { designId: selectedDesignId })
                                        .done(function(data) {
                                            $('#piecesContainer').html(data);
                                        });
                                }
                            } else {
                                alert('Failed to delete piece: ' + response.message);
                            }
                        })
                        .fail(function() {
                            alert('Failed to delete piece');
                        });
                }
            });

            // Design form submit handler
            $(document).on('submit', '#designForm', function(e) {
                e.preventDefault();
                var formData = $(this).serialize();
                var url = $(this).attr('action');
                
                $.post(url, formData)
                    .done(function(response) {
                        if (response.success) {
                            $('#designModal').modal('hide');
                            location.reload();
                        } else {
                            $('#designModalBody').html(response);
                        }
                    })
                    .fail(function() {
                        alert('Failed to save design');
                    });
            });

            // Piece form submit handler
            $(document).on('submit', '#pieceForm', function(e) {
                e.preventDefault();
                var formData = $(this).serialize();
                var url = $(this).attr('action');
                
                $.post(url, formData)
                    .done(function(response) {
                        if (response.success) {
                            $('#pieceModal').modal('hide');
                            // Reload pieces for current design
                            if (selectedDesignId) {
                                $.get('@Url.Action("Pieces", "Tokens")', { designId: selectedDesignId })
                                    .done(function(data) {
                                        $('#piecesContainer').html(data);
                                    });
                            }
                        } else {
                            $('#pieceModalBody').html(response);
                        }
                    })
                    .fail(function() {
                        alert('Failed to save piece');
                    });
            });
        });
    </script>
}
