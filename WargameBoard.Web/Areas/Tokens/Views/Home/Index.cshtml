@{
    ViewData["Title"] = "Tokens";
}

<div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-3 pb-2 mb-3 border-bottom">
    <h1 class="h2">Tokens</h1>
    <div class="btn-toolbar mb-2 mb-md-0">
        <button type="button" class="btn btn-sm btn-primary">New Token</button>
    </div>
</div>

<div class="row">
    <div class="col-md-6">
        <div class="card">
            <div class="card-header">
                <h5 class="card-title">Token Types</h5>
            </div>
            <div class="card-body">
                <div class="list-group">
                    <a href="#" class="list-group-item list-group-item-action">
                        <div class="d-flex w-100 justify-content-between">
                            <h5 class="mb-1">Objective Tokens</h5>
                            <small>12 active</small>
                        </div>
                        <p class="mb-1">Mark objectives and control points</p>
                    </a>
                    <a href="#" class="list-group-item list-group-item-action">
                        <div class="d-flex w-100 justify-content-between">
                            <h5 class="mb-1">Status Tokens</h5>
                            <small>8 active</small>
                        </div>
                        <p class="mb-1">Track unit status and conditions</p>
                    </a>
                    <a href="#" class="list-group-item list-group-item-action">
                        <div class="d-flex w-100 justify-content-between">
                            <h5 class="mb-1">Terrain Tokens</h5>
                            <small>25 active</small>
                        </div>
                        <p class="mb-1">Mark terrain features and obstacles</p>
                    </a>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-6">
        <div class="card">
            <div class="card-header">
                <h5 class="card-title">Token Assignment</h5>
            </div>
            <div class="card-body">
                <form>
                    <div class="mb-3">
                        <label for="TokenGroup" class="form-label">Token Type</label>
                        <select class="form-select" id="TokenGroup">
                            <option>Objective</option>
                            <option>Status</option>
                            <option>Terrain</option>
                        </select>
                    </div>
                    <div class="mb-3">
                        <label for="assignedTo" class="form-label">Assign To</label>
                        <select class="form-select" id="assignedTo">
                            <option>Blue Team</option>
                            <option>Red Team</option>
                            <option>Neutral</option>
                        </select>
                    </div>
                    <button type="submit" class="btn btn-primary">Assign Token</button>
                </form>
            </div>
        </div>
    </div>
</div>
