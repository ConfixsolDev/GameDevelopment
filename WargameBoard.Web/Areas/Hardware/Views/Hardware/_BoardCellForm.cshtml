@model WargameBoard.Core.Entities.BoardCell

<form id="addCellForm" asp-action="CreateBoardCell" method="post">
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

    <div class="row">
        <div class="col-md-6">
            <div class="mb-3">
                <label asp-for="BoardId" class="form-label">Board ID</label>
                <input asp-for="BoardId" class="form-control" value="1" />
                <span asp-validation-for="BoardId" class="text-danger"></span>
            </div>
        </div>
        <div class="col-md-6">
            <div class="mb-3">
                <label asp-for="Row" class="form-label">Row</label>
                <input asp-for="Row" class="form-control" min="0" max="20" />
                <span asp-validation-for="Row" class="text-danger"></span>
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-md-6">
            <div class="mb-3">
                <label asp-for="Col" class="form-label">Column</label>
                <input asp-for="Col" class="form-control" min="0" max="20" />
                <span asp-validation-for="Col" class="text-danger"></span>
            </div>
        </div>
        <div class="col-md-6">
            <div class="mb-3">
                <label asp-for="SensorAddress" class="form-label">Sensor Address</label>
                <input asp-for="SensorAddress" class="form-control" placeholder="e.g., A1, B2, etc." />
                <span asp-validation-for="SensorAddress" class="text-danger"></span>
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-md-6">
            <div class="mb-3">
                <label asp-for="HexId" class="form-label">Hex ID</label>
                <select asp-for="HexId" asp-items="ViewBag.Hexes" class="form-select">
                    <option value="">-- No Hex --</option>
                </select>
                <span asp-validation-for="HexId" class="text-danger"></span>
            </div>
        </div>
        <div class="col-md-6">
            <div class="mb-3">
                <label asp-for="Threshold" class="form-label">Threshold</label>
                <input asp-for="Threshold" class="form-control" min="0" max="100" placeholder="Optional" />
                <span asp-validation-for="Threshold" class="text-danger"></span>
            </div>
        </div>
    </div>

    <div class="d-flex justify-content-end">
        <button type="button" class="btn btn-secondary me-2" data-bs-dismiss="modal">Cancel</button>
        <button type="submit" class="btn btn-primary">
            <i class="fas fa-plus"></i> Add Cell
        </button>
    </div>
</form>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
