@model IEnumerable<WargameBoard.Core.Entities.BoardCell>

<div class="table-responsive">
    <table class="table table-striped table-hover" id="diagnosticsTable">
        <thead>
            <tr>
                <th>Row</th>
                <th>Col</th>
                <th>Sensor Address</th>
                <th>Hex ID</th>
                <th>Threshold</th>
                <th>Last Strength</th>
                <th>Last Update</th>
                <th>Status</th>
            </tr>
        </thead>
        <tbody id="diagnosticsTableBody">
            @foreach (var cell in Model)
            {
                <tr data-cell-id="@cell.Id" class="@(cell.LastStrength > cell.Threshold ? "table-warning" : "")">
                    <td>@cell.Row</td>
                    <td>@cell.Col</td>
                    <td>@(cell.SensorAddress ?? "N/A")</td>
                    <td>@(cell.HexId?.ToString() ?? "N/A")</td>
                    <td>@(cell.Threshold?.ToString() ?? "N/A")</td>
                    <td class="strength-cell">
                        @if (cell.LastStrength.HasValue)
                        {
                            <span class="badge @(cell.LastStrength > cell.Threshold ? "bg-warning" : "bg-secondary")">
                                @cell.LastStrength
                            </span>
                        }
                        else
                        {
                            <span class="text-muted">N/A</span>
                        }
                    </td>
                    <td class="update-time">
                        @if (cell.LastStrengthUpdate.HasValue)
                        {
                            <small class="text-muted">@cell.LastStrengthUpdate.Value.ToString("HH:mm:ss")</small>
                        }
                        else
                        {
                            <span class="text-muted">Never</span>
                        }
                    </td>
                    <td>
                        @if (cell.LastStrength.HasValue)
                        {
                            @if (cell.LastStrength > cell.Threshold)
                            {
                                <span class="badge bg-warning">
                                    <i class="fas fa-exclamation-triangle"></i> Above Threshold
                                </span>
                            }
                            else
                            {
                                <span class="badge bg-success">
                                    <i class="fas fa-check"></i> Normal
                                </span>
                            }
                        }
                        else
                        {
                            <span class="badge bg-secondary">
                                <i class="fas fa-question"></i> No Data
                            </span>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
