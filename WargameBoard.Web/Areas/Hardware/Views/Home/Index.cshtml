@{
    ViewData["Title"] = "Hardware";
}

<div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-3 pb-2 mb-3 border-bottom">
    <h1 class="h2">Hardware Management</h1>
    <div class="btn-toolbar mb-2 mb-md-0">
        <button type="button" class="btn btn-sm btn-primary">Add Device</button>
    </div>
</div>

<div class="row">
    <div class="col-md-6">
        <div class="card">
            <div class="card-header">
                <h5 class="card-title">Connected Devices</h5>
            </div>
            <div class="card-body">
                <div class="list-group">
                    <div class="list-group-item d-flex justify-content-between align-items-center">
                        <div>
                            <h6 class="mb-1">Tablet - Player 1</h6>
                            <small>192.168.1.100 - Online</small>
                        </div>
                        <span class="badge bg-success rounded-pill">Connected</span>
                    </div>
                    <div class="list-group-item d-flex justify-content-between align-items-center">
                        <div>
                            <h6 class="mb-1">Tablet - Player 2</h6>
                            <small>192.168.1.101 - Online</small>
                        </div>
                        <span class="badge bg-success rounded-pill">Connected</span>
                    </div>
                    <div class="list-group-item d-flex justify-content-between align-items-center">
                        <div>
                            <h6 class="mb-1">Projector</h6>
                            <small>192.168.1.102 - Offline</small>
                        </div>
                        <span class="badge bg-danger rounded-pill">Disconnected</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-6">
        <div class="card">
            <div class="card-header">
                <h5 class="card-title">System Status</h5>
            </div>
            <div class="card-body">
                <div class="row">
                    <div class="col-6">
                        <div class="text-center">
                            <h4 class="text-success">CPU</h4>
                            <div class="progress mb-2">
                                <div class="progress-bar bg-success" style="width: 25%"></div>
                            </div>
                            <small>25%</small>
                        </div>
                    </div>
                    <div class="col-6">
                        <div class="text-center">
                            <h4 class="text-info">Memory</h4>
                            <div class="progress mb-2">
                                <div class="progress-bar bg-info" style="width: 60%"></div>
                            </div>
                            <small>60%</small>
                        </div>
                    </div>
                </div>
                <hr>
                <div class="row">
                    <div class="col-6">
                        <div class="text-center">
                            <h4 class="text-warning">Network</h4>
                            <div class="progress mb-2">
                                <div class="progress-bar bg-warning" style="width: 40%"></div>
                            </div>
                            <small>40%</small>
                        </div>
                    </div>
                    <div class="col-6">
                        <div class="text-center">
                            <h4 class="text-primary">Storage</h4>
                            <div class="progress mb-2">
                                <div class="progress-bar bg-primary" style="width: 75%"></div>
                            </div>
                            <small>75%</small>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
