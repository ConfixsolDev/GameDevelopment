@{
    ViewData["Title"] = "Units";
}

<div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-3 pb-2 mb-3 border-bottom">
    <h1 class="h2">Units</h1>
    <div class="btn-toolbar mb-2 mb-md-0">
        <button type="button" class="btn btn-sm btn-primary">New Unit</button>
    </div>
</div>

<div class="row">
    <div class="col-12">
        <div class="card">
            <div class="card-header">
                <h5 class="card-title">Unit Library</h5>
            </div>
            <div class="card-body">
                <div class="row">
                    <div class="col-md-4 mb-3">
                        <div class="card">
                            <div class="card-body">
                                <h5 class="card-title">M1A1 Abrams</h5>
                                <p class="card-text">Main Battle Tank</p>
                                <p class="card-text"><small class="text-muted">Armor: Heavy | Speed: Medium</small></p>
                                <button class="btn btn-sm btn-primary">Edit</button>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-4 mb-3">
                        <div class="card">
                            <div class="card-body">
                                <h5 class="card-title">AH-64 Apache</h5>
                                <p class="card-text">Attack Helicopter</p>
                                <p class="card-text"><small class="text-muted">Armor: Light | Speed: High</small></p>
                                <button class="btn btn-sm btn-primary">Edit</button>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-4 mb-3">
                        <div class="card">
                            <div class="card-body">
                                <h5 class="card-title">Infantry Squad</h5>
                                <p class="card-text">Ground Infantry</p>
                                <p class="card-text"><small class="text-muted">Armor: None | Speed: Low</small></p>
                                <button class="btn btn-sm btn-primary">Edit</button>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
