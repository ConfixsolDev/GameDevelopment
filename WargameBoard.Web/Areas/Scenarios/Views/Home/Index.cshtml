@{
    ViewData["Title"] = "Scenarios";
}

<div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-3 pb-2 mb-3 border-bottom">
    <h1 class="h2">Scenarios</h1>
    <div class="btn-toolbar mb-2 mb-md-0">
        <button type="button" class="btn btn-sm btn-primary">New Scenario</button>
    </div>
</div>

<div class="row">
    <div class="col-12">
        <div class="card">
            <div class="card-header">
                <h5 class="card-title">Available Scenarios</h5>
            </div>
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table table-striped">
                        <thead>
                            <tr>
                                <th>Name</th>
                                <th>Description</th>
                                <th>Players</th>
                                <th>Duration</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr>
                                <td>Operation Desert Storm</td>
                                <td>Modern warfare scenario in desert terrain</td>
                                <td>2-4</td>
                                <td>2-3 hours</td>
                                <td>
                                    <button class="btn btn-sm btn-primary">Edit</button>
                                    <button class="btn btn-sm btn-success">Play</button>
                                </td>
                            </tr>
                            <tr>
                                <td>Battle of Normandy</td>
                                <td>World War II D-Day scenario</td>
                                <td>2-6</td>
                                <td>3-4 hours</td>
                                <td>
                                    <button class="btn btn-sm btn-primary">Edit</button>
                                    <button class="btn btn-sm btn-success">Play</button>
                                </td>
                            </tr>
                            <tr>
                                <td>Urban Warfare</td>
                                <td>Close quarters combat in city environment</td>
                                <td>2-3</td>
                                <td>1-2 hours</td>
                                <td>
                                    <button class="btn btn-sm btn-primary">Edit</button>
                                    <button class="btn btn-sm btn-success">Play</button>
                                </td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>
