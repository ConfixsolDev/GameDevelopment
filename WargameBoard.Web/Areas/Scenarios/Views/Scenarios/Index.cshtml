@model IEnumerable<WargameBoard.Core.Entities.Scenario>
@using WargameBoard.Web.Models

@{
    ViewData["Title"] = "Scenarios";
    var pagingInfo = ViewBag.PagingInfo as PagingInfo;
    var searchString = ViewBag.SearchString as string;
}

<div class="row">
    <div class="col-md-12">
        <div class="card">
            <div class="card-header d-flex justify-content-between align-items-center">
                <h3 class="card-title">Scenarios</h3>
                <a asp-action="Create" class="btn btn-primary">
                    <i class="fas fa-plus"></i> Create New Scenario
                </a>
            </div>
            <div class="card-body">
                <!-- Search and Pagination -->
                <partial name="_SearchAndPaging" model="pagingInfo" />

                @if (Model.Any())
                {
                    <div class="table-responsive">
                        <table class="table table-striped">
                            <thead>
                                <tr>
                                    <th>Name</th>
                                    <th>Turn Length</th>
                                    <th>Max Turns</th>
                                    <th>Weather</th>
                                    <th>Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var scenario in Model)
                                {
                                    <tr>
                                        <td>@scenario.Name</td>
                                        <td>@scenario.TurnLengthMinutes minutes</td>
                                        <td>@scenario.MaxTurns</td>
                                        <td>@(scenario.Weather)</td>
                                        <td>
                                            <div class="btn-group" role="group">
                                                <a asp-action="Edit" asp-route-id="@scenario.Id" class="btn btn-sm btn-outline-primary">
                                                    <i class="fas fa-edit"></i> Edit
                                                </a>
                                                <a asp-action="Units" asp-route-id="@scenario.Id" class="btn btn-sm btn-outline-info">
                                                    <i class="fas fa-users"></i> Units
                                                </a>
                                                <a asp-action="Objectives" asp-route-id="@scenario.Id" class="btn btn-sm btn-outline-success">
                                                    <i class="fas fa-flag"></i> Objectives
                                                </a>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <div class="text-center py-4">
                        <i class="fas fa-clipboard-list fa-3x text-muted mb-3"></i>
                        <h5 class="text-muted">No scenarios found</h5>
                        <p class="text-muted">
                            @if (!string.IsNullOrEmpty(searchString))
                            {
                                <span>No scenarios match your search criteria.</span>
                            }
                            else
                            {
                                <span>Get started by creating your first scenario.</span>
                            }
                        </p>
                        @if (string.IsNullOrEmpty(searchString))
                        {
                            <a asp-action="Create" class="btn btn-primary">
                                <i class="fas fa-plus"></i> Create First Scenario
                            </a>
                        }
                    </div>
                }
            </div>
        </div>
    </div>
</div>
