@model WargameBoard.Web.Models.ViewModels.ScenarioObjectiveEditVm

<tr data-objective-id="@Model.Id">
    <td>
        <input asp-for="Id" type="hidden" />
        <input asp-for="ScenarioId" type="hidden" />
        <select asp-for="HexId" asp-items="Model.Hexes" class="form-select form-select-sm">
            <option value="">-- Select Hex --</option>
        </select>
        <span asp-validation-for="HexId" class="text-danger"></span>
    </td>
    <td>
        <select asp-for="SideId" asp-items="Model.Sides" class="form-select form-select-sm">
            <option value="">-- Select Side --</option>
        </select>
        <span asp-validation-for="SideId" class="text-danger"></span>
    </td>
    <td>
        <input asp-for="VictoryPoints" class="form-control form-control-sm" min="1" max="100" />
        <span asp-validation-for="VictoryPoints" class="text-danger"></span>
    </td>
    <td>
        <select asp-for="ConditionKind" class="form-select form-select-sm">
            <option value="1">Seize By Turn</option>
            <option value="2">Hold To End</option>
            <option value="3">Destroy Units</option>
            <option value="4">Exit Units</option>
            <option value="5">Control</option>
            <option value="6">Destroy</option>
            <option value="7">Defend</option>
            <option value="8">Capture</option>
            <option value="9">Reach</option>
            <option value="10">Survive</option>
        </select>
        <span asp-validation-for="ConditionKind" class="text-danger"></span>
        <input type="hidden" asp-for="ScenarioId" />
    </td>
    <td>
        <input asp-for="TurnThreshold" class="form-control form-control-sm" min="1" max="100" placeholder="Optional" />
        <span asp-validation-for="TurnThreshold" class="text-danger"></span>
    </td>
    <td>
        <div class="btn-group" role="group">
            @if (Model.Id == 0)
            {
                <button type="button" class="btn btn-sm btn-success saveObjectiveBtn">
                    <i class="fas fa-save"></i> Save
                </button>
            }
            <button type="button" class="btn btn-sm btn-danger removeObjectiveBtn" data-objective-id="@Model.Id">
                <i class="fas fa-trash"></i> Remove
            </button>
        </div>
    </td>
</tr>




