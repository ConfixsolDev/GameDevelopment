@{
    ViewData["Title"] = "Map Editor";
}

<div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-3 pb-2 mb-3 border-bottom">
    <h1 class="h2">Map Editor</h1>
    <div class="btn-toolbar mb-2 mb-md-0">
        <div class="btn-group me-2">
            <button type="button" class="btn btn-sm btn-outline-secondary">Load Map</button>
            <button type="button" class="btn btn-sm btn-outline-secondary">Save Map</button>
        </div>
        <button type="button" class="btn btn-sm btn-primary">New Map</button>
    </div>
</div>

<div class="row">
    <div class="col-md-3">
        <div class="card">
            <div class="card-header">
                <h5 class="card-title">Map Tools</h5>
            </div>
            <div class="card-body">
                <div class="d-grid gap-2">
                    <button class="btn btn-outline-primary">Terrain</button>
                    <button class="btn btn-outline-primary">Grid</button>
                    <button class="btn btn-outline-primary">Markers</button>
                    <button class="btn btn-outline-primary">Layers</button>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-9">
        <div class="card">
            <div class="card-header">
                <h5 class="card-title">Map Canvas</h5>
            </div>
            <div class="card-body">
                <div class="bg-light border rounded" style="height: 500px; display: flex; align-items: center; justify-content: center;">
                    <p class="text-muted">Map editor canvas will be rendered here</p>
                </div>
            </div>
        </div>
    </div>
</div>
