@model IEnumerable<WargameBoard.Core.Entities.Hex>

@{
    ViewData["Title"] = "Tactical Game Arena";
    Layout = "/Views/Shared/_Layout.cshtml";
}

<!-- Modern Game Arena Interface -->
<div class="game-arena-container">
    <!-- Top Header with Team Status -->
    <div class="arena-header">
        <div class="team-status-panel">
            <div class="team-info">
                <div class="team-icon">
                    <i class="bi bi-shield-fill"></i>
                </div>
                <div class="team-details">
                    <h3>Alpha Team</h3>
                    <span class="team-status">Ready for Battle</span>
                </div>
            </div>
            <div class="team-metrics">
                <div class="metric-box">
                    <i class="bi bi-check-circle-fill"></i>
                    <span>TOKENS</span>
                </div>
                <div class="metric-box">
                    <i class="bi bi-percent"></i>
                    <span>AREA</span>
                    <div class="metric-value">0%</div>
                </div>
                <div class="metric-box">
                    <i class="bi bi-trophy-fill"></i>
                    <span>SCORE</span>
                </div>
                <div class="metric-box">
                    <i class="bi bi-clock-fill"></i>
                    <span>TIME</span>
                    <div class="metric-value">∞</div>
                </div>
            </div>
        </div>
        
        <div class="session-controls">
            <select id="sessionSelect" class="form-select session-select">
                <option value="">Select Session</option>
                @foreach (var session in ViewBag.Sessions)
                {
                    <option value="@session.Value" selected="@(ViewBag.SessionId?.ToString() == session.Value)">
                        @session.Text
                    </option>
                }
            </select>
            <button type="button" class="btn btn-success" id="joinSessionBtn" disabled>
                <i class="bi bi-play-circle"></i> Join Session
            </button>
            <button type="button" class="btn btn-warning" id="leaveSessionBtn" disabled>
                <i class="bi bi-stop-circle"></i> Leave Session
            </button>
        </div>
    </div>

    <!-- Main Game Area -->
    <div class="arena-main">
        <!-- Left Sidebar - Map Controls -->
        <div class="arena-sidebar-left">
            <div class="control-panel">
                <h4>MAP CONTROLS</h4>
                <div class="control-buttons">
                    <button class="control-btn" title="Layers" id="layersBtn">
                        <i class="bi bi-layers-fill"></i>
                        <span>Layers</span>
                    </button>
                    <button class="control-btn" title="Fullscreen" id="fullscreenBtn">
                        <i class="bi bi-fullscreen"></i>
                        <span>Fullscreen</span>
                    </button>
                    <button class="control-btn" title="Reset" id="resetBtn">
                        <i class="bi bi-arrow-clockwise"></i>
                        <span>Reset</span>
                    </button>
                    <button class="control-btn" title="Coordinates" id="coordsBtn">
                        <i class="bi bi-geo-alt-fill"></i>
                        <span>Coords</span>
                    </button>
                </div>
            </div>
            
            <!-- Map Tools Panel -->
            <div class="map-tools-panel" id="mapToolsPanel">
                <h4>MAP TOOLS</h4>
                <div class="map-tools-grid">
                    <button class="map-tool-btn" id="newMapBtn">
                        <i class="bi bi-plus-square"></i>
                        <span>New Map</span>
                    </button>
                    <button class="map-tool-btn" id="loadMapBtn">
                        <i class="bi bi-folder-open"></i>
                        <span>Load Map</span>
                    </button>
                    <button class="map-tool-btn" id="saveMapBtn">
                        <i class="bi bi-save"></i>
                        <span>Save Map</span>
                    </button>
                    <button class="map-tool-btn" id="terrainEditorBtn">
                        <i class="bi bi-palette"></i>
                        <span>Terrain</span>
                    </button>
                </div>
            </div>
            
            <!-- Map Layers Panel -->
            <div class="map-layers-panel" id="mapLayersPanel">
                <h4>MAP LAYERS</h4>
                <div class="layer-item">
                    <div class="layer-info">
                        <h6>Terrain Layer</h6>
                        <small>Base terrain features</small>
                    </div>
                    <div class="layer-controls">
                        <div class="layer-visibility visible" data-layer="terrain"></div>
                        <div class="layer-opacity" data-layer="terrain">
                            <div class="layer-opacity-slider" style="width: 100%"></div>
                        </div>
                    </div>
                </div>
                <div class="layer-item">
                    <div class="layer-info">
                        <h6>Token Layer</h6>
                        <small>Unit placements</small>
                    </div>
                    <div class="layer-controls">
                        <div class="layer-visibility visible" data-layer="tokens"></div>
                        <div class="layer-opacity" data-layer="tokens">
                            <div class="layer-opacity-slider" style="width: 100%"></div>
                        </div>
                    </div>
                </div>
                <div class="layer-item">
                    <div class="layer-info">
                        <h6>Feature Layer</h6>
                        <small>Buildings and obstacles</small>
                    </div>
                    <div class="layer-controls">
                        <div class="layer-visibility visible" data-layer="features"></div>
                        <div class="layer-opacity" data-layer="features">
                            <div class="layer-opacity-slider" style="width: 100%"></div>
                        </div>
                    </div>
                </div>
            </div>
            
            <!-- Terrain Editor Panel -->
            <div class="terrain-editor-panel" id="terrainEditorPanel">
                <h4>TERRAIN EDITOR</h4>
                <div class="terrain-palette">
                    <div class="terrain-option terrain-clear" data-terrain="clear">
                        <span>Clear</span>
                    </div>
                    <div class="terrain-option terrain-forest" data-terrain="forest">
                        <span>Forest</span>
                    </div>
                    <div class="terrain-option terrain-mountain" data-terrain="mountain">
                        <span>Mountain</span>
                    </div>
                    <div class="terrain-option terrain-water" data-terrain="water">
                        <span>Water</span>
                    </div>
                    <div class="terrain-option terrain-desert" data-terrain="desert">
                        <span>Desert</span>
                    </div>
                    <div class="terrain-option terrain-urban" data-terrain="urban">
                        <span>Urban</span>
                    </div>
                    <div class="terrain-option terrain-swamp" data-terrain="swamp">
                        <span>Swamp</span>
                    </div>
                </div>
            </div>
            
            <!-- Data Entry System -->
            <div class="data-entry-panel active" id="dataEntryPanel">
                <h4>🎖️ MILITARY SIMULATION</h4>
                
                <!-- Collapsible Navigation -->
                <div class="sidebar-nav">
                    <div class="nav-section" onclick="toggleSection('units')">
                        <h5>🎖️ UNITS <i class="bi bi-chevron-down" id="units-arrow"></i></h5>
                    </div>
                    <div class="nav-content" id="units-content">
                        <div class="simple-list">
                            <div class="unit-item" onclick="selectUnit('infantry')">
                                <span>🪖 Infantry</span>
                            </div>
                            <div class="unit-item" onclick="selectUnit('armor')">
                                <span>🚗 Armor</span>
                            </div>
                            <div class="unit-item" onclick="selectUnit('support')">
                                <span>🚁 Support</span>
                            </div>
                        </div>
                    </div>
                
                    <div class="nav-section" onclick="toggleSection('features')">
                        <h5>🏗️ FEATURES <i class="bi bi-chevron-down" id="features-arrow"></i></h5>
                    </div>
                    <div class="nav-content" id="features-content">
                        <div class="simple-list">
                            <div class="feature-item" onclick="selectFeature('fortification')">
                                <span>🛡️ Fortification</span>
                            </div>
                            <div class="feature-item" onclick="selectFeature('obstacle')">
                                <span>🚧 Obstacle</span>
                            </div>
                            <div class="feature-item" onclick="selectFeature('objective')">
                                <span>🎯 Objective</span>
                            </div>
                            <div class="feature-item remove-item" onclick="setRemoveMode('feature')">
                                <span>🗑️ Remove Features</span>
                            </div>
                        </div>
                    </div>
                    
                    <div class="nav-section" onclick="toggleSection('terrain')">
                        <h5>🌍 TERRAIN <i class="bi bi-chevron-down" id="terrain-arrow"></i></h5>
                    </div>
                    <div class="nav-content" id="terrain-content">
                        <div class="simple-list">
                            <div class="terrain-item" onclick="selectTerrain('clear')">
                                <span>🌱 Clear</span>
                            </div>
                            <div class="terrain-item" onclick="selectTerrain('forest')">
                                <span>🌲 Forest</span>
                            </div>
                            <div class="terrain-item" onclick="selectTerrain('mountain')">
                                <span>⛰️ Mountain</span>
                            </div>
                            <div class="terrain-item" onclick="selectTerrain('water')">
                                <span>💧 Water</span>
                            </div>
                            <div class="terrain-item remove-item" onclick="setRemoveMode('terrain')">
                                <span>🗑️ Remove Terrain</span>
                            </div>
                        </div>
                    </div>
                    
                    <div class="nav-section" onclick="toggleSection('tools')">
                        <h5>🛠️ GAME TOOLS <i class="bi bi-chevron-down" id="tools-arrow"></i></h5>
                    </div>
                    <div class="nav-content" id="tools-content">
                        <div class="simple-list">
                            <div class="tool-item tool-btn" data-tool="draw" onclick="setGameTool('draw')">
                                <span>✏️ Draw Area</span>
                            </div>
                            <div class="tool-item tool-btn" data-tool="measure" onclick="setGameTool('measure')">
                                <span>📏 Measure</span>
                            </div>
                            <div class="tool-item tool-btn" data-tool="select" onclick="setGameTool('select')">
                                <span>🎯 Select</span>
                            </div>
                            <div class="tool-item tool-btn" data-tool="area" onclick="setGameTool('area')">
                                <span>📐 Fixed Map Area</span>
                            </div>
                            <div class="tool-item tool-btn" data-tool="maparea" onclick="setGameTool('maparea')">
                                <span>🗺️ Select Map Area</span>
                            </div>
                        </div>
                    </div>
                    
                    <div class="nav-section" onclick="toggleSection('view')">
                        <h5>🔍 VIEW MODES <i class="bi bi-chevron-down" id="view-arrow"></i></h5>
                    </div>
                    <div class="nav-content" id="view-content">
                        <div class="simple-list">
                            <div class="mode-item" onclick="toggleHexMode()">
                                <span>⬡ Hex Mode</span>
                            </div>
                            <div class="mode-item" onclick="showAllFeatures()">
                                <span>👁️ Show All Features</span>
                            </div>
                            <div class="mode-item" onclick="clearMap()">
                                <span>🗑️ Clear Map</span>
                            </div>
                        </div>
                    </div>
                    
                    <div class="nav-section" onclick="toggleSection('location')">
                        <h5>🌍 LOCATION <i class="bi bi-chevron-down" id="location-arrow"></i></h5>
                    </div>
                    <div class="nav-content" id="location-content">
                        <div class="location-search">
                            <input type="text" id="locationSearch" placeholder="Search location..." 
                                   class="form-control" style="margin-bottom: 10px;">
                            <div class="quick-locations">
                                <div class="location-btn" onclick="goToLocation('Dubai, UAE')">
                                    <span>🏙️ Dubai</span>
                                </div>
                                <div class="location-btn" onclick="goToLocation('New York, USA')">
                                    <span>🗽 New York</span>
                                </div>
                                <div class="location-btn" onclick="goToLocation('London, UK')">
                                    <span>🇬🇧 London</span>
                                </div>
                                <div class="location-btn" onclick="goToLocation('Tokyo, Japan')">
                                    <span>🇯🇵 Tokyo</span>
                                </div>
                            </div>
                        </div>
                    </div>
                    
                    <div class="nav-section" onclick="toggleSection('teams')">
                        <h5>👥 TEAMS <i class="bi bi-chevron-down" id="teams-arrow"></i></h5>
                    </div>
                    <div class="nav-content" id="teams-content">
                        <div class="simple-list">
                            <div class="team-item">
                                <span>🦊 Fox Land: 2</span>
                            </div>
                            <div class="team-item">
                                <span>🔵 Blue Land: 1</span>
                            </div>
                            <div class="team-item">
                                <span>👁️ Spectators: 1</span>
                            </div>
                            <div class="team-item" onclick="showPlayerDetails()">
                                <span>📋 Details</span>
                            </div>
                        </div>
                    </div>
                </div>
                
                <hr style="border-color: rgba(255, 255, 255, 0.3); margin: 30px 0;">
                
                <h4>🗺️ MAP CONFIGURATION</h4>
                
                <!-- Map Data Entry -->
                <div class="data-section">
                    <h5>Map Settings</h5>
                    <div class="form-group">
                        <label>Map Name</label>
                        <input type="text" id="mapNameInput" class="form-control" placeholder="Enter map name">
                    </div>
                    <div class="form-group">
                        <label>Map Region</label>
                        <select id="mapRegionSelect" class="form-control">
                            <option value="london">Greater London</option>
                            <option value="paris">Paris Region</option>
                            <option value="berlin">Berlin Area</option>
                            <option value="newyork">New York Metro</option>
                            <option value="tokyo">Tokyo Prefecture</option>
                            <option value="custom">Custom Region</option>
                        </select>
                    </div>
                    <div class="form-group">
                        <label>Map Center (Latitude)</label>
                        <input type="number" id="mapCenterLat" class="form-control" step="0.000001" placeholder="51.5074">
                    </div>
                    <div class="form-group">
                        <label>Map Center (Longitude)</label>
                        <input type="number" id="mapCenterLng" class="form-control" step="0.000001" placeholder="-0.1278">
                    </div>
                    <div class="form-group">
                        <label>Zoom Level</label>
                        <input type="range" id="mapZoomLevel" class="form-range" min="8" max="18" value="12">
                        <span id="zoomValue">12</span>
                    </div>
                </div>
                
                <!-- Hex Grid Configuration -->
                <div class="data-section">
                    <h5>Hex Grid Settings</h5>
                    <div class="form-group">
                        <label>Grid Size</label>
                        <select id="gridSizeSelect" class="form-control">
                            <option value="8x8">8x8 (Small)</option>
                            <option value="12x12" selected>12x12 (Medium)</option>
                            <option value="16x16">16x16 (Large)</option>
                            <option value="20x20">20x20 (Extra Large)</option>
                        </select>
                    </div>
                    <div class="form-group">
                        <label>Hex Size (meters)</label>
                        <input type="number" id="hexSizeMeters" class="form-control" value="1000" min="100" max="10000">
                    </div>
                    <div class="form-group">
                        <label>Show Hex Overlay</label>
                        <input type="checkbox" id="showHexOverlay" class="form-check-input">
                    </div>
                </div>
                
                <!-- Token Configuration -->
                <div class="data-section">
                    <h5>Token Settings</h5>
                    <div class="form-group">
                        <label>Token Size</label>
                        <input type="range" id="tokenSize" class="form-range" min="10" max="50" value="20">
                        <span id="tokenSizeValue">20px</span>
                    </div>
                    <div class="form-group">
                        <label>Token Opacity</label>
                        <input type="range" id="tokenOpacity" class="form-range" min="0.1" max="1" step="0.1" value="0.8">
                        <span id="tokenOpacityValue">80%</span>
                    </div>
                    <div class="form-group">
                        <label>Show Token Labels</label>
                        <input type="checkbox" id="showTokenLabels" class="form-check-input" checked>
                    </div>
                </div>
                
                <!-- Game Rules -->
                <div class="data-section">
                    <h5>Game Rules</h5>
                    <div class="form-group">
                        <label>Turn Duration (minutes)</label>
                        <input type="number" id="turnDuration" class="form-control" value="30" min="1" max="120">
                    </div>
                    <div class="form-group">
                        <label>Max Turns</label>
                        <input type="number" id="maxTurns" class="form-control" value="20" min="1" max="100">
                    </div>
                    <div class="form-group">
                        <label>Victory Conditions</label>
                        <select id="victoryConditions" class="form-control">
                            <option value="territory">Territory Control</option>
                            <option value="objectives">Objective Capture</option>
                            <option value="elimination">Unit Elimination</option>
                            <option value="points">Point System</option>
                        </select>
                    </div>
                </div>
                
                <!-- Actions -->
                <div class="data-actions">
                    <button class="btn btn-primary" id="saveMapDataBtn">
                        <i class="bi bi-save"></i> Save Configuration
                    </button>
                    <button class="btn btn-secondary" id="loadMapDataBtn">
                        <i class="bi bi-folder-open"></i> Load Configuration
                    </button>
                    <button class="btn btn-warning" id="resetMapDataBtn">
                        <i class="bi bi-arrow-clockwise"></i> Reset
                    </button>
                </div>
            </div>
            
            <div class="control-panel">
                <h4>GAME TOOLS</h4>
                <div class="control-buttons">
                    <button class="control-btn active" id="placeTokenBtn" title="Place Token">
                        <i class="bi bi-plus-circle-fill"></i>
                        <span>+ Place Token</span>
                    </button>
                    <button class="control-btn" id="selectBtn" title="Select">
                        <i class="bi bi-cursor-fill"></i>
                        <span>Select</span>
                    </button>
                    <button class="control-btn" title="Measure">
                        <i class="bi bi-rulers"></i>
                        <span>Measure</span>
                    </button>
                    <button class="control-btn" title="Draw Area">
                        <i class="bi bi-pencil-square"></i>
                        <span>Draw Area</span>
                    </button>
                </div>
            </div>

            <!-- Token Selection -->
            <div class="control-panel" id="tokenPanel" style="display: block;">
                <h4>TOKEN SELECTION</h4>
                <select id="tokenSelect" class="form-select">
                    <option value="">Select Token</option>
                    @foreach (var token in ViewBag.TokenPieces)
                    {
                        <option value="@token.Value" data-serial="@token.Text">
                            @token.Text
                        </option>
                    }
                </select>
                <div id="selectedTokenDisplay" class="selected-token">
                    <span class="text-muted">No token selected</span>
                </div>
            </div>

            <!-- Terrain Tools -->
            <div class="control-panel" id="terrainPanel" style="display: none;">
                <h4>TERRAIN TOOLS</h4>
                <select id="terrainSelect" class="form-select">
                    @foreach (var terrain in ViewBag.TerrainTypes)
                    {
                        <option value="@terrain.Value">@terrain.Text</option>
                    }
                </select>
                <select id="sideSelect" class="form-select mt-2">
                    @foreach (var side in ViewBag.Sides)
                    {
                        <option value="@side.Value">@side.Text</option>
                    }
                </select>
            </div>
        </div>

        <!-- Center Map Area -->
        <div class="arena-map-container">
            <div class="map-header">
                <div class="map-info">
                    <h2>Battle Map</h2>
                    <span class="map-coordinates">Grid: 12x12</span>
                </div>
                <div class="map-controls">
                    <button class="btn btn-sm btn-outline-light" id="advanceTurnBtn" disabled>
                        <i class="bi bi-arrow-right"></i> Advance Turn
                    </button>
                    <span class="turn-indicator">
                        Turn: <span id="currentTurn">1</span>
                    </span>
                </div>
            </div>
            
            <div class="map-wrapper">
                <!-- Real Map Container -->
                <div id="realMapContainer" class="real-map-container">
                    <!-- Map will be loaded here -->
                    <div id="map" class="real-map"></div>
                    
                    <!-- Hidden Hex Grid for Game Logic -->
                    <div id="hexGrid" class="hex-grid-hidden" style="display: none;">
                        @foreach (var hex in Model) {
                            <div class="hex-modern @(hex.TerrainTypeId switch 
                            {
                                1 => "terrain-clear",
                                2 => "terrain-forest", 
                                3 => "terrain-mountain",
                                4 => "terrain-water",
                                5 => "terrain-desert",
                                6 => "terrain-urban",
                                7 => "terrain-swamp",
                                _ => "terrain-clear"
                            })" data-hexid="@hex.Id" data-q="@hex.Q" data-r="@hex.R" data-lat="@hex.Latitude" data-lng="@hex.Longitude">
                                <div class="hex-overlay" id="overlay-@hex.Id">
                                    @foreach (var placement in hex.Placements)
                                    {
                                        <span class="token-modern" data-placement-id="@placement.Id" data-token-id="@placement.TokenPieceId">
                                            @placement.TokenPiece?.Serial
                                        </span>
                                    }
                                    @foreach (var feature in hex.HexFeatures)
                                    {
                                        <span class="feature-modern @(feature.Side?.Color == "#0d6efd" ? "feature-blue" : feature.Side?.Color == "#dc3545" ? "feature-red" : "feature-neutral")" data-feature-id="@feature.Id">
                                            @(feature.FortificationType?.Name ?? feature.ObstacleType?.Name ?? "Feature")
                                        </span>
                                    }
                                </div>
                            </div>
                        }
                    </div>
                    
                    <!-- Map Controls Overlay -->
                    <div class="map-controls-overlay">
                        <div class="zoom-controls">
                            <button class="map-control-btn" id="zoomInBtn" title="Zoom In">
                                <i class="bi bi-plus-lg"></i>
                            </button>
                            <button class="map-control-btn" id="zoomOutBtn" title="Zoom Out">
                                <i class="bi bi-dash-lg"></i>
                            </button>
                            <button class="map-control-btn" id="resetViewBtn" title="Reset View">
                                <i class="bi bi-house"></i>
                            </button>
                        </div>
                        
                        <div class="map-layers-controls">
                            <button class="map-control-btn" id="toggleSatelliteBtn" title="Toggle Satellite">
                                <i class="bi bi-globe"></i>
                            </button>
                            <button class="map-control-btn" id="toggleTerrainBtn" title="Toggle Terrain">
                                <i class="bi bi-mountain"></i>
                            </button>
                            <button class="map-control-btn" id="toggleLabelsBtn" title="Toggle Labels">
                                <i class="bi bi-tag"></i>
                            </button>
                        </div>
                    </div>
                    
                    <!-- Coordinate Display -->
                    <div class="coordinate-display" id="coordinateDisplay">
                        <span id="currentCoords">Lat: 0.000, Lng: 0.000</span>
                        <span id="hexCoords">Hex: (0,0)</span>
                    </div>
                </div>
            </div>
        </div>

        <!-- Right Sidebar - Game Info -->
        <div class="arena-sidebar-right">
            <div class="game-info-panel">
                <h4>GAME STATUS</h4>
                <div class="status-grid">
                    <div class="status-item">
                        <span class="status-label">Session</span>
                        <span class="status-value" id="sessionStatus">Not Connected</span>
                    </div>
                    <div class="status-item">
                        <span class="status-label">Connection</span>
                        <span class="status-value" id="connectionStatus">Disconnected</span>
                    </div>
                    <div class="status-item">
                        <span class="status-label">Players</span>
                        <span class="status-value">2</span>
                    </div>
                    <div class="status-item">
                        <span class="status-label">Turn Time</span>
                        <span class="status-value">∞</span>
                    </div>
                </div>
            </div>

            <div class="activity-panel">
                <h4>LIVE ACTIVITY</h4>
                <div id="activityFeed" class="activity-feed">
                    <div class="activity-item">
                        <i class="bi bi-info-circle"></i>
                        <span>Join session to see live updates</span>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Bottom Panel - Team/Role Selection -->
    <div class="arena-footer">
        <div class="team-selector">
            <div class="team-logo">
                <div class="logo-icon">
                    <i class="bi bi-shield-fill"></i>
                </div>
                <div class="team-info">
                    <span class="team-name">Alpha Team</span>
                    <span class="team-status">Active</span>
                </div>
            </div>
        </div>
        
        <div class="role-selector">
            <button class="role-btn" data-role="fox">
                <i class="bi bi-fire"></i>
                <span>FOX LAND</span>
            </button>
            <button class="role-btn" data-role="blue">
                <i class="bi bi-water"></i>
