@section Scripts {
    <!-- Leaflet CSS -->
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
    
    <!-- Leaflet JS -->
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
    
    <script src="~/js/site.js"></script>
    <script src="~/js/realtime-map.js"></script>
    <script src="~/js/real-map-arena.js"></script>
    <script src="~/js/modern-arena.js"></script>
    
    <script>
        // Initialize military simulation features when page loads
        document.addEventListener('DOMContentLoaded', function() {
            console.log('🎖️ Initializing Military Simulation Features');
            
            // Make sure data entry panel is visible
            const dataPanel = document.getElementById('dataEntryPanel');
            if (dataPanel) {
                dataPanel.classList.add('active');
                dataPanel.style.display = 'block';
                console.log('✅ Data Entry Panel made visible');
            }
            
            // Setup location search
            if (typeof setupLocationSearch === 'function') {
                setupLocationSearch();
                console.log('✅ Location search initialized');
            } else {
                console.warn('⚠️ setupLocationSearch function not found');
            }
            
            // Initialize arena
            if (typeof initializeArena === 'function') {
                initializeArena();
                console.log('✅ Arena initialized');
            } else {
                console.warn('⚠️ initializeArena function not found');
            }
            
            // Test if military functions are available
            console.log('Testing military functions:');
            console.log('- selectUnit:', typeof selectUnit);
            console.log('- selectFeature:', typeof selectFeature);
            console.log('- selectTerrain:', typeof selectTerrain);
            console.log('- setGameTool:', typeof setGameTool);
            console.log('- goToLocation:', typeof goToLocation);
            
            console.log('✅ Military Simulation Features Ready');
        });
        
        // Test function to debug military features
        function testMilitaryFeatures() {
            console.log('🔧 Testing Military Features...');
            
            // Test if functions exist
            const functions = [
                'selectUnit', 'selectFeature', 'selectTerrain', 'setGameTool', 
                'goToLocation', 'toggleHexMode', 'showAllFeatures', 'clearMap',
                'setRemoveMode', 'showPlayerDetails'
            ];
            
            functions.forEach(func => {
                if (typeof window[func] === 'function') {
                    console.log(`✅ ${func} - Available`);
                } else {
                    console.log(`❌ ${func} - Missing`);
                }
            });
            
            // Test data panel visibility
            const dataPanel = document.getElementById('dataEntryPanel');
            if (dataPanel) {
                console.log('✅ Data Entry Panel - Found');
                console.log('- Display:', dataPanel.style.display);
                console.log('- Classes:', dataPanel.className);
            } else {
                console.log('❌ Data Entry Panel - Not Found');
            }
            
            // Test military sections
            const militarySections = document.querySelectorAll('.military-section');
            console.log(`✅ Military Sections - Found ${militarySections.length} sections`);
            
            alert('Check browser console for test results');
        }
        
        // Make test function global
        window.testMilitaryFeatures = testMilitaryFeatures;
        
        // Collapsible navigation function
        function toggleSection(sectionName) {
            const content = document.getElementById(sectionName + '-content');
            const arrow = document.getElementById(sectionName + '-arrow');
            
            if (content && arrow) {
                if (content.style.display === 'none' || content.style.display === '') {
                    content.style.display = 'block';
                    arrow.className = 'bi bi-chevron-up';
                } else {
                    content.style.display = 'none';
                    arrow.className = 'bi bi-chevron-down';
                }
            }
        }
        
        // Initialize sections (start with first section open)
        document.addEventListener('DOMContentLoaded', function() {
            // Open units section by default
            const unitsContent = document.getElementById('units-content');
            const unitsArrow = document.getElementById('units-arrow');
            if (unitsContent && unitsArrow) {
                unitsContent.style.display = 'block';
                unitsArrow.className = 'bi bi-chevron-up';
            }
        });
        
        // Make toggle function global
        window.toggleSection = toggleSection;
        
        // Global modal cleanup function
        function cleanupAllModals() {
            // Remove all modal backdrops
            const backdrops = document.querySelectorAll('.modal-backdrop');
            backdrops.forEach(backdrop => backdrop.remove());
            
            // Remove modal-open class from body
            document.body.classList.remove('modal-open');
            
            // Reset body padding
            document.body.style.paddingRight = '';
            
            // Remove any remaining modals
            const modals = document.querySelectorAll('.modal');
            modals.forEach(modal => {
                if (modal.style.display === 'block' || modal.classList.contains('show')) {
                    modal.remove();
                }
            });
            
            console.log('🧹 All modals cleaned up');
        }
        
        // Make cleanup function global
        window.cleanupAllModals = cleanupAllModals;
        
        // Add cleanup on page unload
        window.addEventListener('beforeunload', cleanupAllModals);
    </script>
    
    <!-- Debug script -->
    <script>
        // Wait for everything to load, then run debug
        window.addEventListener('load', function() {
            setTimeout(function() {
                console.log('All scripts loaded, running debug test...');
                if (window.testArenaSystems) {
                    window.testArenaSystems();
                }
            }, 2000);
        });
    </script>
}
