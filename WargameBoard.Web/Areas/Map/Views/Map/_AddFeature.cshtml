@model WargameBoard.Web.Models.ViewModels.HexFeatureEditVm

<div class="panel-header">
    <h5>Add Feature to Hex</h5>
    <button type="button" class="btn btn-sm btn-secondary" onclick="document.querySelector('#hexFeaturesHost').innerHTML = ''">Cancel</button>
</div>

<form asp-action="AddFeature" method="post" onsubmit="postForm(this, '#hexFeaturesHost'); return false;">
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
    <input type="hidden" asp-for="HexId" />
    
    <div class="mb-3">
        <label asp-for="FeatureKind" class="form-label"></label>
        <select asp-for="FeatureKind" class="form-select" onchange="toggleFeatureTypeDropdowns()">
            <option value="">-- Select Feature Kind --</option>
            <option value="Fortification">Fortification</option>
            <option value="Obstacle">Obstacle</option>
            <option value="Objective">Objective</option>
            <option value="Marker">Marker</option>
        </select>
        <span asp-validation-for="FeatureKind" class="text-danger"></span>
    </div>

    <div class="mb-3" id="fortificationTypeGroup" style="display: none;">
        <label asp-for="FortificationTypeId" class="form-label"></label>
        <select asp-for="FortificationTypeId" asp-items="Model.FortificationTypes" class="form-select">
            <option value="">-- Select Fortification Type --</option>
        </select>
        <span asp-validation-for="FortificationTypeId" class="text-danger"></span>
    </div>

    <div class="mb-3" id="obstacleTypeGroup" style="display: none;">
        <label asp-for="ObstacleTypeId" class="form-label"></label>
        <select asp-for="ObstacleTypeId" asp-items="Model.ObstacleTypes" class="form-select">
            <option value="">-- Select Obstacle Type --</option>
        </select>
        <span asp-validation-for="ObstacleTypeId" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="SideId" class="form-label"></label>
        <select asp-for="SideId" asp-items="Model.Sides" class="form-select">
            <option value="">-- Select Side (Optional) --</option>
        </select>
        <span asp-validation-for="SideId" class="text-danger"></span>
        <div class="form-text">Leave blank for neutral features</div>
    </div>

    <div class="d-flex justify-content-between">
        <button type="button" class="btn btn-secondary" onclick="document.querySelector('#hexFeaturesHost').innerHTML = ''">Cancel</button>
        <button type="submit" class="btn btn-primary">
            <i class="bi bi-plus"></i> Add Feature
        </button>
    </div>
</form>

<script>
function toggleFeatureTypeDropdowns() {
    const featureKind = document.getElementById('FeatureKind').value;
    const fortificationGroup = document.getElementById('fortificationTypeGroup');
    const obstacleGroup = document.getElementById('obstacleTypeGroup');
    
    // Hide all groups first
    fortificationGroup.style.display = 'none';
    obstacleGroup.style.display = 'none';
    
    // Show relevant group based on selection
    if (featureKind === 'Fortification') {
        fortificationGroup.style.display = 'block';
    } else if (featureKind === 'Obstacle') {
        obstacleGroup.style.display = 'block';
    }
}
</script>
