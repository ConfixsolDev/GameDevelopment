@model WargameBoard.Web.Models.ViewModels.UnitEditVm

@{
    ViewData["Title"] = "Create Unit";
    Layout = "/Views/Shared/_Layout.cshtml";
}

<div class="row">
    <div class="col-md-8">
        <div class="card">
            <div class="card-header">
                <h5 class="card-title">Create New Unit</h5>
            </div>
            <div class="card-body">
                <form asp-action="Create" method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                    
                    <div class="row">
                        <div class="col-md-6">
                            <div class="mb-3">
                                <label asp-for="Name" class="form-label"></label>
                                <input asp-for="Name" class="form-control" />
                                <span asp-validation-for="Name" class="text-danger"></span>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="mb-3">
                                <label asp-for="SideId" class="form-label"></label>
                                <select asp-for="SideId" asp-items="Model.Sides" class="form-select">
                                    <option value="">-- Select Side --</option>
                                </select>
                                <span asp-validation-for="SideId" class="text-danger"></span>
                            </div>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6">
                            <div class="mb-3">
                                <label asp-for="UnitTypeId" class="form-label"></label>
                                <select asp-for="UnitTypeId" asp-items="Model.UnitTypes" class="form-select">
                                    <option value="">-- Select Unit Type --</option>
                                </select>
                                <span asp-validation-for="UnitTypeId" class="text-danger"></span>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="mb-3">
                                <label asp-for="MovementProfileId" class="form-label"></label>
                                <select asp-for="MovementProfileId" asp-items="Model.MovementProfiles" class="form-select">
                                    <option value="">-- Select Movement Profile --</option>
                                </select>
                                <span asp-validation-for="MovementProfileId" class="text-danger"></span>
                            </div>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6">
                            <div class="mb-3">
                                <label asp-for="Personnel" class="form-label"></label>
                                <input asp-for="Personnel" class="form-control" />
                                <span asp-validation-for="Personnel" class="text-danger"></span>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="mb-3">
                                <label asp-for="VehiclesPrimary" class="form-label"></label>
                                <input asp-for="VehiclesPrimary" class="form-control" />
                                <span asp-validation-for="VehiclesPrimary" class="text-danger"></span>
                            </div>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6">
                            <div class="mb-3">
                                <label asp-for="Quality" class="form-label"></label>
                                <input asp-for="Quality" class="form-control" />
                                <span asp-validation-for="Quality" class="text-danger"></span>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="mb-3">
                                <label asp-for="Cohesion" class="form-label"></label>
                                <input asp-for="Cohesion" class="form-control" />
                                <span asp-validation-for="Cohesion" class="text-danger"></span>
                            </div>
                        </div>
                    </div>

                    <div class="d-flex justify-content-between">
                        <a asp-action="Index" class="btn btn-secondary">Cancel</a>
                        <button type="submit" class="btn btn-primary">Create Unit</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
