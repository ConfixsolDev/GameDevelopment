@{
    ViewData["Title"] = "Dashboard";
    Layout = "/Views/Shared/_Layout.cshtml";
}

<!-- Welcome Banner -->
<div class="alert alert-primary border-0 mb-4" role="alert">
    <div class="row align-items-center">
        <div class="col-md-8">
            <h4 class="alert-heading mb-2">
                <i class="bi bi-trophy-fill"></i> Welcome to WargameBoard!
            </h4>
            <p class="mb-0">Ready to start your tactical wargame? Create a session, select a scenario, and jump into the Game Arena!</p>
        </div>
        <div class="col-md-4 text-end">
            <a class="btn btn-success btn-lg me-2" asp-controller="GameSessions" asp-action="Index">
                <i class="bi bi-play-circle-fill"></i> Start Playing
            </a>
            <a class="btn btn-outline-primary btn-lg" asp-area="Map" asp-controller="Map" asp-action="Index">
                <i class="bi bi-grid-3x3-gap-fill"></i> Game Arena
            </a>
        </div>
    </div>
</div>

<div class="row">
    <div class="col-lg-3 col-md-6 mb-4">
        <div class="card border-left-primary shadow h-100 py-2">
            <div class="card-body">
                <div class="row no-gutters align-items-center">
                    <div class="col mr-2">
                        <div class="text-xs font-weight-bold text-primary text-uppercase mb-1">
                            Active Sessions
                        </div>
                        <div class="h5 mb-0 font-weight-bold text-gray-800">3</div>
                    </div>
                    <div class="col-auto">
                        <i class="bi bi-play-circle fa-2x text-gray-300"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="col-lg-3 col-md-6 mb-4">
        <div class="card border-left-success shadow h-100 py-2">
            <div class="card-body">
                <div class="row no-gutters align-items-center">
                    <div class="col mr-2">
                        <div class="text-xs font-weight-bold text-success text-uppercase mb-1">
                            Total Units
                        </div>
                        <div class="h5 mb-0 font-weight-bold text-gray-800">127</div>
                    </div>
                    <div class="col-auto">
                        <i class="bi bi-shield fa-2x text-gray-300"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="col-lg-3 col-md-6 mb-4">
        <div class="card border-left-info shadow h-100 py-2">
            <div class="card-body">
                <div class="row no-gutters align-items-center">
                    <div class="col mr-2">
                        <div class="text-xs font-weight-bold text-info text-uppercase mb-1">
                            Scenarios
                        </div>
                        <div class="h5 mb-0 font-weight-bold text-gray-800">15</div>
                    </div>
                    <div class="col-auto">
                        <i class="bi bi-book fa-2x text-gray-300"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="col-lg-3 col-md-6 mb-4">
        <div class="card border-left-warning shadow h-100 py-2">
            <div class="card-body">
                <div class="row no-gutters align-items-center">
                    <div class="col mr-2">
                        <div class="text-xs font-weight-bold text-warning text-uppercase mb-1">
                            Tokens
                        </div>
                        <div class="h5 mb-0 font-weight-bold text-gray-800">89</div>
                    </div>
                    <div class="col-auto">
                        <i class="bi bi-circle fa-2x text-gray-300"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="row">
    <div class="col-xl-8 col-lg-7">
        <div class="card shadow mb-4">
            <div class="card-header py-3 d-flex flex-row align-items-center justify-content-between">
                <h6 class="m-0 font-weight-bold text-primary">Recent Activity</h6>
            </div>
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table table-bordered" width="100%" cellspacing="0">
                        <thead>
                            <tr>
                                <th>Time</th>
                                <th>Action</th>
                                <th>Details</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr>
                                <td>10:30 AM</td>
                                <td>Session Started</td>
                                <td>Operation Desert Storm - Player 1</td>
                            </tr>
                            <tr>
                                <td>09:45 AM</td>
                                <td>Unit Created</td>
                                <td>M1A1 Abrams Tank</td>
                            </tr>
                            <tr>
                                <td>09:15 AM</td>
                                <td>Token Assigned</td>
                                <td>Objective Alpha - Blue Team</td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <div class="col-xl-4 col-lg-5">
        <div class="card shadow mb-4">
            <div class="card-header py-3 d-flex flex-row align-items-center justify-content-between">
                <h6 class="m-0 font-weight-bold text-primary">Quick Actions</h6>
            </div>
            <div class="card-body">
                <div class="d-grid gap-2">
                    <a class="btn btn-primary btn-lg" asp-controller="GameSessions" asp-action="Index">
                        <i class="bi bi-play-circle-fill"></i> Game Sessions
                    </a>
                    <a class="btn btn-success btn-lg" asp-area="Map" asp-controller="Map" asp-action="Index">
                        <i class="bi bi-grid-3x3-gap-fill"></i> Game Arena
                    </a>
                    <a class="btn btn-info" asp-area="Scenarios" asp-controller="Scenarios" asp-action="Index">
                        <i class="bi bi-book"></i> Scenarios
                    </a>
                    <a class="btn btn-warning" asp-area="Units" asp-controller="Home" asp-action="Index">
                        <i class="bi bi-shield"></i> Units
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>
