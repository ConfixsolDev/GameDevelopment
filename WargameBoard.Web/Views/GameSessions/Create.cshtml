@model WargameBoard.Web.Models.ViewModels.SessionCreateVm

@{
    ViewData["Title"] = "Start New Session";
    Layout = "/Views/Shared/_Layout.cshtml";
}

<div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-3 pb-2 mb-3 border-bottom">
    <h1 class="h2">Start New Session</h1>
    <div class="btn-toolbar mb-2 mb-md-0">
        <a asp-action="Index" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left"></i> Back to Sessions
        </a>
    </div>
</div>

<div class="row">
    <div class="col-md-8">
        <div class="card">
            <div class="card-header">
                <h5 class="mb-0">Session Configuration</h5>
            </div>
            <div class="card-body">
                <form asp-action="Create" method="post">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>
                    
                    <div class="mb-3">
                        <label asp-for="ScenarioId" class="form-label">Scenario</label>
                        <select asp-for="ScenarioId" asp-items="Model.Scenarios" class="form-select">
                            <option value="">-- Select a Scenario --</option>
                        </select>
                        <span asp-validation-for="ScenarioId" class="text-danger"></span>
                        <div class="form-text">Choose a scenario to play. If no scenarios exist, create one in the Admin area first.</div>
                    </div>
                    
                    <div class="mb-3">
                        <label asp-for="Notes" class="form-label">Session Notes (Optional)</label>
                        <textarea asp-for="Notes" class="form-control" rows="3" placeholder="Add any notes about this session..."></textarea>
                        <span asp-validation-for="Notes" class="text-danger"></span>
                    </div>
                    
                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-play-circle"></i> Start Session
                        </button>
                        <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
    
    <div class="col-md-4">
        <div class="card">
            <div class="card-header">
                <h6 class="mb-0">Need Help?</h6>
            </div>
            <div class="card-body">
                <h6>Getting Started:</h6>
                <ol class="small">
                    <li>Create a scenario with units and objectives</li>
                    <li>Start a new session from this page</li>
                    <li>Join the session to assign players</li>
                    <li>Open the map to begin playing</li>
                </ol>
                
                <div class="mt-3">
                    <a href="/Admin" class="btn btn-sm btn-outline-info">
                        <i class="bi bi-gear"></i> Admin Panel
                    </a>
                    <a href="/Scenarios" class="btn btn-sm btn-outline-info">
                        <i class="bi bi-map"></i> Manage Scenarios
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
