@model WargameBoard.Core.Entities.Session

@{
    ViewData["Title"] = $"Session: {Model.Scenario?.Name}";
    Layout = "/Views/Shared/_Layout.cshtml";
}

<div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-3 pb-2 mb-3 border-bottom">
    <h1 class="h2">@Model.Scenario?.Name</h1>
    <div class="btn-toolbar mb-2 mb-md-0">
        <div class="btn-group me-2">
            <button type="button" class="btn btn-sm btn-success" id="joinSessionBtn">
                <i class="bi bi-play-circle"></i> Join Session
            </button>
            <button type="button" class="btn btn-sm btn-warning" id="leaveSessionBtn" disabled>
                <i class="bi bi-stop-circle"></i> Leave Session
            </button>
        </div>
        <div class="btn-group me-2">
            <button type="button" class="btn btn-sm btn-primary" id="advanceTurnBtn" disabled>
                <i class="bi bi-arrow-right"></i> Advance Turn
            </button>
        </div>
        <div class="btn-group">
            <a href="@Url.Action("Index", "Map", new { area = "Map", sessionId = Model.Id })" class="btn btn-sm btn-success">
                <i class="bi bi-map"></i> Game Board
            </a>
            <a href="@Url.Action("Index", "Map", new { area = "Map", sessionId = Model.Id })" class="btn btn-sm btn-info">
                <i class="bi bi-geo-alt"></i> Map Editor
            </a>
            <a href="@Url.Action("Details", "GameSessions", new { id = Model.Id })" class="btn btn-sm btn-outline-secondary">
                <i class="bi bi-info-circle"></i> Session Details
            </a>
        </div>
    </div>
</div>

<!-- Real-time Status Panel -->
<div id="statusPanel" class="alert alert-info" role="alert">
    <div class="d-flex justify-content-between align-items-center">
        <div>
            <strong>Session Status:</strong> <span id="sessionStatus">Not Connected</span>
            <span class="ms-3"><strong>Current Turn:</strong> <span id="currentTurn">@(Model.Turns?.OrderByDescending(t => t.Number).FirstOrDefault()?.Number ?? 1)</span></span>
            <span class="ms-3"><strong>Current Side:</strong> <span id="currentSide">@Model.CurrentSide?.Name</span></span>
        </div>
        <div>
            <span class="badge bg-success" id="connectionStatus">Connected</span>
        </div>
    </div>
</div>

<div class="row">
    <!-- Session Info -->
    <div class="col-md-4">
        <div class="card">
            <div class="card-header">
                <h5 class="mb-0">Session Information</h5>
            </div>
            <div class="card-body">
                <dl class="row">
                    <dt class="col-sm-4">Scenario:</dt>
                    <dd class="col-sm-8">@Model.Scenario?.Name</dd>
                    
                    <dt class="col-sm-4">Turn Length:</dt>
                    <dd class="col-sm-8">@Model.Scenario?.TurnLengthMinutes minutes</dd>
                    
                    <dt class="col-sm-4">Max Turns:</dt>
                    <dd class="col-sm-8">@Model.Scenario?.MaxTurns</dd>
                    
                    <dt class="col-sm-4">Weather:</dt>
                    <dd class="col-sm-8">@Model.Scenario?.Weather</dd>
                    
                    <dt class="col-sm-4">Created:</dt>
                    <dd class="col-sm-8">@Model.CreatedAt.ToString("yyyy-MM-dd HH:mm")</dd>
                    
                    <dt class="col-sm-4">Status:</dt>
                    <dd class="col-sm-8">
                        @if (Model.EndedAt.HasValue)
                        {
                            <span class="badge bg-secondary">Ended</span>
                        }
                        else if (Model.StartedAt.HasValue)
                        {
                            <span class="badge bg-success">Active</span>
                        }
                        else
                        {
                            <span class="badge bg-warning">Pending</span>
                        }
                    </dd>
                </dl>
            </div>
        </div>
        
        <!-- Turn History -->
        <div class="card mt-3">`
            <div class="card-header">
                <h5 class="mb-0">Turn History</h5>
            </div>
            <div class="card-body" id="turnHistory">
                @foreach (var turn in Model.Turns?.OrderBy(t => t.Number) ?? Enumerable.Empty<WargameBoard.Core.Entities.Turn>())
                {
                    <div class="d-flex justify-content-between align-items-center mb-2">
                        <span>Turn @turn.Number</span>
                        <small class="text-muted">
                            @turn.StartedAt.ToString("HH:mm")
                            @if (turn.EndedAt.HasValue)
                            {
                                <span> - @turn.EndedAt.Value.ToString("HH:mm")</span>
                            }
                        </small>
                    </div>
                }
            </div>
        </div>
    </div>
    
    <!-- Game Board Preview -->
    <div class="col-md-8">
        <div class="card">
            <div class="card-header">
                <h5 class="mb-0">Game Board</h5>
            </div>
            <div class="card-body">
                <div class="text-center mb-3">
                    <a href="@Url.Action("Index", "Map", new { area = "Map", sessionId = Model.Id })" class="btn btn-primary">
                        <i class="bi bi-map"></i> Open Full Map Editor
                    </a>
                </div>
                
                <!-- Mini hex grid preview -->
                <div id="miniHexGrid" class="mini-hex-grid">
                    <!-- This will be populated by JavaScript -->
                </div>
            </div>
        </div>
        
        <!-- Recent Activity -->
        <div class="card mt-3">
            <div class="card-header">
                <h5 class="mb-0">Recent Activity</h5>
            </div>
            <div class="card-body" id="recentActivity">
                <div class="text-muted text-center py-3">
                    <i class="bi bi-info-circle"></i> No recent activity
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Real-time Activity Feed -->
<div class="card mt-3">
    <div class="card-header">
        <h5 class="mb-0">Live Activity Feed</h5>
    </div>
    <div class="card-body">
        <div id="activityFeed" class="activity-feed" style="max-height: 300px; overflow-y: auto;">
            <div class="text-muted text-center py-3">
                <i class="bi bi-info-circle"></i> Join the session to see live activity
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/site.js"></script>
    <script src="~/js/realtime-session.js"></script>
}

<style>
.mini-hex-grid {
    display: grid;
    grid-template-columns: repeat(6, 20px);
    gap: 2px;
    justify-content: center;
    margin: 20px 0;
}

.mini-hex {
    width: 20px;
    height: 18px;
    background: #eef2f7;
    clip-path: polygon(25% 0, 75% 0, 100% 50%, 75% 100%, 25% 100%, 0 50%);
    border: 1px solid #cfd6e0;
    cursor: pointer;
}

.mini-hex.terrain-clear { background: #eef2f7; }
.mini-hex.terrain-forest { background: #28a745; }
.mini-hex.terrain-mountain { background: #6c757d; }
.mini-hex.terrain-water { background: #17a2b8; }
.mini-hex.terrain-desert { background: #ffc107; }
.mini-hex.terrain-urban { background: #dc3545; }
.mini-hex.terrain-swamp { background: #6f42c1; }

.activity-feed .activity-item {
    padding: 8px 12px;
    border-left: 3px solid #007bff;
    margin-bottom: 8px;
    background: #f8f9fa;
    border-radius: 0 4px 4px 0;
}

.activity-feed .activity-item.turn {
    border-left-color: #28a745;
}

.activity-feed .activity-item.placement {
    border-left-color: #ffc107;
}

.activity-feed .activity-item.movement {
    border-left-color: #17a2b8;
}
</style>
