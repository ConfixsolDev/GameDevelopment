@model WargameBoard.Core.Entities.Session
@{
    ViewData["Title"] = "Session";
    var currentTurn = Model.Turns.OrderByDescending(t => t.Number).FirstOrDefault();
    Layout = "/Views/Shared/_Layout.cshtml";
}

<h2>Session for @Model.Scenario?.Name</h2>
<p>Started: @Model.StartedAt?.ToLocalTime()</p>
<p>Current Side: @Model.CurrentSide?.Name ?? "(none)"</p>
<p>Turns: @Model.Turns.Count (current: @currentTurn?.Number)</p>
<p>Status: @(Model.EndedAt == null ? "Active" : $"Ended @ {Model.EndedAt?.ToLocalTime()}")</p>

<form asp-action="AdvanceTurn" method="post" class="d-inline">
    @Html.AntiForgeryToken()
    <input type="hidden" name="id" value="@Model.Id" />
    <button class="btn btn-primary" @(Model.EndedAt != null ? "disabled" : "")>Advance Turn</button>
</form>

<form asp-action="End" method="post" class="d-inline">
    @Html.AntiForgeryToken()
    <input type="hidden" name="id" value="@Model.Id" />
    <button class="btn btn-danger" @(Model.EndedAt != null ? "disabled" : "")>End Session</button>
</form>
