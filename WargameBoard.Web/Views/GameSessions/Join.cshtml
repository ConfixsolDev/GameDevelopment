@model WargameBoard.Core.Entities.Session

@{
    ViewData["Title"] = $"Join Session: {Model.Scenario?.Name}";
    Layout = "/Views/Shared/_Layout.cshtml";
}

<div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-3 pb-2 mb-3 border-bottom">
    <h1 class="h2">Join Session: @Model.Scenario?.Name</h1>
    <div class="btn-toolbar mb-2 mb-md-0">
        <a asp-action="Index" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left"></i> Back to Sessions
        </a>
    </div>
</div>

<div class="row">
    <div class="col-md-8">
        <div class="card">
            <div class="card-header">
                <h5 class="mb-0">Session Information</h5>
            </div>
            <div class="card-body">
                <dl class="row">
                    <dt class="col-sm-3">Scenario:</dt>
                    <dd class="col-sm-9">@Model.Scenario?.Name</dd>
                    
                    <dt class="col-sm-3">Turn Length:</dt>
                    <dd class="col-sm-9">@Model.Scenario?.TurnLengthMinutes minutes</dd>
                    
                    <dt class="col-sm-3">Max Turns:</dt>
                    <dd class="col-sm-9">@Model.Scenario?.MaxTurns</dd>
                    
                    <dt class="col-sm-3">Weather:</dt>
                    <dd class="col-sm-9">@Model.Scenario?.Weather</dd>
                    
                    <dt class="col-sm-3">Current Side:</dt>
                    <dd class="col-sm-9">
                        @if (Model.CurrentSide != null)
                        {
                            <span class="badge" style="background-color: @Model.CurrentSide.Color">
                                @Model.CurrentSide.Name
                            </span>
                        }
                        else
                        {
                            <span class="text-muted">None</span>
                        }
                    </dd>
                    
                    @if (!string.IsNullOrEmpty(Model.Notes))
                    {
                        <dt class="col-sm-3">Notes:</dt>
                        <dd class="col-sm-9">@Model.Notes</dd>
                    }
                </dl>
            </div>
        </div>
        
        <div class="card mt-3">
            <div class="card-header">
                <h5 class="mb-0">Available Units</h5>
            </div>
            <div class="card-body">
                @if (Model.Scenario?.ScenarioUnits?.Any() == true)
                {
                    <div class="row">
                        @foreach (var unit in Model.Scenario.ScenarioUnits.GroupBy(su => su.Unit?.Side?.Name))
                        {
                            <div class="col-md-6 mb-3">
                                <h6 class="text-primary">@unit.Key Forces</h6>
                                @foreach (var scenarioUnit in unit)
                                {
                                    <div class="d-flex justify-content-between align-items-center mb-2 p-2 bg-light rounded">
                                        <div>
                                            <strong>@scenarioUnit.Unit?.Name</strong>
                                            <br>
                                            <small class="text-muted">
                                                Steps: @scenarioUnit.Steps | 
                                                Posture: @scenarioUnit.Posture |
                                                Start: (@scenarioUnit.StartHex?.Q,@scenarioUnit.StartHex?.R)
                                            </small>
                                        </div>
                                        @if (scenarioUnit.Hidden)
                                        {
                                            <span class="badge bg-warning">Hidden</span>
                                        }
                                    </div>
                                }
                            </div>
                        }
                    </div>
                }
                else
                {
                    <p class="text-muted">No units assigned to this scenario.</p>
                }
            </div>
        </div>
    </div>
    
    <div class="col-md-4">
        <div class="card">
            <div class="card-header">
                <h5 class="mb-0">Join as Player</h5>
            </div>
            <div class="card-body">
                <div class="alert alert-info">
                    <i class="bi bi-info-circle"></i>
                    <strong>Player Assignment</strong><br>
                    Choose your side and join the game session.
                </div>
                
                <form asp-action="Join" method="post">
                    <input type="hidden" name="sessionId" value="@Model.Id" />
                    
                    <div class="mb-3">
                        <label class="form-label">Player Name</label>
                        <input type="text" class="form-control" name="playerName" placeholder="Enter your name" required />
                    </div>
                    
                    <div class="mb-3">
                        <label class="form-label">Choose Your Side</label>
                        <select name="sideId" class="form-select" required>
                            <option value="">-- Select Side --</option>
                            @foreach (var side in ViewBag.Sides as IEnumerable<Microsoft.AspNetCore.Mvc.Rendering.SelectListItem>)
                            {
                                <option value="@side.Value">@side.Text</option>
                            }
                        </select>
                    </div>
                    
                    <div class="d-grid gap-2">
                        <button type="submit" class="btn btn-success">
                            <i class="bi bi-person-plus"></i> Join Game
                        </button>
                        <a asp-action="RealTimeDetails" asp-route-id="@Model.Id" class="btn btn-primary">
                            <i class="bi bi-play-circle"></i> Go to Game Board
                        </a>
                    </div>
                </form>
            </div>
        </div>
        
        <div class="card mt-3">
            <div class="card-header">
                <h6 class="mb-0">Quick Actions</h6>
            </div>
            <div class="card-body">
                <div class="d-grid gap-2">
                    <a asp-action="RealTimeDetails" asp-route-id="@Model.Id" class="btn btn-outline-primary btn-sm">
                        <i class="bi bi-map"></i> Open Game Board
                    </a>
                    <a asp-action="Details" asp-route-id="@Model.Id" class="btn btn-outline-info btn-sm">
                        <i class="bi bi-info-circle"></i> Session Details
                    </a>
                    <a href="/Map/Map?sessionId=@Model.Id" class="btn btn-outline-success btn-sm">
                        <i class="bi bi-geo-alt"></i> Map Editor
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>
