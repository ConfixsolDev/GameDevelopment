@model IEnumerable<WargameBoard.Core.Entities.Session>

@{
    ViewData["Title"] = "Game Sessions";
    Layout = "/Views/Shared/_Layout.cshtml";
}

<div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-3 pb-2 mb-3 border-bottom">
    <h1 class="h2">Game Sessions</h1>
    <div class="btn-toolbar mb-2 mb-md-0">
        <div class="btn-group me-2">
            <a asp-action="Create" class="btn btn-primary">
                <i class="bi bi-plus-circle"></i> Start New Session
            </a>
        </div>
    </div>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

@if (!Model.Any())
{
    <div class="text-center py-5">
        <i class="bi bi-controller display-1 text-muted"></i>
        <h3 class="text-muted">No Active Sessions</h3>
        <p class="text-muted">Start a new game session to begin playing!</p>
        <a asp-action="Create" class="btn btn-primary btn-lg">
            <i class="bi bi-play-circle"></i> Start New Session
        </a>
    </div>
}
else
{
    <table class="table table-striped table-hover">
    <thead class="table-dark">
        <tr>
            <th>Scenario</th>
            <th>Started</th>
            <th>Ended</th>
            <th>Current Side</th>
            <th>Turns</th>
            <th>Status</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var s in Model)
        {
            var currentTurn = s.Turns.OrderByDescending(t => t.Number).FirstOrDefault();
            <tr>
                <td>@s.Scenario?.Name</td>
                <td>@s.StartedAt?.ToLocalTime().ToString("g")</td>
                <td>@s.EndedAt?.ToLocalTime().ToString("g")</td>
                <td>@s.CurrentSide?.Name ?? "-"</td>
                <td>@(currentTurn?.Number ?? 0)</td>
                <td>
                    @if (s.EndedAt == null)
                    {
                        <span class="badge bg-success">Active</span>
                    }
                    else
                    {
                        <span class="badge bg-secondary">Ended</span>
                    }
                </td>
                <td>
                    <div class="btn-group" role="group">
                        <a asp-action="Details" asp-route-id="@s.Id" class="btn btn-sm btn-outline-info">
                            <i class="bi bi-eye"></i> View
                        </a>
                        @if (s.EndedAt == null)
                        {
                            <a asp-action="RealTimeDetails" asp-route-id="@s.Id" class="btn btn-sm btn-outline-success">
                                <i class="bi bi-play-circle"></i> Play
                            </a>
                            <a asp-action="Join" asp-route-id="@s.Id" class="btn btn-sm btn-outline-primary">
                                <i class="bi bi-people"></i> Join
                            </a>
                        }
                    </div>
                </td>
            </tr>
        }
    </tbody>
</table>
}
