@model WargameBoard.Web.Models.PagingInfo

@{
    var searchString = ViewBag.SearchString as string ?? "";
    var currentPage = Model.CurrentPage;
    var totalPages = Model.TotalPages;
    var pageSize = Model.PageSize;
}

<!-- Search and Page Size Controls -->
<div class="row mb-3">
    <div class="col-md-6">
        <form method="get" class="d-flex">
            <input type="text" name="searchString" value="@searchString" class="form-control me-2" placeholder="Search..." />
            <input type="hidden" name="page" value="1" />
            <input type="hidden" name="pageSize" value="@pageSize" />
            <button type="submit" class="btn btn-outline-secondary">
                <i class="fas fa-search"></i>
            </button>
            @if (!string.IsNullOrEmpty(searchString))
            {
                <a href="@Url.Action("Index", new { page = 1, pageSize = pageSize })" class="btn btn-outline-danger ms-2">
                    <i class="fas fa-times"></i>
                </a>
            }
        </form>
    </div>
    <div class="col-md-6 text-end">
        <div class="d-flex align-items-center justify-content-end">
            <label for="pageSize" class="form-label me-2 mb-0">Show:</label>
            <select id="pageSize" class="form-select form-select-sm" style="width: auto;" onchange="changePageSize(this.value)">
                @{
                    var options = new[] { new { Value = 10, Text = "10" }, new { Value = 25, Text = "25" }, new { Value = 50, Text = "50" }, new { Value = 100, Text = "100" } };
                }
                @foreach (var option in options)
                {
                    <option value="@option.Value" selected="@(pageSize == option.Value)">@option.Text</option>
                }
            </select>
            <span class="ms-2 text-muted">
                @Model.TotalItems total items
            </span>
        </div>
    </div>
</div>

<!-- Pagination -->
@if (totalPages > 1)
{
    <nav aria-label="Page navigation">
        <ul class="pagination justify-content-center">
            <!-- First Page -->
            @if (currentPage > 1)
            {
                <li class="page-item">
                    <a class="page-link" href="@Url.Action("Index", new { searchString, page = 1, pageSize })">
                        <i class="fas fa-angle-double-left"></i>
                    </a>
                </li>
            }

            <!-- Previous Page -->
            @if (currentPage > 1)
            {
                <li class="page-item">
                    <a class="page-link" href="@Url.Action("Index", new { searchString, page = currentPage - 1, pageSize })">
                        <i class="fas fa-angle-left"></i>
                    </a>
                </li>
            }

            <!-- Page Numbers -->
            @{
                var startPage = Math.Max(1, currentPage - 2);
                var endPage = Math.Min(totalPages, currentPage + 2);
            }

            @for (int i = startPage; i <= endPage; i++)
            {
                <li class="page-item @(i == currentPage ? "active" : "")">
                    <a class="page-link" href="@Url.Action("Index", new { searchString, page = i, pageSize })">
                        @i
                    </a>
                </li>
            }

            <!-- Next Page -->
            @if (currentPage < totalPages)
            {
                <li class="page-item">
                    <a class="page-link" href="@Url.Action("Index", new { searchString, page = currentPage + 1, pageSize })">
                        <i class="fas fa-angle-right"></i>
                    </a>
                </li>
            }

            <!-- Last Page -->
            @if (currentPage < totalPages)
            {
                <li class="page-item">
                    <a class="page-link" href="@Url.Action("Index", new { searchString, page = totalPages, pageSize })">
                        <i class="fas fa-angle-double-right"></i>
                    </a>
                </li>
            }
        </ul>
    </nav>
}

<script>
    function changePageSize(newPageSize) {
        const url = new URL(window.location);
        url.searchParams.set('pageSize', newPageSize);
        url.searchParams.set('page', '1'); // Reset to first page
        window.location.href = url.toString();
    }
</script>
