@{
    var area = ViewContext.RouteData.Values["area"]?.ToString();
    var controller = ViewContext.RouteData.Values["controller"]?.ToString();
    var action = ViewContext.RouteData.Values["action"]?.ToString();
}

<nav aria-label="breadcrumb">
    <ol class="breadcrumb">
        <li class="breadcrumb-item">
            <a asp-area="" asp-controller="Home" asp-action="Index">
                <i class="fas fa-home"></i> Home
            </a>
        </li>
        
        @if (!string.IsNullOrEmpty(area))
        {
            <li class="breadcrumb-item">
                <a asp-area="@area" asp-controller="Home" asp-action="Index">
                    @area
                </a>
            </li>
        }
        
        @if (!string.IsNullOrEmpty(controller) && controller != "Home")
        {
            <li class="breadcrumb-item">
                <a asp-area="@area" asp-controller="@controller" asp-action="Index">
                    @controller
                </a>
            </li>
        }
        
        @if (!string.IsNullOrEmpty(action) && action != "Index")
        {
            <li class="breadcrumb-item active" aria-current="page">
                @action
            </li>
        }
    </ol>
</nav>
