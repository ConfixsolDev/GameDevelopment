<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - WargameBoard</title>

    <!-- Styles -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css" rel="stylesheet">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="bg-light">
    <div class="container-fluid">
        <div class="row">
            <!-- Sidebar -->
           
            <nav id="sidebar" class="col-md-3 col-lg-2 d-md-block bg-dark sidebar collapse">
                <div class="position-sticky pt-3">
                    <div class="text-center mb-4">
                        <h4 class="text-white">
                            <i class="bi bi-shield-check"></i> WargameBoard
                        </h4>
                    </div>

                    <!-- Main Game Section -->
                    <ul class="nav flex-column">
                        <li class="nav-item">
                            <a class="nav-link text-white @(ViewContext.RouteData.Values["area"] == null && ViewContext.RouteData.Values["controller"]?.ToString() == "Home" && ViewContext.RouteData.Values["action"]?.ToString() == "Index" ? "active" : "")"
                               asp-area="" asp-controller="Home" asp-action="Index">
                                <i class="bi bi-speedometer2"></i> Dashboard
                            </a>
                        </li>
                    </ul>

                    <!-- Game Arena Section -->
                    <h6 class="sidebar-heading d-flex justify-content-between align-items-center px-3 mt-4 mb-1 text-muted">
                        <span style="color:#ffc107; font-weight: bold;">🎮 GAME ARENA</span>
                    </h6>
                    <ul class="nav flex-column mb-2">
                        <li class="nav-item">
                            <a class="nav-link text-white @(ViewContext.RouteData.Values["controller"]?.ToString() == "GameSessions" ? "active" : "")"
                               asp-controller="GameSessions" asp-action="Index">
                                <i class="bi bi-play-circle-fill"></i> Game Sessions
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-white @(ViewContext.RouteData.Values["area"]?.ToString() == "Map" ? "active" : "")"
                               asp-area="Map" asp-controller="Map" asp-action="Index">
                                <i class="bi bi-grid-3x3-gap-fill"></i> Game Board
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-white @(ViewContext.RouteData.Values["area"]?.ToString() == "Scenarios" ? "active" : "")"
                               asp-area="Scenarios" asp-controller="Scenarios" asp-action="Index">
                                <i class="bi bi-book-fill"></i> Scenarios
                            </a>
                        </li>
                    </ul>

                    <!-- Lookups Section -->
                    <h6 class="sidebar-heading d-flex justify-content-between align-items-center px-3 mt-4 mb-1 text-muted">
                        <span style="color:lightseagreen">Lookups</span>
                    </h6>
                    <ul class="nav flex-column mb-2">
                        <li class="nav-item">
                            <a class="nav-link text-white @(ViewContext.RouteData.Values["area"]?.ToString() == "Admin" ? "active" : "")"
                               asp-area="Admin" asp-controller="Home" asp-action="Index">
                                <i class="bi bi-gear"></i> Admin
                            </a>
                        </li>
                    </ul>

                    <!-- Game Management Section -->
                    <h6 class="sidebar-heading d-flex justify-content-between align-items-center px-3 mt-4 mb-1 text-muted">
                        <span style="color:lightseagreen">Game Management</span>
                    </h6>
                    <ul class="nav flex-column mb-2">
                        <li class="nav-item">
                            <a class="nav-link text-white @(ViewContext.RouteData.Values["area"]?.ToString() == "Units" ? "active" : "")"
                               asp-area="Units" asp-controller="Home" asp-action="Index">
                                <i class="bi bi-shield"></i> Units
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-white @(ViewContext.RouteData.Values["area"]?.ToString() == "Map" ? "active" : "")"
                               asp-area="Map" asp-controller="Map" asp-action="Index">
                                <i class="bi bi-map"></i> Game Arena
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-white @(ViewContext.RouteData.Values["area"]?.ToString() == "Scenarios" ? "active" : "")"
                               asp-area="Scenarios" asp-controller="Scenarios" asp-action="Index">
                                <i class="bi bi-book"></i> Scenarios
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-white @(ViewContext.RouteData.Values["area"]?.ToString() == "Tokens" ? "active" : "")"
                               asp-area="Tokens" asp-controller="Home" asp-action="Index">
                                <i class="bi bi-circle"></i> Tokens
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-white @(ViewContext.RouteData.Values["area"]?.ToString() == "Hardware" ? "active" : "")"
                               asp-area="Hardware" asp-controller="Home" asp-action="Index">
                                <i class="bi bi-cpu"></i> Hardware
                            </a>
                        </li>
                    </ul>
                </div>
            </nav>

            <!-- Main content -->
            <main class="col-md-9 ms-sm-auto col-lg-10 px-md-4">
                <!-- TempData Alerts -->
                <partial name="_TempDataAlerts" />

                <!-- Breadcrumb -->
                <partial name="_Breadcrumb" />

                <!-- Top Navbar / Header -->
                <div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-3 pb-2 mb-3 border-bottom">
                    <div class="d-flex align-items-center">
                        <!-- Mobile sidebar toggler -->
                        <button class="btn btn-outline-secondary d-md-none me-2"
                                type="button"
                                data-bs-toggle="collapse"
                                data-bs-target="#sidebar"
                                aria-controls="sidebar"
                                aria-expanded="false"
                                aria-label="Toggle sidebar">
                            <i class="bi bi-list"></i>
                        </button>

                        <h1 class="h2 me-3 mb-0">@ViewData["Title"]</h1>

                        <!-- Current Scenario/Session Display -->
                        <div class="d-flex align-items-center">
                            @if (ViewBag.CurrentScenario != null)
                            {
                                <span class="badge bg-primary me-2">
                                    <i class="bi bi-book"></i> @ViewBag.CurrentScenario
                                </span>
                            }
                            @if (ViewBag.CurrentSession != null)
                            {
                                <span class="badge bg-success me-2">
                                    <i class="bi bi-play-circle"></i> @ViewBag.CurrentSession
                                </span>
                            }
                            @if (ViewBag.GameStatus != null)
                            {
                                <span class="badge @(ViewBag.GameStatus == "Active" ? "bg-success" : ViewBag.GameStatus == "Paused" ? "bg-warning" : "bg-secondary")">
                                    <i class="bi bi-circle-fill"></i> @ViewBag.GameStatus
                                </span>
                            }
                        </div>
                    </div>

                    <div class="btn-toolbar mb-2 mb-md-0">
                        <div class="btn-group me-2">
                            <button type="button" class="btn btn-sm btn-outline-secondary">
                                <i class="bi bi-share"></i> Share
                            </button>
                            <button type="button" class="btn btn-sm btn-outline-secondary">
                                <i class="bi bi-download"></i> Export
                            </button>
                        </div>
                        <div class="dropdown">
                            <button class="btn btn-sm btn-primary dropdown-toggle" type="button" data-bs-toggle="dropdown">
                                <i class="bi bi-plus"></i> New
                            </button>
                            <ul class="dropdown-menu">
                                <li>
                                    <a class="dropdown-item" asp-controller="GameSessions" asp-action="Create">
                                        <i class="bi bi-play-circle"></i> New Session
                                    </a>
                                </li>
                                <li>
                                    <a class="dropdown-item" asp-area="Units" asp-controller="Home" asp-action="Index">
                                        <i class="bi bi-shield"></i> New Unit
                                    </a>
                                </li>
                                <li>
                                    <a class="dropdown-item" asp-area="Scenarios" asp-controller="Scenarios" asp-action="Create">
                                        <i class="bi bi-book"></i> New Scenario
                                    </a>
                                </li>
                                <li>
                                    <a class="dropdown-item" asp-area="Map" asp-controller="Map" asp-action="Index">
                                        <i class="bi bi-grid-3x3-gap"></i> Game Board
                                    </a>
                                </li>
                            </ul>
                        </div>
                    </div>
                </div>

                @RenderBody()
            </main>
        </div>
    </div>

    <!-- Scripts: jQuery first (for your code), then Bootstrap bundle, then SignalR, then your site.js -->
    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://unpkg.com/@@microsoft/signalr@latest/dist/browser/signalr.min.js"></script>
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            debugger
            const sidebar = document.getElementById("sidebar");
            const path = window.location.pathname.toLowerCase();

            if (path.includes("/map/map")) {
                sidebar.style.setProperty("display", "none", "important");
            } else {
                sidebar.style.setProperty("display", "block", "important"); // or "flex"
            }
        });
    </script>

    <!-- Your site scripts (can use jQuery if needed) -->
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
