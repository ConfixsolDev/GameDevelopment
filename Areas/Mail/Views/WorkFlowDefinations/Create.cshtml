@model TechWebSol.Areas.Mail.Models.WorkFlowDefination

<div class="modal-header">
    <h4 class="modal-title" id="agencyModalLabel">Add Workflow Defination</h4>
    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
</div>

<div class="card card-shadow">
    <div class="card-body">
        <form asp-area="Mail" asp-action="Create" asp-controller="WorkFlowDefinations" class="frmSubmit">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <div class="mb-3">
                <label asp-for="Name" class="control-label"></label>
                <input asp-for="Name" class="form-control" />
                <span asp-validation-for="Name" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="IsActive" class="control-label"></label>
                <select asp-for="IsActive" class="form-select">
                    <option value="true">Yes</option>
                    <option value="false">No</option>
                </select>
                <span asp-validation-for="IsActive" class="text-danger"></span>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="submit" class="btn btn-primary">Save</button>
            </div>
        </form>
    </div>
</div>

@{
    await Html.RenderPartialAsync("_ValidationScriptsPartial");
}
