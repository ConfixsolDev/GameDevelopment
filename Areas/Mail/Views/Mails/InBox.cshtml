@model IEnumerable<TechWebSol.Areas.Mail.Models.MailMessageDTO>

<div class="col-md-12">
    <div class="card">
        <ul class="message-list">
            @foreach (var item in Model)
            {
                <li>
                    <div class="col-mail col-mail-0" style=" margin-left: 26px;">
                        <a href="#" class="title">@item.CreatedByName</a>
                    </div>
                    <div class="col-mail col-mail-2">
                        <a href="@item.MailEntity?.URL" class="subject">
                            <span class="bg-danger badge me-2">@item.WorkFlow</span>
                            @item.WorkFlowStepName – <span class="teaser">@item.Message</span>
                        </a>
                        @* <div class="date">@DateTime.Now.ToString("dd MMM yyyy")</div> *@
                        <div class="date">@item.CreatedDate.Value.ToString("dd MMM yyyy")</div>
                    </div>
                </li>
            }
            @*<li>
                <div class="col-mail col-mail-1">
