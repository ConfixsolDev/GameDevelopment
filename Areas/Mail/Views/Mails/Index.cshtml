@{
    ViewData["Title"] = "Internal Mail Box";
}

<!-- ============================================================== -->
<div class="email-rightbar mb-3">
    <div class="card">
        <div class="btn-toolbar p-3" role="toolbar">
            <div class="btn-group me-2 mb-2 mb-sm-0" onclick="FetchInbox()">
                <button type="button" class="inbox btn btn-primary btn-secondary waves-light waves-effect"><i class="fa fa-inbox"></i>&nbsp;&nbsp; Inbox</button>
            </div>
            <div class="btn-group me-2 mb-2 mb-sm-0" onclick="SentBox()">
                <button type="button" class="sentbox btn btn-secondary waves-light waves-effect"><i class="fa fa-inbox"></i>&nbsp;&nbsp;Sent Items</button>
            </div>
        </div>
    </div>
    <div id="DisplayData"></div>
</div>


@section Breadcrump {
    <li class="breadcrumb-item"><a asp-area="" asp-action="Index" asp-controller="Home">Home</a></li>
    <li class="breadcrumb-item"><a asp-area="Mail" asp-action="Index" asp-controller="Mails">List</a></li>
    <li class="breadcrumb-item active">Details</li>
}
<script>

    function FetchInbox() {
        $.ajax({
            url: '/Mail/Mails/InBox',
            type: 'POST',
            cache: false,
            success: function (response) {
                $("#DisplayData").empty();
                $("#DisplayData").html(response);

                $(".inbox").addClass("btn-primary");
                $(".inbox").removeClass("btn-secondary");

                $(".sentbox").removeClass("btn-primary");
                $(".sentbox").addClass("btn-secondary");

            },
            error: function (response) {
                console.error('There was a problem with the fetch operation:', response);
            }
        });
    }

    function SentBox() {

        $.ajax({
            url: '/Mail/Mails/SentBox',
            type: 'POST',
            cache: false,
            success: function (response) {
                $("#DisplayData").empty();
                $("#DisplayData").html(response);

                $(".sentbox").addClass("btn-primary");
                $(".sentbox").removeClass("btn-secondary");

                $(".inbox").removeClass("btn-primary");
                $(".inbox").addClass("btn-secondary");
            },
            error: function (response) {
                console.error('There was a problem with the fetch operation:', response);
            }
        });
    }
    document.addEventListener("DOMContentLoaded", function () {
        FetchInbox();
    });
</script>
