@model TechWebSol.Areas.Mail.Models.WorkFlowStep

<div class="modal-header">
    <h4 class="modal-title" id="agencyModalLabel">Add Workflow Steps</h4>
    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
</div>

<div class="card card-shadow">
    <div class="card-body">
        <form asp-area="Mail" asp-action="Create" asp-controller="WorkFlowSteps" class="frmSubmit">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" asp-for="WorkFlowDefinationId" />
            <div class="mb-3">
                <label asp-for="StepSequence" class="control-label"></label>
                <input asp-for="StepSequence" class="form-control" />
                <span asp-validation-for="StepSequence" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Name" class="control-label"></label>
                <select asp-for="Name" class="form-select" asp-items="ViewBag.stepsName"></select>
            </div>
            @* <div class="mb-3">
                <label asp-for="ActionRequired" class="control-label"></label>
                <input asp-for="StepSequence" class="form-control" />
            </div> *@
            <div class="mb-3">
                <label asp-for="ApplicationUserAppID" class="control-label">User</label>
                @* <select asp-for="ApplicationUserAppID" class="form-control select2" asp-items="ViewBag.applicationUserAppID"></select> *@
                @Html.DropDownListFor(model => model.ApplicationUserAppID, (SelectList)ViewData["applicationUserAppID"], htmlAttributes: new { @class = "form-select" })
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="submit" class="btn btn-primary">Save</button>
            </div>
        </form>
    </div>
</div>

@{
    await Html.RenderPartialAsync("_ValidationScriptsPartial");
}