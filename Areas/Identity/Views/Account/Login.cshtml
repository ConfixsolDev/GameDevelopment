@model TechWebSol.ViewModels.LoginViewModel
@{
    Layout = "/Views/Shared/LoginLayout.cshtml";
    ViewData["Title"] = "Human Capital Management System";
}
<div class="login-box">

    <!-- /.login-logo -->
    <div class="login-box-body">
        <p class="login-box-msg">Sign in to start your session</p>

        <form id="account" method="post" asp-area="Identity" asp-controller="Login" asp-action="Index">
            <div class="form-group has-feedback">
                <label asp-for="UserName"></label>
                <input asp-for="UserName" type="text" class="form-control" placeholder="Email">
                <span class="glyphicon glyphicon-envelope form-control-feedback"></span>
                <span asp-validation-for="UserName" class="text-danger"></span>
            </div>
            <div class="form-group has-feedback">
                <label asp-for="Password"></label>
                <input asp-for="Password" type="password"  class="form-control" placeholder="Password" />
                <span class="glyphicon glyphicon-lock form-control-feedback"></span>
                <span asp-validation-for="Password" class="text-danger"></span>
            </div>
            <br/>
            <br/>
            <div class="row">
                <!-- /.col -->
                <div class="col-xs-4">
                    <button type="submit" class="btn btn-primary btn-block btn-lg">Sign In</button>
                </div>
            </div>
            <br />
            <a asp-action="ForgotPassword">I forgot my password</a><br>
        </form>
    </div>
    <!-- /.login-box-body -->
</div>
@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}