@model TechWebSol.ViewModels.RegisterViewModel

    <div class="modal-header">
        <h4 class="modal-title" id="agencyModalLabel">Edit User</h4>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
    </div>
    <div class="modal-body">
        <div class="card ">
            <form asp-area="Identity" asp-controller="AccountAdmin" asp-action="EditRegister" method="post" class="frmSubmit" style="margin-bottom:10px">
                <input asp-for="ApplicationUserID" type="hidden" />
                <div class="form-group col-md-12">
                    <label asp-for="UserName" class="control-label"></label>
                    <input required asp-for="UserName" id="UserName" class="form-control" placeholder="User Name" onblur="checkValue()" />
                    <span asp-validation-for="UserName" class="text-danger"></span>
                    <span id="spandanger" class="text-danger"></span>
                    <span id="spanSuccess" class="text-success"></span>
                </div>
                <div class="form-group col-md-12">
                    <label class="control-label">First Name</label>
                    <input required asp-for="FirstName" class="form-control" placeholder="First Name" />
                    <span asp-validation-for="FirstName" class="text-danger"></span>
                </div>
                <div class="form-group col-md-12">
                    <label class="control-label">Last Name</label>
                    <input required asp-for="LastName" class="form-control" placeholder="Last Name" />
                    <span asp-validation-for="LastName" class="text-danger"></span>
                </div>
                <div class="form-group col-md-12">
                    <label class="control-label">Team</label>
                    <select asp-for="TeamId" class="form-control" asp-items="Model.TeamList">
                        <option value="">-- Select Team --</option>
                    </select>
                    <span asp-validation-for="TeamId" class="text-danger"></span>
                </div>
                <div class="form-group col-md-12">
                    <label asp-for="ForceType" class="control-label">Force Type</label>
                    <select asp-for="ForceType" class="form-control" required>
                        <option value="">-- Select Force Type --</option>
                        <option value="Blueland">Blueland</option>
                        <option value="Foxland">Foxland</option>
                        <option value="Control">Control</option>
                    </select>
                    <span asp-validation-for="ForceType" class="text-danger"></span>
                </div>
                <div class="form-group col-md-12">
                    <label asp-for="Role" class="control-label"></label>
                    <select asp-for="Role" class="form-control" asp-items="Model.RoleList">
                        <option value="" disabled>Select</option>
                    </select>
                    <span asp-validation-for="Role" class="text-danger"></span>
                </div>
                <div class="form-group col-md-12 ">
                    <label asp-for="Password" class="control-label"></label>
                    <input required asp-for="Password" class="form-control" value="Admin@123" placeholder="Password" />
                    <span asp-validation-for="Password" class="text-danger"></span>
                </div>
                <div class="form-group col-md-12">
                    <label asp-for="ConfirmPassword" class="control-label"></label>
                    <input required asp-for="ConfirmPassword" class="form-control" value="Admin@123" placeholder="Confirm Password" />
                    <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
                </div>
                <div class="modal-footer">
                    <button type="submit" class="btn btn-primary">Save</button>
                </div>
            </form>
        </div>
    </div>
    <partial name="_ValidationScriptsPartial" />
