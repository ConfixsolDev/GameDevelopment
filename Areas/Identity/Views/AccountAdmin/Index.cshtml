@model IEnumerable<ApplicationUser>
@{
    ViewData["Title"] = "User Management";
}

<div class="container-fluid">
    <div class="row">
        <div class="col-12">
            <div class="card">
                <div class="card-header">
                    <h3 class="card-title">User Management</h3>
                </div>
                <div class="card-body">
                    <div class="row mb-3">
                        <div class="col-lg-3">
                            <button class="btn btn-primary" onclick="openAddUserModal()">
                                <i class="fas fa-plus"></i> Add New User
                            </button>
                        </div>
                        <div class="col-lg-9">
                            <div class="input-group">
                                <input type="text" id="searchFilter" class="form-control" placeholder="Search by user, email, role...">
                                <button class="btn btn-warning" onclick="resetSearch()" title="Reset Search">
                                    <i class="fas fa-undo"></i>
                                </button>
                            </div>
                        </div>
                    </div>
                    <div class="table-responsive">
                        <table id="userTable" class="table table-bordered w-100">
                            <thead>
                                <tr>
                                    <th>User Name</th>
                                    <th>Email</th>
                                    <th>Team</th>
                                    <th>Role</th>
                                    <th>Last Login</th>
                                    <th>Status</th>
                                    <th>Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in Model)
                                {
                                    <tr>
                                        <td>@item.UserName</td>
                                        <td>@item.Email</td>
                                        <td>@(item.TeamId?.ToString() ?? "N/A")</td>
                                        <td>@(item.RoleName ?? "N/A")</td>
                                        <td>@(item.LastLoginDate?.ToString("dd/MM/yyyy HH:mm") ?? "Never")</td>
                                        <td>
                                            @if (item.IsActive)
                                            {
                                                <span class="badge badge-success">Active</span>
                                            }
                                            else
                                            {
                                                <span class="badge badge-danger">Locked</span>
                                            }
                                        </td>
                                        <td>
                                            <secure-content asp-area="Identity" asp-controller="AccountAdmin" asp-action="EditRegister">
                                                <a asp-area="Identity" asp-controller="AccountAdmin" asp-action="EditRegister" 
                                                   class="btn btn-sm btn-primary" title="Edit" asp-route-id="@item.Id">
                                                    <i class="fas fa-edit"></i>
                                                </a>
                                            </secure-content>
                                            @if (item.IsActive == false)
                                            {
                                                <secure-content asp-area="Identity" asp-controller="AccountAdmin" asp-action="Activate">
                                                    <a asp-action="Activate" class="btn btn-sm btn-success" title="Activate User" asp-route-id="@item.Id">
                                                        <i class="fas fa-unlock"></i>
                                                    </a>
                                                </secure-content>
                                            }
                                            else
                                            {
                                                <secure-content asp-area="Identity" asp-controller="AccountAdmin" asp-action="Delete">
                                                    <a asp-action="Delete" class="btn btn-sm btn-danger" title="Lock User" asp-route-id="@item.Id">
                                                        <i class="fas fa-lock"></i>
                                                    </a>
                                                </secure-content>
                                            }
                                            <secure-content asp-area="Identity" asp-controller="AccountAdmin" asp-action="AdminPasswordReset">
                                                <a asp-area="Identity" asp-controller="AccountAdmin" asp-action="AdminPasswordReset" 
                                                   asp-route-id="@item.Id" class="btn btn-sm btn-warning" title="Reset Password">
                                                    <i class="fas fa-key"></i>
                                                </a>
                                            </secure-content>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Add User Modal -->
<div class="modal fade" id="addUserModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content" id="addUserModalContent">
            <!-- Content will be loaded via AJAX -->
        </div>
    </div>
</div>


@section Scripts {
    <script>
        $(document).ready(function () {
            // Search filter functionality
            $("#searchFilter").on("keyup", function () {
                var value = $(this).val().toLowerCase();
                $("#userTable tbody tr").filter(function () {
                    $(this).toggle($(this).text().toLowerCase().indexOf(value) > -1);
                });
            });
        });

        function openAddUserModal() {
            // Load the Register form via AJAX
            $.ajax({
                url: '@Url.Action("Register", "AccountAdmin", new { area = "Identity" })',
                method: 'GET',
                success: function(data) {
                    $('#addUserModalContent').html(data);
                    $('#addUserModal').modal('show');
                },
                error: function() {
                    alert('Failed to load user registration form');
                }
            });
        }

        function resetSearch() {
            $("#searchFilter").val('');
            $("#userTable tbody tr").show();
        }
    </script>
}