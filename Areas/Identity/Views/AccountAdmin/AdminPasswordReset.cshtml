@model TechWebSol.ViewModels.PasswordResetViewModel

<div class="modal-header">
    <h5 class="modal-title" id="agencyModalLabel">Change Password</h5>
    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
</div>
<div class="modal-body">
    <form novalidate class="needs-validation frmSubmit" asp-area="Identity" asp-controller="AccountAdmin" asp-action="AdminPasswordReset">
        <input type="hidden" asp-for="ApplilicationUserId">
        <div class="mb-3">
            <label for="" class="form-label">Username</label>
            <div class="input-group">
                <input type="text" class="form-control" id="UserName" asp-for="UserName" readonly>
            </div>
            <span asp-validation-for="Password" class="text-danger"></span>
        </div>
        <div class="mb-3">
            <label for="Password" class="form-label">New Password</label>
            <div class="input-group">
                <input type="password" class="form-control" id="Password" asp-for="Password" placeholder="New Password" required>
                <button class="btn btn-outline-secondary toggle-password" type="button" data-target="#Password">
                    <i class="fas fa-eye"></i>
                </button>
            </div>
            <span asp-validation-for="Password" class="text-danger"></span>
        </div>
        <div class="mb-3">
            <label for="ConfirmPassword" class="form-label">Confirm Password</label>
            <div class="input-group">
                <input type="password" class="form-control" id="ConfirmPassword" asp-for="ConfirmPassword" placeholder="Confirm Password" required>
                <button class="btn btn-outline-secondary toggle-password" type="button" data-target="#ConfirmPassword">
                    <i class="fas fa-eye"></i>
                </button>
            </div>
            <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
        </div>
        <div class="d-grid gap-2">
            <button type="submit" class="btn btn-success">Reset Password</button>
        </div>
        @if (Model.ErrorMessage != null)
        {
            <div class="alert alert-danger mt-2">@Model.ErrorMessage</div>
        }
    </form>
</div>

<partial name="_ValidationScriptsPartial" />
<script>
    $(document).ready(function () {
        $('.toggle-password').click(function () {
            // Toggle the eye/eye-slash icon
            $(this).find('i').toggleClass('fa-eye fa-eye-slash');

            // Toggle the password visibility
            var input = $($(this).attr('data-target'));
            if (input.attr('type') === 'password') {
                input.attr('type', 'text');
            } else {
                input.attr('type', 'password');
            }
        });
    });

</script>