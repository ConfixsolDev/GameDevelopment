@model IEnumerable<TechWebSol.ViewModels.UserCountViewModel>
@{
    ViewData["Title"] = "Role Management";
}

<div class="container-fluid">
    <div class="row">
        <div class="col-12">
            <div class="card">
                <div class="card-header">
                    <h3 class="card-title">Role Management</h3>
                </div>
                <div class="card-body">
                    <div class="row mb-3">
                        <div class="col-lg-3">
                            <a class="btn btn-primary" asp-action="Create" asp-route-AppId="HCM">
                                <i class="fas fa-plus"></i> Add New Role
                            </a>
                        </div>
                        <div class="col-lg-9">
                            <div class="input-group">
                                <input type="text" id="searchFilter" class="form-control" placeholder="Search roles...">
                                <button class="btn btn-warning" onclick="resetSearch()" title="Reset Search">
                                    <i class="fas fa-undo"></i>
                                </button>
                            </div>
                        </div>
                    </div>
                    <div class="table-responsive">
                        <table id="roleTable" class="table table-bordered w-100">
                            <thead>
                                <tr>
                                    <th>Role Name</th>
                                    <th>Total Users</th>
                                    <th>Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var role in Model.OrderBy(x => x.AppId))
                                {
                                    <tr>
                                        <td>@role.RollName</td>
                                        <td class="text-center">
                                            <span class="badge badge-info">@role.Count</span>
                                        </td>
                                        <td>
                                            <a class="btn btn-sm btn-primary" asp-action="Edit" asp-route-AppId="@role.AppId" asp-route-id="@role.ApplicationRoleId" title="Edit Role">
                                                <i class="fas fa-edit"></i>
                                            </a>
                                            <a class="btn btn-sm btn-info" asp-action="Details" asp-route-AppId="@role.AppId" asp-route-id="@role.ApplicationRoleId" title="View Details">
                                                <i class="fas fa-eye"></i>
                                            </a>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            // Search filter functionality
            $("#searchFilter").on("keyup", function () {
                var value = $(this).val().toLowerCase();
                $("#roleTable tbody tr").filter(function () {
                    $(this).toggle($(this).text().toLowerCase().indexOf(value) > -1);
                });
            });
        });

        function resetSearch() {
            $("#searchFilter").val('');
            $("#roleTable tbody tr").show();
        }
    </script>
}